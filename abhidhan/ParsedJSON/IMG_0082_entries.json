[
  {
    "headword": "_continuation",
    "transliteration": "",
    "phonetics": "",
    "senses": [
      {
        "raw_text": "Ъ করল ⇒ বরাক উপত্যকার ‘পদ্মাপুরাণ’ বা ‘বিষহরির পুরান সংগ্রহ’ পুঁথিসমূহে এবং ওঝাগানে ‘করণ্ডি’র উল্লেখ রয়েছে। যেমন, ‘পুষ্পের করণ্ডি মধ্যে পদ্মারে লইআ। কৈলাস পর্বতে চলে হরষিত হইয়া।।’ —বিশ্বান্তর দেবনাথ ‘করণ্ডির মধ্যে রাখি দেবী বিষহরি। করণ্ডি হাতেতে রাখি চলে ত্রিপুরারি।’ 'শিঙ্গা ডমরুধ্বনি গঙ্গায় শুনিলা। করণ্ডি দেখিয়া গঙ্গা হরষিত হইলা।’ ‘অতি উচ্চস্থানে নিয়া করণ্ডি রাখিলা। পুনঃ পুনঃ সদাশিব গঙ্গাকে বলিলা।। শুন শুন গঙ্গাদেবী মোর মাথা খাও। ধর্মের দোহাই যদি করণ্ডি নামাও।।’ —নবকুমার রায়টৌধুরী বরাক উপত্যকা ও শ্রীহট্টের বিভিন্ন স্থানে মনসা পূজার সময় করণ্ডি সাজানো হয়। মন্দিরাকৃতি ছোট ঘর তৈরি করে ফুলের মালা দিয়ে সাজিয়ে তাতে মনসার পট বসানো হয়। এই সাজানো করণ্ডিটি কলাগাছের ভেলায় জুড়ে পাড়া বা গ্রাম পরিক্রমা করে ভাসিয়ে দেওয়ার রীতি আছে। করণ্ডিটির দৈর্ঘ্য-প্রস্থ সাধারণত চব্বিশ ইঞ্চির বেশি হয় না, উচ্চতাও এক থেকে দেড়হাত।"
      }
    ],
    "source_page": "IMG_0082"
  },
