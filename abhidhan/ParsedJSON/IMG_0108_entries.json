  {
    "headword": "বারা",
    "transliteration": "bara",
    "phonetics": "bara",
    "etymology": "[<খা ধাতু + রা কৃপ্র.]",
    "senses": [
      {
        "part_of_speech": "বিণ.",
        "definition": "খাইয়ে ; ভোজন পটু।",
        "examples": [
          "পাড়িআ বাউলর লাখান গুড়খারা নাই। ‘খা’ ধাতু নিষ্পন্ন ‘খারা’ কৃদন্ত শব্দটি বিভিন্ন অর্থে নামপদ-উত্তর যুক্ত হয়। দূ.- বাছখারা (= বাছার পর রয়ে গেছে এমন) মালখারা (= মদ্যপান করে এমন) মানুখারা (= মানুষ খায় এমন) ‘খারি’ যুক্ত করে স্ত্রীবাচক শব্দও তৈরি হয়। যেমন, হাইখারি (= বিধবা) পালখারি (অশি = যৌন উপভোগ করা হয়েছে এমন স্ত্রীপশু)",
          "প্রজনন ঋতুতে মনুষ্যেতর প্রাণীর ক্ষেত্রেই শুধু ‘পালখারি’ শব্দটি প্রযোজ্য।"
        ]
      }
    ],
    "source_page": "IMG_0108"
  },
