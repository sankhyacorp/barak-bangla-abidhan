    "transliteration": "tanapitha",
    "phonetics": "ṭanapiṭha",
    "etymology": "[<ববাং টান্ + আ ~ পিঠা]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "চালের গুঁড়োর পিঠা বিশেষ।",
        "examples": [
          "আউশধানের চালের গুঁড়ো সামান্য নুন মিশিয়ে জলে গুলে নিতে হয়। উনুনে অল্প আঁচে কড়াই বসিয়ে পরিমাণ মতো ‘চালগুলা’ ফেলে ঢেকে ঢেকে পিঠাটি তৈরি করতে হয়। প্রতিটি পিঠা তৈরি করার আগে তেল দিয়ে কড়াইটি একবার মুছে নেওয়া উচিত। পিঠাটির নিচ লালচে রঙের হলে চা’য়ের সঙ্গে গরম গরম পরিবেশন করা হয়।"
        ]
      },
      {
        "part_of_speech": "বাগধা. ক্রি.",
        "definition": "কমে যাওয়া।",
        "examples": [
          "কাইল গুলার পানি ঢেফা আশল আইজ বিআন তনে পানিএ টান দিছে।"
        ]
      }
    ],
