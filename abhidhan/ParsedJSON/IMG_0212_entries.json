[
  {
    "headword": "_continuation",
    "transliteration": "",
    "phonetics": "",
    "senses": [
      {
        "raw_text": "কোমরে দিয়ে, ডানহাতে ভঙ্গি করে, কখনো কোঁচড় থেকে কিছু দিচ্ছে এই রকম ভঙ্গি করে নাচতে লাগল। বৃত্তাকারে ডানদিকে পাশাপাশি কিংবা একজনের পিছনে অপরে ঘুরতে লাগল।’ ‘গ্রামীণ নৃত্য ও নাট্য’ —শান্তিদেব ঘোষ ≫ মধ্য বাংলায় 'ধামালি' শব্দের ব্যবহার বিস্তর। বেশিরভাগ ‘কেলিকৌতুক’ অর্থে। আদি মধ্য বাংলায় প্রথম নিদর্শন পাওয়া যাচ্ছে। যেমন, শ্রীকৃষ্ণকীর্তনে— ‘না বুঝোঁ রঙ্গ ধামালী না জানো সুরতী কেলী।’ ‘সব গোপী ছাড়ী বনমালী। মোরে কেহ্নে বোলও ধামালী।’ ‘নহসি মাউলানী রাধা সম্বন্ধে শালী। রঙ্গে ধামালী বোলে দেব বনমালী।। ‘হেন মন করে বড়ায়ি দহে পৈসী মরী। পরার পুরুষ সমেঁ ধামালী না করী।’ মাধাবাচার্যের শ্রীকৃষ্ণমঙ্গলে — (মধ্য বাংলা) ‘রাধাকানুর ধামালী দেখিয়া সব সখী। নয়নে বসন দিয়া ঘন হাস্যমুখী।।’"
      }
    ],
    "source_page": "IMG_0212"
  },
