    "headword": "_continuation",
    "transliteration": "",
    "phonetics": "",
    "senses": [
      {
        "raw_text": "আছে। এ বাঁশ ঝাড় বাঁধে না, তৈরি করে বিশাল বাঁশবন। অনেক বছর (১৫-২৫) পরপর মুলি বাঁশের ফুলের প্রস্ফুটন হয়ে থাকে। পেয়ারার মতো অগ্রভাগ সৃক্ষ্ম নিরেট কঠিন গাঢ় সবুজ রঙের ফল হয়। এই ফল থেকে গাছ হয় বা শাখাকলম থেকেও। তিন বছরে মুলিবাঁশ পরিণত হয়। এর ‘করিল’ উপাদেয় খাদ্য। সবচেয়ে কাজের বাঁশ। এর বৈজ্ঞানিক নাম- Melocanna baccifera।"
      }
    ],
    "source_page": "IMG_0306"
  },
