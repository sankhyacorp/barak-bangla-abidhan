    "transliteration": "ri",
    "phonetics": "ri",
    "etymology": "[< দ্র. রা]",
    "senses": [
      {
        "raw_text": "[< দ্র. রা] কৃৎ প্রত্যয় — বরাক উপত্যকার আঞ্চলিক বাংলা ভাষার খাঁটি কৃৎ প্রত্যয়। নিপুণ বা পারঙ্গম অর্থে ব্যবহৃত হয়। ⇒ √নাচ + রি = নাচরি (= নৃত্য পারদর্শিনী) √রান্দ্ + রি = রান্দ্রি (= পাচিকা) √গা + রি = গারি (= গায়িকা) ≫ দ্র. রা।"
      }
    ],
    "source_page": "IMG_0310"
  },
