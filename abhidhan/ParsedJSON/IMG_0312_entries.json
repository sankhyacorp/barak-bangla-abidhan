[
  {
    "headword": "_continuation",
    "transliteration": "",
    "phonetics": "",
    "senses": [
      {
        "raw_text": "কল্যাণও দীর্ঘ জীবন কামনা করে বৃক্ষদেবতার পাদদেশের মাখা সিদুঁর ও মৃত্তিকা আশীর্বাদ স্বরূপ মা ও সম্ভান উভয়েই শিরোদেশে ধারণ করে থাকেন। এ উপত্যকার শিববাড়ি, কালীবাড়ি প্রভৃতি দেবস্থানে তুলসী গাছের মতো শ্রদ্ধার সঙ্গে শেওড়া গাছও রোপন (প্রতিষ্ঠা) করা হয়। এই গাছে শিশুদের আরোহন করা কঠোরভাবে নিষিদ্ধ।"
      }
    ],
    "source_page": "IMG_0312"
  },
