  {
    "headword": "আনু",
    "transliteration": "anu",
    "phonetics": "anu",
    "etymology": "[< দ্র. শিআন, ]",
    "senses": [
      {
        "part_of_speech": "বিণ.",
        "definition": "প্রাপ্ত বয়স্ক।",
        "examples": [
          "পুড়ি শিআন অই জার জামাই-উমাই চাইও। শ্রীকৃষ্ণকীর্তনে ‘সিআন’ মানে পেয়েছি ‘সজ্ঞান’ বা ‘চতুর’। প্রাপ্তবয়স্ক না হলে সজ্ঞান বা পরিণত হয় না। সেই অর্থপ্রাধান্যে অর্থসংক্রম ঘটে বরাক উপত্যকায় এর অন্যতম মানে দাঁড়িয়েছে ‘প্রাপ্তবয়স্ক’।"
        ]
      }
    ],
    "source_page": "IMG_0329"
  },
