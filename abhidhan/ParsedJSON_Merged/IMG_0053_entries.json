[
  {
    "headword": "আদাজামুইর",
    "transliteration": "adajamuir",
    "phonetics": "adaʒamuir",
    "etymology": "[<বাং আদা + ববাং জামুইর]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "আদা'র গন্ধযুক্ত রসাল লেবু বিশেষ।",
        "examples": [
          "গোলাকার বেশ বড় আকারের লেবু। লেবুর জগতে এমন সুগন্ধযুক্ত ও রসগর্ভ লেবু দ্বিতীয়টি নেই। গন্ধ ও রসের জন্য একে রসরাজ লেবু বলতে পারি। ভেষজগুণে ভরা এটি খুবই উপকারী ও রুচিকর।"
        ]
      },
      {
        "part_of_speech": "বাগধা. ক্রি.",
        "definition": "অবাঞ্জিত উপদেশ দেওয়া বা যুক্তিবৃদ্ধি দেওয়া।",
        "examples": [
          "হর ইন তনে, দাদারে আর আদা পড়া হিখাইস না।"
        ]
      }
    ],
    "source_page": "IMG_0053"
