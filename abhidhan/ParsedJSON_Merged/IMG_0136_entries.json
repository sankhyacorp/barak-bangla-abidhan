  {
    "headword": "চাউর",
    "transliteration": "chaur",
    "phonetics": "c∫aur",
    "etymology": "[< আঞ্চবাং চাউর]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "বনসুপারির গাছ। দেখতে সুদৃশ্য পুষ্পমঞ্জরী ঝুলে থাকে। গ্রীত্মে এ গাছে ফুল ফোটে। ফল দূর থেকে দেখতে লিচুর মতো। পাকলে সবুজ রংটি বাদামি হলুদ হয়। খেতে সুপারির মতো। ভারতই এ গাছের জন্ম স্থান।",
        "examples": [
          "উঁচু ও বিশাল আকারের তাল জাতীয় গাছ। উচ্চতা ২৪ মিটার পর্যন্ত হয়। তালগাছের কান্ডের মতো। গাঁটযুক্ত, শাখাহীন, গোলাকার ও উন্নত। তবে কাণ্ডের বাকলের রং নারকেল বা তালের চেয়ে mino সবুজ ঘন। চাউরগাছের পত্রদণ্ড খুব বড় এবং থাকে গাছের একেবারে মাথায়। ঘোড়ার লেজের মতো"
        ]
      }
    ],
