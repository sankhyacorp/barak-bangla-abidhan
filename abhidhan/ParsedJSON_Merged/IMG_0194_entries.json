  {
    "headword": "তাড়শ",
    "transliteration": "tado়sh",
    "phonetics": "taḍɔ়∫",
    "etymology": "[<ববাং শব্দ তাড়শ]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "নামকীর্তন ও পদাবলীকীর্তনে ব্যবহৃত মাটির তৈরি মৃদঙ্গ জাতীয় বাদ্যযন্ত্র বিশেষ।",
        "examples": [
          "বিত্রশ ঘাটে চামড়ার বাদ্দি বা দুআলি টানানো থাকে। বাদ্দিতে লাগানো থাকে কাঠের গুটি। ডাইনা- বায়া দুদিকেই মাখানো থাকে খিরন বা কালি।"
        ]
      }
    ],
    "source_page": "IMG_0194"
  },
  {
    "headword": "তাড়ু",
    "transliteration": "tado়u",
    "phonetics": "taḍɔ়u",
    "etymology": "[<সং তর্দূ]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "যা দিয়ে ভাত-ব্যঞ্জন নাড়া হয়; হাতা।",
        "examples": [
          "বা দি তাডু বানাইআ ভাত রানধি।"
        ]
      },
      {
        "part_of_speech": "বাগধা. বি.",
        "definition": "ধনীলোকের অপ্রয়োজনীয় ব্যয়বহুল অনুষ্ঠান।",
        "examples": [
          "টেকা থাকলে তালইর হরাদ, না থাকলে বাফর হরাদউ নাই।"
        ]
      },
      {
        "part_of_speech": "বাগধা. ক্রি.",
        "definition": "ঝগড়া বা ষড়যন্ত্রে ইন্ধন যোগানো।",
        "examples": [
          "গাউত দুইজনে লাগলেউ হে তাল টুকিব। তালাতালি করা — বাগধা. ক্রি. একজনের বিরুদ্ধে আরেকজনের কান ভারি করা; একজনের গোপনকথা অন্যজনের কাছে ফাঁস করা।",
          "তার গেছে ভিত্রর মাত মাতিও না, হে অলা তালাতালি করে।"
        ]
      },
      {
        "part_of_speech": "বাগধা. ক্রি.",
        "definition": "উসকানি দেওয়া।",
        "examples": [
          "হে তাল মারিআ মোরে মাইর খাবাইছে।"
        ]
      },
      {
        "part_of_speech": "বাগধা. ক্রি.",
        "definition": "কারো বিরুদ্ধে কথা বলে অসম্ভোষ উৎপাদন করা।",
        "examples": [
          "হড়িএ পুআর গেছে তাল লাগাইআ বউরে গাইল খাবায়।"
        ]
      }
    ],
