    "etymology": "[<ববাং তপ্র. ‘তি’]",
    "senses": [
      {
        "raw_text": "[<ববাং তপ্র. ‘তি’] তপ্র. — বরাক উপত্যকার আঞ্চলিক বাংলার খাঁটি তদ্ধিত প্রত্যয়। ভাবার্থে বা বিশেষণ থেকে বিশেষ্য গঠনে এর ব্যবহার প্রসিদ্ধ। ⇒ শিআন (= সেয়ানা) + তি = শিআনতি (= চালাকি)।"
      }
    ],
    "source_page": "IMG_0194"
