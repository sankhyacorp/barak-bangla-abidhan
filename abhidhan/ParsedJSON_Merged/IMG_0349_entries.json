  {
    "headword": "হুদ্দর",
    "transliteration": "huddor",
    "phonetics": "ɦuddɔr",
    "etymology": "[< আঞ্চবাং সোদর হুকারীভবনে < সং সহোদর]",
    "senses": [
      {
        "part_of_speech": "বিণ.",
        "definition": "এক মায়ের গর্ভজাত। ভাই।’ — মৈমন সিংহ গীতিকা।",
        "examples": [
          "মুখ দেখলেউ বুঝা জার তাই তুমার হুদ্দর বইন।"
        ]
      },
      {
        "part_of_speech": "বিণ.",
        "definition": "আপন; রক্ত সম্পর্ক যুক্ত এমন; ঘনিষ্ঠ।",
        "examples": [
          "'হুদদর মই মই নায় পেরকৃটি মই মই।' — বরাক প্রবাদ",
          "'এফ্পত' ভার্ত্ন 'নির্ালত'। রামন, এফ্পত ভাইগনা; হুদ্দর ভাতিজি; হুদ্দর মামা ইত্যাদি।"
        ]
