  {
    "headword": "ঘাইল",
    "transliteration": "ghail",
    "phonetics": "ghail",
    "etymology": "[<ববাং শব্দ. ঘাইল]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "উদৃখল ; ডমরুর মতো দেখতে একফুট গভীর গর্ত বিশিষ্ট কাঠের পাত্র যাতে ধান, চিড়া বা মশলা কোটা হয়। Manufacture of the Control of the Control of the Control of the Control of the Control of the Control of the Control of the Control of the Control of the Control of the Control of the Control of the Control of the Control 等的自由自由的主义 রুরাক উপত্যকার আঞ্চলিক বাংল"
      },
      {
        "part_of_speech": "বিণ.",
        "definition": "দীর্ঘসূত্রী ; যে যেকোনো কাজে আলস্যের দরুন অহেতুক সময় নেয়।",
        "examples": [
          "আলংকারিক প্রয়োগ। শব্দটি অলস বা দীর্ঘসূত্রী নারীর বেলায় প্রযোজা। বি. [ অশি.] — নারীর যোনিদেশ।",
          "প্রতীকী প্রয়োগ। পুরুষের লিঙ্গকে মুযলের সঙ্গে তুলনা করা হয় আর উদৃখলকে যোনির সঙ্গে। উখলে মুষলাঘাত করাকেও নারীপুরুষের যৌন সঙ্গমের প্রতীক রূপে উল্লেখ করা হয়।"
        ]
      }
    ],
    "source_page": "IMG_0130"
  },
  {
    "headword": "ঘাউআ্",
    "transliteration": "ghaua",
    "phonetics": "ghaua",
    "etymology": "[<বাং ঘা + উআ তপ্র. আধিক্যার্থে]",
    "senses": [
      {
        "part_of_speech": "বি.",
