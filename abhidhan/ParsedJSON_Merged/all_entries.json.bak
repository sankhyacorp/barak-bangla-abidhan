  {
    "headword": "উরু",
    "transliteration": "uru",
    "phonetics": "uru",
    "etymology": "[<সংরু = শব্দ করা]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "উচ্চকণ্ঠের সাংকেতিক আওয়াজ।",
        "examples": [
          "পাড়ো (=পাহাড়ে) জাইতে মুই উরু দিমু।",
          "বরাক উপত্যকা ও উত্তর কাছাড়ে দূরবর্তী সঙ্গীদের ‘উরু’ দিয়ে জানান দেওয়া হয়। লুকোচুরি খেলা, গহনবনে পথ হারিয়ে ফেললে বা বিপদে পড়লে ‘উরু’ দিয়ে জানান দেওয়ার প্রচলন আছে।"
        ]
      },
      {
        "part_of_speech": "বি.",
        "definition": "অত্যাচার; যৌনপীড়ন; প্রহার।",
        "examples": [
          "বেটায় রুজ রাইত মাল খাইআ তার বউর উপরে উরুস লয়।"
        ]
      }
    ],
    "source_page": "IMG_0070"
  },
