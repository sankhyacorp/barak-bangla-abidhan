  {
    "headword": "অনো",
    "transliteration": "ono",
    "phonetics": "ɔno",
    "etymology": "[<ববাং অখানো <বাং এখানে/ওখানে]",
    "senses": [
      {
        "part_of_speech": "ক্রিবিণ.",
        "definition": "এখানে; এইস্থানে। ٤ অবায় কাজও না করা। ⇒ হি বাড়িত আইলে অলা সাএব অয় অনোর কাটকা হনো হরায় না।",
        "examples": [
          "অনো ঘরর ভিটা বানাইও।"
        ]
