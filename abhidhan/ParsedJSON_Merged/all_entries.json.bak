  {
    "headword": "কুম",
    "transliteration": "kum",
    "phonetics": "kum",
    "etymology": "[<বাং কুসুম = ডিমের হলদে অংশ ]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "ডিমের হলদে অংশ।",
