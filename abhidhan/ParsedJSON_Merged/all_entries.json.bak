    "transliteration": "vorot",
    "phonetics": "vɔrɔt",
    "etymology": "[< পা. ভরিত = পূরিত]",
    "senses": [
      {
        "part_of_speech": "বিণ.",
        "definition": "ভরাট; গর্ত বা খাদ যা মাটি দিয়ে পূরিত।",
        "examples": [
          "ভরত মাটিত ঘর বানাইও না।"
        ]
      }
    ],
    "source_page": "IMG_0284"
  },
  {
    "headword": "ভরতা",
    "transliteration": "vorota",
    "phonetics": "vɔrɔta",
    "etymology": "[< হি. ভর্তা = চটকানো ব্যঞ্জন]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "আলু, বেগুন প্রভৃতি পুড়ে বা সেদ্ধ করে তেল-মশলা-নুন সহযোগে চটকে তৈরি ব্যঞ্জন।",
        "examples": [
          "বাইংগন ভরতা; বরুন ভরতা; আলু ভরতা।"
        ]
      },
      {
        "part_of_speech": "বিণ.",
        "definition": "প্রচণ্ড আঘাতে পিষ্ট।"
      }
    ],
    "source_page": "IMG_0284"
  },
  {
    "headword": "ভরন্",
    "transliteration": "voron",
    "phonetics": "vɔrɔn",
    "etymology": "[< বাং √ভর (=ভরতি করা) + ন]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "লতাপাতা গাছ-গাছড়া পিষে মিহি করে তালুর চুল ছেচে গোলাকার পিণ্ড করে বসিয়ে যে চিকিৎসা করা হয়। Þ পান্ডু রোগ, কামলা, সৃতিকা, শিরঃপীড়া, রক্তচাপ প্রভৃতি রোগে এই চিকিৎসা পদ্ধতি উপকারে আসে।"
      }
    ],
    "source_page": "IMG_0284"
  },
  {
    "headword": "ভরন্ত",
    "transliteration": "voronto",
    "phonetics": "vɔrɔntɔ",
    "etymology": "[< আঞ্চ. ভরৎ < সং বর্ত্তা]",
    "senses": [
