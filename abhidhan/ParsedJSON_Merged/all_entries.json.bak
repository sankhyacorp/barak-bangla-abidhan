  {
    "headword": "বাকইর",
    "transliteration": "bakoir",
    "phonetics": "bakɔir",
    "etymology": "[< ববাং শব্দ বাকইর]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "ঢেঁকি দিয়ে ধানভানার প্রথম পর্যায়। ২৭২ বাখা ২. হাউলকা — বেশিরভাগ ধান থেকে তুষ খসে চাল বেরিয়ে আসবে। J ৩. কাড়া যে সামান্য ধান থাকবে তা থেকে পুরোপুরি চাল বার করা হবে ও চাল পরিষ্কার চকচকে করা হবে। ⇒ একমন ধান বাকইর হাউলকা অইগেছে খালি কাড়া বাকি।",
        "examples": [
          "ধানভানার তিনটি পর্যায় : ১. বাকইর — ধান থেকে কিছু কিছু চাল বেরোবে।"
        ]
      }
    ],
    "source_page": "IMG_0263"
  },
  {
    "headword": "বাক্কা",
    "transliteration": "bakka",
    "phonetics": "bakka",
    "etymology": "[< ববাং শব্দ বাক্কা]",
    "senses": [
      {
        "part_of_speech": "বিণ.",
        "definition": "বেশ কিছু সংখ্যক; বেশকিছু পরিমাণ।",
        "examples": [
