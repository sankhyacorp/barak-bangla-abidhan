        ]
      }
    ],
    "source_page": "IMG_0243"
  },
  {
    "headword": "ষ্ণরাশি",
    "transliteration": "shnorashi",
    "phonetics": "∫nɔra∫i",
    "etymology": "[< ববাং/শ্রীহট্ট শব্দ. ফরাশ + ই তপ্র. স্থার্থে]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "মোটাদানার বরবটি।",
        "examples": [
          "বরবটির চেয়ে চেপ্টা কিন্তু লম্বায় মাত্র চার-পাঁচ ইঞ্চি। বিচি কাজু বাদামের মতো। নানা রঙের হয়। নীল, লাল, বেগুনি ও মিশ্র রঙের। গাছ দূরকমের — গুল্ম ও লতা। গুল্ম ২০/২২ ইঞ্চির বেশি হয় না। লতা পাঁচ-ছয় ফুট। এদের বিচি অতি উপাদেয় ডাল। শীতের ফসল। ফলে প্রচুর।"
        ]
      }
    ],
    "source_page": "IMG_0243"
  },
  {
    "headword": "ফরিশ",
    "transliteration": "forish",
    "phonetics": "fɔri∫",
    "etymology": "[< আঞ্চ. বাং ফরিশ < বাং শিরীষ]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "শিরীষ গাছ।",
        "examples": [
          "'গাছটি বিশাল, উঁচু, সরল, পরিণত অবস্থায় ২৫- ৩০ মিটার পর্যন্ত হয়। শিরিষের কাণ্ড গোলাকার, মসৃণ ও স্লাম ধৃসর। গাছের মূল মাটিতে দৃঢ়বদ্ধ নয়, ফলে এ গাছ ঝড়ে সহজেই ধ্বসে পড়ে। গাছের ছাল ফাটা ফাটা। রং কালচে ধূসর। গাছের পাতা শীতে ঝরে যায়, বসন্ভের শেষে পাতা গজায়, বর্যায় ফুল ধরে ও পরে জিভের মতো প্রশস্ত ও ধারালো এক রকম ফল হয়।’ — আজহার ইসলাম বৈজ্ঞানিক নাম— Mimosa Sirisa"
        ]
      }
    ],
    "source_page": "IMG_0243"
  },
  {
