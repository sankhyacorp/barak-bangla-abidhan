  {
    "headword": "হতাই",
    "transliteration": "hotai",
    "phonetics": "ɦɔtai",
    "etymology": "[< মবা. সতাই = সৎমা হকারীভবনে < সং সপত্নী ⇒]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "বিমাতা; সৎমা। কৃত্তিবাসী রামায়ণ। সংক্ষেপে ‘সতা’র দৃষ্টান্ত মেলে। যেমন, 'গঙ্গা নামে সতা (=সতিন) তার তরঙ্গ এমনি' — অন্নদামঙ্গল।",
        "examples": [
          "তাই হতাইর গেছে মানু অইসে।"
        ]
      }
    ],
    "source_page": "IMG_0336"
  },
  {
    "headword": "হতি",
    "transliteration": "hoti",
    "phonetics": "ɦɔti",
    "etymology": "[< ববাং হতিন সংকোচনে]",
    "senses": [
      {
        "part_of_speech": "বিণ.",
