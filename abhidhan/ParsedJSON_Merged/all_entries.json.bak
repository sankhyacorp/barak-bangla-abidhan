  {
    "headword": "আউরানি",
    "transliteration": "aurani",
    "phonetics": "aurani",
    "etymology": "[<ব বাং আউরা + নি কৃপ্র.]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "হারানো। ٤ আউরি কুলক্ষণ। সাংসারিক ক্ষতি হওয়ার নাকি আগাম সংকেত। ≫ শহীদুল্লার সিদ্ধান্ত ‘আউরা’ শব্দের উৎস ফারসি ‘আরারহ্’। আমার মতে শব্দটি মধ্য বাংলা ‘হারাঙ’ থেকে এসেছে। দৃ. ‘হিয়ার ভিতরে থুইতে নহে পরতীত। হারাঙ হারাঙ হেন সদা করে চিত। — বলরাম দাস মবা. হারাঙ্ক > আঞ্চ. বাং হারাউ > ব.বাং আরাউ > অপিনিহিতিতে ‘আউরা’।",
        "examples": [
          "ছাত্তি আউরানি ভালা নায়।",
          "ছাতা হারিয়ে যাওয়া বরাকবাসীর কাছে একটি"
        ]
      }
    ],
    "source_page": "IMG_0045"
  },
  {
    "headword": "আউরি",
    "transliteration": "auri",
    "phonetics": "auri",
    "etymology": "[<ববাং আউরা]",
