  {
    "headword": "শুরাখ",
    "transliteration": "shurakh",
    "phonetics": "∫urakh",
    "etymology": "[< ববাং শব্দ শুরাখ]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "সম্ভান বিয়োগজনিত শোক।",
        "examples": [
          "সম্ভানের মৃত্যুতে যে শোক হয় সে তো সামান্য শোক নয় — শোকানল। তুষের আগুনের মতো পুড়তে পুড়তে মাতা ও পিতার স্বাস্থ্যহানি ঘটে ও আয়ুক্ষয় হয়।",
          "দুই পুড়ি মরার শুরাখে ডাইলর্ মা'র শরিল এখেরে আড়জিরা অই গেশলো; আইজ তিনদিন তনে তাইন হেজাত।"
        ]
      }
    ],
    "source_page": "IMG_0330"
  },
