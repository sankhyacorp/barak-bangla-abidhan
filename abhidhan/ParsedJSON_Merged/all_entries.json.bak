  {
    "headword": "থিথি",
    "transliteration": "thithi",
    "phonetics": "thithi",
    "etymology": "[<ববাং শব্দ থিথি]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "মেয়েদের চুলের কেশবিন্যাস বিশেষ; বিনুনি।",
        "examples": [
          "জুড়া থিথি এ হরু ছুগরিনতরে সুন্দর লাগে। থি-থি thi-thi [<ধ্ব. থি আম্রেড়নে]"
        ]
      },
      {
        "part_of_speech": "অনম্ব.",
        "definition": "হালচালনার সাংকেতিক নির্দেশ।",
        "examples": [
          "‘থি-থি’ মানে ‘সোজা এগিয়ে চল’। আর দ্রুত বাঁক নিতে বলা হয় — ‘ড্রি-ই-ই’।"
        ]
      }
    ],
    "source_page": "IMG_0202"
  },
  {
    "headword": "থুতা",
    "transliteration": "thuta",
    "phonetics": "thuta",
    "etymology": "[<আঞ্চ. থোত্না]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "নিচের ঠোঁটের নিম্নভাগ; চিবুক।",
        "examples": [
          "'গাংগর পারর বাড়ি আর ইন্দুর থুতার দাড়ি।’ — বরাক প্রবাদ"
        ]
      },
      {
        "part_of_speech": "বাগধা. ক্রি.",
        "definition": "কথায় কথায় তর্ক করা; গলাবাজি করা।",
        "examples": [
          "এলকুর ছুগরা-ছুগরিনতে বড় থুতা করইন।"
        ]
      },
      {
        "part_of_speech": "বিণ.",
        "definition": "যে নারী কথায় কথায় তর্ক করে।",
        "examples": [
          "ইলা থুতামুখি বউ মুই দেখছি না।"
        ]
      },
      {
        "part_of_speech": "বাগধা. ক্রি.",
        "definition": "শায়েস্তা করা।",
        "examples": [
          "আমার পালো পড়লে বেটির থুতা মুখ ভূথা করি দিলাম অনে।"
        ]
      }
    ],
    "source_page": "IMG_0202"
  },
  {
    "headword": "থুতি",
    "transliteration": "thuti",
    "phonetics": "thuti",
    "etymology": "[<দ্র. থুতা]",
    "senses": [
