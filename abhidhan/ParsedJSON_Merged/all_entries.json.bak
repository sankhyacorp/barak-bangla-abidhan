        ]
      },
      {
        "part_of_speech": "ক্রিবিণ.",
        "definition": "চুপচাপ।",
        "examples": [
          "জুইতপাইতে বও লড়িও না।"
        ]
      },
      {
        "part_of_speech": "বিণ.",
        "definition": "জোঁকের শরীরের মতো অত্যন্ত পিচ্ছিল।",
        "examples": [
          "'লইছি ছাত্তি লইছি বেগ তিনদিন অইছে পড়ছে মেঘ, কেমনে করতাম বাজার-আট জুকর পিছলা গাংগর ঘাট।’ — আনন্দ জু"
        ]
      },
      {
        "part_of_speech": "বাগধা. বি.",
        "definition": "যথোপযুক্ত জবাব।",
        "examples": [
          "এমেলেরে আইজ জুকর মুখো চুন দিছি চুচা অইআ গেছইন গি। জুকাড় 13ukar [< মবা. জোঁকার = উলুধ্বনি]"
        ]
      },
      {
        "part_of_speech": "বি.",
        "definition": "উলুধ্বনি।",
        "examples": [
          "হানজা মিলাই জারগি জুকাড় দেও। >> মবা. দৃ. 'ডাকিনী যোগিনী দিল জয় জোঁকার।' -‘মনসামঙ্গল’ বিজয়গুপ্ত জুখা 13ukha [< মবা জুখা]"
        ]
      },
      {
        "part_of_speech": "ক্রি.",
        "definition": "কোনোকিছুর মাপ লওয়া।",
        "examples": [
          "‘হাতপেচি ফুতা দিআ জামাইরে জুখিলা কইনার মাএ।’ — বরাকগীত"
        ]
      }
    ],
    "source_page": "IMG_0162"
  },
  {
    "headword": "জুগ্",
    "transliteration": "jug",
    "phonetics": "ʒug",
    "etymology": "[< ববাং শব্দ জুগ]",
    "senses": [
      {
        "part_of_speech": "ক্রি.",
        "definition": "মাথা দিয়ে মার্ [অনুজ্ঞায়]।",
        "examples": [
          "হাতি চালনার পরিভাষা। ‘জুগমার্’ বললেই হাতি মাথা দিয়ে সামনের ‘গাছের কাণ্ড’ বা টিলাতে সজোরে ঢোঁ মারবে। গাছ টেনে নেওয়ার কাজে পরিভাষাটি ব্যবহাত হয়। ‘জুগ’ শব্দের অর্থ ‘মাথা নোয়ানো'। জুগালি 13ugali [< সং যোগ + আলি তপ্র. কর্তায়]"
        ]
      },
      {
        "part_of_speech": "বি.",
        "definition": "মিস্ত্রী বা কারিগরের সাহায্যকারী।"
      },
      {
        "part_of_speech": "বিণ.",
        "definition": "এঁটো; সামান্য খাওয়া হয়েছে এমন।",
        "examples": [
          "কেওরর জুটা সফরি মুই খাই না।"
        ]
      }
    ],
    "source_page": "IMG_0162"
  },
  {
    "headword": "জুটা্ব",
    "transliteration": "jutabo",
    "phonetics": "ʒuṭabɔ",
    "etymology": "[< প্রা. √ জোড্ = জোড়া]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "গুচ্ছ; থোকা।",
        "examples": [
          "জুটাত কটা করি লেচু আছে? জুত 13ut [< বাং জোত < সং যোত্র]"
        ]
      },
      {
        "part_of_speech": "বি.",
        "definition": "জমির মালিকের কাছ থেকে কয়েক বছরের জন্য চাষের স্বত্বে যে জমি গ্রহণ করা হয়।",
        "examples": [
          "ই চিরি আমার নায় বা, জুত জমিন খেত করিআর। জুত 13ut [< সং যুক্ত]"
        ]
      },
      {
        "part_of_speech": "বি.",
        "definition": "বলদের কাঁধে জোয়াল বেঁধে দেওয়ার দড়ি। দ্র. জুআল",
        "examples": [
          "দড়িটি জোয়ালের হলির সঙ্গে লাগানো থাকে। জুতা 13uta [< সংযুক্ত]"
        ]
      },
      {
        "part_of_speech": "ক্রি.",
        "definition": "গোরু বা মোষকে জোয়াল কাঁধে দিয়ে চাষের কাজে লাগানো।",
        "examples": [
          "দ্র. জুআল। জুনাক 13unak [< প্রা. জোণহা < সং জ্যোৎস্না]"
        ]
      },
      {
        "part_of_speech": "বি.",
        "definition": "চাঁদের আলো।",
        "examples": [
          "ফটফটা জুনাক, হাগো একফুটি মেঘ নাই। জুনিআ 13unia [< ববাং শব্দ জুনিআ]"
        ]
      },
      {
        "part_of_speech": "বি.",
        "definition": "বিষহীন একপ্রকার ছোটজাতের সাপ।",
        "examples": [
          "ধানকাটার পর খেতের জমিতে এই সাপ প্রচুর দেখা যায়। সাদায়-কালোয় রং। জুনিপুক 13unipuk [< আঞ্চবাং জোনাইজোনি < সং জ্যোতিরিঙ্গণী"
        ]
      },
      {
        "part_of_speech": "বি.",
        "definition": "জোনাকি পোকা।",
        "examples": [
          "বারিশাত হানজা মিলাইলেউ বনর ধারো জুনিপুক উডইন। জুব্বা 13ubba [< ববাং শব্দ জুব্বা]"
        ]
      },
      {
        "part_of_speech": "বিণ.",
        "definition": "বাকশক্তি ও শ্রবণশক্তি রহিত।",
        "examples": [
          "কোনো দুর্ঘটনার ফলে বোবা ও কালা হয়ে গেলে শব্দটি ব্যবহাত হয়। জুম 13um [< আঞ্চ./দেশি. জুম]"
        ]
      },
      {
        "part_of_speech": "বি.",
        "definition": "পার্বত্য অঞ্চলের চাষ পদ্ধতি বিশেষ।",
        "examples": [
          "মাঘ-ফাল্পুন মাসে পাহাড়ের বন-জঙ্গল কেটে আবাদ করা হয়। শুকিয়ে গেলে এসব পোড়ানো"
        ]
      },
      {
        "part_of_speech": "বি.",
        "definition": "যারা জুম পদ্ধতিতে চাষাবাদ করে। উত্তর-পূর্ব ভারতের প্রায় সবকটি পার্বত্য উপজাতি জুম চাষ করে থাকে। গারো, ডিমাসা, টিপরা, রিয়াং, চাকমা, কুকি, নাগা, কার্বি, লুসাই, রাংখল, রুকনি, হুমার প্রভৃতি উপজাতিদের প্রধান উপজীবিকা এই জুমচাষ। স্ত্রীপুরুষ সকলেই জুমচাষ করে থাকে। জুড়া িʒuṛa [< সং √জোড় (=বন্ধনে)]"
      },
      {
        "part_of_speech": "ক্রি.",
        "definition": "মূল্যবান কিছু কিনে সযত্নে রাখা; পরিশ্রম করে সম্পত্তি বানানো।",
        "examples": [
          "ই সারা জমিন খেত-বাড়ি হকলতা আমি একলা কাম করি জুড়িছি। জুড় <code>J3ur</code> [< বাং জোড়া = এক জাতীয় দুটি বস্তু]"
        ]
      },
      {
        "part_of_speech": "বিণ.",
        "definition": "দুটিতে যুক্ত; যমজ।",
        "examples": [
          "জুড় আম জুড় বাইংগন জুড় কলা জুড় নেনা জুড়র লগর নেনা জুরি 13uri [< ধ্ব. ঝুরঝুর (= ক্ষীণ ধারায় নির্গত হওয়া) + ই তপ্র. ‘উপায়’ অর্থে ]"
        ]
      },
      {
        "part_of_speech": "বি.",
        "definition": "ছোট নালা; জল নির্গমনের জন্য ক্ষুদ্র নালি।",
        "examples": [
          "জুরি কাটি দে, পানি হুকাউক।",
          "স্থাননাম — হাইলাকান্দি জেলার ‘মাটিজুরি’ বাজার। জুরি রানদা কzuri randa [< ববাং জুরি ~ রানদা]"
        ]
      },
      {
        "part_of_speech": "বি.",
        "definition": "র্গ্যাদা বিশেষ।",
        "examples": [
          "<sup>১</sup>/৯ ইঞ্চি ফলা (Blade) যুক্ত রানদা। এটি দিয়ে কাঠের বরগা প্রভৃতিতে খাঁজ (Chennel) কাটা হয়।"
        ]
      }
    ],
    "source_page": "IMG_0162"
  },
  {
    "headword": "জুড়ি",
    "transliteration": "judo়i",
    "phonetics": "ʒuḍɔ়i",
    "etymology": "[< বাং জোড়া + ই স্বার্থে ]",
    "senses": [
      {
        "raw_text": "3uri [< বাং জোড়া + ই স্বার্থে ]"
      },
      {
        "part_of_speech": "বি.",
        "definition": "যুগল; যারা একসঙ্গে কাজ করে।",
        "examples": [
          "একজুড়ি মাটি কমেলা।",
          "‘জুড়ি’ মানে জোড়া। বরাক উপত্যকায় ‘দুটি’তে জোড়া এমন নয়, তিনটিতেও জোড়া আছে। যেমন, মাটি কামলার জুড়ি তিনজনে; পারনর জোড়া তিনটায়।"
        ]
      }
    ],
    "source_page": "IMG_0163"
  },
  {
    "headword": "জুড়ানি",
    "transliteration": "judo়ani",
    "phonetics": "ʒuḍɔ়ani",
    "etymology": "[< আমবা. জুড়া = শীতল করা]",
    "senses": [
