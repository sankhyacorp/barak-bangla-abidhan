  {
    "headword": "বাউলা",
    "transliteration": "baula",
    "phonetics": "baula",
    "etymology": "[< বাং বাউল = সাধক সম্প্রদায় বিশেষ + আ সম্বন্ধার্থে]",
    "senses": [
      {
        "part_of_speech": "বিণ.",
        "definition": "বাউল সম্বন্ধীয়; বাউলদের রচিত গীত।",
        "examples": [
          "পরির বাড়িত আইজ সারা রাইত বাউলা কিরতন, জাইতে নি?"
        ]
      },
      {
        "part_of_speech": "বিণ.",
        "definition": "বাউন্ডুলের মতো স্বভাব যুক্ত।",
        "examples": [
          "বাউলা বেটাইনতরে হেংগা করি সুখ পাইতে নায।"
        ]
      },
      {
        "part_of_speech": "বাগধা. ক্রি.",
        "definition": "সঠিক পথ নির্দেশ করা; যথাযথ পন্থা বাতলে দেওয়া।",
        "examples": [
          "তাইরে বাউগ লাগাইআ দিছি এমনেউ জাগাত জাইব।"
        ]
      },
      {
        "part_of_speech": "বাগধা. ক্রি.",
        "definition": "পলায়নের সুযোগ খোঁজা।",
        "examples": [
          "তারে কামর সময় কানো পাইতায় হি গিআ হারছে, তুড়া আগে দেখছি অনো বাউগ্লা বাউগ্লি করের।"
        ]
      },
      {
        "part_of_speech": "বাগধা. ক্রি.",
        "definition": "সময় নষ্ট করা; অন্যের কাজে হস্তক্ষেপ করা; পশু করা।",
        "examples": [
          "বাউলাড়া দিআ তাই বিআখান আর অইতে দিলি না।"
        ]
      }
    ],
