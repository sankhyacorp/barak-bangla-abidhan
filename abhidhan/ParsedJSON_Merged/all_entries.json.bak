  {
    "headword": "তেআর",
    "transliteration": "tear",
    "phonetics": "tear",
    "etymology": "[<ববাং শব্দ তেআর]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "ধর্মীয় বা সামাজিক অনুষ্ঠান; পার্বণ।",
        "examples": [
