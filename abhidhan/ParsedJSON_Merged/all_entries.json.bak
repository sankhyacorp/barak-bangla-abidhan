        ]
      }
    ],
    "source_page": "IMG_0087"
  },
  {
    "headword": "কানুডার",
    "transliteration": "kanudar",
    "phonetics": "kanuḍar",
    "etymology": "[<বাং কান্ডার (= নৌকার হাল) অর্থপ্রসারে। বি. — বড় বাণিজ্য তরী। ⇒ 'মারলে কানডার (স্থানান্তরে-'গণ্ডার') লুটলে ভান্ডার।' — বপ্র. কান্দ্/কান্ধ্ kand / kandh [<প্রা. কান্ধ < সং স্বন্ধ ]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "বড় বাণিজ্য তরী।",
        "examples": [
          "'মারলে কানডার (স্থানান্তরে-'গণ্ডার') লুটলে ভান্ডার।' — বপ্র. কান্দ্/কান্ধ্ kand / kandh [<প্রা. কান্ধ < সং স্বন্ধ ]"
        ]
      },
      {
        "part_of_speech": "বি.",
        "definition": "কাঁধ; বাহুমূল থেকে গলা পর্যন্ত দেহাংশ।",
        "examples": [
          "'পুড়ির নাতি কানধাে ছাত্তি।' -বরাকপ্রবাদ কানমন kandon [< আমবা./প্রাবা. কান্দন < সং কুন্মন]"
        ]
      },
      {
        "part_of_speech": "বি.",
        "definition": "কানা।",
        "examples": [
          "কি কানদন কানদিলা বাফে-মায়ে।’ — বরাক গীত >> আমবা কান্দন ⇒ ‘নান্দ যশোদা মিলি জুড়িল কান্দন।' — কৃকী। দ্র. কানদা। কানমাং, kanda [< চঃ কন্মরে]"
        ]
      },
      {
        "part_of_speech": "ক্রি.",
        "definition": "কাঁদা; ক্রন্দন করা।",
        "examples": [
          "পেটের ভুখে খালি হরুতায় কানদিতরা। সং ক্রন্দতি > প্রা. কন্দতি > ল্রং কন্দই > প্রাবা. আমবা. কান্দে ⇒ ‘সকল গোআল কান্দে মাথে দি আঁ হাথে।' — কৃকী বরাকবাংলায় আদিমধ্যবাংলার রূপটিই রক্ষিত। ] কান্মা, kanda [<ববাঃ কান্ম্ / কান্ধ্ = কাঁধ] অনু. — কাছে।",
          "বনরবেটা (বাঘ) মোর কানদাবায় গেছে।"
        ]
      },
      {
        "part_of_speech": "বি.",
        "definition": "কিনারা",
        "examples": [
          "মেঘর ডাকে পুশকন্ডির কানদাবায় কই উঠিত্রা।"
        ]
      }
    ],
    "source_page": "IMG_0087"
  },
  {
    "headword": "কানদি",
    "transliteration": "kanodi",
    "phonetics": "kanɔdi",
    "etymology": "[<ববাং কান্দ (= কাঁধ) + ই তপ্র. সম্বন্ধার্থে ]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "বাঁশ প্রভৃতির আঁটি ; বান্ডিল।",
        "examples": [
          "বাং তুল. কাঁদি। বাঁশ, বেত, ঋজু উদ্ভিদ প্রভৃতির বাণ্ডিলকে কানদি বলা হয়। কাঁধে করে বহন করা হয় বলেই এই নাম।",
          "বা'র কানদি; বেতর কানদি।"
        ]
      }
    ],
    "source_page": "IMG_0088"
  },
  {
    "headword": "কানানি",
    "transliteration": "kanani",
    "phonetics": "kanani",
    "etymology": "[<বাং কানাসি <সং কর্ণাস্থি]",
    "senses": [
      {
        "part_of_speech": "ক্রি.",
        "definition": "কড়িকাঠ বা বরগার সঙ্গে খাপ খাইয়ে বসানোর জন্য খুঁটির মাথা মাছের ফুলকার আকৃতির মতো করে কেটে ফেলা।",
        "examples": [
          "অ জেঠ, খুটাগুইন ভালা করি কানাইও।"
        ]
      },
      {
        "part_of_speech": "বি.",
        "definition": "বিশেষ আকৃতিতে খুঁটির মাথা ছাটা।",
        "examples": [
          "কানানি ভালা নাঅইলে মাড়ইল বইত নায়।",
          "বাং কানাসি / কানাসী মানে মাছের ফুলকার কাঁটা। কানাসির মতো খুটির মাথা কাটা হয় বলে এই নায।"
        ]
      }
    ],
    "source_page": "IMG_0088"
  },
  {
    "headword": "কানপাড়া",
    "transliteration": "kanopado়a",
    "phonetics": "kanɔpaḍɔ়a",
    "etymology": "[<বাং কান = কর্ণ + ববাং পাড়া = পদক্ষেপ]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "হাতির ঘাড়ের কাছে বাঁধা পাদানি-রশি।"
      },
      {
        "part_of_speech": "বাগধা. ক্রি.",
        "definition": "ধীরে ধীরে সতর্কভাবে অগ্রসর হওয়া।",
        "examples": [
          "বউত জাগা কান্খা মারিআ গিয়া পুলিশে ডাকাইত ধরছইন। কান কাটরা কুততা — বাগধা. বি — দাগি অপরাধী।",
          "দুইবার ফাটকো গিআ হি এলকু কান কাটরা কৃত্তা, মানে ডাকইন ফাটকি কালামিআ।"
        ]
      },
      {
        "part_of_speech": "বাগধা. বি.",
        "definition": "কুমন্ত্রণা। কামলাবেটির কানমন্ত্রে হে তার বউরে খেদাইছে।"
      },
      {
        "part_of_speech": "বিণ.",
        "definition": "ক্ষণস্থায়ী। ‘অ গো বইনারি— নারির জইবন কানা কইলার পানি।' — বরাকগীত কাফনা = ঝিনুক জাতীয় জলজীব বিশেষ"
      }
    ],
    "source_page": "IMG_0088"
  },
  {
    "headword": "কানার",
    "transliteration": "kanar",
    "phonetics": "kanar",
    "etymology": "[< আঞ্চ. কানার]",
