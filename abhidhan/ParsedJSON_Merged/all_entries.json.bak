    "etymology": "[< বাং দেড় + আ তপ্র. অতিরিক্ত অর্থে < সং দ্ব্যর্থা]",
    "senses": [
      {
        "part_of_speech": "বিণ.",
        "definition": "দেড়গুণ; বেশি।",
        "examples": [
          "বেশ রাইত অইলে রিকশায় দেড়া ভাড়া লয়।",
          "'DER (A) - one and a half. Td. dvi - ardha 'two less half'. — EDB."
        ]
      },
      {
        "part_of_speech": "বাগধা. বি.",
        "definition": "দেবতা ও উপদেবতা।",
        "examples": [
          "কিজাতর মানু তাইন দেয়দেপতা মানইন না। ধ"
        ]
      }
    ],
    "source_page": "IMG_0210"
  },
