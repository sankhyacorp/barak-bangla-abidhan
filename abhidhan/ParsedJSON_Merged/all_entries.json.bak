      {
        "part_of_speech": "বি.",
        "definition": "কলাগাছের ছাই; কলাগাছের ভস্ম থেকে প্রস্তুত পানীয় বিশেষ।",
        "examples": [
          "ডিমাসা কাছাড়ি, রুকনি এবং কুকি উপজাতির বিভিন্ন প্রশাখার মধ্যে ‘খার’ পানীয়র চল্ বেশি। অসমিয়ারা বিভিন্ন ব্যঞ্জনে খারের ব্যবহার করে।"
        ]
      }
    ],
    "source_page": "IMG_0107"
  },
  {
    "headword": "খারা্",
    "transliteration": "khara",
    "phonetics": "khara",
    "etymology": "[<সং ক্ষারক ?]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "ক্ষুদ্র ক্ষুদ্র ফাঁক বিশিষ্ট বড় আকারের বাঁশের খাঁচা বিশেষ।",
