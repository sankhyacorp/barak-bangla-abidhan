  },
  {
    "headword": "কুকড়িকানা",
    "transliteration": "kukodo়ikana",
    "phonetics": "kukɔḍɔ়ikana",
    "etymology": "[<ববাং কুকড়ি আলং ~ বাং কানা ]",
