    "phonetics": "iɔ",
    "etymology": "[< ববাং শব্দ ইঅ]",
    "senses": [
      {
        "part_of_speech": "অনম্ব.",
        "definition": "মুদ্রাদোষ বিশেষ। কথার সূচনায়, কোনো কথা বা ঘটনা স্মরণ করার প্রয়াসে এইটির ব্যবহার।",
        "examples": [
          "ইঅ, তুমারে খুজিআর বা, মোর ডামাগু বানধাইতাম আশলো।",
          "ইঅ..., হদিনকু কিতানু কইতায় আশলো কও না।"
        ]
      }
