  {
    "headword": "উদ্রানি",
    "transliteration": "udrani",
    "phonetics": "udrani",
    "etymology": "[<ববাং শব্দ √ উদ্রা]",
    "senses": [
      {
        "part_of_speech": "ক্রি.",
        "definition": "না জানার ভান করে জিজ্ঞেস করা।",
        "examples": [
          "তুই হকলতা জানিআ হুনিআ আমারে উদ্রারে কেনে? উদ্লা <math>\\mathrm{udla}</math> [<উদড়া < প্রা. উদাড় < সং উদার = উন্মুক্ত ]"
        ]
      },
      {
