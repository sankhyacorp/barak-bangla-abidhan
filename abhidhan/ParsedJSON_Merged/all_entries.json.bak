    "etymology": "[<ববাং শব্দ চেপটি]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "হাঁসের রোগ বিশেষ।",
        "examples": [
          "হাঁসের ডিমপাড়ার ঋতুতে এই রোগ হয়। এই রোগ হলে হাঁস লেপ্টে বসে থাকে এবং পেটের ব্যথায় ডানা ঝাপটায়।"
        ]
      }
    ],
    "source_page": "IMG_0146"
  },
  {
    "headword": "চেফা",
    "transliteration": "chefa",
    "phonetics": "c∫efa",
    "etymology": "[< বাং চাপ + আ যুক্তার্থে]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "বাঁশের শলাকা দিয়ে তৈরি কলসির মতো দেখতে মাছ ধরার ফাঁদ বিশেষ।",
        "examples": [
          "এটির নিচের দিকে মাছ ঢোকার জন্য যে দুটি পথ রাখা হয় তা খানিকটা চাপা, সেই জন্য এই নাম।",
          "মাছ উজাইত্রা, খাড়লো চেফা বআইলে হিং মাগুর পুটি হমাইবা।"
        ]
      }
    ],
    "source_page": "IMG_0146"
  },
