    "transliteration": "korota",
    "phonetics": "kɔrɔta",
    "etymology": "[<সং কর্তা = প্রভূ]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "গুরুদেব ; যিনি দীক্ষা দেন এবং ধর্মোপাসনার পথনির্দেশ করেন।",
        "examples": [
