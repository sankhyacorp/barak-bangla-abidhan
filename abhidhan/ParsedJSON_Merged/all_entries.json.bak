  },
  {
    "headword": "লংগর",
    "transliteration": "lnggor",
    "phonetics": "lŋgɔr",
    "etymology": "[< ফা. লংগর = গেরাফি]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "লোহার তৈরি শৃঙ্খল; Fetters.",
        "examples": [
          "পাগলা কুনকারে লংগর দি বানধিছইন।"
        ]
      },
      {
        "part_of_speech": "বি.",
        "definition": "গাছের নাকায় (দ্র. নাকা) যে লোহার শেকল বাঁধা হয়। লংচাক lɔŋc∫ak [< কুকি. লংচাক]",
        "cross_references": [
          "নাকা"
        ]
      },
      {
        "part_of_speech": "বি.",
        "definition": "বুনো শিম।",
        "examples": [
          "শিরিষ গাছের মতো গাছ। বাকল মসৃণ পর্ণমোচী , পাতা শিরিষের চেয়ে চকচকে। এই শিম প্রায় দেড়ফুট দীর্ঘ হয়। এখানকার উপজাতিদের প্রিয় সবজি। বৈজ্ঞানিক নাম— Parkia Romburghii লরিল logli [< ববার ভক্ন লরিল] বিণ. অশি. — খারাপ চরিত্র যুক্তা; দুশ্চরিত্রা; গালি বিশেষ।",
          "লংলিবেটিরে কেওরর বাড়িত জাগা দিও না।"
        ]
      }
    ],
    "source_page": "IMG_0316"
  },
  {
    "headword": "লা",
    "transliteration": "la",
    "phonetics": "la",
    "etymology": "[< সং লাক্ষা সংকোচনে]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "আঠা; গালা; Gum; Glue। ফা. লা, লাহা।",
        "examples": [
          "লা দি চিঠির মুখ মারিস।",
          "আগে ‘লা’ বলতে মহাল (ধুনাগাছ) ও ফরিশ গাছ থেকে উৎপন্ন আঠা বোঝাতো। এখন যেকোনো আঠাকেই বুঝায়।"
        ]
