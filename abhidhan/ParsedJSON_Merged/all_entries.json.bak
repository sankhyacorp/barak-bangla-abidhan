  {
    "headword": "পাল",
    "transliteration": "pal",
    "phonetics": "pal",
    "etymology": "[< সং পাল]",
    "senses": [
      {
        "part_of_speech": "বাগধা. ক্রি.",
        "definition": "সন্তানার্থে স্ত্রী পশুদের মৈথুনে রত হওয়া।",
        "examples": [
          "গেল আইন কাতৃতিত্ আমার ডেকিএ পাল - খাইছে। ভানহে Palai [< ববাঃ শব্ম. ভানহে]"
        ]
