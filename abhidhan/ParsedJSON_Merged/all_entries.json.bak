    "etymology": "[< ধ্ব. ঝুপ্ = জলে ঝাঁপানোর মকা]",
    "senses": [
      {
        "part_of_speech": "ক্রি.",
        "definition": "উপর্বুপরি ডুব দেওয়া ও সাঁতার কাটা।",
        "examples": [
