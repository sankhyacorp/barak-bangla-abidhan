  {
    "headword": "গাদ",
    "transliteration": "gad",
    "phonetics": "gad",
    "etymology": "[<সং কাথ = নির্যাস ঘোষীভবনে]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "তরল পদার্থের নিচে জমে থাকে যে ময়লা; ঘনরস। О গা পাতৃলা অআ ⇒ ছইআমরার লত পিশিআ পানিত সিদদো করি থই দিলে মুরো গাদ বয়। ই গাদ খাইলে বেটিনতর মাসিকর গুলমাল কমে।",
        "examples": [
          "ফিটকিরি দিলে পানির গাদ তলে বয়।"
        ]
      }
    ],
    "source_page": "IMG_0121"
  },
  {
    "headword": "গান্দ্রা",
    "transliteration": "gandra",
    "phonetics": "gandra",
    "etymology": "[<ফা. গন্দহ্ = নোংরা]",
    "senses": [
      {
        "part_of_speech": "বিণ.",
        "definition": "পচা ; নোংরা।",
        "examples": [
          "বাজারের বা অন্যকোনো পচা, বাসি বা অস্বাস্থ্যকর খাবারের বেলায় শব্দটি প্রযোজ্য।",
          "অটলর গান্দ্রা খানি খাইআ তান পেটো ধরছে।"
        ]
      },
      {
        "part_of_speech": "বিণ.",
