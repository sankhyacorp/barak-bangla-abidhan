  {
    "headword": "মহাজাল",
    "transliteration": "mohajal",
    "phonetics": "mɔɦaʒal",
    "etymology": "[< বাং মহাজাল < সং মহৎ (= বিশাল/শ্রেষ্ঠ) + জাল]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "বিশাল আকারের মাছ ধরার জাল বিশেষ।",
        "examples": [
          "মাছ ধরার জালের মধ্যে এ জাল শ্রেষ্ঠ জাল। ৮০০ হাত দৈর্ঘ্য ৩৫ হাত প্রস্থ এই প্রকাণ্ড জালটি বাইতে কমপক্ষে ২৫ জন লোক ও তিনখানা নৌকা লাগে। এই জাল দিয়ে ছোট-বড় সবরকমের মাছ ধরা যায়। নদী, বিল ও সাগরে এই জাল বাওয়া হয়।"
        ]
      }
    ],
    "source_page": "IMG_0295"
  },
  {
    "headword": "মহাল",
    "transliteration": "mohal",
    "phonetics": "mɔɦal",
    "etymology": "[<বাং মহা (সং মহৎ) + আল্ (<আঞ্চ. বাং. লাল্ = রত্ন)]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "একপ্রকার ধূনাগাছ।",
        "examples": [
          "মহালগাছ ৫০ ফুট পর্যস্ত উঁচু হয়। বেড়ে ছয় হাত পর্যন্ত। আমপাতার মতো পাতা, সামান্য খাটো। উঁচু স্থানে বা পাহাড়ে এই গাছ জন্মে। এই গাছের কশ বা ক্ষীর থেকে উত্তম ধূনা পাওয়া যায়। বৈজ্ঞানিক নাম— Vitia Lanceafolia."
        ]
      }
    ],
    "source_page": "IMG_0295"
  },
  {
    "headword": "মাঅ",
    "transliteration": "mao",
    "phonetics": "maɔ",
    "etymology": "[< আমবা. মাঅ < সং মাতা]",
    "senses": [
