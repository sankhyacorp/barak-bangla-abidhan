      {
        "part_of_speech": "বি.",
        "definition": "স্তম্ভন; রোগ নিরাময় না-হওয়ার জন্য তন্ত্রোক্ত প্রক্রিয়া।",
        "examples": [
          "তন্ত্রোক্ত অভিচারাদি কর্ম দ্বারা রোগ প্রভৃতির জড়ীকরণ।",
          "তোর বরন কিগে থামিছে নাইলে কমিতো না কি? জা, মূললার অন তনে পানিপড়া লইআ আয়।"
        ]
      }
    ],
    "source_page": "IMG_0201"
  },
  {
    "headword": "থাড়ি",
    "transliteration": "thado়i",
    "phonetics": "thaḍɔ়i",
    "etymology": "[<আঞ্চ. থাড়ি < হি. ঠাটী]",
    "senses": [
      {
        "part_of_speech": "বিণ.",
        "definition": "বহুদিন হয়েছে আর সম্ভান প্রসব করেনি এমন (স্ত্রীপশু); দুধ দেওয়া ছেড়ে দিয়েছে এমন (স্ত্রীপশু)।",
        "examples": [
          "আমরার ঘরো দুগ্গু গাই — এগগু পরোতি এগ্ণ্ড থাড়ি।",
          "অশিষ্ট প্রয়োগও হয় শব্দটির। যেমন, মধ্যবয়স্কা স্ত্রীলোক, যার সম্ভানেরা বড় হয়ে গেছে, তাকেও ‘থাডি’ বলা হয়।"
        ]
      }
    ],
    "source_page": "IMG_0201"
  },
  {
    "headword": "থাড়িআ",
    "transliteration": "thado়ia",
    "phonetics": "thaḍɔ়ia",
    "etymology": "[<বাং তাক + ইআ সাদৃশ্যে/স্বার্থে]",
    "senses": [
