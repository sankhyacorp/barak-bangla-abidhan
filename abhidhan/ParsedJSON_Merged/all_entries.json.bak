    "etymology": "[<ববাং শব্দ খাখাই, খাকুই]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "কল্পিত ভয়ংকর সরীসৃপ।",
        "examples": [
          "কানদিস না, খাখাই এ আইআ ধরব। ⇒ শিশুদের কান্না থামানোর জন্য মা-বাবারা এই কল্পিত জীবের ভয় দেখান। এই প্রাণীটির আকৃতি ও ভয়ংকর স্বভাবের সঙ্গে ড্রাগনের কিছুটা মিল রয়েছে।"
        ]
      }
    ],
    "source_page": "IMG_0105"
  },
  {
    "headword": "রাগড়া বিরইন",
    "transliteration": "ragodo়a biroin",
    "phonetics": "ragɔḍɔ়a birɔin",
    "etymology": "[<বাং খাগড়া = reed ~ ববাং বিরইন]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "বিরন ধানের প্রকার বিশেষ।",
        "examples": [
          "শালি ধানের অন্তর্গত। বড় দানার-হালকা সোনালি ধান। চাল সাদা। সুগন্ধযুক্ত ও সুস্বাদু। ভালোই ফলে।"
        ]
      }
    ],
    "source_page": "IMG_0106"
  },
  {
    "headword": "রাটা",
    "transliteration": "rata",
    "phonetics": "raṭa",
