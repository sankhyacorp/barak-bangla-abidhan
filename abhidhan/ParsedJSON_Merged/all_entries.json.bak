  {
    "headword": "হি",
    "transliteration": "hi",
    "phonetics": "ɦi",
    "etymology": "[< প্রাবা. সি হকারীভবনে]",
    "senses": [
      {
        "part_of_speech": "সর্ব.",
        "definition": "সে; প্রথম পুরুষ একবচন পুংলিঙ্গ। শে > ভং ও প্রাবা. সি হকারীভবনে বরাকবাংলায় কর্তৃকারকে একবচনে ‘হি’ পাচ্ছি। প্রাকৃত ‘শে’ এর রক্ষণশীলতা ও ‘সি’ এর স্বরধ্বনির নিম্নাবতরণ [ই > এ ব্যটার ফলে বরাক বাংলায় ‘হি’ এর সঙ্গে ‘হে’ সমানভাবে প্রচলিত। দ্র. তাই; হে। ‘হি’-র স্ত্রীবাচক ‘তাই’।"
      }
    ],
    "source_page": "IMG_0345"
  },
