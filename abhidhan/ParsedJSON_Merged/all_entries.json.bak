    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "কাঁঠালের ব্যঞ্জন। সুচারুরূপে ঘাঁটার ওপর নির্ভর করে।",
        "examples": [
          "কথায় বলে, কাঁঠালের ব্যঞ্জনের সোয়াদ"
