  {
    "headword": "রাটাল",
    "transliteration": "ratal",
    "phonetics": "raṭal",
    "etymology": "[<বাং খাটাল = মধ্যস্থল <সং খট্টা]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "রান্নাঘর ; ভেতরের ঘর, যা মেয়েদের ঘর বলে পরিচিত।",
        "examples": [
          "বরাক উপত্যকার গ্রামদেশে রান্নাঘরই অন্তঃপুরের ভূমিকা নিয়ে থাকে।",
          "আতপাও না ধইআ খাটালো হমানি মুই জারিতাম পারি না। 📆 আ khathua [<সং কমট্ + আ তপ্র]"
        ]
      },
      {
        "part_of_speech": "বি.",
        "definition": "কচ্ছপ।",
        "examples": [
          "‘খাঠুআ’ কচ্ছপের প্রজাতি বিশেষ। এদের বিচরণ স্থলেই বেশি।"
        ]
      }
    ],
    "source_page": "IMG_0106"
  },
