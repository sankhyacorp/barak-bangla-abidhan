  {
    "headword": "শুতরাং",
    "transliteration": "shutorang",
    "phonetics": "∫utɔraŋ",
    "etymology": "[<ববাং শব্দ সুতরং]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "চিরসবুজ বৃক্ষবিশেষ।",
        "examples": [
          "এই গাছ লম্বায় ৬০ হাত ও বেড়ে ৬ হাত পর্যস্ত হয়। পাতা বোঁটার চারদিকে ছড়ানো ও খাঁজকাটা। কুড়া রোম আছে। গাছের বাকল সাদা। বাকল থেকে উদালের মতো তন্তু পাওয়া যায়। এই তন্তু দড়ি প্রভৃতি তৈরি করা যায়। বৈজ্ঞানিক নাম— Lophopetatum Fimbnatam."
        ]
      }
    ],
    "source_page": "IMG_0329"
  },
