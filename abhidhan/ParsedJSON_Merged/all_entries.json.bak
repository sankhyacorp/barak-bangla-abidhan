  },
  {
    "headword": "তাবিজ",
    "transliteration": "tabij",
    "phonetics": "tabiʒ",
    "etymology": "[<আ. তবিজ্ = মাদুলি]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "মাদুলি।",
        "examples": [
          "সোনা, রূপা, তামা প্রভৃতি ধাতুনির্মিত মাদুলির ভেতর ভেষজ বা মন্ত্র-অক্ষরিত ভূর্জপত্রাদি রেখে মোম/গালা দিয়ে মুখ বন্ধ করে বাহু, কোমর বা গলাতে লোকে ধারণ করে। উদ্দেশ্য, রোগ, গ্রহ বা প্রেতাদি অমঙ্গলকারীদের হাত থেকে মুক্তি পাওয়া। বরাক উপত্যকায় সকল সম্প্রদায়ের মধ্যে এই বিশ্বাস রয়েছে।"
        ]
      },
      {
        "part_of_speech": "বাগধা. বি.",
        "definition": "অনেক ওষুধপত্র পূজাতাবিজ করে বড় করা সস্তান।",
        "examples": [
          "তাবিজর পুআরে চখুর আউড় করি না।"
        ]
      }
    ],
    "source_page": "IMG_0193"
  },
  {
    "headword": "তামা",
    "transliteration": "tama",
    "phonetics": "tama",
    "etymology": "[<বাং তামশা সংকোচনে < আ. তমাশা = বাজা]",
