  {
    "headword": "উলুম",
    "transliteration": "ulum",
    "phonetics": "ulum",
    "etymology": "[<ওড়ি ওলম্ < মারা. ওলম্বা]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "ওলনদড়ি; Plumb Line. লা ভাষার অভিধান ও ভাষাতত্ত",
        "examples": [
          "ধাতৃনির্মিত লাটিমের সঙ্গে দড়ি লাগানো রাজমিস্ত্রির যন্ত্র বিশেষ। এটি দিয়ে রাজমিস্ত্রিরা গাঁথনির মাপ ও খাড়াই পরীক্ষা করে দেখেন।"
        ]
      },
