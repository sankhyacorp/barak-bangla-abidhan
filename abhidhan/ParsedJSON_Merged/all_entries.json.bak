    "source_page": "IMG_0321"
  },
  {
    "headword": "লুট",
    "transliteration": "lut",
    "phonetics": "luṭ",
    "etymology": "[< বাং লুঠ, লুট = প্রসাদ ছড়িয়ে দেওয়া]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "নামকীর্তন উপলক্ষে ভক্তদের সমাবেশে কলা, বাতাসা, সন্দেশ ইত্যদি প্রসাদ ছুড়ে দেওয়া। হরিনামকীর্তন, রথযাত্রা প্রভৃতি অনুষ্ঠানে লুটের ব্যবস্থা আছে।"
      }
