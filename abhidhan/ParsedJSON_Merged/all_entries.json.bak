    "source_page": "IMG_0340"
  },
  {
    "headword": "হাগাটালি",
    "transliteration": "hagatali",
    "phonetics": "ɦagaṭali",
    "etymology": "[< ববাং শব্দ হাগাটালি]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "দারকিনা জাতীয় অতিছোট মাছ বিশেষ।",
        "examples": [
          "মাথার উপর চাপা। ওই চাপা জায়গায় তৃতীয় নেত্রের মতো চকচকে একটি চিহ্ন রয়েছে। আঁশযুক্ত এই মাছ সারাদিন ভেসে বেড়ায়। এ মাছ কেউ খায় ন।"
        ]
      }
    ],
    "source_page": "IMG_0340"
  },
