    "phonetics": "kŋkɔṭ",
    "etymology": "[<সং কঙ্কট = বর্ম]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "এক প্রকার ছোট মাছ।",
        "examples": [
          "এ মাছের দৈর্ঘ্য এক থেকে আড়াই ইঞ্চি। বিষাক্ত কাঁটা আছে। এই বিষাক্ত কাঁটা বর্মের মতো কাজ করে বলেই এই নাম। নদীর ডহরে শীতের দিনে পাওয়া যায়।"
        ]
      }
    ],
    "source_page": "IMG_0083"
  },
  {
