  },
  {
    "headword": "মুড়ি কাটা",
    "transliteration": "mudo়i kata",
    "phonetics": "muḍɔ়i kaṭa",
    "etymology": "[< ববাং মুড়ি¸ + √কাট্ + আ]",
    "senses": [
      {
        "part_of_speech": "বিণ.",
        "definition": "মুড়ি বা ধারের সমপরিমাণ।",
        "examples": [
          "শস্যাদি পরিমাপক পাত্রের কিনারার সমপরিমাণ শস্যকে ‘মুড়িকাটা’ বলা হয়।",
          "মানু তো বাক্কা, মুড়িকাটা এককাঠি রানধি লাইও। মু"
        ]
      }
    ],
    "source_page": "IMG_0305"
  },
  {
    "headword": "লগুটটি",
    "transliteration": "logutoti",
    "phonetics": "lɔguṭɔṭi",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "গুটির লৌকিক খেলা বিশেষ। যনি কুড়িটি গুটি থাকবে। সকলের গুটি একত্র করে খেলা শুরু হয়। ডানহাতে উলটে সাধ্যমতো গুটি অধিকার করবে প্রত্যেকে। এগুলি হাতগুটি। এক একটি হাত গুটি শূন্যে ছুড়ে ছড়ানো গুটি অধিকার করে খেলুড়েরা। যে বেশি গুটি অর্জন করবে সেই জিতবে।",
        "examples": [
          "এই খেলাটি দুজন, চারজন, ছজন বা আটজনে খেলতে পারে। প্রত্যেকের কাছে মূলধন স্বরূপ"
        ]
      }
    ],
    "source_page": "IMG_0305"
  },
  {
    "headword": "মুল্লা",
    "transliteration": "mulla",
    "phonetics": "mulla",
    "etymology": "[< তুর্কি. মুল্লা = পণ্ডিত]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "মুসলমান তান্ত্রিক; যিনি ঝাড়ফুঁক বা কবচতাবিজ দিয়ে রোগের চিকিৎসা বা আপদের শান্তি-ব্যবস্থা করেন। মু"
      }
    ],
    "source_page": "IMG_0305"
  },
  {
