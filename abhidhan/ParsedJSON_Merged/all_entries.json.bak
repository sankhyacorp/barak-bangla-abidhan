    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "চিনি ময়দা কলা মিঠাই ইত্যাদি ঘটিত নৈবেদ্য।",
        "examples": [
          "পির বা লৌকিক দেবতার উদ্দেশ্যে নিবেদিত নৈবেদ্য। শিরা ʃira [< ফা. শুরবা, শিরহ্ = রস]"
        ]
      },
      {
        "part_of_speech": "বি.",
        "definition": "মিষ্টিরস।",
        "examples": [
          "চিনি বা গুড় জলের সঙ্গে গুলে জ্বাল দিয়ে ‘শিরা’ তৈরি করা হয়। রসগোল্লা, লবঙ্গ, খাজা, গজা প্রভৃতি নানা রকমের মিঠাই শিরায় ডুবিয়ে প্রস্তুত করা হয়।"
        ]
