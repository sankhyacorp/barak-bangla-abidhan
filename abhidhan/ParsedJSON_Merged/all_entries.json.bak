    ],
    "source_page": "IMG_0208"
  },
  {
    "headword": "দুদচাম্পা",
    "transliteration": "dudochampa",
    "phonetics": "dudɔc∫ampa",
    "etymology": "[<বাং দুধ ~ চম্পা]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "সুন্দি জাতীয় বৃক্ষ বিশেষ।",
        "examples": [
          "এই গাছ ৬০ ফুট পর্যন্ত উঁচু হয়। চক্রপরিধি ৮ হাতের মতো। সরল পাতা গুচ্ছবদ্ধভাবে বিন্যস্ত। ফুল ধরে গুচ্ছাকারে। ফল সবুজ, পাকলে মেটে রঙের হয়। গাছটি অরণ্যে জন্মে। ঘরের আসবাবপত্র তৈরিতে এর কাঠ ব্যবহৃত হয়।"
        ]
      },
      {
        "part_of_speech": "বি.",
        "definition": "উপার্জনশীলা স্তী।",
        "examples": [
          "দুদ দেরা গাই বিআ করছে তার চিন্তা নাই, খার আর ঘুরের।"
        ]
      },
      {
        "part_of_speech": "বাগধা. ক্রি.",
        "definition": "ভালো বস্তুর পরিবর্তে ক্ষতিকর বস্তু গ্রহণ করা।",
        "examples": [
          "ইলা দৃদ বেচি মদ খাইলে তুমার হকলবাজু জাইব।"
        ]
      }
    ],
    "source_page": "IMG_0208"
  },
