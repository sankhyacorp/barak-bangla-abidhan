        ]
      }
    ],
    "source_page": "IMG_0335"
  },
  {
    "headword": "হউজ",
    "transliteration": "houj",
    "phonetics": "ɦɔuʒ",
    "etymology": "[< আ. ফৌজ = জনতা; সৈন্যদল]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "দলবদ্ধ ভূত বিশেষ।",
        "examples": [
          "এ জাতীয় ভূত দলবদ্ধভাবে চলাফেরা করে। দলেও থাকে ভারী। কোনো দুর্ঘটনা বা যুদ্ধে মানুষ একসঙ্গে মরলে নাকি এদের উৎপত্তি হয় — জনশ্রুতি এরাপই।"
        ]
      },
      {
        "part_of_speech": "বাগধা. বি.",
        "definition": "উপদ্রবকারী জনতা। গাড়িত তনে লামতেউ হউজর <math>\\Rightarrow</math> পালে বেরিলাইছইন।"
