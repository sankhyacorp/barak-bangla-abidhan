    "transliteration": "godo়godo়i",
    "phonetics": "gɔḍɔ়gɔḍɔ়i",
    "etymology": "[<ধ্ব. গড়্গড় + ই তপ্র. যুক্তার্থে]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "একপ্রকার শাক চচ্চড়ি।",
        "examples": [
          "প্রথম শিমবিচি বা মটর ভেজে নিয়ে খানিকটা সিদ্ধ করে নিতে হয়। এরপর মিষ্টিকুমড়ো শাকের সঙ্গে শিমবিচি বা মটর ভাজা মিশিয়ে নুন, লংকা, জিরা ও হলুদ ফোড়ন দিয়ে তৈরি হয় ‘গড়গড়ি’। কুমড়ো শাকের সঙ্গে শিমবিচি বা মটর গড়গড় করে নেড়েচেড়ে এটি প্রস্তুত হয় বলেই এই নাম।"
        ]
      }
