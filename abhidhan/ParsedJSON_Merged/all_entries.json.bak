  {
    "headword": "বন্দান্",
    "transliteration": "bondan",
    "phonetics": "bɔndan",
    "etymology": "[< সং বন্ধ (বন্ধনে) + আন কৃপ্র]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "বন্দোবস্ত।",
        "examples": [
