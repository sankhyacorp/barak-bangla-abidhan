  },
  {
    "headword": "ভাওৢ",
    "transliteration": "vaoৢ",
    "phonetics": "vaoৢ",
    "etymology": "[< আঞ্চ. ভাও < সং ভাব]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "রীতিনীতি; যুগধর্ম।",
        "examples": [
          "‘জে দেশর জে ভাও, উপইত্ অইআ নাও বাও।’ —বপ্র."
        ]
      },
      {
        "part_of_speech": "বি.",
        "definition": "উদ্দেশ্য।",
        "examples": [
          "'ঘশন্তি পিশন্তি খুরা চিত্ গেলা বহুদুরা (= বহুদূরে), বুজিআর যুগর ভাও তুমি মোরে মারতায় চাও।’ —বছ"
        ]
      }
    ],
    "source_page": "IMG_0285"
  },
  {
    "headword": "ভাওআ",
    "transliteration": "vaoa",
    "phonetics": "vaoa",
    "etymology": "[< বাং ভাসা]",
    "senses": [
      {
        "part_of_speech": "ক্রি.",
        "definition": "জল বা বায়ুর উপর ভর করে থাকা; Flot; জলের তল থেকে জলের উপরে উঠা। ২১ ভায়ভায়",
        "examples": [
          "'জত মরা ভাইআ জায়, বরাকরে ছইআ জায়।’—বরাক প্রবাদ"
        ]
      }
