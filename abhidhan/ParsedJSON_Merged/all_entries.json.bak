  {
    "headword": "বাংগই",
    "transliteration": "banggoi",
    "phonetics": "baŋgɔi",
    "etymology": "[< ববাং বাং (=ভারযম্ভি) + অই তপ্র. বৈশিষ্ট্যো]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "চিৎ হয়ে শুয়ে হাঁটুমুড়ে শিশুকে পায়ের পাতায় বসিয়ে বানানো দোলনা।",
        "examples": [
          "ভারযিষ্ঠ বা বাঙের সঙ্গে সঙ্গতি আছে বলেই এই নাম। বাং দিয়ে ভার বয়ে নিয়ে যাওয়ার সময় দুদিকের সামগ্রী দোলনার মতো দুলতে থাকে। এই সাদৃশ্যের কথা মনে রেখে ‘বাং’ থেকে ‘বাংগই’ শব্দটি গঠিত হয়েছে।"
        ]
      },
      {
        "part_of_speech": "বাগধা. বি.",
        "definition": "অসার কথা; দন্তের কাহিন।",
        "examples": [
          "মরিব বেটায় বাংগালর গফ দেওয়াত ভাট।"
        ]
      }
    ],
    "source_page": "IMG_0272"
  },
