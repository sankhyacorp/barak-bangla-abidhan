  },
  {
    "headword": "বাকিন",
    "transliteration": "bakin",
    "phonetics": "bakin",
    "etymology": "[< আঞ্চ. বাকিন]",
    "senses": [
      {
        "raw_text": "[< আঞ্চ. বাকিন] সংযোজক. — তবুও; কিন্তু। ⇒ তাই করিলাইছে বাকিন মুই পারতাম নায়। ⇒ শব্দটি বরাক উপত্যকার বাগান এলাকায় বসবাসকারী বাঙালিরা বেশি ব্যবহার করেন।"
      }
    ],
    "source_page": "IMG_0263"
  },
  {
