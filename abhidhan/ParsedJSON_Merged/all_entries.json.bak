  {
    "headword": "আর্ঘা",
    "transliteration": "argha",
    "phonetics": "argha",
    "etymology": "[<সং অর্ঘ্য = উপচার]",
    "senses": [
      {
        "part_of_speech": "ক্রি.",
        "definition": "উপচার দিয়ে বরণ করা; শ্রদ্ধার সঙ্গে বরণ করা। থেকে ‘শ্রদ্ধার সঙ্গে বরণ করা’ অর্থে দাঁড়িয়েছে। এবং এখানে এটি শুধু ক্রিয়াপদ রূপেই ব্যবহৃত হচ্ছে।",
        "examples": [
          "‘হড়িএ আর্ঘিলা জামাই লাম্বা জুকাড় দিয়া।’ — ব. গীত"
        ]
      }
    ],
    "source_page": "IMG_0057"
  },
  {
    "headword": "আর্তা",
    "transliteration": "arta",
    "phonetics": "arta",
    "etymology": "[<বাং আর = অপর ~ তাহা]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "অন্য জিনিস, অন্যান্য বস্তু; অন্যান্য বিষয়।",
        "examples": [
          "‘একতা আনে জদি আরতা'র টান, গুআ আনি দেখে কিতা ফুড়াইগেছে পান।’ —আনন্দ"
        ]
      },
      {
        "part_of_speech": "বি.",
        "definition": "অপর শিশুরা।",
        "examples": [
          "একতা তো আইআ পাটরো বইছইন: আরতা কানো গেলা?"
        ]
      }
    ],
    "source_page": "IMG_0057"
  },
  {
