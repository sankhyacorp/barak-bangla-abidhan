  {
    "headword": "মেনদি",
    "transliteration": "menodi",
    "phonetics": "menɔdi",
    "etymology": "[< ববাং মেনদা +ই লিপ্র স্ত্রী]",
    "senses": [
      {
        "part_of_speech": "বিণ.",
        "definition": "‘মেনদা’র স্ত্রীবাচক শব্দ। মেনদি<sub>s</sub> mendi [< সং মেন্ধি = ভেষজ বিশেষ]"
      },
      {
        "part_of_speech": "বি.",
        "definition": "মেহেদি গাছ।",
        "examples": [
          "‘শুক্ষ যজুর্বেদের ১২/৬৫ সূক্তের মহীধর যে ভাষ্য করেছেন-তার অনুবাদ হল — ওগো মেন্ধে, তুমি আমার শরীরের দুটি বাহু, মণিবন্ধ ও অঙ্গুলিকে সাজিয়ে দাও; আমার প্রিয়তম আলিঙ্গন করে সুখী হবে; তোমার পাতাগুলির রস আমার গোপন অঙ্গকে ক্লেদমুক্ত ও দৃঢ় করবে।’ —চিরঞ্জীব বনৌষধি নারীর সৌন্দর্যবর্ধন ও যৌবনকে কেবল দীর্ঘায়ু করে না, মেনধি চুলের যাবতীয় রোগের আশ্চর্য ভেষজ। এ ছাড়া শুক্রমেহ, শ্বেতপ্রদর পায়োরিয়া ও চোখ ওঠার মহৌষধ। বৈজ্ঞানিক নাম— Lawsonia inermis linn."
        ]
      }
    ],
    "source_page": "IMG_0306"
  },
