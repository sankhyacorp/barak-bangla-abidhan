    ],
    "source_page": "IMG_0150"
  },
  {
    "headword": "ছাত্তাপাত্তি",
    "transliteration": "chhattapatti",
    "phonetics": "c∫hattapatti",
    "etymology": "[<ববাং ছাত্তা + পাত্তি < বাং পাতা]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "শাখাবিহীন পত্র-উদ্ভিদ বিশেষ। ক্যাপসুলের মতো হলেও শক্ত। রামগুআ বা বন্যসুপারি যেভাবে খাওয়া যায় এর ফলও চিবিয়ে সুপারির মতন খাওয়া যায়। এর পাতা দিয়ে ‘ছাতা’ ও ‘ছই’ (দ্র.) ছাওয়া হয়। চালও ছাওয়া যায়। বৈজ্ঞানিক নাম— Lieuala Peltata.",
        "examples": [
          "একবীজপত্রী বৃক্ষ। ৫-৬ হাত উঁচু হয়। এককপত্র— দেখতে তালপাতার মতো; তবে পত্রকগুলো সংযুক্ত নয়। ফুল সুপারির মতো। ফল"
        ]
      }
    ],
    "source_page": "IMG_0150"
  },
  {
    "headword": "ছাত্তি",
    "transliteration": "chhatti",
    "phonetics": "c∫hatti",
    "etymology": "[< ববাং ছাত্তা + ই লিপ্র. স্ত্রীং]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "স্ত্রীলোকের ছাতা। না ধর আসী মোর পাশ।।’) > ববাং ছাত্তি বর্ণদ্বিম্বে। ‘ছাত্তা বা ছাত্তি’ ‘ছাতিম’ (শ্রীকৃষ্ণকীর্তনে ‘ছাতীঅন’ দৃ. ‘রবি লোধ ছাতীঅন/ভান্টি দুধি আকন’) বরাক বাংলায় ‘ছাত্তিপাত্তা’ দিয়ে ছাওয়া হয় বলেও এই নাম। ফুলালি ছাত্তি",
        "examples": [
          "বেতের তৈরি পাতার ছাওয়া বাঁশের হাতল (=কুরা) যুক্ত কারুকার্যময় সৃদৃশ্য ছাতা।"
        ]
      }
    ],
    "source_page": "IMG_0150"
  },
