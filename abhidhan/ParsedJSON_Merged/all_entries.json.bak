    ],
    "source_page": "IMG_0179"
  },
  {
    "headword": "ডনকলশ",
    "transliteration": "donokolosh",
    "phonetics": "ḍɔnɔkɔlɔ∫",
    "etymology": "[<সং দণ্ডকলশ]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "ডানকুনি গাছ।",
        "examples": [
          "গুল্ম বিশেষ। সবুজ চিরল পাতা। ফুল ছোট ছোট সাদা। তিল ফুলের মতো। পাতা অনেকটা গাঁদাফুলের পাতার মতো। মাঠে ঘাটে জন্মায়।"
        ]
      }
    ],
    "source_page": "IMG_0179"
  },
  {
    "headword": "ভফকি",
    "transliteration": "vofoki",
    "phonetics": "vɔfɔki",
    "etymology": "[<সং ডম্ফ = খঞ্জনি সদৃশ বাদ্য]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "একপাশে চামড়া লাগানো খঞ্জনির মতো আনদ্ধ প্রাচীন বাদ্যযন্ত্র বিশেষ। সং ডম্ফ > ডমফি বিপর্যাসে ডফমি > ববাং ডফকি।"
      }
    ],
    "source_page": "IMG_0179"
  },
  {
    "headword": "ভমকা",
    "transliteration": "vomoka",
    "phonetics": "vɔmɔka",
    "etymology": "[<ববাং শব্দ ভমকা]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "বৃহদাকার সেচন যন্ত্র। হয়। ডমকার দুদিকে দুগাছি করে পাাঁচ ছয় হাত দড়ি। দুজনে দুহাতে জোড়া দড়ি ধরে জলসেচন করে থাকে। বিশেষত ডাঙা জমিতে।",
        "examples": [
          "ডমকা বড়িটনের পাত্র বা টিন দিয়ে তৈরি করা"
        ]
      }
    ],
    "source_page": "IMG_0179"
  },
  {
