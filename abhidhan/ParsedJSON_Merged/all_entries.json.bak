          "বাততিক শফরি; বুড় গুআ। ডাঁ dat [< ম্র. ডাঁগ্রেগ]"
        ]
      },
      {
        "part_of_speech": "বিণ.",
        "definition": "অনমনীয়; মজবৃত।",
        "examples": [
          "ডাট অইআ উবাও।"
        ]
      },
      {
        "part_of_speech": "বিণ.",
        "definition": "কাজে পটু।",
        "examples": [
          "তাই পড়াত কামো হকলতাত ডাট।"
        ]
      }
    ],
    "source_page": "IMG_0180"
  },
