  },
  {
    "headword": "মুরা",
    "transliteration": "mura",
    "phonetics": "mura",
    "etymology": "[< ববাং মুর (= তলদেশ) + আ তপ্র. সম্বন্ধার্থে]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "ঢেঁকি বা উদূকলে ধান ভানার পর যে তলানি বা অবশিষ্টাংশ থাকে।",
        "examples": [
          "দেড়মন ধান ভানা শেশ, খালি মুরাটাইন রইছে।"
        ]
      }
    ],
    "source_page": "IMG_0304"
  },
  {
    "headword": "মুরাৣ",
    "transliteration": "muraৣ",
    "phonetics": "muraৣ",
    "etymology": "[< ববাং ধাতু √মুর]",
    "senses": [
      {
        "part_of_speech": "ক্রি.",
        "definition": "নাট (Nut) প্রভৃতি আঁটবার জন্য পাঁয়চে প্যাঁচে ঘোরানো। মুরা<sub>৪</sub> mura [< ববাং ধাতু√মুর্ = মোচড় দেওয়া]"
      },
      {
        "part_of_speech": "বি.",
        "definition": "গাছের ভাঁজ বা মোচড়।",
        "examples": [
          "‘চামর মুরা বলদর খাইত, না অয় সিধা না অয় পাইত।’ — বপ্র."
        ]
      }
    ],
    "source_page": "IMG_0304"
  },
  {
    "headword": "মুরানি",
    "transliteration": "murani",
    "phonetics": "murani",
    "etymology": "[< ববাং ধাতু √মুর+আ ণিজস্তে।]",
    "senses": [
