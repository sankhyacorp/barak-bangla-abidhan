  {
    "headword": "বাইনজা",
    "transliteration": "bainoja",
    "phonetics": "bainɔʒa",
    "etymology": "[< বাং বাঁজা < সং বন্ধ্যা]",
    "senses": [
      {
        "part_of_speech": "বিণ.",
        "definition": "যে নারীর সস্তান হয়নি এমন; বন্ধ্যা।",
        "examples": [
          "মান্য বাংলায় ‘বাঁজা’ বা ‘বন্ধ্যা’ বলতে কেবল মানুষ নয় অন্যান্য প্রাণী, গাছপালা এমনকী শস্যোৎপাদনে অক্ষম ভূমি প্রসঙ্গেও প্রযোজ্য। ‘বাইনজা’ শব্দটি এখানে শুধু নারীর বেলায়ই প্রয়োগ করা হয়।",
          "মনমনে (=মনমোহন) বাইনজা বেটিরে ছাড়ান দিআ জুআন ছুগরি এগ্গু হেংগা করি আনছে।"
        ]
      }
    ],
    "source_page": "IMG_0260"
  },
