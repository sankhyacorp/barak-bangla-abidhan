    ],
    "source_page": "IMG_0130"
  },
  {
    "headword": "ঘাটুআ",
    "transliteration": "ghatua",
    "phonetics": "ghaṭua",
    "etymology": "[< ববাং শব্দ ঘাটুআ]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "ফণীমনসা জাতীয় গাছ। ঘাটো আইআ নাও বুড়া — বাগধা. ক্রি. কার্যসিদ্ধি প্রায় হয়ে এসেছে এমনি সময় সর্বনাশ হওয়া।",
        "examples": [
          "সবতা অইগেছে খালি সাএবর দস্তগত্ বাকি; আখতা একই দিনে তাইন বদলি, আমার ঘাটো আইআ নাও বুড়িল!"
        ]
      }
    ],
    "source_page": "IMG_0131"
  },
  {
    "headword": "ঘানু",
    "transliteration": "ghanu",
    "phonetics": "ghanu",
    "etymology": "[< সং ঘুণ? উৎপত্তি অর্থে]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "ঘরের কড়িকাঠ, চাল, বেড়া প্রভৃতিতে ঝুলে থাকা ময়লা; ঝুলকালি।",
        "examples": [
          "ধোঁয়া ধুলো ছাড়াও ঘুন পোকা খাওয়া কাঠের গুঁড়ো থেকে ঝুলকালি জমে থাকে।",
          "পুজার আগে ঘর লেপা ঘানু ঝাড়ানি কত কাম।"
        ]
      }
    ],
    "source_page": "IMG_0131"
  },
  {
    "headword": "ঘাপুর ঘুপুর",
