  {
    "headword": "থার জাল",
    "transliteration": "thar jal",
    "phonetics": "thar ʒal",
    "etymology": "[<প্রা উত্মল্ল ~জাল]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "মাছ ধরার জাল বিশেষ।",
        "examples": [
          "বড় আকারের জাখিজাল। ২৪ হাত দৈর্ঘ্য পরিধি ৮০ হাত। জালের প্রান্তে ২০ কিলোগ্রাম লোহার গুটিকা লাগানো থাকে। এ জাল দিয়ে বড় ছোট সবরকম মাছ ধরা যায়। উথারজাল বাইতে দুজন লোকের প্রয়োজন হয়।"
        ]
      }
    ],
    "source_page": "IMG_0067"
  },
  {
    "headword": "উথাল",
    "transliteration": "uthal",
    "phonetics": "uthal",
    "etymology": "[<বাং উত্থাল = আপ্লাবন; উদিগরণ]",
