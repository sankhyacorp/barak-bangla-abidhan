    "headword": "বকফুল",
    "transliteration": "bokoful",
    "phonetics": "bɔkɔful",
    "etymology": "[< বাং বক∼ফুল]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "সাদারঙের ফুল বিশেষ।",
        "examples": [
          "১০/১২ হাত উঁচু গাছ হয়। বর্ষায় ফুল ফোটে। এই ফুল উপাদেয় খাদ্যরূপে ব্যবহৃত হয়। গোলাপি ও নীলরঙের বকফুলও আছে।"
        ]
      },
      {
        "part_of_speech": "বি.",
        "definition": "ক্ষীর বা নারিকেল পুর দেওয়া বকফুল আকৃতির ফুলকো পিঠা।",
        "examples": [
          "ময়দার ছোট ও পাতলা রুটি করে ক্ষীর বা নারিকেলের পুর দিয়ে বক্ফুল-আকারে বানিয়ে হালকা তেলে বাদামি করে ভেজে নিতে হয়। এই পিঠার কিনারার নকশি কর্মটি প্রশংসা করার মতো। তাই দেখতে যেমন সুন্দর খেতেও উপাদেয়।"
        ]
      }
    ],
    "source_page": "IMG_0253"
  },
