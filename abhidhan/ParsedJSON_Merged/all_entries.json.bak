  {
    "headword": "ফরফরা",
    "transliteration": "forofora",
    "phonetics": "fɔrɔfɔra",
    "etymology": "[< ধ্ব. ফরফর = সাড়া জ্ঞাপক; চাঞ্চলাস্চক|]",
    "senses": [
      {
