  {
    "headword": "ইঅলি",
    "transliteration": "ioli",
    "phonetics": "iɔli",
    "etymology": "[<মবা. দহিয়াল]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "দোয়েল পাখি; Magpie Robin.",
        "examples": [
          "সাদা কালো মেশানো সকলের পরিচিত পাখি। স্ত্রীপাখি শ্লেট-সাদা। লেজ উঁচু করে তোলা থাকে। ঝোপঝাড়ে ও লোকালয়ে দেখা যায়। দোয়েল অন্যতম শ্রেষ্ঠ গাইয়ে পাখি। পাকা ফল ও মধু এদের খাদ্য।"
        ]
      },
      {
        "part_of_speech": "বাগধা. ক্রি.",
        "definition": "ঘোলা করা।",
        "examples": [
          "পুকরির পানিরে হরুতায় দই দই করিলাইছইন।"
        ]
      }
    ],
    "source_page": "IMG_0203"
  },
