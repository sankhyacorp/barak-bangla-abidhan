    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "বড় ও দীর্ঘ বেত বিশেষ।",
        "examples": [
          "বরাক উপত্যকায় উৎপাদিত বেত সমূহের মধ্যে গল্লা সবচেয়ে বড় ও লম্বা। অন্নাবেত, Į. রাংগিবেত। বৈজ্ঞানিক নাম— daemonops genkinsus . 5 অন্যান্য বেত হচ্ছে : জালিবেত ও হুনদিবেত।"
        ]
      },
      {
        "part_of_speech": "বাগধা. ক্রি.",
        "definition": "শাসন করা ; দাদাগিরি করা।",
        "examples": [
          "ভুটো জিতিলে তাইন হিরিবার গল্লা ঘুরাইবা। গলা করা — বাগধা. ক্রি — চিৎকার করে কলহ করা।"
        ]
      },
      {
        "part_of_speech": "বাগধা. ক্রি.",
        "definition": "পেট পরিপূর্ণ হওয়া।",
        "examples": [
          "‘জিলাপি খাইতে খাইতে গলার গেছে আইছে, ইজাতর মিঠাইর লাগ বউত দিনে পাইছে।’ –আনন্দ"
        ]
