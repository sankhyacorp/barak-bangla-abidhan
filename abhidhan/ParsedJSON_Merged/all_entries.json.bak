  {
    "headword": "টাউট",
    "transliteration": "taut",
    "phonetics": "ṭauṭ",
    "etymology": "[<ইং Taut = পানান]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "যে প্রতারণা করে; ধাউড়।",
        "examples": [
          "‘মাতে উঠে ঠুটে এমন টাউটে লইছে আমার লগ। ‘থ’ দিআ থই মনে মনে কই ট্টিংগিন পিলাগ্ন র্রা ।’ আনন্দ না ভাষার অভিধান ও ভাষাতত্ত"
        ]
      },
      {
        "part_of_speech": "ক্রিবিণ.",
        "definition": "পাত্রে যতটুকু ধরে ততটুকু।",
        "examples": [
          "ডেরামো পানি টায়টায় ভরিও।"
        ]
      },
      {
        "part_of_speech": "ক্রিবিণ.",
        "definition": "খাপ খেয়ে; মুখেমুখে মিলেমিশে।",
        "examples": [
          "ডিবির মুখ একেরে টায় টায় বইছে।"
        ]
      }
    ],
    "source_page": "IMG_0170"
  },
  {
    "headword": "টাক",
    "transliteration": "tak",
