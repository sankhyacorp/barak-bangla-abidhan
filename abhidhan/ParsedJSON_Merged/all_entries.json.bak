  {
    "headword": "মনুকৃতি",
    "transliteration": "monukriti",
    "phonetics": "mɔnukriti",
    "etymology": "[< সং মন + উক্তি]",
    "senses": [
      {
        "part_of_speech": "ক্রিবিণ.",
        "definition": "ইচ্ছামতো; মর্জিমাফিক। · ⇒ হে বালিক অই গেছে, বাফর কথা হুনে না মনুক্তি চলে।"
      },
      {
        "part_of_speech": "বাগধা. ক্রি.",
        "definition": "স্মরণে থাকা; বিস্মৃত না হওয়া।",
        "examples": [
          "হরুবালার কতোতা আবো মনো রইছে।"
        ]
      },
      {
        "part_of_speech": "বাগধা. ক্রি.",
        "definition": "স্মরণ হওয়া।",
        "examples": [
          "আগর কথা মনো অইলে চখুর পানি পড়ে।"
        ]
      },
      {
        "part_of_speech": "বাগধা. ক্রি.",
        "definition": "স্মরণ করা।",
        "examples": [
          "তূরৈন ভালা কতি মত্না কত, ম্মারংকি লূং পৃথান দিছলাম।"
        ]
      }
    ],
    "source_page": "IMG_0294"
  },
  {
    "headword": "মরই",
    "transliteration": "moroi",
    "phonetics": "mɔrɔi",
    "etymology": "[<ববাং শব্দ মরই]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "চিরহরিৎ বৃক্ষ বিশেষ। এই গাছের বাকলের রং সাদা কাঠও সাদা। সজনের মতো পাতা। সজনের মতোই সাদা ফুল। উচ্চতায় ৮০ ফুট অব্দি হয়। বেড় হয় ১০ হাত। বৈজ্ঞানিক নাম— Albizzia Spp."
      }
    ],
    "source_page": "IMG_0294"
  },
