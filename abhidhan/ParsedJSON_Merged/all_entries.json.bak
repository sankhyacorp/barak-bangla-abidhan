  {
    "headword": "হথ",
    "transliteration": "hoth",
    "phonetics": "ɦɔth",
    "etymology": "[< ববাং শব্দ হথ]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "নির্যাস; রস; লেবু, কমলালেবু প্রভৃতি ফলের খোসার তৈল জাতীয় পদার্থ।",
        "examples": [
          "জাম্রির (=লেবুর) হথ লাগলে তিত্কি লাগে।"
        ]
      },
      {
        "part_of_speech": "বি.",
        "definition": "কেঁচো সাপ প্রভৃতি সরীসূপ জাতীয় প্রাণীর শরীরের তৈল জাতীয় পদার্থ।",
        "examples": [
