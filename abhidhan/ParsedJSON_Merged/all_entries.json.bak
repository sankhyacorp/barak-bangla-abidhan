  {
    "headword": "কিঅত",
    "transliteration": "kiot",
    "phonetics": "kiɔt",
    "etymology": "[<বাং কিসেতে ]",
    "senses": [
      {
        "raw_text": "[<বাং কিসেতে ] ক্রিবিণ্. — কোনস্থানে; কোনপাত্রে; কোনখানে; কীদ্রব্যে। ⇒ অতটেকা কিঅত আশলো? ⇒ লাইবিচ্ কিঅত পুরাইছত? শহীদুল্লাহর মতে শব্দটি এসেছে এরকমভাবে ঃ ‘কিসেতে > কিসত > কিঅত’।"
      }
    ],
    "source_page": "IMG_0090"
  },
  {
    "headword": "কিঅর",
    "transliteration": "kior",
    "phonetics": "kiɔr",
    "etymology": "[<আঞ্চ. কিএর < বাং অব্য. কীসের ]",
    "senses": [
      {
        "part_of_speech": "ক্রিবিণ.",
