  {
    "headword": "পুথাইল",
    "transliteration": "puthail",
    "phonetics": "puthail",
    "etymology": "[< ববাং শব্দ পুথাইল]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "যে শিলাখণ্ড দিয়ে মশলাদি পেষা হয়।",
        "examples": [
          "মশলা বাঁটার নিচের চেপ্টা শিলাখণ্ডের নাম ‘পাটা’ আর উপরের গোলাকার লম্বাটে ছোট I শিলাখণ্ডের নাম ‘পুথাইল’।"
        ]
      }
    ],
    "source_page": "IMG_0237"
  },
  {
    "headword": "পুমা",
    "transliteration": "puma",
    "phonetics": "puma",
    "etymology": "[<আঞ্চ. বাং পোমা]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "একপ্রকার বুনো চিরসবুজ বৃক্ষ বিশেষ।",
        "examples": [
          "'দ্রুত বর্ধনশীল এই বৃক্ষের বাকল খসখসে, গাঢ় ধূসর হতে বাদামি রঙের। ডালপালা বহু বিস্তৃত। প্রায় চিরসবুজ এই বৃক্ষের পাতা যৌগিক। মধ্য শিরার দুপাশে পত্রকগুলি জোড়ায় জোয়ায় সাজানো। ফুল , সাদা, মিষ্টিগন্ধযুক্ত। ফল আয়তাকার ক্যাপসুল। বর্ষায় ফল পাকে। বীজগুলি পক্ষল, যা তারের বিস্তারে সাহায্য করে।’ — নলিনী Ī এক কাঠ লালচে ও সুগন্ধযুক্ত। আসবাবপত্র তৈরিব কাজে এই কাঠ ব্যবহৃত হয়। বৈজ্ঞানিক নাম- Cedrela toona."
        ]
      }
    ],
    "source_page": "IMG_0237"
  },
  {
    "headword": "পুরপুর",
    "transliteration": "puropur",
    "phonetics": "purɔpur",
    "etymology": "[< ধ্ব. পুরপুর = অনুভৃতিসূচক]",
