  {
    "headword": "দাতি",
    "transliteration": "dati",
    "phonetics": "dati",
    "etymology": "[< বাং দাঁত+ই তপ্র. যুক্তার্থে স্ত্রীং]",
    "senses": [
      {
        "part_of_speech": "বাগধা. ক্রি.",
        "definition": "অহেতুক হইহল্লা হাসিঠাট্টা করা।",
        "examples": [
          "হরুতা ইতার দাতো বড় পানি অইসে।"
        ]
      },
      {
        "part_of_speech": "বাগধা. ক্রি.",
        "definition": "অনাহারে থাকা।",
        "examples": [
          "ঘরো একজরা খানি নাই, হরুতায়় দাতো দুবড়ি ঘা দি পড়ি রইছইন। তুল. বাং দাঁতে দড়ি দিয়ে পড়ে থাকা। মামি dadi [< আশ্বঃ মামি < প্রা. মাম্মা]"
        ]
      },
      {
        "part_of_speech": "বি.",
        "definition": "গ্রাম সম্বন্ধে দাদা।",
        "examples": [
          "গ্রাম সম্বন্ধে দাদা বুড়ো হলে আদরে দাদি সম্বোধন করা হয়।",
          "দাদি, ই বিআকুনবালা কানো জাইতায়।"
        ]
      }
    ],
    "source_page": "IMG_0205"
  },
  {
