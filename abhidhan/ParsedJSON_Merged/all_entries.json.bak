  {
    "headword": "গিলট",
    "transliteration": "gilot",
    "phonetics": "gilɔṭ",
    "etymology": "[<ববাং শব্দ. গিলট।]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "স্বাভাবিক অবস্থায় যে বস্তু নরম থাকার কথা তার মধ্যে সৃষ্টি হওয়া কঠিন অংশ।",
        "examples": [
          "গাল বা স্তন ইত্যাদি শরীরের নরম অংশে সৃষ্টি হওয়া কঠিন মাংসপিগু। পাকা পেঁপে, কলা প্রভৃতির ভেতর শক্ত অংশ। কোনো তরল পদার্থ জমে ভেতরে ভেতরে কঠিন হয়ে যাওয়া অংশ।"
        ]
      }
    ],
    "source_page": "IMG_0123"
  },
  {
    "headword": "গুআ",
