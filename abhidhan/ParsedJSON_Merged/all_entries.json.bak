  },
  {
    "headword": "মটমট",
    "transliteration": "motomot",
    "phonetics": "mɔṭɔmɔṭ",
    "etymology": "[< মটমট = ভাঙার শব্দ]",
    "senses": [
      {
        "raw_text": "[< মটমট = ভাঙার শব্দ] ধ্ব. — শুকনো ডাল ভাঙার আওয়াজ। ⇒ ‘মটমট করি দেরু ভাংগো মটাই নিরে ভাই!’ -বরাক ছড়া"
      }
    ],
