    "source_page": "IMG_0174"
  },
  {
    "headword": "টুলা",
    "transliteration": "tula",
    "phonetics": "ṭula",
    "etymology": "[< ববাং বাংলার নিজস্ব শব্দ]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "যে মাটির পাত্রে তুষ জ্বেলে আগুন জিইয়ে রাখা হয়।",
        "examples": [
          "মাটির পাতিলে তুষ ভরে জ্বলন্ত অঙ্গার রেখে আগুন ধরানো হয়। এবং সারাদিন ধরে ধীরে ধীরে জুলতে থাকে। এরূপে আগুন জিইয়ে রাখার ব্যবস্থা অতি প্রাচীন। বরাক উপত্যকার গ্রামাঞ্চলে প্রায় প্রত্যেক বাড়িতেই টুলার ব্যবহার আছে।",
          "টুলাগু আউগাই দে, তাইন বিড়ি ধরাইতা।"
        ]
      }
    ],
    "source_page": "IMG_0174"
  },
