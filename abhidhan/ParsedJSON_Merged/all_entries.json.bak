  {
    "headword": "এইআ",
    "transliteration": "eia",
    "phonetics": "eia",
    "etymology": "[<বড়ো. আইমা/মালতো. আইআ]",
    "senses": [
      {
        "part_of_speech": "অনন্ব.",
        "definition": "বিশ্ময়, আনন্দ ও উল্লাসসূচক ধ্বনি।",
        "examples": [
          "এই আ! পাইছি পাইছি। এই আ ! নাও দউড়ো জিতিছি।",
          "গ্যালিলিওর সেই ‘ইউরেকা ইউরেকা!’ এর সঙ্গে তুলনীয়।"
