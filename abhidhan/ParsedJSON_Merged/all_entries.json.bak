  },
  {
    "headword": "বি",
    "transliteration": "bi",
    "phonetics": "bi",
    "senses": [
      {
        "raw_text": "[< সং বি উপসর্গা উপসর্গীয় প্র. — আধিক্য; বিরোধ; বিপরীত; গর্হিত ইত্যাদি নানা অর্থের দ্যোতক হয়ে শব্দের আগে বসে নতুন শব্দ গঠন করে। ⇒ বি + জালা = বিজালা বি + যন + আ = বিযনা বাং জালা > ববাং জালা"
      }
    ],
    "source_page": "IMG_0272"
  },
  {
    "headword": "বিআতি",
    "transliteration": "biati",
    "phonetics": "biati",
    "etymology": "[< প্রাবা. বিআতী = বিবাহিত স্ত্রী]",
    "senses": [
      {
        "part_of_speech": "বিণ.",
        "definition": "বিবাহিত; বিবাহিতা। ২১ বিআন বিআতি বেটা > প্রাবা. দৃ. ‘আঙ্গন ঘরয়ণ সুন ভো বিআতী।’ চর্যাপদ",
        "examples": [
          "বিআতি বেটি"
        ]
