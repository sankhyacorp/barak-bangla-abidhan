  {
    "headword": "ঠাই",
    "transliteration": "thai",
    "phonetics": "ṭhai",
    "etymology": "[<আমবা. ঠাই = স্থান < সং স্থান]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "জলাশয়ের তলদেশে দাঁড়ানোর স্থান; থই।",
        "examples": [
          "গাংগো এলকু ঠাই পাবা জায় না। ≪ আমবা. দৃ. ‘দৈবকী উদরে আন্দো লভিল ঠাই।’ — কুকী।"
        ]
      }
    ],
    "source_page": "IMG_0176"
  },
  {
    "headword": "ঠাউআ",
    "transliteration": "thaua",
    "phonetics": "ṭhaua",
    "etymology": "[<আঞ্চবাং. ঠাউআ (= ঠেলা) অর্থসংক্রমা]",
    "senses": [
      {
        "part_of_speech": "বিণ.",
        "definition": "ভরাট; মোটা; ফোলা।",
        "examples": [
          "‘ভাব নাই ভক্তি নাই উবা উবা ফাল, পশাদ খাইবার বালা ঠাউআ ঠাউআ গাল।’ —বপ্র."
        ]
      },
      {
        "part_of_speech": "বি.",
        "definition": "ঘাড়ে ধরে ধাকা।"
