    "etymology": "[<আ + √তুর্ + অ কর্তৃবাচ্য]",
    "senses": [
      {
        "part_of_speech": "বিণ.",
        "definition": "প্রতিবন্ধী; হাত-পা বা চোখের মতো অতি প্রয়োজনীয় অঙ্গের অভাব হেতু চলৎশক্তিহীন বা কাজে অক্ষম।",
        "examples": [
          "না-গ-মাই, আতুর অইআ দুনিআত বাচিআ ফয়দা নাই।"
        ]
      },
      {
        "part_of_speech": "বাগধা. ক্রি.",
        "definition": "পরমুখাপেক্ষী হওআ",
        "examples": [
          "হারা জমিনবাড়ি উনাইআ এলকু তাইন জামাইর আতে দি চাই থাকইন।"
        ]
      },
      {
        "part_of_speech": "বাগধা. ক্রি.",
        "definition": "গণ্য করা।",
        "examples": [
          "টেকা না থাকলে কেউ আইজকাইল আতো লয় ন।"
        ]
      }
    ],
