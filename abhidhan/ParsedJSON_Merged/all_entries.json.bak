  {
    "headword": "দুচালা লাগানি",
    "transliteration": "duchala lagani",
    "phonetics": "duc∫ala lagani",
    "etymology": "[< ববাং দুচালা ~ √লাগ]",
    "senses": [
      {
        "part_of_speech": "সক্রি.",
        "definition": "দুজনের সঙ্গে দুরকম কথা বলে ফন্দি আঁটা বা চালবাজি করা; একজনের বিরুদ্ধে অন্যজনের কানভারী করা।",
        "examples": [
          "ই নাউবেটারে (=নাপিত) কুনতা কইও না, বড় দুচালা লাগায়।"
        ]
