    "phonetics": "fec∫a",
    "senses": [
      {
        "raw_text": "[< ববাং ছেপা বিপর্যাসে < চাপা = অনুচ্চা না ভাষার অভিধান ও ভাষাতত্ত"
      },
      {
        "part_of_speech": "বিণ.",
        "definition": "থেবড়া; চ্যাপটা। দ্র. চেফা",
        "cross_references": [
          "চেফা"
        ],
        "examples": [
          "'রক্ঠা নারকা জুনাত নথ নাকে কয় ঘত্ঘত্।’ — বপ্র.",
          "কইলা পড়িআ ফেচা অই গেছে।"
