    "phonetics": "ni",
    "etymology": "[< ববাং কৃপ্র. নি]",
    "senses": [
      {
        "raw_text": "[< ববাং কৃপ্র. নি] 2: নঅইল কুপ্র. — ধাতুর সঙ্গে ‘নি’ যুক্ত হয়ে কৃদন্তপদ গঠিত হয়। ⇒ √খা + নি = খানি (=আহার)। √উঠ + নি = উঠনি (=চড়াই)।"
      }
