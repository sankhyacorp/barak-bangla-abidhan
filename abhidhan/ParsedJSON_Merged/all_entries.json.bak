    "etymology": "[<আঞ্চ. টোক্রি]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "বাঁশ বা বেতের তৈরি গোলাকার ঝুড়ি বিশেষ।",
        "examples": [
          "ইবার তারা ক টুকরি শেখরগন্দ [= আলু বিশেষ] পাইছইন? লা ভাষার অভিধান ও ভাষাতত্ত"
        ]
      }
