  },
  {
    "headword": "পুটি মুরালি",
    "transliteration": "puti murali",
    "phonetics": "puṭi murali",
    "etymology": "[< ববাং পুটি ~ মুরালি]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "প্রসিদ্ধ আউশ ধান।",
        "examples": [
          "আউশধান মুরালির প্রকার বিশেষ। গোল গোল ধান। সোনালি রং। মাঝারি দানা। মিঠা স্বাদযুক্ত। ফলেও মন্দ নয়।"
        ]
      },
      {
        "part_of_speech": "বাগধা. বি.",
        "definition": "যে অল্পেতে কাতর হয়। পুঁটি মাছের প্রাণ।",
        "examples": [
          "ধনি বাড়ির পুড়িনতর পুটি মাছর পরান, তুড়া কুনতা অইলে গলি জাইন।"
        ]
      }
    ],
    "source_page": "IMG_0237"
  },
