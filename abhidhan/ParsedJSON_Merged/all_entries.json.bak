  {
    "headword": "পন্চক",
    "transliteration": "ponchok",
    "phonetics": "pɔnc∫ɔk",
    "senses": [
      {
        "raw_text": "[< সং পঞ্চক = কর, জমিদারের খাজনা বি. — ঠাঁমা। ⇒ বাঘরামর সেবার পন্চক হকলে দিছইন নি? ≫ মবা. পঞ্চক = পাঁচজনের মিলিত চাঁদা। অর্থপ্রসারে ‘যে কোনোজনের দেওয়া চাঁদা’।"
      }
    ],
    "source_page": "IMG_0224"
  },
  {
