  {
    "headword": "ফান",
    "transliteration": "fan",
    "phonetics": "fan",
    "etymology": "[< ববাং ফান্দ সংকোচনে]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "ষাটহাত দীর্ঘ মজবুত দড়ি দিয়ে বানানো হাতি শিকারের ফাঁদ।",
        "examples": [
          "'ফান' উড়িয়ে মেরে বুনো হাতির গলায় ফাঁস পরানো হয়। দ্র. ফানদি। কান্জান fanj3al [< ববাঃ কান্ম + সঃ জান]"
        ]
      },
      {
        "part_of_speech": "বি.",
        "definition": "মাছ ধরার জাল বিশেষ।",
        "examples": [
          "ফানজালের জালিছিদ্র ১০ বর্গ সেন্টিমিটার থেকে ৩০ বর্গ সেন্টিমিটার পর্যস্ত নানা মাপের হয়। জালটির দৈর্ঘ্য ২০০ হাত, প্রস্থ ১৫ হাত। দশজন লোক এই জাল দিয়ে বড় ছোট সবরকম মাছ ধরে। এটি সাধারণত ফিশারি বা মাঝারি জলাশয়ে ব্যবহার করা হয়। কান্ম্ fand [< আঞ্চ. বাং ফান্দ < আমবা. ফান্দ = ফাদা"
        ]
      },
      {
        "part_of_speech": "বি.",
        "definition": "ফাঁদ। কৃকী বরাক উপত্যকার আঞ্চলিক বাং .64 .. .. ,..., · ·",
        "examples": [
          "ফানদো পড়িআ বগায় (=বক) কান্দে রে।"
        ]
      }
    ],
    "source_page": "IMG_0245"
  },
  {
    "headword": "ফানদি্",
    "transliteration": "fanodi",
    "phonetics": "fanɔdi",
    "etymology": "[< ববাং ফান্দ্ +ই তপ্র. কর্তায়]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "যিনি ফাঁদ পেতে হাতি ধরেন।",
        "examples": [
          "এখানে হাতি ধরা বলতে বন্যহাতি ধরার কথা বলা হচ্ছে। একজন দক্ষ ফানদি বা হাতিশিকারি এবং একজন অভিজ্ঞ মাহুত তিনটি প্রশিক্ষিত হাতি আর ফাঁদ, দড়ি, বুজালি গুফতি ঝাটা ইত্যাদি সরঞ্জাম নিয়ে বুনো হাতি ধরতে যান।"
        ]
      }
    ],
    "source_page": "IMG_0245"
  },
  {
    "headword": "ফানদি",
    "transliteration": "fanodi",
    "phonetics": "fanɔdi",
    "etymology": "[< ববাং ফান্দ্ + তপ্র. ই < মুন্ডারি ফাঙ্ক = খোলা জায়গা]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "বেড়ার ফাঁক; ফাঁক।",
        "examples": [
          "'বেরর ফানদি পাইলে ঢিলা, মাথা হারাইআ মার্তা ঠেলা; — মাহ্তাবুর"
        ]
      },
      {
        "part_of_speech": "বাগধা. ক্রি.",
        "definition": "বিপদে ফেলা।",
        "examples": [
          "জে দিন তানে ফানদো ফালাইমু হিদিন টের পাইবা।"
        ]
      }
    ],
    "source_page": "IMG_0245"
  },
  {
    "headword": "ফানপাড়া",
    "transliteration": "fanopado়a",
    "phonetics": "fanɔpaḍɔ়a",
    "etymology": "[< ববাং ফান্ +ফাড়া অনুকার মক]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "হাতি শিকারের (=ধরার) জন্য ব্যবহৃত নানা আকারের দড়ি ও সরঞ্জাম।",
        "examples": [
          "বুনো হাতিকে ধরার জন্য প্রয়োজনীয় সরঞ্জাম ঃ = ৬০ হাত দড়ির ফাঁদ। ফান ডুলটি = ৩০০ হাত বড় দড়ির তৈরি হাতির (প্রশিক্ষিত হাতি, যেটি হাতি ধরার কাজে ব্যবহার করা হয়) শরীর সজ্জা। কাচ = দড়ির সরঞ্জাম। বুজালি = অস্ত্র বিশেষ। গুফতি = লোহার পরিচালন যন্ত্র।"
        ]
      }
    ],
    "source_page": "IMG_0245"
  },
