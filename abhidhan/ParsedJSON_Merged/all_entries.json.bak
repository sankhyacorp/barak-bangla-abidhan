  {
    "headword": "করও",
    "transliteration": "koroo",
    "phonetics": "kɔrɔo",
    "etymology": "[<কে রে গো]",
    "senses": [
      {
        "part_of_speech": "সর্ব.",
        "definition": "কে (সম্ভ্রমাত্মক)। কর্তৃকারকের একবচন সম্ভ্রমাত্মক নির্দেশক সর্বনাম পদ। অসম্ভ্রমাত্মক ‘কিগু’ [<প্রাতি. কি + প্রত্যয় ]। বহুত্ববোধক ‘ইন’ প্রত্যয় সহযোগে বহুবচনে পাচ্ছি সম্ভ্রমাত্মক ‘করগুইন’ এবং অসম্ভ্রমাত্মক ‘কিগুইন’।",
        "examples": [
          "করগু আইছইন।"
        ]
      }
    ],
    "source_page": "IMG_0081"
  },
  {
    "headword": "করগে",
    "transliteration": "koroge",
    "phonetics": "kɔrɔge",
    "etymology": "[< দ্র. করগু]",
    "senses": [
      {
        "part_of_speech": "সর্ব.",
        "definition": "কে (সম্রমাত্মক)।",
        "examples": [
          "‘মাতিবার পথ নাই কাশিনাথ সর্গে, টেকাকড়ি ঘরো নাই রিন্ দিত করগে।’ আনন্দ kɔrɔc∫ [<বাং করমচা সংকোচনে < সং করচ করমর্দক] বরাক উপত্যকার আঞ্চলিক বা * ."
        ]
      },
      {
        "part_of_speech": "বিণ.",
        "definition": "করঞ্জা বা করমচা গাছ।",
        "examples": [
          "‘‘এটি একটি ছোট ঝোপ জাতীয় গাছ; এর কাণ্ড গাঁট যুক্ত, ধূসর বর্ণ ও মসৃণ। এ গাছ শাখাপ্রশাখা দিয়ে ঘেরা থাকে। শাখায় কাঁটা থাকে। পাতা ছোট ও পাতলা এবং সবুজ। শীতে পাতা ঝরে, বসস্তে পাতা গজায়, বর্ষাকালে ফল হয়। ফল আঙুরের মতো ছোট, ফলের রং বেদানার কোয়ার রঙের মতো।... করমচা খুব টক।\" ‘বাংলাদেশের গাছপালা’ আজাহার ইসলাম"
        ]
      }
    ],
    "source_page": "IMG_0081"
  },
  {
    "headword": "করজা",
    "transliteration": "koroja",
    "phonetics": "kɔrɔʒa",
