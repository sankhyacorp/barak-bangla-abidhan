  },
  {
    "headword": "গনইআ",
    "transliteration": "gonoia",
    "phonetics": "gɔnɔia",
    "etymology": "[<সং গণক + ইআ স্বার্থিক প্রত্যয়]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "যিনি মানুষের ভাগ্য গণনা করেন; জ্যোতিষী।",
        "examples": [
          "‘তিথি নক্ষত্রানুসারে গ্রহগণের গতি দ্বারা শুভাশুভ নিরূপণকারী ব্রাহ্মণজাতি বিশেষ।’ — বাভা। বরাক উপত্যকায় কিন্তু কোনো জাতিবিশেষের অন্তর্গত গণককেই [ গ্রহাচার্য ] বোঝায় না, গণনা করে ভবিতব্য বলে দেন, হারিয়ে যাওয়া বস্তুর সন্ধান জানিয়ে দেন এমন যে কোনো লোককেই ‘ গণইআ’ বলা হয়।"
        ]
      }
    ],
    "source_page": "IMG_0115"
  },
  {
    "headword": "গন্ধি",
    "transliteration": "gondhi",
    "phonetics": "gɔndhi",
    "etymology": "[< সং গন্ধ + ই তপ্র. যুক্তার্থে]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "অতি উগ্রগন্ধযুক্ত বীরুৎ জাতীয় উদ্ভিদ।",
        "examples": [
          "বরাক উপত্যকা সহ উত্তর-পূর্ব ভারতের পাহাড়ি অঞ্চলের ছায়াময় স্থানে উদ্ভিদটি প্রচুর জন্ম। উদ্ভিদটি গ্রন্থিকন্দযুক্ত। পাতার বোঁটা বেশ লম্বা। পাতার আকৃতি কচুপাতার মতো। ফুল সবুজ রঙের মঞ্জরীপত্র দিয়ে ঢাকা থাকে। অগস্ট-সেপ্টেম্বরে ফুল র্য । K Į ব র এই গাছের রস মাথায় লাগালে উকুন মরে যায়। সবজি হিসাবে এর ব্যবহার এ উপত্যকার পুরোনো বাসিন্দাদের মধ্যে এখনো চল্ আছে। এই গাছ থেকে বিস্ফোরক দ্রব্যের উপাদান তৈরি হয়।"
        ]
      }
    ],
    "source_page": "IMG_0115"
  },
  {
