  {
    "headword": "গুরন",
    "transliteration": "guron",
    "phonetics": "gurɔn",
    "etymology": "[< ববাং শব্দ গুরন]",
    "senses": [
      {
        "raw_text": "[< ববাং শব্দ গুরন] — পত্র উদ্ভিদ। আনারস গাছের মতো। পাতায় দানা নেই। আনারস পাতা থেকে মোটা ও নরম। ফুল সাদা ও সুন্দর। গোরু মহিষের গলা ও যকৃৎ সংক্রান্ত রোগের মহৌষধ। না ভাষার অভিধান ও ভাষাতত্ত"
      }
    ],
    "source_page": "IMG_0126"
  },
