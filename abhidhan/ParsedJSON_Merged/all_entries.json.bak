    ],
    "source_page": "IMG_0272"
  },
  {
    "headword": "বিআন",
    "transliteration": "bian",
    "phonetics": "bian",
    "etymology": "[< প্রাবা. / আমবা. বিহান = প্রভাত < সং বিভাত বি. —প্রভাত বেলা; সকাল। ⇒ বিআনে উঠিআউ তাইন আলো গেছইন। ≫ আমবা. দৃ. 'লাস বেশ করে রাধা বড়ই বিহানে।' — কৃকী। প্রাবা. দৃ. ‘পওস বিহান’ — শূন্যপুরাণ। ⇒ সমার্থ শব্দ. বিআনবালা; বিআনতোবালা। বিআন<sub>s</sub> bian [< প্রাবা. বিআণ = প্রসব]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "প্রভাত বেলা; সকাল। — কৃকী। প্রাবা. দৃ. ‘পওস বিহান’ — শূন্যপুরাণ।",
        "examples": [
          "বিআনে উঠিআউ তাইন আলো গেছইন।",
          "সমার্থ শব্দ. বিআনবালা; বিআনতোবালা। বিআন<sub>s</sub> bian [< প্রাবা. বিআণ = প্রসব]"
        ]
      },
      {
        "part_of_speech": "বি.",
        "definition": "প্রসব। চর্যা ২০",
        "examples": [
          "এক বিআনর গাই।"
        ]
      }
    ],
    "source_page": "IMG_0273"
  },
