  {
    "headword": "মুড়ি",
    "transliteration": "mudo়i",
    "phonetics": "muḍɔ়i",
    "etymology": "[< কুই. মুড়ি; মুরি = চালভাজা]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "সিদ্ধ চাল তপ্ত বালুতে ভেজে তৈরি হালকা মুড়মুড়ে খাদ্য বিশেষ; মুড়ি। শব্দটি গঠিত হতে পারে।",
        "examples": [
          "এটি সাধারণ চালভাজা থেকে পৃথক।"
        ]
      }
    ],
    "source_page": "IMG_0305"
  },
  {
    "headword": "মুড়ি",
    "transliteration": "mudo়i",
    "phonetics": "muḍɔ়i",
    "etymology": "[< বাং মোড় (=বাঁক)+ই তপ্র. ক্ষুদ্রার্থে]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "কিনারা; ধার; কাপড় চাটাই প্রভৃতির বর্ডার।",
        "examples": [
          "কাথাত থানি মৃড়ি মারি থই দিমু।",
          "চাটির মুড়ি জালিবেত দি বানদিছি।"
        ]
      }
    ],
    "source_page": "IMG_0305"
  },
  {
    "headword": "মুড়ি",
    "transliteration": "mudo়i",
    "phonetics": "muḍɔ়i",
    "etymology": "[< ববাং মুড় (= মাথা)+ই ক্ষুদ্রার্থে < মুগু সং]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "মাছের মুড়ো; মাথা।",
        "examples": [
