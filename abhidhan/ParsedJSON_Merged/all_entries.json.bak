    "source_page": "IMG_0059"
  },
  {
    "headword": "আড়ল",
    "transliteration": "ado়l",
    "phonetics": "aḍɔ়l",
    "etymology": "[<ববাং আডুআ + ল তপ্র. স্বার্থে]",
    "senses": [
      {
        "part_of_speech": "বিণ.",
        "definition": "বোকা।",
        "examples": [
          "অলা আডুল, সাএবরে মুখ খুলিআ নিজর কথা খান কইত পাললো না। — মোটাবুদ্ধি।",
          "ই আড়লরে দি অইত নায়, হে এক কামরে তিন কাম করব।"
        ]
      }
    ],
    "source_page": "IMG_0059"
  },
  {
    "headword": "আড়লামি",
    "transliteration": "ado়lami",
    "phonetics": "aḍɔ়lami",
    "etymology": "[<আড়ল + আমি তপ্র ভাবার্থে]",
