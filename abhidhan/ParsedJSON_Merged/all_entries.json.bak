    "transliteration": "vag",
    "phonetics": "vag",
    "etymology": "[< ববাং শব্দ ভাগ্]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "কোনোকিছু করার ক্ষমতা; সামর্থ্য; সাধ্য।",
        "examples": [
          "‘বিল নি ভাষ্ট নার্টে, রার্টেত কলাত্লা ভাগ নারে।’ -বপ্র."
