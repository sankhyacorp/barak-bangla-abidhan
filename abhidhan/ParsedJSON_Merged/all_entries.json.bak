  {
    "headword": "টাইন্ব",
    "transliteration": "tainbo",
    "phonetics": "ṭainbɔ",
    "etymology": "[<প্রাবা. টা + ইন বহুবচনে < প্রা. অট্ট]",
    "senses": [
      {
        "raw_text": "[<প্রাবা. টা + ইন বহুবচনে < প্রা. অট্ট] অ.প্র. — বহুত্ববোধক প্রত্যয়। মানে—গুলো, সমষ্টি, রাশি ইত্যাদি। ⇒ বইটাইন দেরুটাইন হইরোটাইন মেঘটাইন চাউলটাইন মানুশটাইন ⇒ টাইন’ এর একবচন টা’। যেমন, বইনটা চকিটা"
      }
    ],
    "source_page": "IMG_0170"
  },
  {
