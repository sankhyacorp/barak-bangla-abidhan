  {
    "headword": "উলিরঘর",
    "transliteration": "uliroghor",
    "phonetics": "ulirɔghɔr",
    "etymology": "[< ববাং নিজস্ব শব্দ]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "পৌষ সংক্রান্তির আগের দিন নির্মিত বাঁশ ও খড়ের গম্বুজাকৃতি ঘর, যা সংক্রান্তির দিন কাকভোরে চান্ করে জ্বালিয়ে দেওয়া হয়। ⇨ ‘উলিরঘর’ পোড়ানোটা বরাক উপত্যকার লোক সংস্কৃতি। আবার অনেকে মহাভারতের ভীত্মের দাহকার্যের সঙ্গে সম্পর্কযুক্ত বলে মনে করেন।"
      }
    ],
    "source_page": "IMG_0072"
  },
  {
    "headword": "উলু্",
    "transliteration": "ulu",
    "phonetics": "ulu",
    "etymology": "[<প্রা. উঅলিআ < সং উপদিকা]",
