  {
    "headword": "এউক্রিআ",
    "transliteration": "eukria",
    "phonetics": "eukria",
    "etymology": "[<বাং এক + ফা. রুখ-আ]",
    "senses": [
      {
        "part_of_speech": "বিণ.",
        "definition": "একগুঁয়ে।",
        "examples": [
          "বনুআ হুঅর এউকরিআ থাকইন। বাং এক + ফা. রুক + আ > একরুকা অপিনিহিত বিপর্যাসে ‘এউকরিআ’।",
          "শব্দটি নিন্দার্থে বা ইতর প্রাণীর বেলায় ব্যবহৃত হয়।"
        ]
      }
    ],
    "source_page": "IMG_0073"
  },
  {
    "headword": "এউতি",
    "transliteration": "euti",
    "phonetics": "euti",
    "etymology": "[<আঞ্চ. এমন্ত < সং হেমন্ত]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "হেমন্ত ঋতু; কার্তিক অগ্রহায়ণ মাস।",
        "examples": [
          "যে সময়ে বৃষ্টি জল কাদায় রাস্তাঘাট মাখামাখি হয় না অর্থাৎ শুকনা সময়। ⇒ ‘ফলনার মাতে আর এউতি পথে হমান।’ ⇒ এখানে ‘এউতি’ মানে শুকনো সময়। মানে অমুকের কথা শুকনো ঋতুর মতো বাধাবন্ধহীন দীর্ঘ পথের মতোই অর্থাৎ নির্জলা লম্বা-চওড়া কথা।"
        ]
      }
    ],
    "source_page": "IMG_0073"
  },
  {
    "headword": "এওত",
    "transliteration": "eot",
    "phonetics": "eot",
    "etymology": "[<ববাং এউতি < সং হেমন্ত]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "হেমন্ত ঋতু; শুকনো সময়।",
        "examples": [
          "‘এওত’ বলতে বরাক উপত্যকায় কার্তিক মাস থেকে ফাল্পন মাস অর্থাৎ বৃষ্টিপড়ার আগে পর্যন্ত পুরো শুকনো সময়টা বোঝানো হয়।",
          "এওতর দিন পাকচাক নাই বন্দ্ কুনাকুনি জাবা জায়।"
        ]
