  {
    "headword": "আটিল",
    "transliteration": "atil",
    "phonetics": "aṭil",
    "etymology": "[<ববাং আট + ইল]",
    "senses": [
      {
        "part_of_speech": "বিণ.",
        "definition": "আঁটসাট; যা আঁটো বা সংকুচিত হয়ে গেছে; মজবুত।",
        "examples": [
          "তুমার আংগরখা আটিল অইগেছে।",
          "টানাইআ বান্ধ্ না দিলে বান্ধ্ আটিল অইত নায।"
        ]
      },
      {
        "part_of_speech": "বাগধা. ক্রি.",
        "definition": "দুর্বল বোধ করা; ভয়"
      },
      {
        "part_of_speech": "বাগধা. ক্রি.",
        "definition": "শক্ত কাজের জন্য তৈরি হওয়া।",
        "examples": [
          "আটু বুকুত দি হি ইবার খেতো লামছে।"
        ]
      },
      {
        "part_of_speech": "ক্রিবিণ.",
        "definition": "কোমর বেঁধ।",
        "examples": [
          "বজির মায় আটু বুকুত দি লইছে গাইল।"
        ]
      },
      {
        "part_of_speech": "বাগধা. ক্রি.",
        "definition": "খুব হিসেব করে খরচ করা: কার্পণ্য করা।"
      },
      {
        "part_of_speech": "ক্রিবিণ.",
        "definition": "মাঝে মাঝে; অনেকদিন পরপর; কোনো কোনো দিন।",
        "examples": [
          "আগে তাইন বরাবর আইতা, এলকু আটে-চাইরে আইন।"
        ]
      }
    ],
    "source_page": "IMG_0051"
  },
  {
    "headword": "আঠিকলা",
    "transliteration": "athikola",
    "phonetics": "aṭhikɔla",
    "senses": [
      {
        "raw_text": "[<ববাং আঠালি সংকোচনে < বাং কাঁঠালি বি. — কাঁঠানি কনা। ⇒ বেশ বড় আকার। স্বাদ মধুর তবে শাঁস বড় বড় বিচিতে ঠাসা। খাদ্যরূপে কলাটি মোটেই জনপ্রিয় নয়। মোচা খেতে মন্দ নয়।"
      }
    ],
    "source_page": "IMG_0051"
  },
  {
    "headword": "আড্ডি",
    "transliteration": "addi",
    "phonetics": "aḍḍi",
    "etymology": "[<হি. হড্ডী < সং হড্ড]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "হাড়; BONE",
        "examples": [
          "ডামাগুর শইললোর আড্ডি গনা জার।"
        ]
      }
    ],
    "source_page": "IMG_0051"
  },
  {
    "headword": "আড্ডাআড্ডি",
    "transliteration": "addaaddi",
    "phonetics": "aḍḍaaḍḍi",
    "etymology": "[<ববাং আড্ডি ~ অনুকারো বিণ. — প্রচণ্ড; তীব্র। ⇒ ইবার দুদলে আড্ডাআড্ডি লাড়াই অইব। আত্তির পাড়া পড়া — বাগধা. ক্রি. — বড়লোকের আগমন হওয়া। ⇒ আউকা আউকা, এমেলে সাএব, আইজ মোর বাড়িত আতৃতির পাড়া পড়ছে। আত পাও আটানি — বাগধা. ক্রি. — কর্মবিমুখ হওয়া। ⇒ আতপাও আটাইলে মোরে কিগে খানি দিব? আত্রি [<বাং আঁতুড় = সৃতিকাগার]",
    "senses": [
      {
        "part_of_speech": "বিণ.",
        "definition": "প্রচণ্ড; তীব্র।",
        "examples": [
          "ইবার দুদলে আড্ডাআড্ডি লাড়াই অইব।"
        ]
      },
      {
        "part_of_speech": "বাগধা. ক্রি.",
        "definition": "বড়লোকের আগমন হওয়া।",
        "examples": [
          "আউকা আউকা, এমেলে সাএব, আইজ মোর বাড়িত আতৃতির পাড়া পড়ছে।"
        ]
      },
      {
        "part_of_speech": "বাগধা. ক্রি.",
        "definition": "কর্মবিমুখ হওয়া।",
        "examples": [
          "আতপাও আটাইলে মোরে কিগে খানি দিব? আত্রি [<বাং আঁতুড় = সৃতিকাগার]"
        ]
      },
      {
        "part_of_speech": "বি.",
        "definition": "সৃতিকাগার; আঁতুড় ঘর। গঠিত হতে পারে।",
        "examples": [
          "আবো রূপশি পুজা অইসে না, বউ আত্রি তনে বারইছইন না।"
        ]
      },
      {
        "part_of_speech": "বাগধা. ক্রি.",
        "definition": "হস্তগত হওয়া।",
        "examples": [
          "পাওনা টেকাগুইন আবো আত লইছে না।"
        ]
      },
      {
        "part_of_speech": "বাগধা. ক্রি.",
        "definition": "ছোটখাটো চুরি করার স্বভাব।",
        "examples": [
          "ভেখ লইআও তাইর আতলাবড়ামি গেছে না।"
        ]
      }
    ],
    "source_page": "IMG_0051"
  },
