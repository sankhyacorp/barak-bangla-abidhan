  {
    "headword": "কুকি",
    "transliteration": "kuki",
    "phonetics": "kuki",
    "etymology": "[< ভোট চীনীয় শব্দ]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "উত্তরপূর্ব ভারতে বসবাসকারী উপজাতি বিশেষ। কুকিরা মঙ্গোলীয়। মধ্য এশিয়া থেকে ওরা ভারতে এসেছে। এখন ওরা আসাম, মণিপুর ও ত্রিপুরায় বাস করে। ওদের কয়েকটি শাখা-প্রশাখা আছে। ওদের শরীর হৃষ্টপুষ্ট। চোয়াল বের হওয়া মুখমগুল। চোখ ছোট, নাক ভোঁতা। ওষ্ঠ সামান্য দীর্ঘ। বর্ণ শ্যাম। જ কুচ বাঁশ-বেত-শনের তৈরি দীর্ঘ মাচান-ঘরে কুকিরা জুমখেত ও পশুপালন ওদের মূল থাকে। উপজীবিকা। চাভাংকুট তাদের প্রধান উৎসব। আগে প্রকৃতি-উপাসক ছিল, এখন অধিকাংশ খ্রিস্টান।"
      }
    ],
    "source_page": "IMG_0094"
  },
  {
    "headword": "কুচ",
    "transliteration": "kuch",
    "phonetics": "kuc∫",
    "etymology": "[<আঞ্চ. কোঁচ < বাং কোঁচড় < সং ক্রোড় ]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "কোলের আঁচল ; জামার সম্মুখের প্রান্তভাগ; কোঁচড।",
        "examples": [
          "মুই কুনতা আনছি না, চাউলগুইন কুচো দিলাও। কুকুর নআই — বাগধা. বি. - বার বার স্থান পরিবর্তন; এক কাজে বার বার যাওয়া-আসা।",
          "দুই হাফতা কুকুর নআই দিআ রিলিফ পাইছি মুটে দুইকাঠি চাউল আর এখান রাগ্।"
        ]
      }
    ],
    "source_page": "IMG_0095"
  },
  {
    "headword": "কুচি",
    "transliteration": "kuchi",
    "phonetics": "kuc∫i",
    "etymology": "[<ববাং গুছি <সং গুচ্ছ ]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "ধানের চারার গুচ্ছ।",
        "examples": [
          "পাচকুচি আলিএ খাড়ুআ মরব।"
        ]
      }
    ],
    "source_page": "IMG_0095"
  },
  {
    "headword": "কুচিআ",
    "transliteration": "kuchia",
    "phonetics": "kuc∫ia",
    "etymology": "[<সং কুচিকা = কুঁচে মাছ ]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "সাপের মতো দেখতে পাঁতিহীন বাদামী রঙের মাছ বিশেষ ; কুঁচে মাছ; eel.",
        "examples": [
          "কুচিআ জলাশয়ের মধ্যে গর্ত করে থাকে। কুঁচে শিকারিরা বঁড়শিতে টোপ গেঁথে গর্তে ঢুকিয়ে কুঁচে শিকার করে। রক্তাল্পতায় মাছটি খুব উপকারী।"
        ]
      },
      {
        "part_of_speech": "বাগধা. বি.",
        "definition": "কুটিল স্বভাবযুক্ত বৃদ্ধা রমণী।",
        "examples": [
          "যে বুড়ি প্রণয়াসক্ত নায়ক-নায়িকার অবৈধ মিলন সংঘটিত করে; এক বাড়ির গোপন কথা বহুবাড়িতে বলে বেড়ায় ; গুজব রটায়; তাকে কুটনি বা কুটনা বুড়ি বলে। যেমন, শ্রীকৃষ্ণকীর্তনের ‘বড়াই বুড়ি’। দ্র. পেরকুটি।"
        ]
      }
    ],
    "source_page": "IMG_0095"
  },
  {
    "headword": "কুটনি",
    "transliteration": "kutoni",
    "phonetics": "kuṭɔni",
    "etymology": "[<ধ্ব. কুট্ কুট্ = সুপারি চুর্ণকরার আওয়াজ ]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "বাঁশের চুঙে তৈরি সুপারি প্রভৃতি চূর্ণ করা বা পেষার যন্ত্র বিশেষ।",
        "examples": [
          "পাকা বাঁশের চুঙা ও ছোট দণ্ড নিয়ে কুটনি। কুটনি দুরকমের : এক, গুআ কুটনি — এর ভেতরের তলায় কাঠের চাকা বসাতে হয়। এর দণ্ড হল বাটালির মতো ধারাল লোহার ছোট খুনতি। বৃদ্ধ বৃদ্ধারা এটিতে পানসুপারি চূর্ণ করেন। দুই, বরই কুটনি। এটি দণ্ড বাঁশের। এটিতে কুল জলপাইয়ের সঙ্গে নুন লঙ্কা মশলা দিয়ে ভর্তা তৈরি করা হয়।"
        ]
      }
    ],
    "source_page": "IMG_0095"
  },
  {
    "headword": "কুটভিপুক",
    "transliteration": "kutovipuk",
    "phonetics": "kuṭɔvipuk",
    "etymology": "[< ববাং শব্দ কুটভিপুক]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "বিষধর অতি ক্ষুদ্র পতঙ্গ বিশেষ।",
        "examples": [
          "খালি চোখে প্রায় দেখাই যায় না এই পোকাকে। থাকে জঙ্গলাকীর্ণ অঞ্চলে। দংশনে বিষ ও জ্বালা ওঠে। এর দংশন হাতির মতো বিশাল জন্তুকেও চঞ্চল করে তোলে। কৃষ্ণ kutla [< ধ্ব. কৃষ্কুষ্ + না জ্থ সাপৃত্গা]"
        ]
      },
      {
        "part_of_speech": "বি.",
        "definition": "প্রহার।",
        "examples": [
          "একই কুটলায় বাছাধন সিদা।"
        ]
      }
    ],
    "source_page": "IMG_0095"
  },
  {
    "headword": "কুট্লা দেবা",
    "transliteration": "kutla deba",
    "phonetics": "kuṭla deba",
    "etymology": "[<ববাং কুটলা ~ √দে ]",
