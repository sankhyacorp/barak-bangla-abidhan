  {
    "headword": "লড়া",
    "transliteration": "lodo়a",
    "phonetics": "lɔḍɔ়a",
    "etymology": "[< আমবা. √লড় < সং লড় কম্পনে]",
    "senses": [
      {
        "part_of_speech": "ক্রি.",
        "definition": "নড়া; চলা; সরা।",
        "examples": [
          "অলা গরম, গাছর এগগু পাত্তা লড়ের না।",
          "কুমবালা কইছি বনদো জাইত, আবো লড়িল না।"
        ]
      },
      {
        "part_of_speech": "বিণ.",
        "definition": "নড়ে গেছে এমন।দ্র. লড়খড়া। GIG ‘লড়হ না কেহেু/ ≫ আমবা. দৃ. নিলজ কাহ্নাঞিঁ/ এড়িআঁ দধির ভারে।’ — কৃকী"
      }
    ],
    "source_page": "IMG_0315"
  },
  {
    "headword": "লড়খড়া",
    "transliteration": "lodo়khodo়a",
    "phonetics": "lɔḍɔ়khɔḍɔ়a",
    "etymology": "[< ববাং √লড় অনুকারে]",
    "senses": [
      {
        "part_of_speech": "বিণ.",
        "definition": "নড়ে গেছে এমন; নড়বড়ে।",
        "examples": [
          "লড়খড়া দাত। লফ্র ফ্রি larbari [< প্র. লফ্; লফ্র]"
        ]
      },
      {
        "part_of_speech": "বি.",
        "definition": "কানের দোল বা ঝুমকা। ‘আসে (=হাঁসে) উনা মুরকিএ দুনা <math>\\Rightarrow</math> ছাগলে পিনধায় লড়বড়ি সুনা।’ – বরাকপ্রবাদ"
      }
    ],
    "source_page": "IMG_0315"
  },
  {
    "headword": "ললই",
    "transliteration": "loloi",
    "phonetics": "lɔlɔi",
    "etymology": "[< 'লল্ = লালসায়'—বাভাঅ]",
