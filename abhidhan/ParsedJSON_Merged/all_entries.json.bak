  {
    "headword": "আবো",
    "transliteration": "abo",
    "phonetics": "abo",
    "etymology": "[<হি. অব্]",
    "senses": [
      {
        "part_of_speech": "ক্রিবিণ.",
        "definition": "এখনও; বর্তমান সময় পর্যন্ত।",
        "examples": [
          "আবো তুমরার চুংগাপুড়া হেশ অইছে নানি? — এসব সত্বেও।",
          "আবো তারে চুর কইতায় নানি? আম-আমানি am-amani [<ধ্ব. হাম্ হাম্ (= জল স্ফীতির আওয়াজ) + আমি তপ্র. ভাবার্থে]"
        ]
      },
      {
        "part_of_speech": "বি.",
        "definition": "জলপ্রবাহের আওয়াজ; জলস্ফীতির বা জলের তোড়ের ধ্বনি; জলের বেগের প্রচণ্ডতা।",
        "examples": [
          "‘মূল ছড়াত (= ছোট নদী) নাই পানি, ফেউআ (= শাখা) ছড়াত আমআমানি।’"
        ]
      }
    ],
    "source_page": "IMG_0056"
  },
  {
    "headword": "আমটা",
    "transliteration": "amota",
    "phonetics": "amɔṭa",
    "etymology": "[<বাং আম + টা < প্রা. অম্ম < সং অম্ল]",
    "senses": [
      {
        "part_of_speech": "বিণ.",
        "definition": "টাটকা নয় এমন ; প্রকৃত স্বাদ নষ্ট হয়ে গেছে এমন।",
        "examples": [
          "আমটা উরি ইগুইন ফালা, খাবা জাইত নায়।"
