  {
    "headword": "আই",
    "transliteration": "ai",
    "phonetics": "ai",
    "etymology": "[<প্রা. আইঅ]",
    "senses": [
      {
        "raw_text": "[<প্রা. আইঅ] তপ্র. — স্বার্থে ও আদরার্থে ব্যবহৃত হয়। ⇒ তন |তনু] + আই = তনাই।"
      }
    ],
    "source_page": "IMG_0043"
  },
  {
    "headword": "আই",
    "transliteration": "ai",
    "phonetics": "ai",
    "etymology": "[<আঞ্চবাং আলিক <মবা. হালিক = গোরু রাখাল]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "বরাক উপত্যকায় প্রচলিত কার্তিক মাসে অনুষ্ঠিত ‘রাখালসেবা’ নামক ব্রতের ছড়াগান।",
        "examples": [
          "কার্তিক মাসের শুরু থেকেই সংক্রান্তির দিন সকাল বা আগের দিন রাত পর্যন্ত ‘আই’ বা ছড়াগান গাওয়া হয়। জনৈক কিশোরের নেতৃত্বে একদল বালক গ্রামের ঘরে ঘরে এই ছড়াগান গেয়ে চাল হলুদ টাকা’ ভিক্ষে করে। দলনেতা ‘আই’ এর মূলপদ গায় আর সঙ্গীরা চক্রাকারে নেচে নেচে ‘দোয়ার’ দেয়।এই ছড়াগানে কোনোরকম বাদ্যযন্ত্রের ব্যবহার নেই। এবং এভাবে সংগৃহীত ধন দিয়ে সংক্রান্তির দিন ‘রাখালসেবা’ ব্রত উদ্যাপিত হয়। একটি ‘আই’ দৃষ্টান্তস্বরূপ উল্লেখ করছি : বনর ভাই আই রে আই লখকি ফলে বন জুলে গৌড়র গোবিন মইপাল (=মহীপাল) তাইন দিলা ফলাহার ٧ ধন লইআ ফলাহার খাইআ বাউএ থইআ ডাইনে সিংগাসন দিলাম কইআ আইর জনম কাত্তি হামাইতে আইন জাইতে ভুই জুড়িতে শানতির পুতে লাম্বা পাত আস্রা ধানর আড়াই আত হিজা ছাড়ে চইলতা গাছে ধরছে কাড়ার একই কিত্তায় ভরছে নয়ানর ভাড়ার।"
        ]
      },
      {
        "part_of_speech": "বি.",
        "definition": "রাখাল বালক।"
      }
    ],
    "source_page": "IMG_0044"
  },
