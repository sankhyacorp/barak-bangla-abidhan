  {
    "headword": "কাচমিলকা",
    "transliteration": "kachomiloka",
    "phonetics": "kac∫ɔmilɔka",
    "etymology": "[<আঞ্চ. কাচমিরকা = তুঁতে লকারীভবনে ]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "তামা ও গন্ধকের অস্লঘটিত নীলচেসবুজ মিছরির দানার মতো পদার্থ বিশেষ; তুঁতে। Copper-sulphate. লা ভাষার অভিধান ও ভাষাতত্ত"
      },
      {
        "part_of_speech": "বি.",
        "definition": "শালিধান বিশেষ।",
        "examples": [
          "শালিধানের অন্তর্গত আসরা ধানের প্রকার। বড় দানার সোনালি সাদা ধান। চালও সাদা। ফলন মন্দ র নয।"
        ]
      }
    ],
    "source_page": "IMG_0085"
  },
  {
    "headword": "কাচামাত",
