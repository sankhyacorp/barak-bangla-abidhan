  {
    "headword": "পিচ্ছাড়ি",
    "transliteration": "pichchhado়i",
    "phonetics": "pic∫c∫haḍɔ়i",
    "etymology": "[< ববাং পিচ্ (=পেছন) + √ছাড়]",
    "senses": [
      {
        "raw_text": "[< ববাং পিচ্ (=পেছন) + √ছাড়] ক্রি. [অনুজ্ঞায়]— পা দিয়ে ওইটি পেছনে সরা। হাতি চালনার পরিভাষা। ‘ধর পিচছাড়ি’ বললেই নির্দিষ্ট বস্তু পা দিয়ে পেছনে সরিয়ে দেবে হাতি।"
      }
    ],
    "source_page": "IMG_0234"
  },
  {
    "headword": "পিচছো",
    "transliteration": "pichochho",
    "phonetics": "pic∫ɔc∫ho",
    "etymology": "[< ববাং পিচ্ (=পেছন্) + √যা]",
    "senses": [
      {
        "raw_text": "[< ববাং পিচ্ (=পেছন্) + √যা] ক্রি. [অনুজ্ঞায়]— পেছনে যা; পেছনে হাঁট। ⇒ পারিভাষিক শব্দ। হাতিকে পেছনে সরার আদেশ। এই আদেশ করেই মাহুত পা দিয়ে হাতির ঘাড়ের কাছে পেছন দিকে মৃদু ঠেলা দেবে।"
      }
    ],
    "source_page": "IMG_0234"
  },
  {
    "headword": "পিচপিচা",
    "transliteration": "pichopicha",
    "phonetics": "pic∫ɔpic∫a",
    "etymology": "[< ধ্ব. পিচ্পিচ্ (=সিক্ত ভাবসূচক) + আ বিশেষণে বিণ. — পিচ্ছিল; কাদামাখা। ⇒ বারিশাত পথখান বড় পিচপিচা অয়। বিণ. — মৃদু ও অনবরত [বৃষ্টি]",
    "senses": [
      {
        "part_of_speech": "বিণ.",
        "definition": "পিচ্ছিল; কাদামাখা।",
        "examples": [
          "বারিশাত পথখান বড় পিচপিচা অয়।"
        ]
      },
      {
        "part_of_speech": "বিণ.",
        "definition": "মৃদু ও অনবরত [বৃষ্টি]। 5, থি । লি ⇒ কদিন তনে পিচপিচা মেঘ, বারনি জার না।"
      }
    ],
    "source_page": "IMG_0234"
  },
  {
