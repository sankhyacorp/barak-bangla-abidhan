  {
    "headword": "আনতু",
    "transliteration": "anotu",
    "phonetics": "anɔtu",
    "etymology": "[<আঞ্চ. আনদু মূর্ধন্যভবনে < সং অন্দু = হাতি বাঁধার শেকল]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "লোহার তৈরি হাতি বেঁধে রাখার শেকল বিশেষ।",
        "examples": [
          "তীক্ষ্ণ অঙ্কুশযুক্ত এই বিশেষ আকৃতির শেকল (অনেকটা প্রথম বন্ধনীর মতো) দিয়ে হাতির পা জড়িয়ে গাছের সঙ্গে বাঁধা হয়। বাঁধার অংশ নারিকেলের বড় ও মজবুত রশি। টানাটানি করলেই শেকলের অঙ্কুশ পায়ে বিঁধে যায়।"
        ]
      }
    ],
    "source_page": "IMG_0054"
  },
