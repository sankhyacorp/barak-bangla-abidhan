    "source_page": "IMG_0114"
  },
  {
    "headword": "গইবি",
    "transliteration": "goibi",
    "phonetics": "gɔibi",
    "etymology": "[<আ. গায়িব্ = গুপ্ত]",
    "senses": [
      {
        "part_of_speech": "বিণ.",
        "definition": "গুপ্ত ; বাইরে অপ্রকাশিত।",
        "examples": [
          "গইবি ধন পাইআ বাউল এলকু রাজা। — ভাগ্যগুণে প্রাপ্ত ; দৈব।",
          "শপ্নে পাবা গইবি অশুদ দিআ কতকত বেমারি তাইন ভালা করছইন। » ময়য়য়য়য়য়য়য়য়য়য়য়য়য়য়য়য়য়য়য়য়য়য়য়য়য়য়য়য়য়য়য়য়য়য়য় ‘গইবি আদেশ গর্গ শুনিলা শ্রবণে।’"
        ]
      }
    ],
    "source_page": "IMG_0114"
  },
  {
    "headword": "গগা",
    "transliteration": "goga",
    "phonetics": "gɔga",
    "etymology": "[<ধ্ব গগ্গগ্ রুদ্ধপ্রায় গলার আওয়াজ]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "কণ্ঠনালি ; গলদেশ। সমার্থ শব্দও ডিমাসা ভাষায় রয়েছে। যেমন, গ্রগ্ = গলা দিয়ে গেলা ঢোক। হয়তো, সং গ্রীবা (= যা দিয়ে ভোজন করা যায়) শব্দটির প্রভাব থাকতে পারে।",
        "examples": [
          "তুমার গগাত গুটা, ডাকতর দেখাও।"
        ]
      }
    ],
    "source_page": "IMG_0114"
  },
