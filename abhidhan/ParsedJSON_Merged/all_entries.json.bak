    "phonetics": "bapata",
    "etymology": "[< বাং বাঁশ ~ পাতা < বংশপত্রক]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "আঁশহীন লালচে রূপোলি রঙের ছোট জাতের মাছ; কাজলি মাছ।",
