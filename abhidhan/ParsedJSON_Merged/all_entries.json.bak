  {
    "headword": "গুমাইট",
    "transliteration": "gumait",
    "phonetics": "gumaiṭ",
    "etymology": "[<ববাং নিজস্ব শব্দ গুমাইট্]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "বেগুন জাতীয় বড় আকারের গুল্ম।",
        "examples": [
          "গাছটি বেগুন গাছের মতো হলেও আকারে বেগুনগাছ থেকে বেশ বড় হয়। পাতা ত্রিশ থেকে পঁয়ত্রিশ সেমি. পর্যন্ত লম্বা আঠারো থেকে চব্বিশ সেমি. চওড়া হয়। শাখা, বোঁটা, ফল ঘন সৃক্ষু নরম রোমে পরিপূর্ণ। পাতার মধ্যশিরায় পাত্লা কাঁটা থাকে। ফল গোলাকার সবুজ ও স্বাদে টক। পাকলে লালচে হয়। ভেষজ গুণ সম্পন্ন এই ফল প্লীহা ও যকৃতের রোগে উপকারী। এই ফলের টক বরাক উপত্যকায় পথ্য রূপে গণ্য। এই গাছ যেখানে সেখানে হয় না। যত্ন সহকারে রোপণ করতে হয়।"
        ]
      }
    ],
    "source_page": "IMG_0126"
  },
