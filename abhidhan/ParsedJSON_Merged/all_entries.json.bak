        ]
      }
    ],
    "source_page": "IMG_0304"
  },
  {
    "headword": "মুরমুরি",
    "transliteration": "muromuri",
    "phonetics": "murɔmuri",
    "etymology": "[< ধ্ব. মুরমুর +ই তপ্র ‘ময়’ অর্থে]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "শীতকালীন সবুজ শাক বিশেষ।",
        "examples": [
          "ছোট ছোট সবুজ পাতাময় গুল্ম। স্বাদ ঈষৎ টক। রুচিকারক। শস্য ও সবজি খেতে প্রচুর জন্মে। ‘মুরমুর’—মৃদুশব্দে নরম শাক গাছটি ভেঙে যায়"
        ]
      },
      {
        "part_of_speech": "বাগধা. ক্রি.",
        "definition": "বিমুখ হওয়া; বিরুদ্ধে যাওয়া।",
        "examples": [
          "'এক গুরোয় মাইল্লা মুরা বুছার নিতি বড় বুরা।’ — মাহতাবুর"
        ]
      }
    ],
    "source_page": "IMG_0304"
  },
  {
    "headword": "মুরামুরি",
    "transliteration": "muramuri",
    "phonetics": "muramuri",
    "etymology": "[< ববাং √মুর (=ঘোরানো) আম্রেড্নে]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "গড়িমসি; গররাজি।",
        "examples": [
          "জাইবার অইলে জা মুরামুরি করিস না।",
          "বেশ মুরামুরি করলে টেকা দিলাইস।"
        ]
      }
    ],
    "source_page": "IMG_0304"
  },
  {
    "headword": "মুরালি",
    "transliteration": "murali",
    "phonetics": "murali",
    "etymology": "[< ববাং শব্দ মুরালি]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "প্রসিদ্ধ আউশ ধান বিশেষ।",
        "examples": [
          "ঈষ৯ গোলাকার। রং ময়য়লা সোনালি। মাঝারি দানা। লাল চাল। স্বাদে সুমিষ্ট। মুরালির প্রকার ভেদ রয়েছে। যথা— ভাশামুরালি, পুটিমুরালি, কইমুরালি, বুড়িমুরালি, মুনসিমুরালি ইত্যাদি। শ্রেণীভেদে ধানের রং ও স্বাদ সামান্য কমবেশি হালকা ঘন দেখতে পাই।"
        ]
      },
      {
        "part_of_speech": "বিণ.",
        "definition": "হিজিবিজি।",
        "examples": [
          "তোর মুরকর ঠেং আসর ঠেং লেখা ইতা চিনা জায় না।"
        ]
      },
      {
        "part_of_speech": "বাগধা. ক্রি.",
        "definition": "গজগমনে চলা।",
        "examples": [
          "অবায় হুনো গো বউ কামর বালা মুরিমুরি আটিও না।"
        ]
      }
    ],
    "source_page": "IMG_0304"
  },
  {
    "headword": "মুরোশি",
    "transliteration": "muroshi",
    "phonetics": "muro∫i",
    "etymology": "[< আ. মউরুশ = উত্তরাধিকার সূত্রে প্রাপ্ত সম্পত্তি৷]",
    "senses": [
