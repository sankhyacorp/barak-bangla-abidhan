  {
    "headword": "তেউ",
    "transliteration": "teu",
    "phonetics": "teu",
    "etymology": "[<আমবা. তেঁউ = সেজন্য < প্রাবা. তউ = তবু]",
    "senses": [
      {
        "part_of_speech": "যোজ.",
        "definition": "তাহলে; তারপর। ٩ তেনা আমরা তানে নেতা মানমু। ≫ প্রাবা. দৃ. ‘‘তউ সে হেরুজ্ঞ ণ পাবিঅই।’ — চর্যা আমবা. দৃ. ‘‘মথুরার হাট জাই তেঁউ চিত্তের হরষে।’ — কৃকী।",
        "examples": [
          "দরে বনলে তেউ মাল বেছিমু, নাইলে না।",
          "তাইন আগে দেশর কাম করি দেখাউকা তেউ"
        ]
      }
    ],
    "source_page": "IMG_0198"
  },
  {
    "headword": "তেউর",
    "transliteration": "teur",
    "phonetics": "teur",
    "etymology": "[<প্রা. তেওড় < সং তীর্যক]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "ঝুড়ি টুকরি ধুচুনি প্রভৃতি বাঁশের তৈরি পাত্র মজবুত করার জন্য আড়াআড়িভাবে যে দৃটি বা চারটি বাঁ শের শক্ত শলাকা ঢুকিয়ে দেওয়া হয়। ওগুলোকে ‘তেউর’ বলে।",
        "examples": [
          "পটাংগিত খালি তেউর লাগানি বাকি।"
        ]
      }
    ],
    "source_page": "IMG_0198"
  },
  {
    "headword": "তেখতেখা",
    "transliteration": "tekhotekha",
    "phonetics": "tekhɔtekha",
    "etymology": "[<ধ্ব. তেখতেখ = আর্দ্রতা ব্যঞ্জক]",
    "senses": [
