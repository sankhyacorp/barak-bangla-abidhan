  },
  {
    "headword": "অনতে",
    "transliteration": "onote",
    "phonetics": "ɔnɔte",
    "etymology": "[<বাং অন্তরে = তরে]",
    "senses": [
      {
        "part_of_speech": "অনু.",
        "definition": "চেয়ে [তুল্যার্থে]।",
        "examples": [
          "'শরম অনতে মরণ ভালা' — বরাকপ্রবাদ"
        ]
      },
      {
