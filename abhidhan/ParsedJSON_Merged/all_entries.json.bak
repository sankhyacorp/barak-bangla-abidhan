  {
    "headword": "ডালা",
    "transliteration": "dala",
    "phonetics": "ḍala",
    "etymology": "[<বাং ডালা < সং ডল্লক]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "বাঁশের তৈরি গোলাকার প্রশস্ত পাত্র; চেপটা ও গোলাকার কুলো বিশেষ।",
        "examples": [
          "শস্যাদি ঝাড়া থেকে শুরু করে নানা গৃহস্থালি কাজের অত্যাবশ্যক আসবাব এই ‘ডালা’।",
          "ডালাদি তিলগুইন ঝারিআ মেলি দে। Ī ডালা<sub>s</sub> ḍala [<দ্র. ডালা১]"
        ]
      },
      {
        "part_of_speech": "বি.",
        "definition": "বৃহদাকার পাত্রের ঢাকনা; ছোট দোকানঘরের ঝাঁপ।",
        "examples": [
          "মিঠাঁদেত পূॅকতিত ফালা না লাগাঁদেল উন্পৃত্ত খাইবা।",
          "হকল দুকানর ডালা বন্ধ্ অই গেছে।"
        ]
      }
    ],
    "source_page": "IMG_0181"
  },
  {
    "headword": "ভালাু",
    "transliteration": "valau",
    "phonetics": "valau",
    "etymology": "[<দ্র. ডালা]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "ডালাতে সাজানো পূজা বা বিবাহের উপচার।",
        "examples": [
          "পূজাতে ফুল ফল ধূপ দীপ নৈবেদ্য প্রভৃতি পঞ্চোপচার, দশোপচার বা ষোড়শোপচার দিয়ে সাজিয়ে ‘ডালা’ প্রস্তুত করা হয়। বিয়েতে থাকে বস্ত্র, অলংকার, ফল, মিঠাই ইত্যাদি।"
        ]
      }
    ],
    "source_page": "IMG_0181"
  },
  {
    "headword": "ডালানি",
    "transliteration": "dalani",
    "phonetics": "ḍalani",
    "etymology": "[<ববাং √ ডালা < দেশি. ডাল + আ নামধাতু নির্মাণে]",
    "senses": [
      {
        "part_of_speech": "ক্রি.",
        "definition": "গাছের ডাল কেটে ফেলা; গাছের ডাল ছেঁটে ফেলা।",
        "examples": [
          "পিংগাছগু ডালাইও।",
          "গাছের ডালকে উদ্ভিদবিজ্ঞান সম্মতভাবে অর্থাৎ গাছের কোনোরূপ ক্ষতি যাতে না হয় সেদিকে লক্ষ্য রেখে কাটা বা ছাঁটাকে ‘ডালানি’ বলা হয়"
        ]
      },
      {
        "part_of_speech": "বি.",
        "definition": "ডাল কেটে ফেলার কাজ। f",
        "examples": [
          "শ্রিম্বর শাহ জানিত লাশি মানু জাতা। াংলা ভাষার অভিধান ও ভাষাতত্ত"
        ]
      }
    ],
    "source_page": "IMG_0181"
  },
