    "senses": [
      {
        "raw_text": "[<ববাং শব্দ ডাবা ি. — ধান প্রভৃতি রোদে মেলে দেওয়ার হাতিয়ার বা যন্ত্র বিশেষ। ⇒ বউএ ডাব দি চাত্লর ধানটাইন আটাইলাও।"
      }
    ],
