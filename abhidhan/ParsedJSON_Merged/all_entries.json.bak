  {
    "headword": "খেদুড়ি",
    "transliteration": "khedudo়i",
    "phonetics": "kheduḍɔ়i",
    "etymology": "[<মবা. খেদা <√খেদ + উড়ি নামপদ গঠনো বি. — তাড়ানোর জন্য পেছনে দৌড়। ⇒ একই খেদুড়িএ বন্দ্ পার করি দিছি বইতলরে। ≫ প্রাবা. / মবা. খেদাড়ান [⇒‘জনমিআ মণ্ডুক জলে লাফালাফি জাএ। অনন্ত বাসুকি তারে খেদাড়িআ খাএ।’ — শূন্যপুরাণ]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "তাড়ানোর জন্য পেছনে দৌড়। লাফালাফি জাএ। অনন্ত বাসুকি তারে খেদাড়িআ খাএ।’ — শূন্যপুরাণ] আঞ্চলিক বাংলায় ‘খেদুড়িআ’ বরাকবাংলার ‘খেদুড়ি’।",
        "examples": [
          "একই খেদুড়িএ বন্দ্ পার করি দিছি বইতলরে।"
        ]
      }
    ],
    "source_page": "IMG_0112"
  },
  {
    "headword": "খেদুড়ি লবা",
    "transliteration": "khedudo়i loba",
    "phonetics": "kheduḍɔ়i lɔba",
    "etymology": "[<ববাং খেদুড়ি ~ √ল]",
    "senses": [
      {
        "part_of_speech": "সক্রি.",
        "definition": "বিতাডনের উদ্দেশ্যে কারো পেছনে দ্রুত ধাবমান হওয়া। — কাউকে তাড়ানোর জন্য সশস্ত্র ছুটে যাওয়া।",
        "examples": [
          "চুররে অলা খেদুড়ি লইছি আর ভাগিআ জাইত পারছে না।"
        ]
      }
    ],
    "source_page": "IMG_0112"
  },
  {
    "headword": "খেপ",
    "transliteration": "khep",
    "phonetics": "khep",
    "etymology": "[<বাং ক্ষেপ = দফা]",
    "senses": [
