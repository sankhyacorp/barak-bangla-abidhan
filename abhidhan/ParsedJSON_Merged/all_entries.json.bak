  {
    "headword": "ফর",
    "transliteration": "for",
    "phonetics": "fɔr",
    "etymology": "[< ববাং শব্দ. ফর]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "ফড়িং জাতীয় পতঙ্গ বিশেষ; মথ।",
        "examples": [
          "প্রজাপতি ও মথের মধ্যে পার্থক্য সৃক্ষ্। প্রজাপতির রঙের বাহার বেশি এবং দিনের বেলায় বেশি উড়াউড়ি করে। মথের পাখার রঙের বাহার কিছুটা কম তবে পাখাটা একটু পুরু। সন্ধ্যের সময় বা রাতে বেশি দেখা যায়। তবে প্রকৃত পার্থক্য ওদের শুঁড়ে বা অ্যান্টেনায়। প্রজাপতির শুঁড়ের আগায় যবাকৃতি পুঁটুলি আছে, মথের নেই। মথের শুঙ্গে চিরুন দাঁত ভর্তি।"
        ]
      }
    ],
    "source_page": "IMG_0242"
  },
  {
    "headword": "ফরফরানি",
