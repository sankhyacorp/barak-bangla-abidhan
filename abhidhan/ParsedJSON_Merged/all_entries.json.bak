  {
    "headword": "মাড়া",
    "transliteration": "mado়a",
    "phonetics": "maḍɔ়a",
    "etymology": "[< বাং মাড়া = মর্দন করা < সং √মৃদ্]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "ধান ঝাড়া।",
        "examples": [
          "কাটা ধানের আঁটি খুলে লেপা উঠানে বা চাতলে গোলাকার করে ছড়িয়ে দেওয়া হয়। এই ছড়ানো ধানের স্তুপের উপর বৃত্তাকারে হাঁটানো হয় চার- পাঁচটি গোরু বা দুতিনটি মহিষ। এদের পায়ের চাপে ও খুরের আঘাতে খড় থেকে ধান ঝরে পড়ে। এরূপ ধান মাড়াইয়ের কাজকে ‘মাড়া’ বলা হয়।৩০ থেকে ৮০ মুটা ধানের মাড়া একসঙ্গে দেওয়া হয়।"
        ]
      }
    ],
    "source_page": "IMG_0300"
  },
