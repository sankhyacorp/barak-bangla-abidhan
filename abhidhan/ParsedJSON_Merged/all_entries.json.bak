  {
    "headword": "তিথি",
    "transliteration": "tithi",
    "phonetics": "tithi",
    "etymology": "[< ববাং শব্দ তিথি]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "বিনুনি; সাপের মতো লম্বা করে বাঁধা চুল।",
        "examples": [
          "তাইর চুল গারি আর লামবা, তিথি বলিলে পরির লাখান দেখা জায়।"
        ]
      },
      {
        "part_of_speech": "বাগধা.",
        "definition": "নাবালক ছেলে; অল্পবয়সি ছেলে। দ্র. আংলা।",
        "examples": [
          "'তিন আংলা ছাগি, মাত হুনো তার। বড় মানর লগে তর্কো, মুর্খো কুথাকার।’ আনন্দ"
        ]
      },
      {
        "part_of_speech": "বাগধা. ক্রি.",
        "definition": "একাধিক মাধ্যমে কার্যসিদ্ধি করা।",
        "examples": [
          "মাতিআ লাভ নাই, সরকারি টেকাগুইন উগাইছি তিন কুটায় বাইংগন পাড়িআ।"
        ]
      },
      {
        "part_of_speech": "বি.",
        "definition": "সামান্য লোক।",
        "examples": [
          "তিন না তেরো, হে কয় বুড়াইল নাও একলাউ তুলিলাইব।"
        ]
      }
    ],
    "source_page": "IMG_0195"
  },
  {
    "headword": "তিনপনচাশ",
