    "etymology": "[<বাং গোরা + আনা তপ্র. যুক্তার্থে <সং গৌর = শুভ্রবর্ণ]",
    "senses": [
      {
        "part_of_speech": "বিণ.",
        "definition": "গায়ের বর্ণ গৌর এমন।",
        "examples": [
          "মোর বাফ কালিআনা মা গুরিআনা।"
        ]
      }
    ],
    "source_page": "IMG_0127"
  },
  {
    "headword": "গুড়া",
    "transliteration": "gudo়a",
    "phonetics": "guḍɔ়a",
    "etymology": "[<অমবা. গুঢ়া = গুঁড়ির কাঠ থেকে নির্মিত তক্তা]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "নৌকার ভেতরে পাশাপাশি সংযুক্ত কাঠের বর্গা বা তক্তা।",
        "examples": [
          "নৌকাকে নৌকার মতো করে ধরে রাখার জন্য নৌকার ভেতরে পাশাপাশি বর্গা গেঁথে ডান ও বাঁদিক মজবুত করে সংযুক্ত করা হয়। অনেকটা ঘরের কড়িকাঠ বা বিমের মতো। গুড়া দুরকমের — ১. বড় গুড়া, যা নৌকার উপরিভাগে গাঁথা থাকে। সংখ্যায় কমপক্ষে পাঁচ। ২. পানিগুড়া, এগুলি নৌকার ভেতরের তলায় সংযোজিত থাকে — তলাকে দৃঢ়বদ্ধ করার জন্য।",
          "আফাল উঠের গুড়াত বইরও।",
          "আমবা. দৃ. ‘চারি পাট চিরী নাঅ দিল যোখ মাপে। তাত গুঢ়া যোড়ী দিল তৌল ঝাঁপে।।’ — কৃকী"
        ]
      }
    ],
    "source_page": "IMG_0127"
  },
  {
    "headword": "গুড়ি",
    "transliteration": "gudo়i",
    "phonetics": "guḍɔ়i",
    "etymology": "[<আঞ্চ বাং গুড়া + ই <গুণ্ড = গুঁড়ো]",
    "senses": [
