  },
  {
    "headword": "রুব্বটি মারা",
    "transliteration": "rubboti mara",
    "phonetics": "rubbɔṭi mara",
    "etymology": "[<ববাং কমটি ~ √মার]",
    "senses": [
      {
        "part_of_speech": "সক্রি.",
        "definition": "শক্ত করে কোঁচা মারা। কম্পানির মাছ বেশপানিত পড়া — বাগধা. ক্রি - দৈন্যদশা থেকে হঠাৎ আর্থিক স্বচ্ছলতায় পৌছা। ⇒ কম পানির মাছ বেশ পানিত পড়লে বুড়াবুড়ি করইন।",
        "examples": [
          "দ্র. কমটি।"
        ]
      }
    ],
    "source_page": "IMG_0080"
  },
  {
    "headword": "কমর",
    "transliteration": "komor",
    "phonetics": "kɔmɔr",
    "etymology": "[<ফা. কমর = কটি ]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "কোমর।",
        "examples": [
          "এলকু আর তাইন কমর সিদা করি উবাইতা পারইন না। কমর সিদা করা — বাগধা. ক্রি. - উঠে দাঁড়ানো; দুর্দশা কাটিয়ে ওঠা।",
          "ঘর জঁলার (জুলা) বাদে আবো তারা কমর সিদা করতা পারছইন না।"
        ]
      },
      {
        "part_of_speech": "বাগধা. বি.",
        "definition": "কোমরে ব্যথা।",
        "examples": [
          "বেশ নআউঠা করতে করতে মইর কমরো ধরা বেমার অইছে।"
        ]
      },
      {
        "part_of_speech": "ক্রি.",
        "definition": "কোমরে ব্যথা হওয়া।",
        "examples": [
          "নইআ নইআ কাম করলেউ মোর কম্রো ধরে। কম-সে-কম kom se kom [<ফা. কম]"
        ]
      },
      {
        "part_of_speech": "যোজ.",
        "definition": "কমপক্ষে।",
        "examples": [
          "কমসেকম রুজ পনচাশ টেকা করিআ না দিলে তার পুশাইত নায়।"
        ]
      }
    ],
    "source_page": "IMG_0080"
  },
