  {
    "headword": "করই",
    "transliteration": "koroi",
    "phonetics": "kɔrɔi",
    "senses": [
      {
        "raw_text": "[<আঞ্চ. কড়ই <ধ্ব কড় কড় = চাল"
      },
      {
        "part_of_speech": "বি.",
        "definition": "চালভাজা ; চালভাজার গুড়ো।",
        "examples": [
          "বরাক উপত্যকায় লৌকিক ব্রত ও পূজায় ভক্তদের প্রিয় নৈবেদ্য প্রস্তুত হয় করই, দুধ, গুড় ও শবরিকলা সহযোগে। শব্দটি দক্ষিণ বঙ্গ ও বাংলাদেশে ‘মুড়ি’ অর্থেই প্রচলিত।"
        ]
      }
    ],
    "source_page": "IMG_0080"
  },
  {
    "headword": "করইল",
    "transliteration": "koroil",
    "phonetics": "kɔrɔil",
    "etymology": "[<আঞ্চ. কোড়ল = বাঁশের চারা]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "বাঁশের কোঁড়; বাঁশের অতিকচি চারাগাছ বা মুকি। করইল।",
        "examples": [
          "বউএ ইচাদি করইল রান্দিছইন।",
          "'করইল' বরাক উপত্যকার আদি বাঙালি এবং পার্বত উপজাতিদের প্রিয় সবজি। করইলের ব্যঞ্জন রান্না হয় ডাল, মাছ, শুটকিমাছ ও শিদল দিয়ে। বাজারে বেশ দামেই বিক্রি হয়। উত্তরকাছাড়ের হাফলং করইলের বড় বাজার।"
        ]
      }
    ],
    "source_page": "IMG_0081"
  },
  {
    "headword": "করকরা",
    "transliteration": "korokora",
    "phonetics": "kɔrɔkɔra",
    "etymology": "[<ধ্ব. কর্ কর্ = শুকনো তপ্র. আ ভাবার্থে]",
    "senses": [
