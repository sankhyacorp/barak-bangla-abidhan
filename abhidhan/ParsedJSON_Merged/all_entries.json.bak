    "etymology": "[< আঞ্চ. লেচ্ছড়]",
    "senses": [
      {
        "part_of_speech": "বিণ.",
        "definition": "অভাবের দরুণ যে অতি কষ্টে ধার-কর্জ বা ভিক্ষা ইত্যাদি করে সংসার চালায়।",
        "examples": [
          "কদিন আর দুনিআত লেচ্ছড় অইআ থাকতাম।"
        ]
      },
      {
        "part_of_speech": "বিণ.",
        "definition": "যে সহজে ঋণ পরিশোধ করতে পারে না।",
        "examples": [
