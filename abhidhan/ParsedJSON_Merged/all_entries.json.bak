    "phonetics": "ba",
    "senses": [
      {
        "raw_text": "< আঞ্চ. বাং ‘বা’, ‘ব’ সম্বোধনে] অনম্ব — সম্বোধনে ‘গো’। ≫ সম্বোধন উপপদ। বাংলা ‘গো’-এর মতো তবে এটি শুধু পুরুষের বেলায় ব্যবহাত হয়। ⇒ কানো গেশলায় বা?"
      }
    ],
    "source_page": "IMG_0259"
  },
