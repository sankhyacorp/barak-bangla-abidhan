  },
  {
    "headword": "লেবইর",
    "transliteration": "leboir",
    "phonetics": "lebɔir",
    "etymology": "[< ববাং শব্দ লেবইর]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "আমলকির মতো দেখতে একপ্রকার টকফল।",
        "examples": [
          "লেবইর গাছ ১০/১২ হাত উঁচু হয়। পাতা গোল গোল ছোট ছোট। ফল হালকা হলদে-সবুজ। পাকলে হলদে হয়। দেখতে আমলকির মতো হলেও রসালো ও টক। এর পাতা চর্মরোগে উপকারী।"
        ]
      }
    ],
    "source_page": "IMG_0324"
  },
  {
    "headword": "লেম",
    "transliteration": "lem",
    "phonetics": "lem",
    "etymology": "[< ইং Lamp = বাতি সংকোচনে]",
    "senses": [
