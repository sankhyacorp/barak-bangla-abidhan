  {
    "headword": "দুবড়ি",
    "transliteration": "dubodo়i",
    "phonetics": "dubɔḍɔ়i",
    "etymology": "[< সং দূর্বা = ঘাস বিশেষ]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "দূর্বা ঘাস; চিক্কণ ঘাস বিশেষ।",
        "examples": [
          "দূর্বার শ্রেণীভেদ থাকলেও ‘দূবড়ি’ বলতে সাধারণ দূর্বাঘাসকেই বোঝায়। যার বৈজ্ঞানিক নায এটি eynodon dactylon (linn) pers. I gramineae পরিবার ভুক্ত। দুবড়ি ঘাস হিন্দুদের পূজা ও শ্রাদ্ধাদি অনুষ্ঠানে ব্যবহৃত হয়।"
        ]
      }
    ],
    "source_page": "IMG_0208"
  },
