    "transliteration": "kumari puk",
    "phonetics": "kumari puk",
    "etymology": "[<বাং কুমার (<সং কুম্ভকার) + ই তপ্র সাদৃশ্যে]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "কুমরে পোকা।",
        "examples": [
          "‘এই পোকা মুখে মাটি আনিয়া গৃহনির্মাণ করে এবং তার মধ্যে ডিম ছাড়িয়া সরিয়া যায়। কুমারের মতো মাটির কাজ করে বলিয়া এই নাম।’ — বাভা"
        ]
      }
    ],
    "source_page": "IMG_0098"
  },
  {
    "headword": "কুর",
    "transliteration": "kur",
    "phonetics": "kur",
    "etymology": "[<ব্রজবুলি. কোর <সং ক্রোড়]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "কোল।",
        "examples": [
          "পুআগুর কিতা জে অইছে খালি কুরো থাকত চায়। > মধ্যবাংলা. ব্রজবুলি. ‘দুহুঁ কোরে দুহুঁ কাঁদে বিচ্ছেদ ভাবিয়া।' —চণ্ডীদাস"
        ]
      }
    ],
    "source_page": "IMG_0098"
  },
  {
    "headword": "কুরতা",
    "transliteration": "kurota",
    "phonetics": "kurɔta",
    "etymology": "[<তুর্কি. কুর্তা = পুরুষদের ছোটজামা ]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "পুরুষদের ছোটজামা ; নিমা।",
        "examples": [
          "‘খলিফার ফারা কুরতা।’ — বরাক প্রবাদ।"
        ]
      }
    ],
    "source_page": "IMG_0098"
  },
  {
    "headword": "কুরতা",
    "transliteration": "kurota",
    "phonetics": "kurɔta",
    "etymology": "[<ববাং শব্দ কুর্তা]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "চিরহরিৎ বৃক্ষ বিশেষ।",
        "examples": [
          "এই গাছ ৫০ ফুট পর্যন্ত উঁচু হয়। চক্র পরিধি ছয় হাত অব্দি হতে পারে। এর পাতা আকন্দ গাছের পাতার মতো পুরু। আকারেও সে-রকম। বাকল সাদাটে মসৃণ। কাঠ লাল। এই গাছের কাঠ ঘরের কাজে ব্যবহৃত হয়। বৈজ্ঞানিক নাম— Palaquium Polyanthus."
        ]
      }
    ],
    "source_page": "IMG_0098"
  },
