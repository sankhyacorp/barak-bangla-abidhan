  },
  {
    "headword": "ডেখ",
    "transliteration": "dekh",
    "phonetics": "ḍekh",
    "etymology": "[< ববাং শব্দ ডেখ]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "কলাগাছের নরম নিরেট অভ্যস্তর ভাগ; কলাগাছের মজ্জা।",
        "examples": [
          "ডেখ না অইলে বইরাগির লাবড়া অয় না।",
          "কুমিল্লায় ‘ডেখ’কে বুগুলি বলা হয়। শ্রীহট্টে ‘ডেক’ মানে কলার থোড়। বরাক বাংলায় ‘ডেক’ বলতে কলাগাছের ভেতরকার বর্তুলাকার সারপদার্থ।"
        ]
      }
    ],
    "source_page": "IMG_0186"
  },
