  {
    "headword": "আতিআর",
    "transliteration": "atiar",
    "phonetics": "atiar",
    "etymology": "[<বাং হাতিয়ার]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "শিল্পকর্মের সহায়ক যন্ত্রপাতি।",
        "examples": [
          "মেসতইরে তান আতিআর লইআ আইছইন।"
        ]
      },
      {
        "part_of_speech": "বি.",
        "definition": "শুধু হাতে বহনযোগ্য অস্ত্রশস্ত্র।",
        "examples": [
          "নকলি আতিআর লইআ আইজকাইল মানে ডাকাতি করি লাইন।",
          "কাঠমিস্ত্রী, রাজমিস্ত্রী থেকে শুরু করে নাপিতের সরঞ্জাম পর্যন্ত সবকিছুই ‘আতিআর’ এর অন্তর্গত।"
        ]
      }
    ],
    "source_page": "IMG_0052"
  },
  {
    "headword": "আতিমরা",
    "transliteration": "atimora",
    "phonetics": "atimɔra",
    "etymology": "[<ববাং আতি ~ মরা]",
    "senses": [
      {
        "part_of_speech": "বিণ.",
        "definition": "আধমরা; আধাশুকনো (উদ্ভিদের ক্ষেত্রে)।",
        "examples": [
          "বাগু আতিমরা অইলে তুমি কাটি লাও। ⇒ বাঁশ, বেত, গাছপালা মরে শুকিয়ে যাওয়া অর্থেই শব্দটির ব্যবহার সর্বাধিক।"
