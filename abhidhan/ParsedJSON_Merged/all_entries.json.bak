    "source_page": "IMG_0131"
  },
  {
    "headword": "ঘাড়া",
    "transliteration": "ghado়a",
    "phonetics": "ghaḍɔ়a",
    "etymology": "[<বাং ঘা (= ক্ষত) + ড়া তপ্র. আধিক্যে]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "গভীর ক্ষত।",
        "examples": [
          "পাড়িজুকে কামড়ানিএ ফুট ঘাড়া অই গেছে। ঘাড়ানি gharani [< প্র. ঘাড়া]"
        ]
      },
      {
        "part_of_speech": "ক্রি.",
        "definition": "গভীরে প্রবেশ করানো।",
        "examples": [
          "ভালা করি ঘাড়াইআ কাট। — জোরে দেগে দেওয়া।",
          "কারবন তলেদি লেখলে পেনসিল ঘাড়াইও।"
        ]
      }
    ],
    "source_page": "IMG_0131"
  },
  {
    "headword": "ঘাড়ুআ",
    "transliteration": "ghado়ua",
    "phonetics": "ghaḍɔ়ua",
    "etymology": "[<ধ্ব. ঘড় ঘড় = বড় ব্যাঙ্কের গলার আওয়াজা]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "বড় রকমের ব্যাঙ।",
        "examples": [
          "এ অঞ্চলের সবচেয়ে বড় ব্যাঙ। এদের উচ্চগ্রামের আওয়াজ ‘ঘেঘুড়ে ঘুঁ’ থেকেই এর এই নাম।"
        ]
      },
      {
        "part_of_speech": "বিণ.",
        "definition": "গাঁজাখুরি; আজগুবি।",
        "examples": [
          "‘একো সময় একোখানো এমন গফ ছাড়ে, জায় না জারা, মাত্লে বেরা ঘাড়ে আর পাড়ে।’ মাহতাবুর"
        ]
      }
    ],
    "source_page": "IMG_0131"
  },
  {
    "headword": "ঘিন",
    "transliteration": "ghin",
