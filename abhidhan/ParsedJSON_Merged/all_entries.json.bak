    "source_page": "IMG_0198"
  },
  {
    "headword": "তেজিআ",
    "transliteration": "tejia",
    "phonetics": "teʒia",
    "etymology": "[<সং তেজঃ + ববাং ইআ তপ্র. যুক্তার্থো]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "চিরহরিৎ বৃক্ষ বিশেষ।",
        "examples": [
          "মাঝারি উচ্চতার গাছ। তেজপাতার মতো পাতার তেজালো গন্ধ আছে। শক্ত কাঠ। রং লালচে। শক্ত হলেও কাঠ হিসেরে ভালোই। বৈজ্ঞানিক নাম- Cinnamomum Obtusifolium."
        ]
      }
    ],
    "source_page": "IMG_0198"
  },
