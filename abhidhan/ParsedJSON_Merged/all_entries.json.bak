  {
    "headword": "ভূবি",
    "transliteration": "vubi",
    "phonetics": "vubi",
    "etymology": "[< ববাং শব্দ ভূবি]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "লটকন ফলের গাছ বা ফল।",
        "examples": [
          "মাঝারি আকারের গাছ। প্রচুর শাখা প্রশাখা ও পত্রবিন্যাস ঘন। পাতা কাঁঠাল পাতার মতো। গাছের বাকল ধূসর ও অমসৃণ। ছোট ছোট ডাল এমন কী কাণ্ড থেকেও লম্বা ডাটা গজিয়ে থোকায় থোকায় ফল ঝুলে থাকে।ফল গোল গোল।কাঁচা ফল সবুজ, পাকলে হলদে। ফলের পুরু নরম খোসা ছাড়ালে তিন বা চার বিচির কোয়া বেরোয়। ফলের শাঁস লিচুর মতো সাদা ও রসালো। স্বাদ টক-মিঠা। শিশুদের অতি প্রিয়।"
        ]
      }
    ],
    "source_page": "IMG_0288"
  },
