  {
    "headword": "হুধা",
    "transliteration": "hudha",
    "phonetics": "ɦudha",
    "etymology": "[< সং √শুধ্ = সংস্কার করা]",
    "senses": [
      {
        "part_of_speech": "ক্রি.",
        "definition": "ধানের চারাগাছের মরাপাতা আগাছা ইত্যাদি সাফ করা; ধানের চারা বা যেকোনো গাছের চারার চারপাশের ঝঞ্জাল পরিষ্কার করা; ধানের বীজ বা চারা শোধন করা।",
        "examples": [
          "বিআলে আসরার আলিগুইন হুরিতে হুধিআ ছরিস।"
        ]
      }
    ],
    "source_page": "IMG_0349"
  },
  {
    "headword": "হুনদা",
    "transliteration": "hunoda",
    "phonetics": "ɦunɔda",
    "etymology": "[< ববাং শব্দ হুনদা]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "তৃণ জাতীয় জলজ উদ্ভিদ। শনের মতো গাছ। নরম ও পুরু। ঘনসবুজ রং। অগ্রভাগ ক্রমশ সরু হয়ে শেষে পেঁয়াজের ফুলের কলির মতো কলি হয়। ফুলও ধরে। ফুলের রং সাদা। পুকুর বা জলাশয়ের পাড়ের দিকের অল্পজলে এটি জন্মায়।"
      }
    ],
    "source_page": "IMG_0349"
  },
  {
    "headword": "হুনদা",
    "transliteration": "hunoda",
    "phonetics": "ɦunɔda",
    "etymology": "[< দ্র. হুনদা,]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "হুনদা গাছ, ফুল, ধান্য, দূর্বা, ধূপ, বাতি সহযোগে বিয়ের আগের দিন রাতের অনুষ্ঠান; বিয়ের অধিবাস। ⇒ বরাক উপত্যকায় হিন্দুদের এই অনুষ্ঠানে হুনদা গাছের ভূমিকা প্রধান বলেই এই নাম।"
      }
    ],
    "source_page": "IMG_0349"
  },
  {
    "headword": "হুনদি",
    "transliteration": "hunodi",
    "phonetics": "ɦunɔdi",
    "etymology": "[< ববাং শব্দ হুনদি < আঞ্চবাং সুনদি হকারীভবনে]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "উৎকৃষ্ট বেতগাছ বিশেষ।",
        "examples": [
          "চিকন মজবুত বেতগাছ। ৫০০-৭০০ হাত দীর্ঘ হতে পারে এই বেত। অতি উৎকৃষ্টমানের এই বেত ঘুনে ধরে না, পোকায় কাটে না। নষ্টও হয় না সহজে। হুনদি বেতের তৈরি আসবাবপত্র বাজারে দামে বিক্রি হয়। বরাক উপত্যকায় এই বেত প্রচুর জন্মে। বৈজ্ঞানিক নাম— Calamus Guruba."
        ]
      }
    ],
    "source_page": "IMG_0349"
  },
  {
