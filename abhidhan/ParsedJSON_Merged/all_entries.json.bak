  },
  {
    "headword": "কুটা্",
    "transliteration": "kuta",
    "phonetics": "kuṭa",
    "etymology": "[<সং কুট্ট = চূর্ণ করা]",
    "senses": [
      {
        "part_of_speech": "ক্রি.",
        "definition": "ভানা ; শস্যের খোসা ছাড়ানো; শস্য ইত্যাদি চূর্ণ করা।",
        "examples": [
          "খলিলর মায় রুজ দেড়মন ধান কুটে।"
        ]
      }
    ],
    "source_page": "IMG_0095"
  },
  {
    "headword": "কুটা",
    "transliteration": "kuta",
    "phonetics": "kuṭa",
    "etymology": "[<সং কূট =  বৃক্ষ ]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "বাঁশের লম্বা দণ্ড যা দিয়ে গাছ থেকে ফুল ফল ইত্যাদি পাড়া হয়; আঁকশি। ক্ষা, kuța [< প. ক্ষা,]"
      },
      {
        "part_of_speech": "বি.",
        "definition": "লাঙলের হাতল।",
        "examples": [
          "কুটায় ধরে চাষিরা হালচাষ করেন।"
        ]
      },
      {
        "part_of_speech": "বাগধা. ক্রি.",
        "definition": "উদ্দেশ্য- মূলকভাবে নিজে নেপথ্যে থেকে অপরকে দিয়ে কাজ করানো।",
        "examples": [
          "হকলতাত কুটা দি বাইংগন পাড়লে কাম অইত নায়।"
        ]
      }
    ],
    "source_page": "IMG_0095"
  },
  {
    "headword": "কুটিমুটি",
    "transliteration": "kutimuti",
    "phonetics": "kuṭimuṭi",
    "etymology": "[<আঞ্চ. কুটি (<হি. কুট্টি) অনুকারে মুটি ]",
    "senses": [
      {
        "part_of_speech": "বিণ.",
