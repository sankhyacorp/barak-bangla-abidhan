    ],
    "source_page": "IMG_0321"
  },
  {
    "headword": "লুকলুকি",
    "transliteration": "lukoluki",
    "phonetics": "lukɔluki",
    "etymology": "[< ধ্ব. লুকলুক (=পাকা ও রসাল ভাবসূচক) +ই।]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "কুলজাতীয় টক-মিঠা-কষায় স্বাদবিশিষ্ট ফল।",
        "examples": [
          "১৫/ ২০ হাত উঁচু গাছ। পাতা সরু আগা বিশিষ্ট। গাছের কাণ্ডে ও শাখায় কাঁটার গুচ্ছ থাকে। কাঁচা ফল সবুজ। ডাঁশা হলে লালচে-বেগুনি। পাকলে নরম ও মিষ্টি হয়। আকার কুলের মতোই। বৈজ্ঞানিক নাম— Flacourtia Cataphracta."
        ]
      }
    ],
    "source_page": "IMG_0321"
  },
  {
