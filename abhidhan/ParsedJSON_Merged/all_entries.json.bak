    "transliteration": "paikari",
    "phonetics": "paikari",
    "etymology": "[< ফা. পাইকার + ই তপ্র. ভাবার্থো]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "পাইকারের কর্ম বা বৃত্তি; পাইকার সুলভ আচরণ।"
      },
      {
        "part_of_speech": "বিণ.",
        "definition": "খুচরোর চেয়ে কম মূল্যে কেনা এমন।",
        "examples": [
          "মুরকির ডিমর পাইকারি দর কিলা?",
          "পাইকারেরা যে মূল্যে ক্রয় করেন তাকে ‘পাইকারি দর’ বলা হয়। সাধারণত খুচরো ক্রয়বিক্রয়ের চেয়ে একসঙ্গে একজাতীয় অনেক বা প্রচুর পরিমাণ পণ্যের কেনাবেচার ‘দর’ কম থাকে। এই কমমূল্যকেই বলে পাইকারি দর।"
        ]
      }
    ],
    "source_page": "IMG_0227"
  },
