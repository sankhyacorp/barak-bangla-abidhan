  {
    "headword": "লং",
    "transliteration": "lng",
    "phonetics": "lŋ",
    "etymology": "[< আমবা. লঙ্গ < সং লবঙ্গ]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "লবঙ্গ; Clove; গরম মশলা বিশেষ। ভিড়িআঁ বান্ধে লোটনে।’ — কৃকী",
