  {
    "headword": "পিত পড়া",
    "transliteration": "pit podo়a",
    "phonetics": "pit pɔḍɔ়a",
    "etymology": "[< সং পিত্ত ~ √পড়]",
    "senses": [
      {
        "part_of_speech": "সক্রি.",
        "definition": "সময় মতো আহার না পেয়ে পিত্তাশয় থেকে পিত্তরস ক্ষরিত হওয়া এবং ফলে ক্ষুধা নষ্ট হওয়া।",
        "examples": [
          "ভুখর সমে না খাইলে পিতৃ পড়ে।"
        ]
      },
      {
        "part_of_speech": "বাগধা. ক্রি.",
        "definition": "রাগ ও বিরক্তি তীব্র হওয়া।",
        "examples": [
          "তার ইতা কানডো দেখলে মোর পিত জলি জায়।"
        ]
      }
    ],
    "source_page": "IMG_0235"
  },
  {
    "headword": "পিনদা",
    "transliteration": "pinoda",
    "phonetics": "pinɔda",
    "etymology": "[< আমবা পিন্ধা = পরা]",
    "senses": [
      {
        "part_of_speech": "ক্রি.",
        "definition": "পরিধান করা।",
        "examples": [
          "রাখ, মুই হাড়ি পিনদিআর। আমবা. দৃ. ‘আইস ল বড়ায়ি হের/ বচন আমার ধর / রতনমুদড়ী পিন্ধ হাতে।’ — কৃকী 'M.B. পিন্ধ<Pindha>(api-nah, api-naddha)' ODBL"
        ]
      },
      {
        "part_of_speech": "ক্রি.",
        "definition": "অলংকার পরিধানের জন্য কান, নাক প্রভৃতি সূঁচ ইত্যাদি দিয়ে ছিদ্র করা।",
        "examples": [
          "'আপিন্রায় পিনদিছইন কান, নাচিআ মইল্লা ডেফল গাছ।’ বপ্র."
        ]
      }
    ],
    "source_page": "IMG_0235"
  },
  {
    "headword": "পিনদাউরি",
    "transliteration": "pinodauri",
    "phonetics": "pinɔdauri",
    "etymology": "[< ববাং পিনদা + উরি কুপ্র. নামপদে]",
