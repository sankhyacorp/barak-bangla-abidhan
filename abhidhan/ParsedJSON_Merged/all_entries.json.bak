  {
    "headword": "বরন",
    "transliteration": "boron",
    "phonetics": "bɔrɔn",
    "etymology": "[< ববাং শব্দ বরন]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "বড় আকারের বিষফোঁড়া।",
        "examples": [
          "'পরর কাম পরে করে জুআল দি বরন গালে।’ —বরাকপ্রবাদ"
        ]
      },
      {
        "part_of_speech": "বাগধা. ক্রি.",
        "definition": "দৃষ্টান্তসহ বিস্তারিত বলা। ١",
        "examples": [
          "'লবন পড়িআ মুল্লায় কর দওআইএ ধরতো নায় তিত্কি নজর। পাত্তাত্ লবন লইআ বেরেনচিত বইছে মুল্লায় বুলে আমার কথা Ì বরনাই বরনাই কইছে।' —আনন্দ Ī"
        ]
      }
    ],
