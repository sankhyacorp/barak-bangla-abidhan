  {
    "headword": "ধুমভইল",
    "transliteration": "dhumovoil",
    "phonetics": "dhumɔvɔil",
    "etymology": "[<ববাং শব্দ ধুমভইল]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "পর্ণমোচী বৃক্ষ বিশেষ। বরাক উপত্যকায় এ গাছ প্রচুর জন্মে। বৈজ্ঞানিক নাম— Bombassinsignelora.",
        "examples": [
          "দেখতে প্রায় শিমুল গাছের মতো। পাতার আকৃতি শিমুলের মতো হলে আকারে কিছুটা ছোট। শিমুলের মতো কলা ধরে কিন্তু ভেতরে তুলো থাকে না। উঁচু ৭০-৮০ ফুট পর্যস্ত হয়। বেড়ে ১০-১২ হাত হয়।"
        ]
      }
    ],
    "source_page": "IMG_0213"
  },
