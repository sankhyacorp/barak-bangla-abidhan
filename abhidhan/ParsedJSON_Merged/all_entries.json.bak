        ]
      }
    ],
    "source_page": "IMG_0263"
  },
  {
    "headword": "বাকাল",
    "transliteration": "bakal",
    "phonetics": "bakal",
    "etymology": "[< আঞ্চ. বাকাল]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "বড় আকারের মজবুত বাঁশ বিশেষ।",
        "examples": [
          "ভালুকা বা ভোলকা জাতীয় বাঁশ। বরাক উপত্যকায় বাঁশ বেতের ঘর নির্মাণে খুঁটি, তির, মাড়ইল ইত্যাদি রূপে ব্যবহার করা হয়।"
        ]
