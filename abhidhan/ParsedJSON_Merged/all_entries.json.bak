  {
    "headword": "মটকা",
    "transliteration": "motoka",
    "phonetics": "mɔṭɔka",
    "etymology": "[< বাং মোটা + কা ?]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "মাটির তৈরি পেটমোটা বড় কলসি জাতীয় জলাধার বিশেষ; জালা।",
        "examples": [
          "কলসির চেয়ে অস্তত ছগুণ বড় মাটির জলপাত্র। গ্রীষ্মে ঠাণ্ডা জলের জন্য এর ব্যবহার। তবে এখানে চাল, সর্যে, ডাল প্রভৃতি রাখার জন্যও ব্যবহাত হয় এই পাত্র।"
        ]
      }
    ],
