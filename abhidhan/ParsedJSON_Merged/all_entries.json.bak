  },
  {
    "headword": "টং",
    "transliteration": "tng",
    "phonetics": "ṭŋ",
    "etymology": "[<প্রা. টক্ষ <সং টক্ষ = উচ্চস্থান]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "মাচা উপর ঘর।",
        "examples": [
          "উচুঁ মাচার উপর ঘরটি তৈরি করা হয়। বন্য শৃকর, মোষ প্রভৃতির হাত থেকে শস্যক্ষেত রক্ষার জন্য এই ঘরে বসে পাহারা দেন কৃষকরা।"
        ]
      }
