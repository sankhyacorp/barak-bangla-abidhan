    "phonetics": "fatair kul",
    "etymology": "[< ববাং ফাতাইর ~ কুল (=কোল)]",
    "senses": [
      {
        "raw_text": "[< ববাং ফাতাইর ~ কুল (=কোল)]"
      },
      {
        "part_of_speech": "বি.",
        "definition": "মাথা এক হাতের উপর পায়ের দিক অন্য হাতের উপর রেখে বুকের কাছে নিবিড় করে কোলে লওয়ার রীতি।",
        "examples": [
