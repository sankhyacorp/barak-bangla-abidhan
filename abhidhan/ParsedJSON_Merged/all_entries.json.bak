  {
    "headword": "হটিআ",
    "transliteration": "hotia",
    "phonetics": "ɦɔṭia",
    "etymology": "[<ববাং হটিআ]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "একপ্রকার পর্ণমোচী বৃক্ষ।",
        "examples": [
          "পোমা জাতীয় গাছ। পাতাও পোমার মতো। ৫০- ৬০ ফুট উঁচু হয়। বেড় ৬ হাত পর্যন্ত হয়ে থাকে। বাকল পুরু, চির্চির। কাঠ লাল ও খুব শক্ত। ক্যাপসুল আকারের ফল। এই কাঠ দিয়ে মোটরগাড়ির কাঠামো নির্মাণ করা হয়। বৈজ্ঞানিক নাম— Chikrassia Tabularis."
        ]
      }
    ],
    "source_page": "IMG_0336"
  },
