  {
    "headword": "ধন্নি",
    "transliteration": "dhonni",
    "phonetics": "dhɔnni",
    "etymology": "[< আঞ্চবাং ধরনি < বাং √ধর +নি কৃপ্র. অবলম্বনে]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "সাঁকোর দুপাশের বেড়া বা বেঁধে দেওয়া বাঁশ যা ধরে ধরে পার হতে হয়।",
        "examples": [
          "একগাছুআ পুল ধন্নি না অইলে পারোনি জাইত নায। ধন্নি"
        ]
      },
      {
        "part_of_speech": "বাগধা. ক্রি.",
        "definition": "ভয় দেখিয়ে কার্যোদ্ধার করা।",
        "examples": [
          "হুনো বাছাই, মানে মানে হরি জাও, ইনো ধমকে বগুড়া উড়াইতায় পারতায় নায়।"
        ]
      }
    ],
    "source_page": "IMG_0210"
