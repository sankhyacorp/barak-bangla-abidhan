  {
    "headword": "ছলাকাক",
    "transliteration": "chholakak",
    "phonetics": "c∫hɔlakak",
    "etymology": "[< ববাং শব্দ ছলাকাক]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "বক জাতীয় জলচর বৃহৎ পাখি বিশেষ; সারস পাখি। বিণ. |আলং| — রোগা লম্বা শরীর বিশিষ্ট। ⇒ তোর বউনা তো ছলাকাক আত দি হাগ লাগাল পায়।",
        "examples": [
          "ছলাকাক বিরাট আকৃতির সাদা-ধুসর রঙের পাখি। আকারে বড় শকুনের মতো, গলা খুব লম্বা। দাঁড়ালে মানুষের সমান উঁচু। চাষের জমিতে বা জলা জায়গায় বিচরণ করে। এদের খাদ্য দানা, শাকসবজি, পোকা ও মাছ। ববাক উপত্যকাব আঞ্চলিক বাং"
        ]
      }
    ],
    "source_page": "IMG_0149"
  },
