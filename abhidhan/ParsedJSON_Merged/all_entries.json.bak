  {
    "headword": "বে",
    "transliteration": "be",
    "phonetics": "be",
    "etymology": "[< ফা. উপ. বে নঞর্থে, নিন্দার্থে]",
    "senses": [
      {
        "raw_text": "[< ফা. উপ. বে নঞর্থে, নিন্দার্থে] উ.প্র. — নএবর্থে বা নিন্দার্থে এই উপসর্গীয় প্রত্যয়টি শব্দের আগে বসে নতুন শব্দ গঠন করে। ⇒ বেবুতা বেগুরে বেখলে বেফানা বেঘরো বেগরত বেঠিক বেকামা বেখাইচ্লত্ বেনালো বেতালা লা ভাষার অভিধান ও ভাষাতত্ত S বে"
      }
    ],
    "source_page": "IMG_0278"
  },
  {
    "headword": "বে",
    "transliteration": "be",
    "phonetics": "be",
    "etymology": "[< ববাং ‘বে’ স্ত্রী সম্বোধনে]",
    "senses": [
      {
        "part_of_speech": "অনম্ব.",
        "definition": "সম্বোধনে ‘গো’। > সম্বোধন উপপদ। বাংলা ‘গো’ এর মতো। বাংলা ⇒ কোথায় যাচছ গো? বরাকবাংলা ⇒ কানো জাইতে বে? বরাক উপত্যকার মেয়েরা বা নারীরাই এই সম্বোধন উপপদটি ব্যবহার করে। পুরুষেরা বা ছেলেরা ব্যবহার করে ‘বা’। যেমন ⇒ ‘কানো জাইতায় বা’"
      }
    ],
    "source_page": "IMG_0279"
  },
  {
