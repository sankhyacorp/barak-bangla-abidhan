  {
    "headword": "থুআ",
    "transliteration": "thua",
    "phonetics": "thua",
    "etymology": "[< সং বাস্তুক]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "শীতকালীন অতি উৎকৃষ্ট শাক বিশেষ; বেথোশাক।",
        "examples": [
          "উপাদেয়তা ও পুষ্টিগুণে একে শাকের রাজা বলা হয়। ‘গুল্ম জাতীয় ছোট ছোট গাছ, পাতা তুলসীর পাতার মতো কিন্তু ধারগুলি ঢেউ খেলানো: এগুলিকে বলে ক্ষুদ্র বাস্তৃকী, এর আরেকটি নাম জুরদ্মী বা জুরনাশকারী।’ — চিব আরো নানা ভেষজগুণে সমৃদ্ধ এই শাক। বৈজ্ঞানিক নাম — Cheno podium album linn."
        ]
      }
    ],
    "source_page": "IMG_0268"
  },
