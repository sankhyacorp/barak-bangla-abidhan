        ]
      }
    ],
    "source_page": "IMG_0336"
  },
  {
    "headword": "হদ",
    "transliteration": "hod",
    "phonetics": "ɦɔd",
    "etymology": "[< ববাং হআদ = সুস্বাদ]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "মনের ইচ্ছা; সাধ। ‘মনের স্বাদে’ রূপান্তরিত।",
        "examples": [
          "আমদা টেকা পাইআ তাইন গাড়ি লইতরা বাড়ি বানাইত্রা এখেরে হদ মিটাইলাইতরা।"
        ]
      }
    ],
    "source_page": "IMG_0336"
  },
  {
    "headword": "হদ্দার",
    "transliteration": "hoddar",
    "phonetics": "ɦɔddar",
    "etymology": "[< ববাং শব্দ হদ্দার]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "এক প্রকার রোগ।",
        "examples": [
          "গলা, নাভি বা বুকে প্রথম বেদনাযুক্ত কালো কালো ফুসকুড়ি দেখা দেয়। গলায় হলে ধীরে ধীরে সমস্ত গলা পাঁচিয়ে ফুসকুড়ি ওঠে। ব্যথা বাড়ে।"
        ]
      },
      {
        "part_of_speech": "বি.",
        "definition": "বাহু ও কাঁধের সংযোগস্থল।",
        "examples": [
          "ধানর ভার বইতে বইতে মোর হনাত বিশ।",
          "শ্রীহট্ট অঞ্চলেও শব্দটি একই অর্থে প্রচলিত। রন্নি honni [< ববাঃ ভক রন্নি]"
        ]
      },
      {
        "part_of_speech": "বি.",
        "definition": "বানমারার (দ্র.) সময় ওঝা বা তান্ত্রিক কর্তৃক বেঁধে দেওয়া ‘মৃত্যুর কালসীমা’।",
        "examples": [
          "বান মারার সময় হন্নি করলে লগে লগে উস্তাদর গেছে জাবা লাগে নাইলে রুগি বাচানি জায় না।",
          "বানমারার কালে ওঝা যার ওপর বান মারছে তার মৃত্যুর সময়সীমা বেঁধে দেওয়াকেই বলে ‘হননি’। যেমন— ‘অমুক মঙ্গলবারের দুপুরের মধ্যে মারা যাবে।’"
        ]
      },
      {
        "part_of_speech": "বাগধা. ক্রি.",
        "definition": "বাণ মেরে মৃত্যুর সময় বেঁধে দেওয়া।",
        "examples": [
          "হননি না করায় আবো বেটা মরের না।"
        ]
      }
    ],
    "source_page": "IMG_0336"
  },
