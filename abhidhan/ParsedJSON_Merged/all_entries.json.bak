    "transliteration": "dhefa",
    "phonetics": "ḍhefa",
    "etymology": "[<ডি. ডিডেফা = বন্যার ভরাজল]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "বন্যার জলের স্লোতহীন পরিপূর্ণতা।",
        "examples": [
          "ছনাত (=বন্যাত) পানিব গাঃ নানা একা নািংগ রইছে।",
          "বন্যায় নদীর জল ঢোকে উপনদী বা স্রোতযুক্ত খালের জলকে কিছু সময়ের জন্য স্থির করে দেয়, এই স্থির অবস্থাই ঢেফা।"
        ]
      }
    ],
    "source_page": "IMG_0189"
  },
