  {
    "headword": "কপাল",
    "transliteration": "kopal",
    "phonetics": "kɔpal",
    "etymology": "[<আমবা. কপাল = ভাগ্য < সং কপাল]",
    "senses": [
      {
        "part_of_speech": "বিণ.",
        "definition": "ললাট।",
        "examples": [
          "বইরাগিহকলে কপালো তিলক কাটইন।"
        ]
      },
      {
        "part_of_speech": "বি.",
        "definition": "ভাগ্য। >> আমবা, ‘ বিধি না লিখিত তার কপালের ভাতো’ — কুকী। কপাল কুচ করা — বাগধা. ক্রি. - বিরক্ত হওয়া।",
        "examples": [
          "বাড়িত বাইরা মানু দেখলেউ তাইন কপাল কুচ করইন।"
        ]
      }
    ],
    "source_page": "IMG_0079"
  },
  {
    "headword": "কপালি",
    "transliteration": "kopali",
    "phonetics": "kɔpali",
    "etymology": "[<ববাং কপাল + ই তপ্র. যুক্তার্থে]",
    "senses": [
      {
        "part_of_speech": "বিণ.",
        "definition": "ভাগ্যবান; ধনশালী।",
        "examples": [
