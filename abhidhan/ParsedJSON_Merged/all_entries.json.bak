  {
    "headword": "খুদুনি",
    "transliteration": "khuduni",
    "phonetics": "khuduni",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "খুদের তৈরি পিঠা বিশেষ; রান্না করা খুদ।",
