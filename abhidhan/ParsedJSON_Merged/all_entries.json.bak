  {
    "headword": "বরখত",
    "transliteration": "borokhot",
    "phonetics": "bɔrɔkhɔt",
    "etymology": "[< আ. বরকত = উন্নতি]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "ধান, গম প্রভৃতি শস্যের পুষ্টিগুণের জন্য যে আয় বা উন্নতি হয়।",
        "examples": [
          "ধান সুপুষ্ট হয়ে পাকলে ভাল ও খাদ্যগুণ বিশিষ্ট হয়। এই সুপুষ্ট পাকা ধানে আনুপাতিক হারে চালও হয় বেশি।ভাতও বাড়ে। ফলে কম চালে বেশি কুলায়। এতে যে আয় হয় তারই নাম ‘বরখত’।"
        ]
      }
    ],
    "source_page": "IMG_0257"
  },
