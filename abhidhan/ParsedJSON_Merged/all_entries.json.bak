  {
    "headword": "ডলু",
    "transliteration": "dolu",
    "phonetics": "ḍɔlu",
    "etymology": "[<আঞ্চ. ডলু]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "বাঁশ বিশেষ।",
        "examples": [
          "পাতলা কালচে বাঁশ। ঋজু ও লম্বা হয়। গায়ে চকচকে রোমাবলি থাকে। সৃক্ষ্ম বেত তৈরির আদর্শ বাঁশ। পাকা ডলু দিয়ে ঘরের ভালো ‘রুআ’ হয়। ডলুবাঁশের চুঙ দিয়ে তৈরি হয় প্রসিদ্ধ ‘চুংগাপিঠা’।"
        ]
      }
    ],
    "source_page": "IMG_0179"
  },
