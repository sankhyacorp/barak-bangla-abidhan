  },
  {
    "headword": "টক্",
    "transliteration": "tok",
    "phonetics": "ṭɔk",
    "etymology": "[<ববাং টক্টক্ দ্র.]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "নেশা; অভ্যাস। ধূমপান, চা, পানসুপারি ইত্যাদি খাওয়ার অভ্যাস।",
        "examples": [
          "ভাত খাইআউ তান তামাকু খাইবার টক আছে।"
        ]
      }
    ],
    "source_page": "IMG_0170"
  },
  {
    "headword": "টক্টক্ করা",
    "transliteration": "toktok kora",
    "phonetics": "ṭɔkṭɔk kɔra",
    "etymology": "[<ধ্ব. টক্টক্ = খাওয়ার বা পান করবার ইচ্ছাবোধকা]",
    "senses": [
      {
        "part_of_speech": "সক্রি.",
        "definition": "আসক্তির দরুন পান করার ইচ্ছে হওয়া।",
        "examples": [
          "মোরে ফকির বেটায় কইলা, 'এগ্গু বিড়ি দে বা, বড় টক্টক করের।’"
        ]
      }
    ],
    "source_page": "IMG_0170"
  },
  {
    "headword": "টনটনি",
    "transliteration": "tonotoni",
    "phonetics": "ṭɔnɔṭɔni",
    "etymology": "[<ধ্ব. টন্ টন্ = দ্রুততা সূচক]",
    "senses": [
      {
        "part_of_speech": "ক্রিবিণ.",
        "definition": "অল্প সময় অস্তর অস্তর; ঘন ঘন।",
        "examples": [
          "তাই বরি দি টনটনি পুটি লাগারি।"
        ]
      },
      {
        "part_of_speech": "ক্রিবিণ.",
        "definition": "ক্ষিপ্রতার সঙ্গে।",
        "examples": [
          "ইটগুইন এগগু এগগু করি টনটনি ধইআ তুল। <mark>টক্কর</mark> ṭɔkkɔr [<হি. টক্র = ধাকা]"
        ]
      },
      {
        "part_of_speech": "বি.",
        "definition": "প্রতিযোগিতা।",
        "examples": [
          "দুই মিত্তার মাজে ঢুলক বাজানির টক্কর অয়।"
        ]
      }
    ],
    "source_page": "IMG_0170"
  },
  {
