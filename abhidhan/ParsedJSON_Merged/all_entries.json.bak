  {
    "headword": "বাজুমারা",
    "transliteration": "bajumara",
    "phonetics": "baʒumara",
    "etymology": "[< ববাং বাজু (<ফা. বাজু = বাহু, পক্ষ) = পার্শ ~ ববাং √ মার্ + আ কৃপ্র.]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "পক্ষাঘাত রোগ; Paralysis।",
        "examples": [
