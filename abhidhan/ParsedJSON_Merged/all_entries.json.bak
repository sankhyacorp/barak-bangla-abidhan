  {
    "headword": "টাকা",
    "transliteration": "taka",
    "phonetics": "ṭaka",
    "etymology": "[<ইং. tuck = পটি সেলাই করা]",
    "senses": [
      {
        "raw_text": "[<ইং. tuck = পটি সেলাই করা] ক্রি..— সেলাই দিয়ে বা বেঁধে আটকানো। ⇒ পইলা কুনুমতে টাকিছি বাদে সিলাই করমু। ⇒ শব্দটি সং টিক্ক’ (= বন্ধনে) থেকেও আসতে পারে।"
      }
    ],
    "source_page": "IMG_0171"
  },
  {
    "headword": "টাকি",
    "transliteration": "taki",
    "phonetics": "ṭaki",
    "etymology": "[< দেশি. টাক + ই তপ্র. যুক্তার্থে]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "ছাগলের চর্মরোগ বিশ্রেষ।",
        "examples": [
          "এই রোগ হলে ছাগলের সমস্ত শরীরের লোম ঝরে পড়ে ঠিক টাক পড়ার মতন। তাই এই রোগের নাম টাকি। লোমপড়া জায়গা অনেক সময় ঘা হয়।"
        ]
      }
    ],
    "source_page": "IMG_0171"
  },
  {
