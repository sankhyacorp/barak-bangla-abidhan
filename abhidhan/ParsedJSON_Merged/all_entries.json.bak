  {
    "headword": "পেড়া",
    "transliteration": "pedo়a",
    "phonetics": "peḍɔ়a",
    "etymology": "[< বাং পেড়া = ক্ষীরের সন্দেশ]",
    "senses": [
      {
        "part_of_speech": "বিণ.",
        "definition": "বেশি সেদ্ধ হওয়ার ফলে নরম হয়ে গেছে এমন; গলে গেছে এমন।",
        "examples": [
          "পেড়া ভাত।"
        ]
      },
      {
        "part_of_speech": "বিণ.",
        "definition": "পচে যাওয়া ধানগাছ মাড়িয়ে নেওয়ার ফলে খড়গুলো মজে একেবারে দলা পাকিয়ে গেছে এমন।",
        "examples": [
          "হিজা মুইটর মাড়া পেড়া অইবউ।",
          "অর্থসংক্রমের ফলে ক্ষীরের মিঠাই ‘পেড়া’র মধ্যে নিহিত ‘ক্ষীরের তরল ঘন’ অবস্থাই শব্দটির ব্যঞ্জনায় প্রাধান্য পেয়েছে।"
        ]
      }
    ],
    "source_page": "IMG_0241"
  },
