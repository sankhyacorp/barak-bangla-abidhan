  {
    "headword": "করটে",
    "transliteration": "korote",
    "phonetics": "kɔrɔṭe",
    "etymology": "[<ববাং কর + টে]",
    "senses": [
      {
        "raw_text": "[<ববাং কর + টে] অনু. — দিকে; পানে। ⇒ 'এও খানো না পাইলা গংগা মাইর উদ্দেশ, পছিম করটে ভগিরথ গেলা জে চলিআ।’ বগী ক্রিবিণ. অনু — পেছন দিকে।"
      }
    ],
    "source_page": "IMG_0081"
  },
  {
