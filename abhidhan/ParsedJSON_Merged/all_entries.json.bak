    "phonetics": "anɔʒani",
    "etymology": "[<চাক. আজানাহ্ = চেঁছে ফেলা]",
    "senses": [
      {
        "part_of_speech": "ক্রি.",
        "definition": "বেগুন কচু মাছ প্রভৃতি ফালি ফালি করে কাটা।",
        "examples": [
