  {
    "headword": "কন্নি",
    "transliteration": "konni",
    "phonetics": "kɔnni",
    "etymology": "[<সং কর্ণিক = রাজমিস্ত্রিদের হাতিয়ার বিশেষ]",
    "senses": [
