  {
    "headword": "কালিউরি",
    "transliteration": "kaliuri",
    "phonetics": "kaliuri",
    "etymology": "[< ববাং শব্দ কালিউরি]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "কপালের উভয় দিকের শিরা বা রগ। লা <mark>ভাষা</mark>র অভিধান ও ভাষাতত্ত্ব ъ কালিগদা ⇒ কালিউরি বই গেলে (=বসে গেলে) মানু বাচইন না।"
      }
