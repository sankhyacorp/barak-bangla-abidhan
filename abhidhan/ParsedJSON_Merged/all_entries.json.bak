    "etymology": "[< আঞ্চ. পিড়িআ < সং পীটিকা]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "কাঠের তৈরি বসবার নিচু আসন; পিঁড়ি।",
        "examples": [
          "আমরা পিড়াত বইআ খাই।"
        ]
      },
      {
        "part_of_speech": "বি.",
        "definition": "পাত্র বসাবার জন্য উনুনের তিনদিকে যে গোলাকার মাটির পিশু করা হয়।",
        "examples": [
          "ইট দি চুলার পিড়া বানাইলে বেশ দিন জায়।"
        ]
      }
    ],
