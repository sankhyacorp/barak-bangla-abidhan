  {
    "headword": "সাতরাংগি",
    "transliteration": "satoranggi",
    "phonetics": "satɔraŋgi",
    "etymology": "[< ববাং শব্দ সাতরাংগি]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "প্রস্রাব সংক্রান্ত একপ্রকারের রোগ।",
        "examples": [
          "সাধারণত যুবকযুবতীদের এই রোগ বেশি হয়ে থাকে।এ রোগ হলে প্রস্রাবের বেগ থাকা সত্ত্বেও অল্প অল্প করে বার বার পেচ্ছাব হয়। লিঙ্গদেশে ব্যথাও হয়। পেচ্ছাবের রং থাকে হলুদবর্ণ। প্রস্রাবের সময় যন্ত্রণা অনুভূত হয়।এ রোগের প্রচলিত নাম মূত্রাঘাত"
        ]
      }
    ],
    "source_page": "IMG_0332"
  },
