  {
    "headword": "ফাই",
    "transliteration": "fai",
    "phonetics": "fai",
    "etymology": "[< ববাং শব্দ ফাই]",
    "senses": [
      {
        "part_of_speech": "বিণ.",
        "definition": "অনেক; প্রচুর। ,",
        "examples": [
          "গিআ দেখি হিনো ফাই মানু জমছইন। , ফাই<sub>s</sub> fai [< ববাং শব্দ ফাই]"
        ]
      },
      {
        "part_of_speech": "বি.",
        "definition": "পশু পাখি ধরার ফাঁদ বিশেষ।",
        "examples": [
          "নারিকেলের তন্তুর দড়ি বা শক্ত সূতার তৈরি ছিদ্রযুক্ত ফাঁদ। ফাঁদটি গাছ বা মাটির সঙ্গে শক্ত বাঁশের ছোট ছোট খুঁটি বা লোহার শিক দিরে আটকানো থাকে। এতে নানারকম প্যাঁচ ও গিঁট দেওয়া থাকে। এটি দিয়ে ডাহুক, বনমোরগ, বরু প্রভৃতি পাখি এবং সজারু, হরিণ, বুনোছাগল - খরগোশ, উদ প্রভৃতি পশু শিকার করা হয়। ব্গংডেংব্রা faŭra [< প্রা. পাস্সরঅ = বিস্তৃত হওয়া]"
        ]
      },
      {
        "part_of_speech": "ক্রি.",
        "definition": "বিস্মৃত হওয়া।",
        "examples": [
          "শ্ক্রবালাত কথা পাউতা জাগ্রিন ?"
        ]
      }
    ],
    "source_page": "IMG_0243"
  },
