  {
    "headword": "উনদাল",
    "transliteration": "unodal",
    "phonetics": "unɔdal",
    "etymology": "[<প্রা. আন্দেউর]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "রান্নাঘর; বাড়ির যে অংশে স্ত্রীলোকেরা থাকেন।",
        "examples": [
          "একজাতর বেটাইন আছইন জেছার বাড়িত গিআউ রুবিলা উনদালো হুমাইজাইন। >> সং অন্তঃপুর > প্রা. অন্তেউর, অন্দেউর েষেমন ⇒ শকুন্তলা = শউন্দলা ‘হলা শউন্দলে’) বরাকবাংলায় লকারীভবনে অন্দেউল > উনদাল। ‘রস্কনশালা’ শব্দটির প্রভাব থাকা বিচিত্র নয়।"
        ]
      }
    ],
    "source_page": "IMG_0068"
  },
