  {
    "headword": "পানচাল",
    "transliteration": "panochal",
    "phonetics": "panɔc∫al",
    "etymology": "[<বাং পান ~ ছাল]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "একপ্রকার বনজ বৃক্ষ। ঘষলে সাবানের মতো ফেনা উৎপন্ন হয়। ছোট ছোট গুচ্ছবদ্ধ ফল ধরে। গামারির মতো কাঠ।",
        "examples": [
          "৫০ ফুট পর্যন্ত উঁচু হয় এই গাছ। চক্রপরিধি ৫ হাত। ৬-৭ ইঞ্চি লম্বা পাতা। পাতা জলে ফেলে"
        ]
      }
    ],
    "source_page": "IMG_0231"
  },
  {
    "headword": "পান্জনি",
    "transliteration": "panjoni",
    "phonetics": "panʒɔni",
    "etymology": "[< আঞ্চ. বাং পানযনি = পায়ে পরবার গহনা]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "ঝাঁঝর জাতীয় বাদ্যযন্ত্র।",
        "examples": [
          "কাঁসা বা পেতলের ঝুমিঝুমি। গোলাকার ফাঁপা মলের মতে এই যন্ত্রটির ভেতর কড়াই বা গুটি দেওয়া থাকে। ঝম্ঝম্ ঝর্ঝর্ শব্দে বাজে। বাদ্যযন্ত্রটি অতি প্রাচীনকাল থেকে বরাক উপত্যকায় ওঝাগানে ব্যবহৃত হয়ে আসছে।"
        ]
      }
    ],
    "source_page": "IMG_0231"
  },
  {
    "headword": "পানি আইক",
    "transliteration": "pani aik",
    "phonetics": "pani aik",
    "etymology": "[< বাং পানি (=জল) + ববাং অাইক (=গাঁট)]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "গোড়ালির গ্রন্থি; Ankle।",
        "examples": [
          "Joint connecting the foot with the leg.",
          "‘গতবার দেখলাম নাতিনর জামাত কুচিকুচি দেবা পানি আকির লামাত কইলি ঠাকুমা কিলা লাগে? কইলাম — পদ্দোপুরানোর উঝায় লাগাইতা আগে।’—আনন্দ"
        ]
      },
      {
        "part_of_speech": "বাগধা. ক্রি.",
        "definition": "জল কমে আসা। (আলং) — ধন হ্রাস পাওয়া।",
        "examples": [
          "পানি আটিলে হকলউ শাইর (এখানে ‘হিসেবি’) অইন।"
        ]
      }
    ],
    "source_page": "IMG_0231"
  },
  {
    "headword": "পানিকচু",
    "transliteration": "panikochu",
    "phonetics": "panikɔc∫u",
    "etymology": "[< বাং পানি ~ কচু]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "মাঝারি আকৃতির কচু বিশেষ।",
        "examples": [
          "জলা জায়গায় ফলে। এর বাগু লতি কন্দ তরকারি হিসেবে ব্যবহৃত হয়। গেঁড় দীর্ঘ হয়।"
        ]
      },
      {
        "part_of_speech": "বাগধা. বি.",
        "definition": "প্রাথমিক কাজ; প্রাথমিক খরচ।",
        "examples": [
          "ই টেকায় হরাদোর পানিকানজিউ ধরতো নায়।"
