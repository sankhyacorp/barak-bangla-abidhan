  {
    "headword": "নাল",
    "transliteration": "nal",
    "phonetics": "nal",
    "etymology": "[< তা. নাণল = নল খাগড়া]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "শাড়ির পাড়ের সূতা; কাপড়ের সূতা; সূতা। স্বভাবের যে সাযুজ্য রয়েছে তা থেকেও সূতার ব্যঞ্জনা আসতে পারে।",
        "examples": [
          "কামা (=পাড়) তনে নাল বার করি গুনডিলা বল।"
        ]
      },
      {
        "part_of_speech": "বি.",
        "definition": "গাছি।",
        "examples": [
          "ফুতার নালদি বেরা। নাল<sub>্</sub> nal [< আমবা. নাল দ্র. নালে]"
        ]
      },
      {
        "part_of_speech": "বি.",
        "definition": "ধারা। নানু nal [< প্র. নান্ঽ]",
        "examples": [
          "গাইর বান বড় এরলাগি দুদর নালও বড়।"
        ]
      },
      {
        "part_of_speech": "বিণ.",
        "definition": "সোজা।",
        "examples": [
          "নাল অইআ ফ।"
        ]
      },
      {
        "part_of_speech": "বিণ.",
        "definition": "শয্যাশায়ী।",
        "examples": [
          "‘হে বেটা আইজ নাল, কিতা করবো বেমার কাল।’—আনন্দ"
        ]
      }
    ],
    "source_page": "IMG_0218"
  },
