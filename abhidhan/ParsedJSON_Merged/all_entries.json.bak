        ]
      }
    ],
    "source_page": "IMG_0256"
  },
  {
    "headword": "বনরউ",
    "transliteration": "bonorou",
    "phonetics": "bɔnɔrɔu",
    "etymology": "[< সং বন + ববাং রউ = রুইমাছ]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "শক্ত খোলসযুক্ত চতুষ্পদ বন্য প্রাণী বিশেষ; বজ্রকীট; পিপীলিকাভুক; Pangolin. নিজের শরীর গুটিয়ে একটা বলের মতো করে নেয় আর মাথাটা ঢুকিয়ে ফেলে নরম পেটের মধ্যে। ঝোপঝাড়ের লুকনো সুড়ঙ্গের মধ্যে এদের বাস। এদের মুখ আকারে ছোট এবং চোয়ালে কোনও দাঁত নেই। এরা পাঞ্জা ও ল্যাজের সাহায্যেই গাছে ওঠে। মাটিতে চলে ধীরে ধীরে। এদের একসঙ্গে একটা বা দুটো বাচ্চা হয়। বাচ্চারা মায়র দুধ খায় আর মা- প্যাঙ্গোলিন বাচ্চাদের ল্যাজের ওপর বসিয়ে রাখে।’ — সাধনা মুখোপাধ্যায় এদের প্রধান খাদ্য উইপোকা ও পিঁপড়া। বরাক উপত্যকার জঙ্গলে ও উত্তরকাছাড়ে প্রচুর বনরউ বা প্যাঙ্গোলিনের বসবাস। বনরউয়ের আঁশ ও মাংসের জন্য শিকারিরা এদের শিকার করে। ফলে এই বিরল প্রাণীটির সংখ্যা দ্রুত কমছে। এর আঁশ দিয়ে হাড়ের ব্যথা ও বাতরোগের টোটকা চিকিৎসা করা হয়। ⇒ রুই (= রউ) মাছের মতো আঁশ আছে বলেই এই নাম।",
        "examples": [
          "‘দু ফুট লম্বা এই প্রাণীর আছে লম্বাটে এবং ক্রমশ সরু হয়ে যাওয়া ল্যাজ। আছে নাক আর লম্বা জিভ। ভারিকানিত্তত ভির্ঠ, কাথ, কান, ভা আত ন্যাং জ তিনকোনা আঁশে ঢাকা থাকে। সামান্যতম বিপদের আশঙ্কাতেই বা সামান্যতম বাধা পেলে প্যাঙ্গোলিন বরাক উপত্যকার আঞ্চ লিক বাংল"
        ]
      }
    ],
    "source_page": "IMG_0256"
  },
  {
    "headword": "বনা",
    "transliteration": "bona",
    "phonetics": "bɔna",
    "etymology": "[< বাং √ বন + আ]",
    "senses": [
      {
        "part_of_speech": "ক্রি.",
        "definition": "মিল হওয়া।",
        "examples": [
          "খুড়ার লগে মোর বনে না।"
        ]
      },
      {
        "part_of_speech": "ক্রি.",
        "definition": "বিবাহাদিতে যোটক বিচারে পাত্রপাত্রীতে মিল হওয়া।",
        "examples": [
          "গনকে গনিআ কইছইন ই পুআর লগে মোর বড় পুড়ির কুশঠি বনে না।",
          "জ্যোতিষশাস্ত্র মতে বিবাহাদিতে বর-কন্যার জন্মলগ্ন, রাশি ইত্যাদির শুভফলদায়ক মিল হওয়া। জন্মরাশি ইত্যাদি বিচার করে এই মিল স্থির করা হয়।"
        ]
      }
    ],
    "source_page": "IMG_0256"
  },
  {
    "headword": "বনাক",
    "transliteration": "bonak",
    "phonetics": "bɔnak",
    "etymology": "[<আঞ্চ. বাং বনাক]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "একপ্রকার চিরসবুজ বৃক্ষ।",
        "examples": [
          "ঋজু গাছ। ৭০ থেকে ৮০ ফুট উঁচু হয়। বেড় পাঁচ হাত পর্যস্ত। শালপাতার মতো পাতা হলেও কিছুটা গোলাকার ও বড়। গাছটির বাকল পুরু ও ফাটা ফাটা। রং মেটে। কুড়া বা শুং আছে। কাঠের রং লাল। বৈজ্ঞানিক নাম— Schima Wallichii."
        ]
      }
    ],
    "source_page": "IMG_0256"
  },
  {
    "headword": "বনাজি",
    "transliteration": "bonaji",
    "phonetics": "bɔnaʒi",
    "etymology": "[< বাং বনজ/বনজাত]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "আয়ুর্বেদ চিকিৎসা; গাছগাছড়া থেকে তৈরি ঔষধ।",
        "examples": [
          "হকলতা বাদ দিআ এলকু বনাজি করাইআর।"
        ]
      }
    ],
    "source_page": "IMG_0256"
  },
  {
    "headword": "বনালু",
    "transliteration": "bonalu",
    "phonetics": "bɔnalu",
    "etymology": "[< বাং বন + আলু।]",
    "senses": [
      {
        "raw_text": "[< বাং বন + আলু।] লা ভাষার অভিধান ও ভাষাতত্ত্ব . . . . ."
      },
      {
        "part_of_speech": "বি.",
        "definition": "বন্য আলুর লতা বা আলু।",
        "examples": [
          "বন্য আলুর গাছ গুল্ম নয়—লতাগাছ। নিচে বৃহৎ আকারের কালো রঙের আলু ধরে। আলুর ভেতর সাদা ধবধবে। এক একটি আলু ৩ থেকে ৬ কেজি পর্যন্ত হয়। খেতে সুস্বাদু ও খাদ্যগুণ বিশিষ্ট। নিরামিষ আমিষ সবরকম ব্যঞ্জনে খাওয়া যায়।"
        ]
      }
    ],
    "source_page": "IMG_0256"
  },
  {
    "headword": "বনি",
    "transliteration": "boni",
    "phonetics": "bɔni",
    "etymology": "[< বাং বউন স্বরধ্বনি লোপে < সং বর্ধনী]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "পণ্যের বেচাকেনার শুভ সূচনা স্বরূপ সবার আগে লওয়া নগদ মূল্য; প্রথম শুভ বিক্রয়।",
        "examples": [
          "বনি অইসে না, এলকু বাকি দিতাম নায়।"
        ]
      }
    ],
    "source_page": "IMG_0257"
  },
  {
    "headword": "বনুআতুলসি",
    "transliteration": "bonuatulosi",
    "phonetics": "bɔnuatulɔsi",
    "etymology": "[< ববাং বনুআ (= বনজ) ~ সং তুলসী]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "বনজ তুলসী গাছ।",
        "examples": [
          "‘প্রচুর শাখাযুক্ত বীরুৎ জাতীয় গাছ। কাগু ও পাতায় নক্ষত্রাকৃতি রোম থাকে। পাতা সরল, ২.৫ থেকে ৬ সেমি. লম্বা, ভল্লাকৃতি, কিনারা দন্তুর। ফলকের নীচের দিকে তিনটি শিরা থাকে। বোঁটা ছোট, ফুল একলিঙ্গ। রেসিম পুষ্পবিন্যাসে উপরের দিকে পুংপুষ্প এবং নীচের দিকে স্ত্রীপুষ্প থাকে। ফল ত্রিশিরাযুক্ত উপবৃত্তাকার।’ – নলিনীকাস্ত চক্রবর্তী বড় আল-জাংগাল বা পতিত জমিতে দেখা যায়।"
        ]
      }
    ],
    "source_page": "IMG_0257"
  },
