  {
    "headword": "গোড়জাল",
    "transliteration": "godo়jal",
    "phonetics": "goḍɔ়ʒal",
    "etymology": "[< বাং গোড়া ~ জাল]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "থলিযুক্ত মাছধরার জাল বিশেষ।",
        "examples": [
          "৪০০ হাত দীর্ঘ দরার (দড়ি) মাঝখানে ২০ হাত থলিযুক্ত জাল। তিনজন লোক একটি নৌকা দিয়ে এই জাল বায়। এ জাল দিয়ে ছোট-বড় সবরকমের মাছ ও কচ্ছপ ধরা হয়। ঘ ঘটghɔṭ [<বাং ঘট = ছোট কলস বিশেষ]"
        ]
      },
      {
        "part_of_speech": "বি.",
        "definition": "যে ঘটকে বা ছোট কলসকে দেববিগ্রহ রূপে কল্পনা করে পূজা করা হয়।",
        "examples": [
          "টেকাপইশা নাই, ইবার বিশরির ঘট বওআইআ পূজা করমু।"
        ]
      }
    ],
    "source_page": "IMG_0129"
  },
