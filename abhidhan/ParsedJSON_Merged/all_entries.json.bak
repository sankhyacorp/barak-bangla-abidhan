  {
    "headword": "বিজলাউনি",
    "transliteration": "bijolauni",
    "phonetics": "biʒɔlauni",
    "etymology": "[< ববাং বিজল + উনি তথ পরিপূর্ণ অর্থো বিণ. — বিজলপূর্ণ; পিচ্ছিল রসযুক্ত। ⇒ বিজলাউনি পানি ফালাইআ ভালা পানি ভর। বিজানা bij3ala [< উ.শ্র. বি + জ্যানা]",
    "senses": [
      {
        "part_of_speech": "বিণ.",
        "definition": "বিজলপূর্ণ; পিচ্ছিল রসযুক্ত।",
        "examples": [
          "বিজলাউনি পানি ফালাইআ ভালা পানি ভর। বিজানা bij3ala [< উ.শ্র. বি + জ্যানা]"
        ]
      },
      {
        "part_of_speech": "বি.",
        "definition": "শিশুদের উৎপাত।",
        "examples": [
          "হরুতা ইতায় কামর সময় বিজালা করইন।"
        ]
      },
      {
        "part_of_speech": "বি.",
        "definition": "বিরক্তি উৎপাদন।",
        "examples": [
          "ছকইন পুড়িআ দিসি, খাও তে খাও, এম্মা বিজানা কতি অ না।"
        ]
      }
    ],
    "source_page": "IMG_0273"
  },
