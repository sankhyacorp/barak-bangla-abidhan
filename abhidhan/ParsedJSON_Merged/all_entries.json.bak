  },
  {
    "headword": "ভূআরা",
    "transliteration": "vuara",
    "phonetics": "vuara",
    "etymology": "[< ববাং শব্দ ভূআরা]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "বৃক্ষ বিশেষ।",
        "examples": [
          "পাতা গামারির মতো। আকারে সামান্য ছোট। সাদা-কালো-লালে চিত্রিত বাকল। ফল সবুজ পাকলে মেটে। কাঠ সাদা।"
        ]
      }
    ],
    "source_page": "IMG_0288"
  },
  {
    "headword": "ভূআরা",
    "transliteration": "vuara",
    "phonetics": "vuara",
    "etymology": "[<ববাং শব্দ ভূআরা]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "একপ্রকার চিরসবুজ বৃক্ষ।",
        "examples": [
          "৪০-৫০ ফুট দীর্ঘ ৬ হাত বেড়ের এই গাছ শাখাপ্রশাখায় নিবিড়-সুন্দর হয়ে থাকে। পানের মতো গোল গোল পাতা। ছোট ছোট ফুল। কাঠ ঈষৎ হলুদ রঙের। এই গাছের অন্য নাম ‘বিজলি’।"
        ]
      }
    ],
    "source_page": "IMG_0288"
  },
  {
    "headword": "ভূইতুলা",
    "transliteration": "vuitula",
    "phonetics": "vuitula",
    "etymology": "[< প্রা. ভুঁই < সং ভূমি + তুলা]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "বীরুৎ জাতীয় উদ্ভিদ বিশেষ। ٩ ভুবি ক্যাপসূল আকৃতির ফুলের কলি। ফুল ফুটলে ফুলের আঁশ-তুলোর মতো বাতাসে ওড়ে। ফুল সাদা হলেও আঁশের অগ্রভাগ লাল। সবজিখেতে, পতিত জমিতে এই গাছ জন্ম।",
        "examples": [
          "হালকা সবুজ রঙের নরম কাণ্ড। পাতা নরম ও ভূহতুল দন্তুর। দেড় হাত উঁচু হয়।"
        ]
      }
    ],
    "source_page": "IMG_0288"
  },
  {
