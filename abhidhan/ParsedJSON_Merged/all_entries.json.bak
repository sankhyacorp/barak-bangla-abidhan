  {
    "headword": "টেকই",
    "transliteration": "tekoi",
    "phonetics": "ṭekɔi",
    "etymology": "[<ববাং শব্দ টেকই]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "টুনটুনি পাখি; Tailor Bird. ওদের খাদ্য কীটপতঙ্গ। ওরা তুলা দিয়ে সূতা তৈরি করে, গিঁটও দিতে পারে।",
        "examples": [
          "জলপাই-সবুজ ছোট পাখি। শরীরের নীচের অংশ সাদা, মাথা লালচে। কাঁটা মতো পালকযুক্ত খাড়া লেজ। ঝোপেঝাড়ে ঘুরে বেড়ায়। টুইট-টুইট্ ডাকে।"
        ]
      }
    ],
    "source_page": "IMG_0174"
  },
  {
    "headword": "টেকনি",
    "transliteration": "tekoni",
    "phonetics": "ṭekɔni",
    "etymology": "[<আঞ্চ. ঠেকনা অল্পপ্রাণিতে]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "ঠেকিয়ে রাখবার জন্য ব্যবহৃত দড়ির গাঁট; ঠেকিয়ে রাখবার জন্য ব্যবহৃত কাঠের দণ্ড।"
      },
      {
        "part_of_speech": "বাগধা. ক্রি.",
        "definition": "আকার ইঙ্গিতে উদ্দেশ্য অনুমান করা; মুখের কথা শোনে ভেতরের কথা বুঝতে পারা; হাবভাবে মনোভাব বোঝা।",
        "examples": [
          "বছাইবুড়ায় টে কইতে টেংরা বুঝতো পারে।"
        ]
      }
    ],
    "source_page": "IMG_0175"
  },
  {
    "headword": "টেকর",
    "transliteration": "tekor",
    "phonetics": "ṭekɔr",
    "etymology": "[< বাং ঠোকর]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "হাতের আঙুলের পিঠ দিয়ে জোরে আঘাত।",
        "examples": [
          "'টেকর' সাধারণত মাথায় মারা হয়। চুলোচুলির মতো টেকর মারার প্রচলন মেয়েদের মধ্যেই বেশি।",
          "উকইন চাবাত গিআ তুড়া লড়িলেউ তাই টেকর মারে।"
        ]
      }
    ],
    "source_page": "IMG_0175"
  },
  {
