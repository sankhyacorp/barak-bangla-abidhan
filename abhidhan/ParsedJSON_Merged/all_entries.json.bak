  {
    "headword": "তিলকই",
    "transliteration": "tilokoi",
    "phonetics": "tilɔkɔi",
    "etymology": "[<ববাং শব্দ তিলকই]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "সরীসৃপ জাতীয় প্রাণী বিশেষ; একরকমের গোসাপ।",
        "examples": [
          "আগে বরাক উপত্যকার জঙ্গলাকীর্ণ স্থানে ঘড়িয়াল বা গোসাপের মতো আঁশহীন সরীসূপ দেখা যেত। এরা ফোঁস্ ফোঁস্ করে আওয়াজ করত। এদেরই বলা হত তিলকই। অনেকের ধারণা, এটি ছিল গোসাপের বৃহদাকার প্রজাতি বিশেষ। কারো মতে এটি প্রাগৈতিহাসিক সরীস্পের বংশধর।"
        ]
      }
    ],
    "source_page": "IMG_0196"
  },
