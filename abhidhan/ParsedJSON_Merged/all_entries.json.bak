  {
    "headword": "ফুত",
    "transliteration": "fut",
    "phonetics": "fut",
    "etymology": "[< সং ম্রোত = জল প্রবাহ]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "জলপ্রবাহ।",
        "examples": [
          "উজানে মেঘ দেবায় গাংগো অলা ফুত্। সং স্রোত র-কার লোপ ও উ-কার প্রবণতায় ‘সূত’ উদ্মীভবনে বরাকবাংলায় ‘ফুত’।"
        ]
      },
      {
        "part_of_speech": "বিণ.",
        "definition": "স্রোতের শেওলার মতো অবলম্বনহীন। \\Rightarrow মা-বাফ নাই, ফুতর হেওলা অইআ ভাইআ জাইআর।"
      }
    ],
