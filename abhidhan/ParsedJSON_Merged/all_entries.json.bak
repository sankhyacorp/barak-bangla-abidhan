  {
    "headword": "ইস্রাং",
    "transliteration": "israng",
    "phonetics": "israŋ",
    "etymology": "[<ববাং শব্দ ইসরাং]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "ইক্ষুর রস নিংড়ানোর পর যে রসহীন অংশ থাকে; গরম ইক্ষুরসে মাখা রসহীন ইক্ষুর পরিত্যক্ত অংশ। ইক্ষুর রস নিংড়ানোর পর যে রসহীন অংশ থাকে, তাই ইক্ষুরস জ্বাল দিয়ে গুড় বানানোর সময় ওই রসে ডুবিয়ে নেওয়া হয়। একে ‘ইসরাং’ বলে। এই তপ্তরসে মাখা ‘ইসরাং’ চুষে খাওয়া হয়। বড় মিষ্টি লাগে। উ T 🖥 u অপ্র.— নিশ্চয়তা বোঝাতে ‘উ’ অনুসর্গীয় প্রত্যয় ক্রপে ব্যবহাত হয়। উ",
        "examples": [
          "জত বিপদ আউক হি জাইবউ। —‘একমাত্র’ অর্থে।",
          "আমিউ তুমার লগে আসলাম। — আধিক্য' বোঝাতে Ĭ",
          "জতউ ফাললাও জিত্তায় পারতায় নায়।"
        ]
      }
    ],
    "source_page": "IMG_0064"
  },
