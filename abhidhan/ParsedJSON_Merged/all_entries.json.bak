  {
    "headword": "চুল",
    "transliteration": "chul",
    "phonetics": "c∫ul",
    "etymology": "[<ক. দোলু = আনদ্ধ বাদ্য]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "গাছের পাতা দিয়ে বানানো গেছো পিঁপড়ার বাসা।",
        "examples": [
          "আনদ্ধবাদ্য ঢুলের মতো দেখতে বলেই এরূপ পিঁপড়ার বাসাকে ‘ঢুল’ বলা হয়। রামডালা গাছে এরূপ ঢুল বেশি দেখা যায়।"
        ]
      },
      {
        "part_of_speech": "বি.",
        "definition": "দুদিকে চামড়া দিয়ে আচ্ছাদিত বড় আকারের বাদ্যযন্ত্র বিশেষ।"
      }
    ],
