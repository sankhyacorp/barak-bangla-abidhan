        "examples": [
          "দেখাত ঝুটিমুটি, বেটার ভিতরে মাল (= জ্ঞান) আছে।"
        ]
      }
    ],
    "source_page": "IMG_0168"
  },
  {
    "headword": "ঝুপ্পুত",
    "transliteration": "jhupput",
    "phonetics": "ʒhupput",
    "etymology": "[< ধ্ব. ঝুপ্ = জলে ঝাঁপানোর আওয়াজ]",
    "senses": [
