  {
    "headword": "আরা",
    "transliteration": "ara",
    "phonetics": "ara",
    "etymology": "[<ববাং তদ্ধিতপ্রত্যয় দেখ]",
    "senses": [
      {
        "raw_text": "[<ববাং তদ্ধিতপ্রত্যয় দেখ] তপ্র.— ‘যুক্ত’ বা ‘আছে’ অর্থে। দ্র. তদ্ধিতপ্রত্যয় (ভাষাতত্ত্ব)। ⇒ গুড়িআরা চামগাছ। গাটিআরা মানুশ।"
      }
    ],
    "source_page": "IMG_0058"
  },
  {
    "headword": "আরি",
    "transliteration": "ari",
    "phonetics": "ari",
    "etymology": "[< উর্দু আরি = ছোট করাত]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "কাঠমিস্ত্রিদের করাত; HAND SAW.",
        "examples": [
          "'আরি' নানা রকমের। গাছ চেরার বড় আরি। গাছ টুকরো করার টানা আরি।"
        ]
      }
    ],
    "source_page": "IMG_0058"
  },
  {
    "headword": "আরি",
    "transliteration": "ari",
    "phonetics": "ari",
    "etymology": "[< মবা. আহীরী সংকোচনে]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "প্রতিবেশী; পাড়ার লোক।",
        "examples": [
          "দ্র. আরিপরি। >> মবা. দৃ. ‘আহীরী রমণী হাসে দাঁড়াইয়া চারিপাশে হয় নয় দেখ সুধাইয়া।’ —বলরাম দাস"
        ]
      }
    ],
    "source_page": "IMG_0058"
  },
  {
    "headword": "অরিপরি",
    "transliteration": "oripori",
    "phonetics": "ɔripɔri",
    "senses": [
      {
        "raw_text": "[<বাং পড়শি অনুকারে < সং প্রতিবেশী। ⇒ আরিপরির লগে কাজিআপশাদ করিও না, ডাকর কুটুম তারাউ। কাং পড়শি অনুকারে আড়শিপড়শি > ববাং আরিপরি। দ্র. আরি।"
      }
    ],
    "source_page": "IMG_0058"
  },
  {
    "headword": "রুৱাকরি",
    "transliteration": "ruৱakori",
    "phonetics": "ruৱakɔri",
    "senses": [
      {
        "raw_text": "[< ফা. আরাকশ (= করাতিয়া) + ই তপ্র. স্বার্থে ির— যারা করাত দিয়ে গাছ চিরে তক্তা ইত্যাদি তৈরি করে; করাতি।"
      }
    ],
    "source_page": "IMG_0058"
  },
  {
    "headword": "আরোআল",
    "transliteration": "aroal",
    "phonetics": "aroal",
    "etymology": "[<প্রাবা. রাখোয়াল]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "রক্ষণাবেক্ষণ করে যে; তত্ত্বাবধায়ক; Caretaker",
        "examples": [
          "পুননা রাজবাড়ির আরোআল নাই-গতিকে ভাংগি ভাংগি পড়ের। সং রক্ষাপাল > প্রা. রক্খাআল > ভ্রং রক্খআল > প্রাবা. রাখোয়াল বিপর্যাসে ‘খারোয়াল’। আদি ব্যঞ্জনলোপে বরাক বাংলায় দাঁডিয়েছে ‘আরোআল’।"
        ]
      }
    ],
    "source_page": "IMG_0058"
  },
  {
    "headword": "আরোআলি",
    "transliteration": "aroali",
    "phonetics": "aroali",
    "etymology": "[< ববাং আরোআল + ই বৃত্তি অর্থো]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "দেখাশোনার দায়িত্ব; তত্ত্বাবধায়কের কাজ।",
        "examples": [
          "বিনপইসায় আরোআলি কেও করের না।"
        ]
      }
    ],
    "source_page": "IMG_0058"
  },
  {
    "headword": "আড়",
    "transliteration": "ado়",
    "phonetics": "aḍɔ়",
    "etymology": "[<হি. আড় < সং অরাল]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "আডকাঠ।",
        "examples": [
          "ই গাছ আড়ো তুলতে আরো মানু লাগব। খালতা বাইশা - আড চদরি"
        ]
      }
    ],
    "source_page": "IMG_0058"
  },
  {
    "headword": "আড়া",
    "transliteration": "ado়a",
    "phonetics": "aḍɔ়a",
    "etymology": "[<হি. আড়]",
    "senses": [
      {
        "part_of_speech": "ক্রি.",
        "definition": "আড়াল করা; প্রতিরোধ করা।",
        "examples": [
          "দইখ্নর বা’ঝারে রইদ আড়ে এরশালে উঠনিখান চেম্রা।",
          "হেশে বাং দি আড়িছে নাইলে ডাকাইতে আত (= হাত) কাটি ফালাই দিল অনে!",
          "টিলার উফরে গাছগুইনতে বানতুফান আড়ে।"
        ]
      }
    ],
    "source_page": "IMG_0058"
  },
  {
    "headword": "আড়ি",
    "transliteration": "ado়i",
    "phonetics": "aḍɔ়i",
    "etymology": "[<ববাং আড় (=হাড়) + ই তপ্র ক্ষুদ্রার্থে]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "কানের ভেতরের অংশ; কানের অভ্যন্তরের হাড়। রে। —আধার।",
        "examples": [
          "খুচা গিআ কানর আড়িত লাগছে। — গোপন আস্তানা",
          "ডাকাইতর আড়িত গিআ পড়ি গেশলাম।",
          "মানুগুর মাত মিট্ঠা, ভিত্রে ভিত্রে বদমাশর আড়ি।"
        ]
      }
    ],
    "source_page": "IMG_0058"
  },
  {
    "headword": "আড়িকুনা",
    "transliteration": "ado়ikuna",
    "phonetics": "aḍɔ়ikuna",
    "etymology": "[<বাং আড় = তির্যক]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "ঈশান কোণ।",
        "examples": [
          "আড়িকুনাবায় মেঘ করের। >> পুবদিকে দাঁড়িয়ে আড়চোখে চাইলেই ঈশান কোণ নজরে আসে। তাই বোধ হয় ওই কোণকে ‘আড়িকুনা’ বলা হয়। দ্র. ইআনকুন।"
        ]
      }
    ],
    "source_page": "IMG_0059"
  },
