  {
    "headword": "লাড়া",
    "transliteration": "lado়a",
    "phonetics": "laḍɔ়a",
    "etymology": "[< বাং নাড়া লকারীভবনে]",
    "senses": [
      {
        "part_of_speech": "ক্রি.",
        "definition": "নাড়া দেওয়া; ঘাঁটানো।",
        "examples": [
          "লাবড়াটাইন লাড়িস, মুই তুড়া বারে তনে আই। লাি lari [< ববাঃ ভক লাি ]"
        ]
      },
      {
        "part_of_speech": "বি.",
        "definition": "নিতম্ব; Hip।",
        "examples": [
          "‘উচ্চা বুচি লাউআ (লাউয়ের মতো ভারী) লাড়ি, তেউ গি পিনধো ঢাকাই হাড়ি।’ — বরাকপ্রবাদ"
        ]
      }
    ],
    "source_page": "IMG_0319"
  },
  {
    "headword": "লাড়িআ",
    "transliteration": "lado়ia",
    "phonetics": "laḍɔ়ia",
    "etymology": "[< ববাং শব্দ লাড় + ইআ]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "আঁশহীন অতি সুস্বাদু নদীর মাছ বিশেষ।",
        "examples": [
          "পাবদা জাতীয়় মাছ। মাঝারি আকার। চেপ্টা। হালকা নীলচে রূপালি রং। আধ কিলোগ্রাম পর্যন্ত বড় হয়। অনেকেই এই মাছ খান না। কারণ, চোখের সামনের মাছটি বিষ্ঠা খায়। প্রবাদ আছে,",
          "‘হকল মাছে গু খায় লাড়িআর উফরে দুশ জায়; দুশ তার দেখাদেখি খাইলায়।’ —বরাকপ্রবাদ"
        ]
      }
    ],
    "source_page": "IMG_0319"
  },
  {
    "headword": "লাড়াই",
    "transliteration": "lado়ai",
    "phonetics": "laḍɔ়ai",
    "etymology": "[< বাং লড়াই স্বরসঙ্গতিতে]",
