  {
    "headword": "গআ",
    "transliteration": "goa",
    "phonetics": "gɔa",
    "etymology": "[<প্রা. ঘসা]",
    "senses": [
      {
        "part_of_speech": "ক্রি.",
        "definition": "শরীরে শরীরে ঘষা; গায়ে গা লাগানো; কাছে আসা।",
        "examples": [
