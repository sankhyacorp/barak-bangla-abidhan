  {
    "headword": "ভুলটি",
    "transliteration": "vuloti",
    "phonetics": "vulɔṭi",
    "etymology": "[<ববাং শব্দ ভুলটি]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "হাতি শিকারের জন্য ব্যবহৃত ৩০০ হাত দীর্ঘ বড় পাটের দড়ি।",
        "examples": [
          "শিকারি হাতিটিকে এই দড়ি দিয়ে সজ্জিত করা হয়। যাতে মাহুত ও ফানদি (দ্র.) হাতির বিশাল দেহে সহজে ওঠানামা ও দৌড়ানোর সময় সহজে হাতির ওপর আরোহণ করা বা পেটের তলায় কানের পেছনে লুকিয়ে পড়া যায়। ষ্ট্রনিন dulli [< সং দোলী]"
        ]
      },
      {
        "part_of_speech": "বি.",
        "definition": "কা<del>প</del>ড় দিয়ে আচ্ছাদিত পালকি।",
        "examples": [
          "আগে ডুললিত করি কইননা বুবাই লইআ জাইতা।",
          "শব্দটি বাংলাদেশেও প্রচলিত।"
        ]
      }
    ],
