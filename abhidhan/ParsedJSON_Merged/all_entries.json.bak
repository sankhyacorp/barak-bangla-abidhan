  {
    "headword": "বিচি",
    "transliteration": "bichi",
    "phonetics": "bic∫i",
    "etymology": "[< সং বীজ]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "ফল বা শস্যাদির বীজ যা থেকে গাছ হয়।",
        "examples": [
          "কাঠলর বিচি এলকু আলুর দরে বিকে। বি. অশি.— অণ্ডকোষ।",
          "আমড়া, গুলাল, কাঁঠাল প্রভৃতির বিচির মতো দেখতে বলেই অগুকোষকে ‘বিচি’ বলা হয়। এই বলার ভঙ্গিটি অশ্লীল।",
          "আউকি করিস না, টিপিআ বিচি গালি লাইমু।"
        ]
      }
    ],
    "source_page": "IMG_0273"
  },
  {
    "headword": "বিজল",
    "transliteration": "bijol",
    "phonetics": "biʒɔl",
    "etymology": "[< সং বিজ্জল]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "পিচ্ছিল জলীয় পদার্থ; গাছের ঘন ও পিচ্ছিল রস।",
        "examples": [
          "‘এওলা খাইআ খাইছে পানি খাইছে গংগার জল, চইলতা খাইআ খাইছে পানি খাইছে বিজল।’ — বরাকপ্রবাদ"
        ]
      },
      {
        "part_of_speech": "বি.",
        "definition": "মুখের লালা।",
        "examples": [
          "গাইর মুখ তনে খালি বিজল পড়ের।"
        ]
      }
    ],
    "source_page": "IMG_0273"
  },
