  {
    "headword": "বাতেশা মরিচ",
    "transliteration": "batesha morich",
    "phonetics": "bate∫a mɔric∫",
    "etymology": "[< ববাং বাতেশা ~ মরিচ]",
    "senses": [
      {
        "raw_text": "[< ববাং বাতেশা ~ মরিচ]"
      },
      {
        "part_of_speech": "বি.",
        "definition": "বাতাসার মতো দেখতে চেপ্টা গোলাকার মরিচ বিশেষ।",
        "examples": [
