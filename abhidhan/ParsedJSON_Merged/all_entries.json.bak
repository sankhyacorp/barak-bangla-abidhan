  {
    "headword": "মান্ডর",
    "transliteration": "mandor",
    "phonetics": "manḍɔr",
    "etymology": "[< সং মণ্ডপ = মেরাপ]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "মন্দিরের সংলগ্ন গানকীর্তনের জন্য নির্মিত বড় আকারের ঘর; নাচঘর।",
