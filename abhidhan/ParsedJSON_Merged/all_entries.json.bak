  {
    "headword": "আওলে",
    "transliteration": "aole",
    "phonetics": "aole",
    "etymology": "[<আঞ্চ. হাওয়ালে < আ. হাৱালাহ = জিম্মা]",
    "senses": [
      {
        "part_of_speech": "ক্রিবিণ.",
        "definition": "জিম্মায়; তত্ত্বাবধানে। ধ্বনিলোপের ফলে বরাকবাংলায় দাঁড়াল আওলে। আ করি চাওআ — বাগধা. ক্রি. অবাক হয়ে দেখা।",
        "examples": [
          "আমি হকল মাল তুমার আওলে থইআ জাইআর।",
          "হেই বেটা, ছুগরিইগুর বায় আ করি কিতা চাস।"
        ]
      }
    ],
    "source_page": "IMG_0047"
  },
  {
    "headword": "আকি",
    "transliteration": "aki",
    "phonetics": "aki",
    "etymology": "[<বাং কি]",
    "senses": [
      {
        "raw_text": "[<বাং কি] তপ্র. — ভাবার্থে বা বৃত্তি অর্থে ব্যবহৃত হয়। ⇒ পির + আকি > পিরাকি [ = পিরের অলৌকিক কর্মা > বাং ‘-কি’ পদপূরণে সম্প্রসারিত রূপ ‘-আিক’। আকি আকি আনা — বাগধা. ক্রি. ভুলিয়ে-ভালিয়ে নিয়ে আসা। ⇒ হিতায় মোরে আকি আকি আনিআ বেরাচাটো ফালাইছইন।"
      }
    ],
    "source_page": "IMG_0047"
  },
  {
    "headword": "আকড়ি",
    "transliteration": "akodo়i",
    "phonetics": "akɔḍɔ়i",
    "etymology": "[<বাং আকষি = হস্তীতাড়নদণ্ড <সং অঙ্কুশ]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "হাতি তাড়ন দণ্ড।",
        "examples": [
          "লোহার তৈরি এই দণ্ডের দুটি মুখ। মুখ দুটি সৃক্ষাগ্র। একটি মুখ সোজা, অন্যটি আঁকশি বা বড়শির মতো বাঁকা। কানের পাতায় ও মাথার বিশেষ স্থানে আঘাত করা হয় এটি দিয়ে।"
        ]
      },
      {
        "part_of_speech": "বাগধা. ক্রি.",
        "definition": "আগলে রাখা।",
        "examples": [
          "কয়দিন তনে তাইরে মুই আকি আকি রাখিআর।"
        ]
      }
    ],
    "source_page": "IMG_0047"
  },
  {
