  {
    "headword": "ভেড়াপাওআ",
    "transliteration": "vedo়apaoa",
    "phonetics": "veḍɔ়apaoa",
    "etymology": "[< ববাং শব্দ ভেড়া পাওআ]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "অতি উৎকৃষ্ট শালিধান বিশেষ। লাল রঙের চিকন ধান। চুলের মতো লম্বা শুঙ্ বা Antenna আছে। কাচসাদা মিহি চাল। স্বাদে পরিমলে এমন রুচিকর উপাদেয় ধান দেশে দ্বিতীয়টি নেই।শক্তি বর্ধক। রোগীর সেরা পথ্য।ফলে প্রচুর। কৃষকদের বিশ্বাসঃ মূল জমি খণ্ডের দুপাশে এই ধান রোপন করলে তন্ত্রমন্ত্র দিয়ে কেউ জমির উর্বরাশক্তিকে বিয়োজিত বা স্থানাম্বরিত করতে পারে বা।",
        "cross_references": [
          "হসআটানি"
        ]
      }
    ],
    "source_page": "IMG_0291"
  },
  {
    "headword": "তেরেন্ডা",
    "transliteration": "terenda",
    "phonetics": "terenḍa",
    "etymology": "[< সং এরন্ড ?]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "গুল্ম জাভীয় উদ্ভিদ বিশেষ। কাণ্ড লরম। গাছ পাঁচ থেকে সাত হাত উঁচু হয়ে থাকে। পাতা করতলাকৃতি। একলিঙ্গ ফুলগুলি যৌগিক মঞ্জরীতে বিন্যস্ত। ফল ডিম্বাকৃতি। বিচি এ কটি। গ্রামাঞ্চলে বাড়ির বেড়ার জন্য এ গাছ লাগানো হয়। এই গাছের রস জমিয়ে ছোটরা বুদবুদ ওড়ায়। ভেরেন্ডার বীজের তেল মোম ও সাবান ভৈরিতে ব্যবহাত হয়।"
      },
      {
        "part_of_speech": "বাগধা. ক্রি.",
        "definition": "কর্মহীনভাবে বসে থাকা।",
        "examples": [
          "কামো লাগ, তুইন কিভা ভেরেন্ডা ভাজিতে নি?"
        ]
      }
    ],
    "source_page": "IMG_0291"
  },
