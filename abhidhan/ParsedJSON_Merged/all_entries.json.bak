    "senses": [
      {
        "part_of_speech": "বিণ.",
        "definition": "প্রত্যেক।",
        "examples": [
          "পর্তি দিন পর্তি বছর সংস্কৃতি উপসর্গ ‘প্রতি’ মধ্যস্বরাগমে বরাক উপত্যকায় দাঁড়িয়েছে ‘পর্তি’। সংস্কৃতের বহু অর্থের মাত্র একটি (প্রত্যেক) গ্রহণ করেছে। এবং এটি পৃথক পদ রূপে ব্যবহৃত হয়। '"
        ]
      }
    ],
