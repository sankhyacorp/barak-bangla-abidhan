  {
    "headword": "হুফরাগাছ",
    "transliteration": "huforagachh",
    "phonetics": "ɦufɔragac∫h",
    "etymology": "[< ববাং হুফরা (দ্র.) + গাছ]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "বীরুৎ জাতীয় জলাভূমির উদ্ভিদ বিশেষ; শোলাগাছ।",
        "examples": [
          "বহু শাখাযুক্ত এই গাছটি এক মিটার থেকে দেড় মিটারের মতো লম্বা হয়। পাতা যৌগিক। দেখতে আমলকি পাতার মতো। ফুল রেসিম পুষ্পবিন্যাসে পাতার কক্ষে থাকে। ফল শিম জাতীয়। গাছটি জলাভূমিতে উৎপন্ন হয়। হুফরাগাছের নরম সাদা কাণ্ড দিয়ে টুপি, মুকুট, দেবদেবী প্রতিমার সাজ-অলংকার ও নানা শিল্প প্রস্তুত করা হয়।"
        ]
      }
    ],
    "source_page": "IMG_0350"
  },
  {
    "headword": "হফা",
    "transliteration": "hofa",
    "phonetics": "ɦɔfa",
    "etymology": "[< আঞ্চবাং সুপা; সুফা]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "গোরুমহিষের মুখের ঠুলি।",
        "examples": [
          "খেতে কাজের সময় গোরু-মোষেরা যাতে ধান না খেতে পারে সে জন্য ওদের মুখে বেতের তৈরি ঠুলি পরানো হয়। এই ঠুলির নাম ‘হুফা’।",
          "হুফা লাগাইআ দামাগুইনতরে দি মাড়া দিস্।"
        ]
