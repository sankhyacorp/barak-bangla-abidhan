        ]
      }
    ],
    "source_page": "IMG_0169"
  },
  {
    "headword": "রুফা",
    "transliteration": "rufa",
    "phonetics": "rufa",
    "etymology": "[< তা./ মু/ জগ্নু (= ঝোপ) + আ স্বার্থিক প্র.]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "ছোট ছোট গাছের ঝাড়; ঝোপ।",
        "examples": [
          "জালি বেতর ঝুফা।"
        ]
      },
      {
        "part_of_speech": "বি.",
        "definition": "থোকা।",
        "examples": [
          "লেচুর ঝুফা; বুফা ঝুফা লেবইর। ঝুফড়া কবhufra [< ববাং ঝুফ (< বাং ঝোপ্) +ড়া তপ্র. কুদ্রার্থে]"
        ]
      },
      {
        "part_of_speech": "বি.",
        "definition": "ছোট ঝোপ।",
        "examples": [
          "বেকরির ঝুফড়াত টুনটুনিএ বাদা বানাইছইন।"
        ]
      }
    ],
    "source_page": "IMG_0169"
  },
  {
    "headword": "রুমটা",
    "transliteration": "rumota",
    "phonetics": "rumɔṭa",
    "etymology": "[< ধ্ব. ঝুম্ ঝুম্ (= গুচ্ছাকারে বিস্তৃত) +টা]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "গুচ্ছ; ঘনভাবে সন্নিবিষ্ট ক্ষুদ্র ফলের রাশি।",
        "examples": [
          "আগাত দুই ঝুমটা ভুবি পাককিছে।"
        ]
      }
    ],
    "source_page": "IMG_0169"
  },
  {
    "headword": "ঝুমিআ",
    "transliteration": "jhumia",
    "phonetics": "ʒhumia",
    "etymology": "[< ধ্ব. ঝুম্ঝুম্ (= গুচ্ছাকারে বিস্তৃত ও ঘন অর্থে) + ইআ প্র.]",
    "senses": [
      {
        "part_of_speech": "ক্রিবিণ.",
        "definition": "প্রচুর পরিমাশে বা সংখ্যায়; ঘন ও গুচ্ছ গুচ্ছ হয়ে।",
        "examples": [
          "খালিবাড়িত গাছো অলা ঝুমিআ এওলা ধরছে। পুমঝুমি'র ছোট ছোট ঘণ্টাগুলি গুচ্ছাকারে গাঁথা থেকে ঝুমঝুম ধ্বনি তোলে। এর সাদৃশ্যে ‘ঘন ও গুচ্ছাকার’ ভাবের প্রকাশ। ঝুরমুট িʒhurmuṭ [<ববাং শব্দ ঝুরমুট]"
        ]
      },
      {
        "part_of_speech": "বি.",
        "definition": "দোদুল্যমান নারকোলের ছড়া।",
        "examples": [
          "'ডাব-নাইড়ল ঝুরমুট ঝুরমুট।' — বগীত ঝুরা, কʒhura [< ধ্ব. ঝুরঝুর = গুঁড়া দ্রব্যের পতন]"
        ]
      },
      {
        "part_of_speech": "বি.",
        "definition": "গুঁড়া; চূর্ণ; ঝুরাভাজা।"
      },
      {
        "part_of_speech": "ক্রি.",
        "definition": "অনুতাপ করা; নীরবে চোখের জল ফেলা। ‘একসরী ঝুঁরো মো কদমতলে বসী।’ — কৃকী ঝুরুং িʒhuruŋ [< ববাং শব্দ ঝুরুং]",
        "examples": [
          "চুরর মায় কান্দে না মনে মনে ঝুরে।’ — বরাক প্রবাদ"
        ]
      },
      {
        "part_of_speech": "বি.",
        "definition": "গভীর খাদ; পাহাড়ের জঙ্গলাকীর্ণ গহুর।",
        "examples": [
          "আত্তিমুড়ার ঝুরুংও পড়লে কেও তুকাইআ পাইত নায়।"
        ]
      }
    ],
    "source_page": "IMG_0169"
  },
  {
    "headword": "ঝুড়",
    "transliteration": "jhudo়",
    "phonetics": "ʒhuḍɔ়",
    "etymology": "[< ববাং শব্দ ঝুড়]",
    "senses": [
      {
        "part_of_speech": "বিণ.",
        "definition": "ডাঁসা; পুষ্ট; ঝুনো। ৩আ ঝুড় অইলেউ পাড়ি লাইমু। যূন্যূনা 13hul 13hula [< ধ্ব. যূন্যূন = মিথিন ভাবা"
      },
      {
        "part_of_speech": "বিণ.",
        "definition": "শিথিল; ঝুলা ভাবযুক্ত।",
        "examples": [
          "তাইর জামাগু গাত ঝুলঝুলা অই গেছে। Ì ঝুলা কবhula [< আঞ্চবাং ঝুল + আ < সং লোল]"
        ]
      },
      {
        "part_of_speech": "বি.",
        "definition": "কাঁধে বহনযোগ্য বড় থলে বিশেষ।",
        "examples": [
          "বরাক উপত্যকায় বৈষ্ণব-বৈষ্ণবীরা ঝুলা বয়ে বেড়ান। ঝেজরা কবheকবra [< বাং ঝাঁঝরা]"
        ]
      },
      {
        "part_of_speech": "বিণ.",
        "definition": "ছিদ্রময়।",
        "examples": [
          "উলুএ পুথিখানরে কাটিআ ঝেজরা করি থইছইন।"
        ]
      }
    ],
    "source_page": "IMG_0169"
  },
  {
    "headword": "রোং",
    "transliteration": "rong",
    "phonetics": "roŋ",
    "etymology": "[< দ্র. জেং]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "তেজ; ঝাল।",
        "examples": [
          "ধানু মরিচর ঝেং বেশ। বি. [আলং] — অহংকার; পৌরুষ।",
          "কৃটিমুটি ছুগরার অলা ঝেং। ঝেংওআ ক3heŋgua [< ববাং ঝেং + উআ তপ্র. ‘আছে’ অর্থে]"
        ]
      },
      {
        "part_of_speech": "বিণ.",
        "definition": "তেজাল।",
        "examples": [
          "ঝেংগুআ মরিচ অইল কামরেংগা। ঝেংড়া কʒheŋṛa [< ববাং ঝেং + ড়া তপ্র. যুক্তার্থে]"
        ]
      },
      {
        "part_of_speech": "বিণ.",
        "definition": "উগ্র। ট",
        "examples": [
          "হারাদিন ঘামিআ হিনান বুড়ান নাই, শইললো তনে ঝেংড়া গন্ধ্ বারর। বাংলা ভাষার অভিধান ও ভাষাতত্ত"
        ]
      }
    ],
    "source_page": "IMG_0169"
  },
  {
    "headword": "টউ",
    "transliteration": "tou",
    "phonetics": "ṭɔu",
    "etymology": "[< বোড়ো. তৌ, কক. তুক = পাত্র বিশেষ]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "পিতলের তৈরি পুরু ও ভারী হাঁড়ি বিশেষ।",
        "examples": [
          "বরাক উপত্যকার বাঙালি হিন্দু ও মণিপুরিরাই কেবল ‘টউ’ ব্যবহার করেন।"
        ]
