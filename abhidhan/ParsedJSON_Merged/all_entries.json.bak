          "নাঁরেনাঁরে কিত বাক্কা করে ধিতলাঁরেছি।"
        ]
      }
    ],
    "source_page": "IMG_0263"
  },
  {
    "headword": "বাকনল",
    "transliteration": "bakonol",
    "phonetics": "bakɔnɔl",
    "etymology": "[< বাং বাঁকা + নল]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "লোহা বা পেতলের সৃক্ষ্ম বাঁকা নল।",
        "examples": [
