    "transliteration": "tep",
    "phonetics": "ṭep",
    "etymology": "[<বাং টোপ]",
    "senses": [
      {
        "raw_text": "[<বাং টোপ]"
      },
      {
        "part_of_speech": "বি.",
        "definition": "মাছ ধরবার জন্য বড়শিতে গাঁথা খাদ্য। ভাত, ময়দার গুলি, সিদল, কেঁচো দিয়ে ছোটমাছের আর চেং, শিঙি, পুঁটি, চিংড়ি দিয়ে বড়মাছের টোপ বানানো হয়। ;"
      }
    ],
    "source_page": "IMG_0175"
  },
  {
