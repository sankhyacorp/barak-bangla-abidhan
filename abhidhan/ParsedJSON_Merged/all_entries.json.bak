  {
    "headword": "রুষটি",
    "transliteration": "rushoti",
    "phonetics": "ru∫ɔṭi",
    "etymology": "[< ববাং শব্দ কমটি]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "কপীনের মতো শক্ত করে মারা কাপড়ের কোঁচা; ধৃতি গামছা ইত্যাদির যে কুঞ্চিত অংশ কোমরের পেছন দিকে গোঁজা থাকে। কমটি মারিআ রুআত লাগি চল্।",
        "examples": [
          "কমটি খুলায় বেরো বেরা লাগি হে উলটিআ পড়ছে"
