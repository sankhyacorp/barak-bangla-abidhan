  {
    "headword": "রাংগিবেত",
    "transliteration": "ranggibet",
    "phonetics": "raŋgibet",
    "etymology": "[<ববাং রাং + ই ~ বেত]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "মাঝারি আকারের বেতগাছ বিশেষ।",
        "examples": [
          "জলাশয়ের পাড়ে বিশেষত নদী-নালা-বিল প্রভৃতির কাছে জন্মায় এই বেত। কোনো গাছের আশ্রয় পেলে ৬০-৭০ হাত পর্যস্ত লম্বা হয়। বিভিন্নরকমের আসবাব তৈরির কাজে এই বেত ব্যবহৃত হয়ে থাকে।"
        ]
      }
    ],
    "source_page": "IMG_0310"
  },
  {
    "headword": "রি",
    "transliteration": "ri",
    "phonetics": "ri",
    "etymology": "[< দ্র. রা]",
    "senses": [
      {
        "raw_text": "[< দ্র. রা] কৃৎ প্রত্যয় — বরাক উপত্যকার আঞ্চলিক বাংলা ভাষার খাঁটি কৃৎ প্রত্যয়। নিপুণ বা পারঙ্গম অর্থে ব্যবহৃত হয়। ⇒ √নাচ + রি = নাচরি (= নৃত্য পারদর্শিনী) √রান্দ্ + রি = রান্দ্রি (= পাচিকা) √গা + রি = গারি (= গায়িকা) ≫ দ্র. রা।"
      }
    ],
    "source_page": "IMG_0310"
  },
  {
    "headword": "রিআ",
    "transliteration": "ria",
    "phonetics": "ria",
    "etymology": "[< ববাং শব্দ রিআ]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "বন্য ছাগল বিশেষ।",
        "examples": [
