  },
  {
    "headword": "ফেটিআ",
    "transliteration": "fetia",
    "phonetics": "feṭia",
    "etymology": "[< ববাং শব্দ ফেটিআ]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "কই জাতীয় রঙিন ছোট মাছ।",
        "examples": [
          "বাহারে পাঁতি বিন্যাস এই ছোটমাছকে বিশিষ্ট করে তুলেছে। নতুন বৃষ্টিতে কই মাছের সঙ্গে উজিয়ে থাকে। খেতে খুবই ভালো।"
        ]
      },
      {
        "part_of_speech": "বাগধা. ক্রি.",
        "definition": "অতি আদুরে হওয়ার দরুণ সামান্য শ্রমে ভেঙে পড়া।",
        "examples": [
          "জেতা বেটিনতর ফেত করতে নথ পড়ি জায় ইতারে আনিআ মোর ঘর চলত নায়। কাং তুল. ‘ফুলের ঘায়ে মূর্ছা যাওয়া।’"
        ]
      }
    ],
    "source_page": "IMG_0251"
  },
