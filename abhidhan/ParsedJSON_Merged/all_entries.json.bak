  },
  {
    "headword": "ভরমানি",
    "transliteration": "voromani",
    "phonetics": "vɔrɔmani",
    "etymology": "[< বাং ভ্রমা ণিজন্তে < সং ভ্রম = ভ্রমণ করা]",
    "senses": [
      {
        "part_of_speech": "ক্রি.",
        "definition": "ভ্রমণ করানো; দেশে দেশে নিয়ে ফেরা; যাযাবর বৃত্তি অবলম্বন করানো।",
        "examples": [
          "জে বেটির পিংলা চউক লামবা মাথার কেশ; হেই বেটিএ জানি লইও ভরমাইবো দেশ দেশ। — বপ্র."
        ]
      }
    ],
    "source_page": "IMG_0284"
  },
  {
    "headword": "ভরে",
    "transliteration": "vore",
    "phonetics": "vɔre",
    "etymology": "[< দ্র. ভরে ভরে]",
    "senses": [
      {
        "part_of_speech": "ক্রিবিণ.",
        "definition": "ধীরে; সাবধানের সঙ্গে।",
        "examples": [
          "পড়ি জাইবায় দ, ভরে আটিআ জাও। — কম আঁচে। ⇒ দুদ ভরে আটাইও, নাইলে লাল অই জাইব।"
        ]
      }
    ],
    "source_page": "IMG_0284"
  },
  {
    "headword": "ভরে ভরে",
    "transliteration": "vore vore",
    "phonetics": "vɔre vɔre",
    "etymology": "[< বাং ভর (= ঠেকনা) + এ তপ্র. করণো]",
    "senses": [
      {
        "part_of_speech": "ক্রিবিণ.",
        "definition": "সাবধানে; আস্তে আস্তে। দ্র. হমভরে",
        "cross_references": [
          "হমভরে"
        ],
        "examples": [
          "বেমার থাকি উঠিছ খালি, ভরে ভরে জাইও।"
