  {
    "headword": "আদাজামুইর",
    "transliteration": "adajamuir",
    "phonetics": "adaʒamuir",
    "etymology": "[<বাং আদা + ববাং জামুইর]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "আদা'র গন্ধযুক্ত রসাল লেবু বিশেষ।",
        "examples": [
          "গোলাকার বেশ বড় আকারের লেবু। লেবুর জগতে এমন সুগন্ধযুক্ত ও রসগর্ভ লেবু দ্বিতীয়টি নেই। গন্ধ ও রসের জন্য একে রসরাজ লেবু বলতে পারি। ভেষজগুণে ভরা এটি খুবই উপকারী ও রুচিকর।"
        ]
      },
      {
        "part_of_speech": "বাগধা. ক্রি.",
        "definition": "অবাঞ্জিত উপদেশ দেওয়া বা যুক্তিবৃদ্ধি দেওয়া।",
        "examples": [
          "হর ইন তনে, দাদারে আর আদা পড়া হিখাইস না।"
        ]
      }
    ],
    "source_page": "IMG_0053"
  },
  {
    "headword": "আদার",
    "transliteration": "adar",
    "phonetics": "adar",
    "etymology": "[<প্রাবা. আধার = খাদ্য]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "পাখির খাদ্য।",
        "examples": [
          "ময়নাগুরে আদার দেও। 'আধার' মানে প্রাচীন বাংলায় 'আশ্রয়' ছাড়াও বাঁচার জন্য কোনো প্রাণীর অবলম্বিত খাদ্যও বোঝাত। এখন অর্থসংকোচে কেবল ‘পাখির খাদ্য’। ‘ধ’ অল্পপ্রাণিতে বরাক বাংলা ‘দ’ হয়েছে।"
        ]
      }
    ],
    "source_page": "IMG_0053"
  },
  {
    "headword": "আদালি",
    "transliteration": "adali",
    "phonetics": "adali",
    "etymology": "[<‘আ + ঢাল + ই √ঢল’ শহী.]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "নদীতীরের ঢালু স্থান বিশেষ; ঝুপঝাড়পূর্ণ নদীর পাড়। আরেকটি সম্ভাবনা উড়িয়ে দেওয়া যায় না। যথা, বাং আবর্জনা > আদাড় + ইআ > আদাড়ি > ববাং আদালি।"
      }
    ],
    "source_page": "IMG_0053"
  },
  {
