  {
    "headword": "লাঠা",
    "transliteration": "latha",
    "phonetics": "laṭha",
    "etymology": "[< ববাং লা + বাং আঠা]",
    "senses": [
      {
        "part_of_speech": "বিণ.",
        "definition": "আঠাযুক্ত।",
        "examples": [
          "ময়দা ভালা করি মাঠিআ লাঠা বানাও। নাঠী, latha [< প্র. নাঠী]"
        ]
      },
      {
        "part_of_speech": "বি.",
        "definition": "গো লমাল কোন্দল।",
        "examples": [
          "পানচাইত অফিসো দুইদলে লাঠা লাগছে।"
        ]
      },
      {
        "part_of_speech": "বি.",
        "definition": "অবৈধ প্রেম; যৌন সম্পর্ক।",
        "examples": [
          "গাংগর পারো চইলতা গাছর তলে কানুএ আর লিলায় লাঠা লাগছইন। নাষ্ড্র laddu [< র্শ. নষ্ড্র]"
        ]
      },
      {
        "part_of_speech": "বি.",
        "definition": "গোল মিঠাই বিশেষ।",
        "examples": [
          "তিলর লাড্ডু মুড়ির লাড্ডু"
        ]
      },
      {
        "part_of_speech": "বি.",
        "definition": "গোলাকার পদার্থ।",
        "examples": [
          "কিঅর লাড়ডু তার আতো?"
        ]
      },
      {
        "part_of_speech": "বি.",
        "definition": "গোল্লা; Zero।",
        "examples": [
          "হি অংকত লাড়ডু পাইছে।"
        ]
      },
      {
        "part_of_speech": "বিণ.",
        "definition": "গোলাকৃতি।",
        "examples": [
          "বনরউ ডরাইলে লাড্ডু অইজাইন।"
        ]
      },
      {
        "part_of_speech": "বাগধা. ক্রি.",
        "definition": "উঠেপড়ে লাগা।",
        "examples": [
          "চা গিআ, জামাইএ লাড্ডু অইআ খেতর কামো লাগছে।"
        ]
      },
      {
        "part_of_speech": "বাগধা. ক্রি.",
        "definition": "গোলমাল লাগা।",
        "examples": [
          "হে দুইজন দি লাড্ডা লাগাইআ দুরই তনে তামা চার।"
        ]
      },
      {
        "part_of_speech": "বাগধা. ক্রি.",
        "definition": "সমাজে মূল্যহীন ও ঘৃণ্য ব্যক্তি।",
        "examples": [
          "বইরাগি অইআ ইলা বাদ কাম করলে তাইন লাথর কাঠল অইবা।"
        ]
      },
      {
        "part_of_speech": "বি.",
        "definition": "পশুর মলপিগু।",
        "examples": [
          "কয় লাদ গুফর বাইংগনউরাত দিস।"
        ]
      }
    ],
    "source_page": "IMG_0318"
  },
  {
    "headword": "লাদা",
    "transliteration": "lada",
    "phonetics": "lada",
    "etymology": "[< আঞ্চবাং লাদ < সং লণ্ড]",
    "senses": [
      {
        "part_of_speech": "ক্রি.",
        "definition": "বিষ্ঠা ত্যাগ করা।",
        "examples": [
          "উবা করা, ডামায় লাদিতো। লান্ি lanti [< আ. লা-নজ্ = বম্ মাযা]"
        ]
      },
      {
        "part_of_speech": "বি.",
        "definition": "লাঞ্ছনা; হয়রানি; ক্লেশ দুঃখজনক অবস্থা; দুর্গতি।।",
        "examples": [
          "বেংকো তনে লউন লইআ অলা লানতি পাইছি।",
          "‘সিআনতিত্ (= চালাকিতে) লানতি।’ — বপ্র."
        ]
      }
    ],
    "source_page": "IMG_0318"
  },
