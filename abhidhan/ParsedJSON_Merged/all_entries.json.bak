  {
    "headword": "মেনজুআ",
    "transliteration": "menojua",
    "phonetics": "menɔʒua",
    "etymology": "[< ববাং শব্দ মেনজুআ]",
    "senses": [
      {
        "part_of_speech": "বিণ.",
        "definition": "স্বাভাবিক বৃদ্ধিহীন।",
        "examples": [
          "যেমন, কুমড়োর জালি অনেক সময় স্বাভাবিক ভাবে বড় না হয়ে জালিই থেকে যায়, এরূপ ফলকে ‘মেনজুআ’ বলা হয়।",
          "পুকে খাইলে লাউকুমড়া মেনজুআ অয়।"
        ]
      }
    ],
