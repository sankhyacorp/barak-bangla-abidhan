  {
    "headword": "ডাফুর",
    "transliteration": "dafur",
    "phonetics": "ḍafur",
    "etymology": "[<ধ্ব. ডফ্ ডফ্ = বাঁশের আগা দিয়ে জলে আঘাত করার শব্দা]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "মাছকে আকর্ষণ করার জন্য বঁড়শির দণ্ড দিয়ে জলে মাছের ‘ঘাই’ এর মতো শব্দ সৃষ্টি করা।",
        "examples": [
          "ডাফুর দিলে চেং লাগব।",
          "মাছের শ্রেণীভেদে ‘ডাফুর’ আলাদা আলাদা রকম দিতে হয়। যারা বঁড়শি দিয়ে মাছ ধরে তারা বুঝতে পারে কোথায় কী জাতের মাছ আছে এবং সেই অনুযায়ী তারা ‘ডাফুর’ দেয়।"
        ]
      }
    ],
    "source_page": "IMG_0181"
  },
  {
