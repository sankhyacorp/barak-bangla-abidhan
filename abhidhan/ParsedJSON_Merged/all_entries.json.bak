  {
    "headword": "দাশ",
    "transliteration": "dash",
    "phonetics": "da∫",
    "etymology": "[< বাং ডাঁশ = বিষাক্ত মাছি < সং দংশ]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "দংশনক্ষম মাছি বিশেষ; ডাঁশ।",
        "examples": [
          "সাধারণ মাছি থেকে অনেক বড়। এদের কামড় মশার চেয়েও তীক্ষ্ণ, বিষাক্ত ও জ্বালাময়।"
        ]
      }
    ],
    "source_page": "IMG_0206"
  },
  {
    "headword": "দাশ্ব",
    "transliteration": "dashbo",
    "phonetics": "da∫bɔ",
    "etymology": "[< সং দাস = অনার্য জাতি বিশেষ]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "পাটনি বা ধীবর জাতীয় লোকের উপাধি।",
        "examples": [
          "বরাক উপত্যকার ‘দাশ’ উপাধিযুক্ত লোকেরা শূদ্রজাতীয়। এদের জীবিকা এখন কৃষি। আগে ওরা পাটনি বা ধীবর সম্প্রদায়ের অস্তর্ভুক্ত ছিল।"
        ]
      }
    ],
    "source_page": "IMG_0206"
  },
  {
    "headword": "দি",
    "transliteration": "di",
    "phonetics": "di",
    "etymology": "[< বাং দিকে = অভিমুখে]",
    "senses": [
      {
        "raw_text": "[< বাং দিকে = অভিমুখে] অনু. — অভিমুখে; দিকে। ⇒ ‘ মাগ্র ঠাগ্র পে ি ি ি বউএ চায় কুচে দি। বরাক প্রবাদ দি<sub>s</sub> di [< আমবা. দিআঁ = দ্বারা করণে] অনু. — দ্বারা। ⇒ বাড়িত গিআউ তুমি তাইরে দি বিরইন টাইন পাঠাইও। >> আমবা. দৃ. ‘যঁবে আহ্মা দিআঁ কাহ্নাঞিঁ পাঠায়িলে তাম্বুল।’—নিজন্তে। ‘নিজ ধন দিআঁ সুন্দরী রাধা নির্ম্মায়িলোঁ এ বৃন্দাবনে।’ —সকর্মক ক্রিয়ায়। —শ্রীকৃষ্ণকীর্তন"
      }
    ],
    "source_page": "IMG_0206"
  },
  {
