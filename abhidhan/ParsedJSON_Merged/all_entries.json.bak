  {
    "headword": "ললই দেবা",
    "transliteration": "loloi deba",
    "phonetics": "lɔlɔi deba",
    "etymology": "[< ববাং ললই ~ √দে]",
    "senses": [
      {
        "part_of_speech": "সক্রি.",
        "definition": "লোভ দেখানো; প্রশ্রয় দেওয়া।",
        "examples": [
          "ললই দিলে মানু মুড়ো উঠইন। ননকাতি ləlkari [< প্র. ননরে]"
        ]
      },
      {
        "part_of_speech": "বি.",
        "definition": "খাদ্যের লোভে মুখ বাড়িয়ে অগ্রসর।",
        "examples": [
          "শব্দটি মূলত জোকের মুখ বাড়িয়ে খাদ্য খোঁজার ব্যাপারটি বোঝাত। এখন এটি অর্থ প্রসারণে ‘লোভের বশবতী হয়ে কোনো ভোগ্যবস্তুর প্রতি ধাবিত' অর্থেই ব্যবহৃত হয়।",
          "বারিশাত ই পথো জুকে ললকারি দেইন।",
          "টেকার গনধ পাইলেউ বড়বাবু এ ললকারি দিবা।"
        ]
      }
    ],
    "source_page": "IMG_0315"
  },
  {
    "headword": "ললাম্",
    "transliteration": "lolam",
    "phonetics": "lɔlam",
    "etymology": "[< দ্র. ললাম<sub>s</sub>]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "লতা বিশেষ।",
        "examples": [
          "পান আকৃতির বড় বড় পাতা। কমলার চেয়ে বড় সবুজ ফল। পাকলে কমলা রং হয়। টক স্বাদ বিশিষ্ট।"
        ]
      }
    ],
    "source_page": "IMG_0315"
  },
  {
    "headword": "ললাম",
    "transliteration": "lolam",
    "phonetics": "lɔlam",
    "etymology": "[< ববাং ললই + বাং আম]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "বন্য সুস্বাদু আম বিশেষ; নাম-না-জানা লম্বা ডাঁটা যুক্ত বন্য সুস্বাদু ফল বিশেষ। , ‘বনর মাঝে ধরছে ললাম <math>\\Rightarrow</math> ডেটা নাই বুটা নাই কও চাইন কিতা নাম।' — বরাক ধাঁধা (=ডিম) নি loli [< সং নানি ?]"
      },
      {
        "part_of_speech": "বি.",
        "definition": "দোলনা।",
        "examples": [
          "গাছের ডালে বা বাথানের বিমে দড়ি টানিয়ে পিঁড়ি বসিয়ে এখানকার গ্রামাঞ্চলে দোলনা বা ললি টাঙ্বানো হয়। বাংলা ভাষার অভিধান ও ভাষাতত্ত"
        ]
      }
    ],
    "source_page": "IMG_0315"
  },
  {
