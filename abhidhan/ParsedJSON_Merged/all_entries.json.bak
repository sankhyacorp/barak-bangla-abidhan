  {
    "headword": "ভুলাভুলি",
    "transliteration": "vulavuli",
    "phonetics": "vulavuli",
    "etymology": "[< ববাং ভুলা আম্রেড়নে]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "কার্তিক মাসের সংক্রান্তি উপলক্ষে বরাক উপত্যকায় অনুষ্ঠিত উৎসব বিশেষ।",
        "examples": [
          "কার্তিক সংক্রাস্তিতে গোরু-বাছুরদের উত্তম রূপে স্নানাদি করিয়ে পুষ্পমাল্য দিয়ে সাজানো হয়। উত্তম আহার দেওয়া হয়। আয়োজন করা হয় রাখালসেবারও।"
        ]
      }
    ],
    "source_page": "IMG_0289"
  },
