  {
    "headword": "সেলপই",
    "transliteration": "selopoi",
    "phonetics": "selɔpɔi",
    "etymology": "[<সেলপই < বাং জলপাই?]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "একপ্রকার বন্য বৃক্ষ।",
        "examples": [
          "এই গাছের পাতা শীতের দিনে পুরোপুরি ঝরে না। পাতা ঝরা শেষ হতে হতে আবার নতুন পাতা গজায়। জলপাই গাছের মতো পাতা। গাছের উচ্চতাও জলপাই গাছের মতোই। গাছটির বাকলের রং সাদা। ছোট ছোট ফল গুচ্ছাকারে ধরে। কাঠ লাল।"
        ]
      }
    ],
    "source_page": "IMG_0334"
  },
