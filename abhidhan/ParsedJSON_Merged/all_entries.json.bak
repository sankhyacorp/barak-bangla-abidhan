  {
    "headword": "ধলফর",
    "transliteration": "dholofor",
    "phonetics": "dhɔlɔfɔr",
    "etymology": "[< প্রা. ধওলা + পর < আঞ্চবাং পসরী]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "ভোরের আলোর ঝলক। আঞ্চবাং পসর < প্রা. সফর < সং স্ফর = দীপ্তি। ‘পসর’ মহাপ্রাণিত ও সংকোচনে ‘ফর’।",
        "examples": [
          "কাইল ধলফর দিবার আগেউ বারনি লাগব।"
        ]
      }
    ],
    "source_page": "IMG_0210"
  },
  {
    "headword": "ধলমেঘ",
    "transliteration": "dholomegh",
    "phonetics": "dhɔlɔmegh",
    "etymology": "[< সং ধবল ~ সং মেঘ]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "প্রসিদ্ধ শালিধান বিশেষ। সোনালি রং। চিকন দানা। সাদা চাল। সুস্বাদু ও উপাদেয়। ফলেও খুব। ধানের ডাটা শক্ত তাই ধান মাড়াই কন্টকর। ৪লা dhola [< প্রা. ধওলা সম্প্রকর্ষে < সং ধবল = শ্বেত]"
      },
      {
        "part_of_speech": "বি.",
        "definition": "সাদা রং।",
        "examples": [
          "থনা, কালা, অইল্দা, মাটিআ কত রং।"
        ]
      },
      {
        "part_of_speech": "বিণ.",
        "definition": "শুভ্র; সাদা।",
        "examples": [
          "'বার কালা ভিতর ধলা তার ভিতরে গুললি ভরা।’(=পেঁপে) —বরাক ধাঁধা"
        ]
      }
    ],
    "source_page": "IMG_0210"
  },
  {
    "headword": "ধলাউঝা",
    "transliteration": "dholaujha",
    "phonetics": "dhɔlauʒha",
    "etymology": "[< সং ধবল ~ বাং ওঝা]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "বৃক্ষ বিশেষ। ত্বক সাদা ও খসখসে। কাঠও সাদা। পাক খাওয়া দড়ির মতো টানটান ৪০/৫০ হাত উচ্চতার গাছ। তাই একে ‘পাকখির আড়’ গাছও বলা হয়। কাঠ হিসেবে উৎকৃষ্ট নয়। 2: ধশি"
      }
    ],
    "source_page": "IMG_0210"
  },
