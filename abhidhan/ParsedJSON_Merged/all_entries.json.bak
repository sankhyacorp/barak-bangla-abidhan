    "transliteration": "lado়iali",
    "phonetics": "laḍɔ়iali",
    "etymology": "[< ববাং লাড়ি + আলি তপ্র. অধিকারিনী অর্থে ]",
    "senses": [
      {
        "part_of_speech": "বিণ.",
        "definition": "স্থূল ও প্রশস্ত নিতম্ব যুক্তা; নিতম্বিনী।",
        "examples": [
          "পাড়িজাতো লাড়িআলি বেটিন বেশ।"
        ]
      },
      {
        "part_of_speech": "বাগধা. ক্রি.",
        "definition": "ভয়ে শরীর লারগ কাঁপা। ⇒ হাইকউটো উঠিলে হকল বেটাইনতরউ লাড়িএ করতাল বাজে।"
      }
    ],
    "source_page": "IMG_0319"
  },
  {
    "headword": "লাড়",
    "transliteration": "lado়",
    "phonetics": "laḍɔ়",
    "etymology": "[< বাং নাড় লকারীভবনে]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "নাডু।",
        "examples": [
          "মুড়ির লাডু খইর লাড় লাল্ lal [< হি. লাল ?]"
        ]
      },
      {
        "part_of_speech": "বি.",
        "definition": "খুব মূল্যবান মণিমুক্তা; রত্ন সদৃশ বস্তু যা মানুষের ভাগ্য ফেরায়।",
        "examples": [
          "তালইবেটার কুনতা আশলো না, বেংগর লাল পাইআ এলকু মিরাশদার।"
        ]
      },
      {
        "part_of_speech": "বাগধা. ক্রি.",
        "definition": "ধনী হওয়া।",
        "examples": [
          "ইশকুলর হরুতার বিনপইশি চাউল মারিআ তাইন লাল অইছইন। লাল lalc∫ [< সং লাল মা = লাখ]"
        ]
      },
      {
        "part_of_speech": "বি.",
        "definition": "কিছু পাওয়ার জন্য প্রবল ইচ্ছা।",
        "examples": [
          "মানর লালচ দিনদিন বাড়ের।"
        ]
      }
    ],
    "source_page": "IMG_0319"
  },
  {
    "headword": "লালচি",
    "transliteration": "lalochi",
    "phonetics": "lalɔc∫i",
    "etymology": "[< ববাং লালচ +ই তপ্র. বিশেষণে]",
    "senses": [
      {
        "part_of_speech": "বিণ.",
        "definition": "লোভী।",
        "examples": [
          "এলকু হকলউ টেকার লালচি।"
        ]
      },
      {
        "part_of_speech": "বিণ.",
        "definition": "লোভনীয়।",
        "examples": [
          "জিলাপি লালচি মিঠাই, হকলরউ লালচ অয়। Ī"
        ]
      },
      {
        "part_of_speech": "বাগধা. ক্রি.",
        "definition": "কারবারে দেউলিয়া হওয়া।",
        "examples": [
          "ইলা টেকা উড়াইলে দুইদিনে বেপারর লাল বাতৃতি জলিব। লানি lali [< ববাঃ শব্দ লালি]"
        ]
      },
      {
        "part_of_speech": "বি.",
        "definition": "বাঁশ বা বেতের পিঠের শক্ত সবুজ ছাল।",
        "examples": [
          "লালি দি ছানদিবার বেত বানাইও। সিপরী.শব্দ বুকা।"
        ]
      },
      {
        "part_of_speech": "বি.",
        "definition": "বাকল ছুলে শুকিয়ে রাখা সুপারি।",
        "examples": [
          "লালি দেখতে ভালা নায়, খাইতে ভালা।"
        ]
      }
    ],
    "source_page": "IMG_0319"
  },
  {
    "headword": "লাস",
    "transliteration": "las",
    "phonetics": "las",
    "etymology": "[< দ্র. লাসা]",
    "senses": [
      {
        "part_of_speech": "বিণ.",
