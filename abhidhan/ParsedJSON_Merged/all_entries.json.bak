    "etymology": "[< প্রাবা. হরিণা = মৃগ]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "হরিণ; Deer। > প্রাবা. দৃ. ‘অপণা মাংসেঁ হরিণা বৈরী।’ চর্যা ৬",
        "examples": [
          "তিন রকমের হরিণ বরাক উপত্যকার অরণ্যে দেখা যায়। যেমন, মায়া হরিং = বার্কিং ডিয়ার বারো হিংগি = হগ ডিয়ার চিতরা হরিং = চিত্র হরিণ দ্র. অরিং"
        ]
      }
