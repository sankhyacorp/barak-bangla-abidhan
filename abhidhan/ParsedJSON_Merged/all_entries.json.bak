        ]
      }
    ],
    "source_page": "IMG_0251"
  },
  {
    "headword": "ফৈরা",
    "transliteration": "foira",
    "phonetics": "fɔĭra",
    "etymology": "[< ববাং শব্দ ফেরা]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "ঘামাচির মতো একপ্রকার প্রদাহযুক্ত গুটিকা নির্গমনকারী সংক্রামক জুর বিশেষ; হাম; Measles লাল রঙের পীড়কা উঠে।’ — ড. যোগেশ চন্দ্র ঘোষ। ",
        "examples": [
          "‘প্রথমে সর্দির লক্ষণ প্রকাশ প্রায়; হাঁচি হয় ও নাক দিয়া জল পড়ে; চক্ষু লাল হয় ও ছলছল করে: কপাল পিঠ ও শরীরে বেদনা অনুভূত হয়; কাশি হয় গলা ভাঙিয়া যায় এবং জুর হয়। চতুর্থ দিনে প্রথমত মুখে ও গলায় এবং, পরে সমস্ত শরীরে ছোট লা ভাষার <mark>অ</mark>ভিধান ও ভাষাতত্ত্ব"
        ]
      }
    ],
    "source_page": "IMG_0251"
  },
  {
