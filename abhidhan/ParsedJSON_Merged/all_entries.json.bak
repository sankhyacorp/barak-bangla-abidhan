    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "বাদামি রঙের এক প্রকার অতি ক্ষুদ্র পাখি।",
        "examples": [
          "মুনিআর পালে ধান খাইত্রা। 🗢 চডুয়ের চেয়েও ক্ষুদ্র। বাদামি রং। দলবদ্ধভাবে ওড়ে। বিশেষত ধানের ক্ষেতে বেশি দেখা যায়। ধান ও শস্যবীজ এদের প্রধান খাদ্য। ঝোপঝাড়ে বা হালকা জঙ্গলে ছোট ছোট ঘাস-লতার বাসা বানিয়ে থাকে।"
        ]
      }
    ],
    "source_page": "IMG_0304"
  },
