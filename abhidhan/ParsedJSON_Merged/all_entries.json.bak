    "phonetics": "vi∫",
    "etymology": "[< বাং বিশ ?]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "ধানের পরিমাণ বিশেষ।",
        "examples": [
          "(২ কিলোগ্রামে) ১ কাঠি ২০ কাঠিএ ১ মন ২০ মনে ১ ভিশ চাল ২ কিলোগ্রামে ১ কাঠি হলে ধান, তিল, সর্যে ইত্যাদি কম হবে। আসলে ১ কাঠি হচ্ছে ধান্যাদি শস্য মাপার আধার একক। অতএব গ্রাম পদ্ধতিতে এটি মাপা যায না।"
        ]
      }
    ],
    "source_page": "IMG_0288"
  },
  {
    "headword": "ভুইচাল",
    "transliteration": "vuichal",
    "phonetics": "vuic∫al",
    "etymology": "[< প্রা. ভুঁই + চাল < সং ভূমি + চাল < প্রা. √চল]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "ভূমিকম্প।",
        "examples": [
          "প্রাকৃতিক কারণে পৃথিবীর অভ্যন্তরে যে কম্পন উৎপন্ন হয় তাকে ভূমিকম্প বলে।",
          "উতরেদি ইবার অলা ভুইচাল দিছে কইবার নায়।"
        ]
