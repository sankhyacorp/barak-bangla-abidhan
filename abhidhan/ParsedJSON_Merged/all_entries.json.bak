  {
    "headword": "হআদ",
    "transliteration": "hoad",
    "phonetics": "ɦɔad",
    "etymology": "[< মবা. সোয়াদ √সং স্বাদ]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "খাদ্যবস্তুর আস্বাদ। — কবিকঙ্কন মুকুন্দ দাসের চণ্ডীমঙ্গল মবা. সোয়াদ হকারীভবনে বরাকবাংলায় হআদ।",
        "examples": [
          "দুদুর কাঠলর বেনজন বড় হআদ অয়।"
        ]
      }
    ],
    "source_page": "IMG_0335"
  },
  {
    "headword": "হইরো",
    "transliteration": "hoiro",
    "phonetics": "ɦɔiro",
    "etymology": "[< হরিঅ < হরিস < প্রা. সরিস = সর্যে ]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "দানা জাতীয় শস্য; সরিষা।",
        "examples": [
          "সরিষা থেকে খাবার তেল বেরোয়। মশলা রূপেও এর ব্যবহার প্রসিদ্ধ। আছে বাংলার কাসুন্দিও। সং সর্যপ > প্রা. সরিস হকারীভবনে ‘হরিহ’ অন্ত্যব্যঞ্জনলোপ ও অপিনিহিত হয়ে ‘হইরো’।"
        ]
      },
      {
        "part_of_speech": "বাগধা. বি.",
        "definition": "প্রতিকারের মধ্যেই ক্ষতিকর উপাদান।",
        "examples": [
          "পুলিশু জেনো চুর, চুরি তনে হিনো বাচাইতো কুনে ?"
        ]
      }
    ],
    "source_page": "IMG_0335"
  },
  {
    "headword": "হউ",
    "transliteration": "hou",
    "phonetics": "ɦɔu",
    "etymology": "[< ববাং উপ্র. হ + উ নির্দেশক]",
    "senses": [
      {
        "part_of_speech": "সর্ব.",
