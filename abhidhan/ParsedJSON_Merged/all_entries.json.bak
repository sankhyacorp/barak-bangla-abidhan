  },
  {
    "headword": "মজা",
    "transliteration": "moja",
    "phonetics": "mɔʒa",
    "etymology": "[< ববাং ধাতু √মজ্]",
    "senses": [
      {
        "part_of_speech": "ক্রি.",
        "definition": "বেশি পেড়ে যাওয়া; পেকে নরম হয়ে খাওয়ার উপযুক্ত হওয়া।",
        "examples": [
          "আতা, পেঁপে প্রভৃতি ফল গাছ থেকে মোটামুটি পাকা অবস্থায় পেড়ে রাখলে নরম ও স্বাদুগন্ধযুক্ত শ্য ।"
        ]
      },
      {
        "part_of_speech": "ক্রি.",
        "definition": "নিমগ্ন হওয়া।",
        "examples": [
          "কিরতনো গিআ হে মজি রইছে।"
        ]
      },
      {
        "part_of_speech": "বাগধা. ক্রি.",
        "definition": "জব্দ হওয়া।",
        "examples": [
          "হনো গেলে তুইন মজা বুধ পাইবে।"
        ]
      }
    ],
