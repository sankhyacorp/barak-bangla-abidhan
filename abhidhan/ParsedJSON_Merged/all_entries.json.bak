  {
    "headword": "হাগচুআ",
    "transliteration": "hagochua",
    "phonetics": "ɦagɔc∫ua",
    "etymology": "[<ববাং হাগ (= আকাশ) ~ √ চ (= স্পর্শ করা)]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "অতি উঁচু চিরহরিৎ বন্য বৃক্ষ বিশেষ।",
        "examples": [
          "‘হাগচুআ’ মানে ‘আকাশ স্পর্শ করে আছে যে’। সত্যিই এমন গগনচুম্বী বৃক্ষ এ অঞ্চলে বিরল। এ গাছ ৯০-১০০ ফুট পর্যস্ত উঁচু হতে দেখা/যায়। বেড়ে মাত্র ৪ হাত। পাতা সুন্দিগাছের পাতার মতো। কাঠও সুন্দির মতো সোনালি-সাদা। বাকল সাদা।"
        ]
      }
    ],
    "source_page": "IMG_0340"
  },
  {
    "headword": "হাগর",
    "transliteration": "hagor",
    "phonetics": "ɦagɔr",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "আকাশ; স্বর্গ।",
        "examples": [
          "আখতা চাইআ দেখি, হাগরে নগরে এক ধলা বইরাগিবেটা উবাই রইছে।"
