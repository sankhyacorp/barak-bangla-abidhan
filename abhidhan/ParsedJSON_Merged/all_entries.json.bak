    "phonetics": "kakhɔrɔl",
    "etymology": "[<আঞ্চ কাকরোল <সং কর্টোটক]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "সারা গায়ে কাঁটার মতোন তীক্ষ্ণ দানা যুক্ত ফলের লতাগাছ বা ফল; কাকরোল গাছ বা ফল।",
        "examples": [
          "এই ফল তরকারি রূপে বঙ্গদেশ, আসাম সহ পূর্বভারতে খুবই জনপ্রিয়। পুর, বড়া, ভাজা, ব্যঞ্জন সবই উপাদেয়। উৎপন্ন হয় বর্ষায়।"
        ]
      }
    ],
    "source_page": "IMG_0085"
  },
  {
    "headword": "কাগজি জামুইর",
    "transliteration": "kagoji jamuir",
    "phonetics": "kagɔʒi ʒamuir",
    "etymology": "[<বাং কাগজ (<চীনা কায়গদ) + ই তপ্র-সাদৃশ্যে ~ জামুইর]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "উৎকৃষ্ট লেবু বিশেষ।",
        "examples": [
          "সবচেয়ে ক্ষুদ্র অথচ সবার সেরা এই লেবু। গাছও ছোট। রুচিকরত্বে রসে সৌগন্ধে ভেষজ ও খাদ্যগুণে উৎকৃষ্ট। কাগজের মতো পাত্লা খোসা থাকে বলেই এই নাম।"
        ]
      }
    ],
    "source_page": "IMG_0085"
  },
  {
    "headword": "কাচ",
    "transliteration": "kach",
    "phonetics": "kac∫",
    "etymology": "[< ববাং শব্দ কাচ]",
    "senses": [
