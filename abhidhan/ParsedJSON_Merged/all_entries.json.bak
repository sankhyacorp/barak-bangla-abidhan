  {
    "headword": "আস্রা",
    "transliteration": "asra",
    "phonetics": "asra",
    "etymology": "[< ববাং শব্দ আসরা]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "উচ্চ ফলনশীল উৎকৃষ্ট শালিধান।",
        "examples": [
          "সোনালি রঙের চিকন লম্বাটে ধান। এটি সাধারণত নিচু বা জলা জমিতে চাষ করা হয়। বহুপ্রকারের আসরা ধান রয়েছে। যেমন, সুনা আসরা, হরুলাকি, বড়লাকি, পাড়ই, আমন, বাদাল, বুমবাদাল ইত্যাদি।"
        ]
      }
    ],
    "source_page": "IMG_0061"
  },
  {
    "headword": "আসলা",
    "transliteration": "asola",
    "phonetics": "asɔla",
    "etymology": "[< ববাং শব্দ আসলা]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "মহিষ হালের গলদণ্ড।",
        "examples": [
          "মহিষের লাঙলে এটি ব্যবহৃত হয়। মহিষের কাঁধে যে জোয়াল থাকে তারই সঙ্গে দড়ি বা বেত দিয়ে বেঁধে গলায় ঝুলানো হয় এই ‘আসলা’। ইংরেজি V এর মতো দেখতে। কাঠের তৈরি। কাঁধ থেকে জোয়াল আলগা না হওয়ার জন্যই এটির ব্যবহার।"
        ]
      }
    ],
    "source_page": "IMG_0061"
  },
