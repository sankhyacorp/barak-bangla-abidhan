        ]
      }
    ],
    "source_page": "IMG_0305"
  },
  {
    "headword": "মুড়ি কাটা",
    "transliteration": "mudo়i kata",
    "phonetics": "muḍɔ়i kaṭa",
    "etymology": "[< ববাং মুড়ি ৢ + √কাট্ + আ]",
    "senses": [
      {
        "part_of_speech": "বিণ.",
        "definition": "মাথা কাটা গেছে এমন।",
        "examples": [
