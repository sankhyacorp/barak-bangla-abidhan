  {
    "headword": "কানখাড়া",
    "transliteration": "kanokhado়a",
    "phonetics": "kanɔkhaḍɔ়a",
    "etymology": "[<বাং কান + আঞ্চবাং খাড়া = দণ্ডায়মান]",
    "senses": [
      {
        "part_of_speech": "বিণ.",
        "definition": "সতর্ক।",
        "examples": [
          "কিগু কুনবায় আর জার হি কানখাড়া।"
        ]
      },
      {
        "part_of_speech": "বাগধা. ক্রি.",
        "definition": "উৎকর্ণ হওয়া।",
        "examples": [
