  },
  {
    "headword": "ফুড়ানি",
    "transliteration": "fudo়ani",
    "phonetics": "fuḍɔ়ani",
    "etymology": "[< ববাং নিজস্ব ধাতু √ ফুড়া ]",
    "senses": [
      {
        "part_of_speech": "ক্রি.",
        "definition": "শেষ হওয়া।",
        "examples": [
          "বন্দো ধান পাক্কের না, উগারর ধানও ফুড়ার, কিতা জে অইব।"
        ]
      },
      {
        "part_of_speech": "ক্রি.",
        "definition": "ব্যয় হওয়া।",
        "examples": [
          "চাইর মাস তনে বেতন নাই, আতর টেকাও ফুড়াইছে।"
        ]
      }
    ],
    "source_page": "IMG_0249"
  },
  {
    "headword": "ফুলকই",
    "transliteration": "fulokoi",
    "phonetics": "fulɔkɔi",
    "etymology": "[< বাং ফুল + ববাং কই =কচিফল]",
    "senses": [
      {
        "raw_text": "[< বাং ফুল + ববাং কই =কচিফল] ⇒ ‘ফুলকই এ গুরিছে পুবর ঘরর চাল বাদরদিনউ উরিঝারখান গুড়ি অনতে লাল। -আনন্দ"
      }
    ],
    "source_page": "IMG_0249"
  },
  {
    "headword": "ফুলওট্টি",
    "transliteration": "fulootti",
    "phonetics": "fulɔoṭṭi",
    "etymology": "[< বাং ফুল ~ ববাং গুট্টি]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "লৌকিক খেলা বিশেষ।",
        "examples": [
          "মারবেল গুটির মতো গোল গোল পাঁচটি নুছি এই খেলার উপকরণ। একটি, দুটি, তিনটি করে এক একবারে শূন্যে ছুঁড়ে আবার লুফে নিতে হয়। এরূপ ৬টি পর্যায়ে খেলাটি খেলতে হয়। বিভিন্ন পর্যায় হল: ফুল (১টি গুটি লোফা), দুইজাইড় (২টি গুটি লোফা), তিনজাইড় (৩টি গুটি লোফা), চাক্কী (৪টি শুটি লোফা), উট্টম (৫টি শুটি লোফা); শুট্টা বা গেম (৫টি গুটি হাতের পিঠে নিয়ে লোফা)।"
        ]
      }
    ],
    "source_page": "IMG_0249"
  },
  {
    "headword": "ফুলালি",
    "transliteration": "fulali",
    "phonetics": "fulali",
    "etymology": "[< বাং ফুল + ববাং আলা (হি. ওয়ালা) +ই সাদৃশ্যে/যুক্তার্থো]",
    "senses": [
      {
        "part_of_speech": "বিণ.",
        "definition": "ফুলের মতো সুন্দর; ফুল আঁকা। কুলকুলি আদলে তৈরি। আর ‘ফুলালি কাথা’ মানে ফুল লতা পাতা সেলাই করা ‘নকশি কাঁথা’।",
        "examples": [
          "ফুলালি ছাত্তা; ফুলালি কাথা।",
          "বরাক উপত্যকা ও বাংলাদেশে আগে বাঁশ € পাতার তৈরি অতি সুদৃশ্য ফুলের মতো কারুকার্যমন্ত্র ছাতা দেখা যেত। মুসলমান স্ত্রীলোকেরা এরূপ ছাতা বেশি ব্যবহার করতেন। এটি অনেকটা রাজছত্রের লা ভাষার অভিধান ও ভাষাতত্ত"
        ]
      }
    ],
    "source_page": "IMG_0249"
  },
  {
