    "transliteration": "vaga",
    "phonetics": "vaga",
    "etymology": "[< বাং ভাগ (=অংশ) + আ তপ্রস্বার্থে]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "অংশ; পৃথক পৃথক করে রাখা ভাগ; বিক্রয় করার জন্য থোকা থোকা করে রাখা ফল, সবজি ইত্যাদি।",
        "examples": [
          "মাছর ভাগা মরিচর ভাগা লেচুর ভাগা কাঠল বিচির ভাগা।"
        ]
      }
