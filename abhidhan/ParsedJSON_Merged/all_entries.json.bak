  {
    "headword": "ঘরুআ",
    "transliteration": "ghorua",
    "phonetics": "ghɔrua",
    "etymology": "[<বাং ঘর + উআ তপ্র. বিশেষণে]",
    "senses": [
      {
        "part_of_speech": "বিণ.",
        "definition": "ঘর সম্বন্ধীয় ; [ যে সব কথা বা কাজ ] নিজের ঘরের মধ্যে সীমাবদ্ধ থাকে এমন। াংলা ভাষার অভিধান ও ভাষাত্ত とかり ঘরো পড়া ⇒ হেরার ঘরুআ মাতো মাতি কুনু লাভ নাই। ঘরো পড়া — বাগধা. ক্রি — কোনো মেয়ের বিয়ে হওয়া। ⇒ তাই ভালা ঘরো পড়শ্লো গতিকে খানিকাপ্ড়র কুন্তার অভাব নাই।"
      }
    ],
    "source_page": "IMG_0129"
  },
