    ],
    "source_page": "IMG_0285"
  },
  {
    "headword": "ভড়",
    "transliteration": "vodo়",
    "phonetics": "vɔḍɔ়",
    "etymology": "[< ধ্ব. ভড় ভড়]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "অন্তু, যকৃৎ, পাকস্থলি প্রভৃতি পেটের যাবতীয় অঙ্গ-প্রত্যঙ্গ সমূহ; নাড়িভুঁড়ি।",
        "examples": [
          "গাড়ির তলে পড়িআ ছাগির পেটর ভড় বারই গেছে।"
        ]
      }
    ],
    "source_page": "IMG_0285"
  },
  {
    "headword": "ভলোআ",
    "transliteration": "voloa",
    "phonetics": "vɔloa",
    "etymology": "[< ববাং শব্দ ভলোআ]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "মহিষের লাঙলের Y আকৃতির দুটি শাখাযুক্ত দণ্ড।",
        "examples": [
          "ভলোআ মহিষের লাঙলের সঙ্গে যুক্ত থাকে। আবার ভলোআর দণ্ডদুটির সঙ্গে বাঁশের দণ্ডযুক্ত করে জোয়াল বাঁধা হয়। জুআল ভলোআ ১ আস্লা চাইন মহিষের ‘জুআল’"
        ]
      }
    ],
    "source_page": "IMG_0285"
  },
  {
    "headword": "ভলোআ",
    "transliteration": "voloa",
    "phonetics": "vɔloa",
    "etymology": "[< বরাক বাংলার নিজস্ব শব্দ]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "তীক্ষ্ণ ঠোঁট ও ধারালো নখযুক্ত এক প্রকারের শিকারি পাখি।",
        "examples": [
          "দেখতে বাজপাখির মতো। ঠোঁট ছোট, তরে তীক্ষ্ণ। চিলের মতো ঝাঁপিয়ে পড়ে সাপ, মাছ, ব্যাঙ ও পাখির ছানা ধরে। এই পাখি দিনে শিকার করে না। সন্ধ্যা নামলেই সে বেরিয়ে পড়ে। বরাক উপত্যকার ‘বিঝুতুতু’র সঙ্গে এর ডাকের সাদৃশ্য আছে।"
        ]
      }
    ],
    "source_page": "IMG_0285"
  },
