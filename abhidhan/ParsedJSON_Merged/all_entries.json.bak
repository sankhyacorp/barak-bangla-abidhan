        ]
      }
    ],
    "source_page": "IMG_0056"
  },
  {
    "headword": "আব্রা",
    "transliteration": "abra",
    "phonetics": "abra",
    "etymology": "[<ডি. আব্রা = বোবা]",
    "senses": [
      {
        "part_of_speech": "বিণ.",
        "definition": "যে কথা বলতে পারে না; বাকশক্তিহীন। ৯ তুলনীয় সংস্কৃত ‘অব্রুবান’। তবে বরাক- উপত্যকা ও শ্রীহট্ট অঞ্চলে ‘আব্রা’ শব্দটি ডিমাসাকাছাড়ি ভাষা থেকেই গৃহীত হয়েছে বলে মনে হয়। জ্ঞানেন্দ্রমোহন দাসেরও অভিমত ‘কাছাড়ের হৈড়িম্ব (=ডিমাসা) ভাষায় ও আসামের অনার্য ভাষায় ব্যবহৃত। বড়ো ও ককবরক ভাষায়ও শব্দটি পাওয়া যায়।"
      }
    ],
    "source_page": "IMG_0056"
  },
  {
