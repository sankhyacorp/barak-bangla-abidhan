  {
    "headword": "ইলফা",
    "transliteration": "ilofa",
    "phonetics": "ilɔfa",
    "etymology": "[<আঞ্চ. বাং শইলফা]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "গুল্ম জাতীয় গাছ বিশেষ।",
        "examples": [
          "বর্মজীবী উদ্ভিদ। পাতার ফলক করতলাকার, তিন বা পাঁচটি ভাগে খণ্ডিত কিন্তু বিযুক্ত নয়। ফুল হালকা বেগুনি-সাদা। ফল আবির লাল। এই আবির-লাল অংশটি পাঁপড়ির মতো। পাঁপড়িগুলো একটি সবুজ গুটিকে আবৃত করে রাখে। ফলের আবির-লাল কপাটিকা বা পাঁপড়ি দিয়ে উত্তম-টক চাটনি ও জেলি ইত্যাদি তৈরি করা হয়। অঘ্রানে ফুল ও পৌষে ফল র্য ।"
        ]
      }
    ],
    "source_page": "IMG_0223"
  },
