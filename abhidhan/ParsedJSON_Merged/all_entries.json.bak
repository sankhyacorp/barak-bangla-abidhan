  {
    "headword": "তা্",
    "transliteration": "ta",
    "phonetics": "ta",
    "etymology": "[<বাং তাহা]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "রকম; প্রকার।",
        "examples": [
          "অ মউআ, মোর লগে ক’তা মিঠাই আনবায়। ⇔ ক’তা = কত রকম। অপ্র. — টা; খান।",
          "ইগুতা (= এইটা)। অপ্র. [বহুবচনে] — - গুলো।",
          "সবতা (= সবগুলো)। হকলতা (= সবকিছু)।"
        ]
      },
      {
        "part_of_speech": "সর্ব.",
        "definition": "সাফল্যবাচক নির্দেশক সর্বনাম। মানুষ ও সম্পদের পরিবর্তে বসে।",
        "examples": [
          "তুমারতা (= তোমার ছেলেমেয়েরা) পুজাত আইছইন নি?",
          "আমারতা (= আমার জিনিসপত্র) বার করছি না।"
        ]
      },
      {
        "part_of_speech": "সর্ব.",
        "definition": "কোনো বিষয় বা বস্তু।",
        "examples": [
          "বাজার তনে কুনতা (= কোনো জিনিস) আনছ না নি?"
        ]
      }
    ],
    "source_page": "IMG_0192"
  },
