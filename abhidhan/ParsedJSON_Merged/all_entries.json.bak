  {
    "headword": "ফেডুআ",
    "transliteration": "fedua",
    "phonetics": "feḍua",
    "etymology": "[<ববাং শব্দ ফেডুআ]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "অতি ক্ষুদ্র আঁশযুক্ত মাছ বিশেষ।",
        "examples": [
          "চেং মাছের পোনার ভাইশের মতো ওরা দল বেঁধে থাকে। সুস্বাদু ও তৈলাক্ত। নদীতে থাকে। আষাঢ়- শ্রাবণ মাসে ফেডুআমাছ উজায়।"
        ]
      }
    ],
    "source_page": "IMG_0252"
  },
  {
    "headword": "ফেসকুল্লা",
    "transliteration": "fesokulla",
    "phonetics": "fesɔkulla",
    "etymology": "[<ববাং শব্দ ফেসকুল্লা]",
    "senses": [
      {
        "part_of_speech": "বিণ.",
        "definition": "নোংরা; অপরিচ্ছন্ন।"
      },
      {
        "part_of_speech": "বি.",
        "definition": "অপরিচ্ছন্ন ব্যক্তি। > পুরুষ ও স্ত্রী উভয়ের ক্ষেত্রেই প্রযোজ্য। যেমন, ফেসকুল্লা বেটায় সুন্দর বউ পাইছে। বেটি ফেসকুললা অইলে কিতা অইব তাইর রান্ধা অলা সোআদ। দ্র. ফেসতা, ফেসতি। দ্র. ফেসকুললি।"
      }
    ],
    "source_page": "IMG_0252"
  },
  {
    "headword": "ফেসকুল্লি",
    "transliteration": "fesokulli",
    "phonetics": "fesɔkulli",
    "etymology": "[<ববাং ফেসকুললা + ই স্ত্রীপ্রত্যয়]",
    "senses": [
