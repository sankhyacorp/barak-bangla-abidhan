  },
  {
    "headword": "সুনা আসরা",
    "transliteration": "suna asora",
    "phonetics": "suna asɔra",
    "etymology": "[< বাং সোনা + ববাং আসরা]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "শালিধানের অন্তর্গত আসরা ধানের প্রকার বিশেষ। সোনালি রঙের আসরা ধান। মাঝারি দানা। সাদা সুন্দর চাল। খেতে ভালো। কিন্তু ফলে কম।"
      }
    ],
    "source_page": "IMG_0334"
  },
  {
    "headword": "সুনারাতা",
    "transliteration": "sunarata",
    "phonetics": "sunarata",
    "etymology": "[< বাং সোনা + আঞ্চবাং রাতা]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "বোরো ধানের মধ্যে উৎকৃষ্ট ধান।",
        "examples": [
          "ধানের বর্ণ নিবিড় সোনালি। চাল ঝকঝকে সাদা। মিহি দানা। সুগন্ধিত, সুস্বাদু ও উপাদেয়। রোগীর পথ্য ছাড়াও উৎসব অনুষ্ঠানে এর সমাদর খুব। ফলন কম। বাজারে খুব কদর।"
        ]
      }
    ],
    "source_page": "IMG_0334"
  },
