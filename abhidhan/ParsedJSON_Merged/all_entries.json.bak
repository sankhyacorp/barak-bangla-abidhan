  {
    "headword": "কাশশলা",
    "transliteration": "kashoshola",
    "phonetics": "ka∫ɔ∫ɔla",
    "etymology": "[< আঞ্চ. কাশশল]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "পাশা খেলার ঘুঁটির আকৃতি অতি ক্ষুদ্র ক্ষুদ্র গোলাকার ছাপবিশিষ্ট স্বর্ণকারের সরঞ্জাম বিশেষ। স্বর্ণকারের ছাঁচ বিশেষ। এটির ছটি পিঠ বা তল। সোনা রূপার ছোট ছোট বল তৈরি করতে এটি ব্যবহাত হয়। 🎫 🕶 kaŋkɔr̞ [<সং কন্ধর = পাথরের কুচি ।"
      },
      {
        "part_of_speech": "বি.",
        "definition": "দ্র. কাকড়।"
      }
    ],
    "source_page": "IMG_0090"
  },
  {
    "headword": "কাংলা",
    "transliteration": "kangla",
    "phonetics": "kaŋla",
    "etymology": "[<আঞ্চবাং কান্লা]",
    "senses": [
      {
        "part_of_speech": "বিণ.",
        "definition": "চিতল বর্গীয় মাঝারি আকারের ক্ষুদ্র ক্ষুদ্র আঁশযুক্ত মাছ।",
        "examples": [
          "রূপোলি রং। চেপটা। মাছটির ভেতরে চুলের মতো অজস্র কাঁটা। তবে সুস্বাদু।"
        ]
      },
      {
        "part_of_speech": "বাগধা. বি.",
        "definition": "গরিবের ভালোবাসার উপহার। কি <math>ki</math> <math>|<</math>ববাং কি ভাবার্থে ও সম্বন্ধার্থে <math><</math>সং ঠক (ইক)] তপ্র. — এই তদ্ভব তদ্ধিত প্রত্যয় ভাবার্থে বা সম্বন্ধার্থে ব্যবহৃত হয়।",
        "examples": [
          "বড়মানর মাংসভাত তনে গরিবর খুদখুড়াউ ভালা :",
          "বুড়াকি < বুড়া + কি (দ্র.)</p> জুআনকি < জুআন + কি (দ্র.) মুল্লাকি < মুল্লা + কি (দ্র.) বছরকি< বছর + কি (দ্র.)"
        ]
      }
    ],
    "source_page": "IMG_0090"
  },
  {
