  {
    "headword": "দিরগা",
    "transliteration": "diroga",
    "phonetics": "dirɔga",
    "etymology": "[< দ্র. দিগরা]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "দ্র. দিগরা।",
        "cross_references": [
          "দিগরা"
        ]
      },
      {
        "part_of_speech": "বাগধা. ক্রি.",
        "definition": "নির্দিষ্ট সময় বা দিন 🗸 এগিয়ে আসা।",
        "examples": [
          "ফাঁসি, জেল বা জেল থেকে মুক্তি, চাকুরি থেকে অবসর গ্রহণ, পরীক্ষা ইত্যাদি বিষয়ের ক্ষেত্রে প্রযোজ্য।",
          "পরিক্খার দিন জত ঘনার অত রাইতকুর ঘুম কমি জার।"
        ]
      },
      {
        "part_of_speech": "বাগধা. ক্রি.",
        "definition": "রোদ ওঠা।",
        "examples": [
          "জেলা মেঘর ঘুর করছে আইজ আর দিন দিত নায। ক্রি. (আলং) — সৌভাগ্যের উদয় হওয়া; সুযোগ পাওয়া।",
          "গুআর দাম বাড়ায় গুআ বেপারি হকলর দিন দিছে, লুঠিত্রা টেকারে।"
        ]
      },
      {
        "part_of_speech": "বাগধা. ক্রি.",
        "definition": "সুযোগ আসা; ভালো সময় আসা।",
        "examples": [
          "‘মুল্কো উইল পড়ছে উপরিখাউরির দিন পড়ছে।’ — বরাকপ্রবাদ দ্র, উইল"
        ]
      }
    ],
    "source_page": "IMG_0207"
  },
