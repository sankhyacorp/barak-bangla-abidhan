        ]
      }
    ],
    "source_page": "IMG_0095"
  },
  {
    "headword": "কৃটি",
    "transliteration": "kriti",
    "phonetics": "kriṭi",
    "etymology": "[<আঞ্চ কৃটি < হি. কুট্টি ]",
    "senses": [
      {
        "part_of_speech": "বিণ.",
        "definition": "ছোট।",
        "examples": [
          "পুড়িগু কুটি রইছে, আট্তো পারে না।"
        ]
      }
    ],
    "source_page": "IMG_0095"
  },
  {
    "headword": "কৃত্তি",
    "transliteration": "kritti",
    "phonetics": "kritti",
    "etymology": "[<হি. কুত্তী = স্ত্রী কুকুর ]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "স্ত্রী কুকুর।",
        "examples": [
          "দইখনো বাড়ির কুত্তিএ তিনগু বাইচ্চা দিছে।"
        ]
      }
    ],
    "source_page": "IMG_0096"
  },
  {
    "headword": "কৃত্তি",
    "transliteration": "kritti",
    "phonetics": "kritti",
    "etymology": "[< ববাং শব্দ কুত্তি]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "ভাঁড়ারের শস্যধ্বংসকারী একপ্রকার পোকা।",
        "examples": [
          "সাদা রঙের পাখাওলা অতি ক্ষুদ্র পতঙ্গ। এটি ধান ও গমের ভাঁড়ারে আক্রমণ করে। আবার চাল ডাল আটা ময়দা প্রভৃতিতে এক রকমের ঘন বাদামি অতি ছোট-কীট দেখা যায়। এগুলিকেও লাল কুত্তি বলা ২৩।",
          "কুত্তিএ ধরিআ উগারর ধান আধাআধি করিলাইছইন।"
        ]
      }
    ],
    "source_page": "IMG_0096"
  },
  {
    "headword": "কৃতিপুক",
    "transliteration": "kritipuk",
    "phonetics": "kritipuk",
    "etymology": "[< দ্র. কুত্তিপুক]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "ধান বা চালের কেড়ি পোকা; Rice Weevil পূর্ণাঙ্গ কীট তিন মিলিমিটার লম্বা। রং বাদামি। মাথায় ঈষৎ বাঁকানো ও সরু লম্বা শুঁড় আছে। কীটের পিঠে অনেক সময় চারটি লালচে বা হলুদরঙের বিন্দুবৎ দাগ দেখা যায়। পূর্ণবৃদ্ধিপ্রাপ্ত পোকার মাথা হলুদাভ-বাদামি রঙের হয়। স্ত্রী কেড়ি পোকা প্রায় ৪০০টি পর্যন্ত ডিম পাড়ে এবং ছ-সাত দিনের মধ্যে বাচ্চা বেরিয়ে এসে শস্যদানা ছিদ্র করে সারাংশ খেয়ে ফেলে। বছরে পাঁচ-সাতটি প্রজন্মের সৃষ্টি করে। বৈজ্ঞানিক নাম- Sito Philus Oryzae."
      }
    ],
    "source_page": "IMG_0096"
  },
  {
    "headword": "কুথানি",
    "transliteration": "kuthani",
    "phonetics": "kuthani",
    "etymology": "[<সং কুন্থন]",
    "senses": [
      {
