    "source_page": "IMG_0092"
  },
  {
    "headword": "হ্নিতানে",
    "transliteration": "hnitane",
    "phonetics": "ɦnitane",
    "etymology": "[<ববাং শব্দ কিন্তানে]",
    "senses": [
      {
        "raw_text": "[<ববাং শব্দ কিন্তানে] কলা ক্রিবিণ./অনু. — দরুন; কারণে; জন্য। ⇒ বেমারর কিন্তানে পানর ধান লইআ জাইতাম পারছি না। ⇒ তুমারতান আলখান পাইসলাম কিন্তানে দুইগুটি খেত করশ্লাম।"
      }
    ],
    "source_page": "IMG_0092"
  },
