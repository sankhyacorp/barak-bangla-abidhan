  },
  {
    "headword": "বইনা",
    "transliteration": "boina",
    "phonetics": "bɔina",
    "etymology": "[<ববাং শব্দ বইনা]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "ধানের ক্ষতিকর পোকা বিশেষ; চুষি পোকা।",
        "examples": [
          "অতি ছোট কালো রঙের পোকা। প্রায় সবরকমের ধানের চারাতলায় এরা ঝাঁকে ঝাঁকে আক্রমণ করে। গাছের রস চুষে খায়। ফলে চারাগাছ শুকিয়ে মরে যায়। এদের দেহে পাখা থাকতে পারে আবার নাও থাকতে পারে। পাখা থাকলে দীর্ঘ চুল বিশিষ্ট পাখা থাকে। পোকাটি খালি চোখে দেখতে পাওয়া যায় না। ধান এই পোকার দ্বারা আক্রান্ত হলে ‘বইনায় ধরা’ বলে। বৈজ্ঞানিক নাম— Thrips Oryzab."
        ]
      },
      {
        "part_of_speech": "বি.",
        "definition": "দ্র. বায়না।",
        "cross_references": [
          "বায়না"
        ]
      }
    ],
    "source_page": "IMG_0252"
  },
  {
    "headword": "বইনারি",
    "transliteration": "boinari",
    "phonetics": "bɔinari",
    "etymology": "[< ববাং বইন + আরি তপ্র. সমতুল্যার্থে]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "বান্ধবী; নারীবন্ধু; সখী।",
        "examples": [
          "'বইনারি গ বইনারি হিংগাইর তুলাত জাইতায়নি হিংগাইরে দিল খুচা বইনারির নাক বুচা।'— বরাক ছড়া"
        ]
      }
    ],
    "source_page": "IMG_0253"
  },
  {
    "headword": "বইনারিআলা",
    "transliteration": "boinariala",
    "phonetics": "bɔinariala",
    "etymology": "[< ববাং বইনারি ~ আলা তপ্র নামপদে]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "মেয়ের সঙ্গে মেয়ের বন্ধুত্ব; সখীত্ব।",
        "examples": [
          "বরাক উপত্যকায় বারুণী পূণ্যস্নান লগ্নে কুমারী বা নবোঢ়াদের মধ্যে বইনারিআলা বা সখী সম্পর্ক পাতানোর প্রথা আছে। লোকবিশ্বাস, বারুণীর পূণ্য মানের সময় আনুষ্ঠানিক ‘সখীসম্পর্ক’ করলে তা আজীবন অক্ষুন্ন থাকে।"
        ]
      }
    ],
    "source_page": "IMG_0253"
  },
  {
    "headword": "বইরাতি",
    "transliteration": "boirati",
    "phonetics": "bɔirati",
    "etymology": "[< মবা. বৈরাতি = বরযাত্রী]",
    "senses": [
