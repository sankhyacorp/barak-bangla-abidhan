  {
    "headword": "লেসরা",
    "transliteration": "lesora",
    "phonetics": "lesɔra",
    "etymology": "[< দ্র. লেচ্ছড়]",
    "senses": [
      {
        "part_of_speech": "বিণ.",
        "definition": "যে কাজ করতে অনেক সময় নষ্ট করে; দীর্ঘসূত্রী।",
