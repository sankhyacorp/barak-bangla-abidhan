  },
  {
    "headword": "অআ",
    "transliteration": "oa",
    "phonetics": "ɔa",
    "etymology": "[<বাং √ হ]",
    "senses": [
      {
        "part_of_speech": "ক্রি.",
        "definition": "জন্ম হওয়া",
        "examples": [
