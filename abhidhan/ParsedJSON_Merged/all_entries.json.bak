  {
    "headword": "ঘাগ্রা",
    "transliteration": "ghagra",
    "phonetics": "ghagra",
    "etymology": "[< আঞ্চবাং ঘাগরা]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "একপ্রকার গুল্ম।",
        "examples": [
          "সবুজ গুলা। পাতা করতলাকৃতি। অনেকটা বেগুনের পাতার মতো। ফুল সাদা, বেগুনি পোছ। ফল ক্যাপসুল বা কালোজামের আকার। রং সবুজ। ফলের গা তারের মতো সরু কাঁটায় আবৃত। পতিত জমি বা পথের ধারে গাছটি পাওয়া যায়।"
        ]
      }
    ],
    "source_page": "IMG_0130"
  },
  {
    "headword": "যাও",
    "transliteration": "jao",
    "phonetics": "ʒao",
    "senses": [
      {
        "part_of_speech": "বিণ.",
        "definition": "অভিজ্ঞতাসম্পন্ন ও চালাক। ঘটেছে। বাংলাতে ধূর্ত এখানে বিশেষ অভিজ্ঞতা সম্পন্ন ও বুদ্ধিমান।",
        "examples": [
          "মামলা খেলাইতে ঘাগু মানর লগে জুক্তি করা ভালা।"
        ]
      }
