  {
    "headword": "ফাসজাল",
    "transliteration": "fasojal",
    "phonetics": "fasɔʒal",
    "etymology": "[< সং পাস = জাল]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "মাছ ধরার জাল বিশেষ। সিসার গুটি থাকে আড়াই কেজির মতোন। একখানা নৌকা নিয়ে দুজন লোক বড় ছোট সবরকম মাছ ধরতে পারে। শোনা যায়, এই জালটি পশ্চিমবঙ্গ ও বিহার অঞ্চল থেকে এসেছে।",
        "examples": [
          "১০ বর্গ সেন্টিমিটার থেকে ২০ বর্গ সেন্টিমিটার পর্যন্ত নানা মাপের ফা বা জালের ছিদ্র থাকে। এতে লা ভাষার অভিধান ও ভাষাত ত্ত"
        ]
      }
    ],
    "source_page": "IMG_0246"
  },
