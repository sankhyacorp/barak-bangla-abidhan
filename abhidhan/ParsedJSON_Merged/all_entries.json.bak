  {
    "headword": "কাঠল",
    "transliteration": "kathol",
    "phonetics": "kaṭhɔl",
    "etymology": "[<বাং কাঁঠাল < প্রা. কংটঅল < সং কন্টকফল ]",
    "senses": [
      {
