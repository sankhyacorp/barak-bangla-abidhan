  {
    "headword": "মেড়া পিঠা",
    "transliteration": "medo়a pitha",
    "phonetics": "meḍɔ়a piṭha",
    "etymology": "[< ধ্ব. মেড়মেড় (= নরমভাব সূচক) ~ পিঠা]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "দ্র. গাইআড়ি পিঠা। মেড়ামেড়ির ঘর — বাগধা. বি. (ব্যাঙ্গার্থে) নবদম্পতির ঘর।",
        "cross_references": [
          "গাইআড়ি পিঠা"
        ],
        "examples": [
          "পৌষ সংক্রান্তির আগের দিন রাত শেষে বাঁশ- খড় দিয়ে তৈরি চুড়া-তোলা-ঘর জ্বালানো হয়। এই ঘরের নাম ‘মেড়ামেড়ির ঘর বা উলির ঘর’। দ্র. উলির ঘর।"
        ]
      }
    ],
