  {
    "headword": "কাউআ হিনান",
    "transliteration": "kaua hinan",
    "phonetics": "kaua ɦinan",
    "etymology": "[<ববাং কাউআ ~ ববাং হিনান <মবা. সিনান]",
    "senses": [
      {
        "part_of_speech": "বাগধা. বি.",
        "definition": "অল্পজল দিয়ে স্নান সারা; কোনোরকমে দায়মুক্ত হওয়া।",
        "examples": [
          "কুড়িআ মানে কাউআ হিনান করইন।",
          "পুড়ির বিআত সুনারুপা দিতাম পারতাম নায়, খালি তিল অরতকি দি কাউআ হিনান দিমু।"
        ]
      }
    ],
    "source_page": "IMG_0084"
  },
  {
    "headword": "কাউলুলি",
    "transliteration": "kaululi",
    "phonetics": "kaululi",
    "etymology": "[< ববাং কাউআ + লুলি সংকোচনে]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "একপ্রকার ফলের গাছ। Ъ কাএম ভূবির চেয়ে একটু বড়। ফলটি কাকপাখিদের অতিপ্রিয়। তাই এই নাম। স ববাং কাউআ (= কাক) + লুলি < বাং লোল </p> (=লকলকে) < সাং লুল + অ।",
        "examples": [
          "কমলা রঙের ফল। আকৃতিতে ভূবি বা লটকা ফলের চেয়ে সামান্য বড়। চারটি কোয়া থাকে। কাঁচাফলের স্বাদ খুব টক আবার পাকলে মিষ্টি। এ ফলের গাছটি পঁচিশ/ত্রিশ হাত পর্যন্ত হয়। পাতা"
        ]
      }
    ],
    "source_page": "IMG_0084"
  },
  {
    "headword": "কাএম",
    "transliteration": "kaem",
    "phonetics": "kaem",
    "etymology": "[<আ. কাইম = স্থায়ী]",
    "senses": [
      {
        "part_of_speech": "বিণ.",
        "definition": "মজবুত ; স্থায়ী",
        "examples": [
          "কেজা মারি বআইলে গিআ খুটা কায়েম অইব। কাং ভব কাং শ্বা (< ববার নে কাং ভব কাং শ্বা বিকাস কাং শ্বা বিকাস কাং শ্বা বিকাস কাং শ্বা বিকাস কাং শ্বা বিকাস কা"
        ]
      },
      {
        "part_of_speech": "বি.",
        "definition": "পর্ণমোচী বৃক্ষ বিশেষ। ২৪ — ২৮ হাত উঁচু বৃক্ষ। নিমের মতো পাতা। গাছের বাকল ফাটা ফাটা। কালোজামের মতো ফল। স্বাদে টক। উৎকৃষ্ট কাঠ। লাল রং। ঘরের খুঁটির জন্য প্রশস্ত । বৈজ্ঞানিক নাম— Garuga Pinnata"
      }
    ],
    "source_page": "IMG_0085"
  },
  {
    "headword": "কাও",
    "transliteration": "kao",
    "phonetics": "kao",
    "etymology": "[<আঞ্চবাং কাও; কাউ]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "এক প্রকার চিরসবুজ লতা গাছ।",
        "examples": [
          "এর পাতা কেন্দুক বা গাবগাছের পাতার মতো। ফল কমলাম মতো। পাকলে লাল। এই লতা কোনো গাছকে অবলম্বন করে উপরে ওঠে। অবলম্বিত গাছটি যত উঁচু হবে কাওলতা ততই বাড়বে। এর ফল কাকপাখি খেতে খুব ভালোবাসে বলেই এই নাম। লতাটি অরণ্যে জন্মে।"
        ]
      }
    ],
    "source_page": "IMG_0085"
  },
  {
    "headword": "কাক",
    "transliteration": "kak",
    "phonetics": "kak",
    "etymology": "[< ববাং শব্দ কাক]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "একপাত্র থেকে অন্যপাত্ত্রে তরল পদার্থ ঢালার জন্য ব্যবহৃত চুঙি বিশেষ; Funnel."
      }
    ],
    "source_page": "IMG_0085"
  },
  {
    "headword": "কাকইন",
    "transliteration": "kakoin",
    "phonetics": "kakɔin",
    "etymology": "[< ববাং শব্দ কাকইন]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "বীরুৎ জাতীয় শস্য বিশেষ। শেকড় বের হয়। পাতা সরু ও ভল্লাকার। ফল সাগুদানার মতো। সাদা ও গোল। এই শস্য থেকে উত্তম খই হয়। পাখিদের প্রিয় খাদ্য। খইয়ের জন্য বরাক উপত্যকায় বাঙালি ও উপজাতি লোকেরা এর চাষ করেন। এই শস্য থেকে রুটিও তৈরি হয়। সাধারণত উটু জমিতে ভালো চাষ হয়। বাজারেও কদর আছে।",
        "examples": [
          "আঁখগাছের মতো কাণ্ড ও পাতা। গাছ ৬/৭ লম্বা হয়, রেসিম পুষ্প বিন্যাস। কাণ্ডের নীচের পর্ব থেকে বরাক উপত্যকার আঞ্চলিক বাং . . . . . ."
        ]
      }
    ],
    "source_page": "IMG_0085"
  },
