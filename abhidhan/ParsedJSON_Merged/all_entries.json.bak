    "source_page": "IMG_0166"
  },
  {
    "headword": "ঝাকি",
    "transliteration": "jhaki",
    "phonetics": "ʒhaki",
    "etymology": "[< ববাং ঝাঁক (=দল) + ই তপ্র. করণে বি. — বড় গোলাকার জাল বিশেষ। ⇒ জালটির প্রান্তে লোহার ছোট ছোট গুটি লাগানো থাকে। বিশেষ কৌশলে জালটি আকাশে উড়িয়ে মাছের ঝাঁক লক্ষ্য করে ফেলতে হয়। এই জালের দারা মাছের ঝাঁক আটকানো যায় বলে এই নাম। ছোট-বড় সবরকম মাছই এ জাল দিয়ে ধরা যায়। ঝাখা ক3hakha [< আঞ্চবাং ঝাঁকা = খাচা বিশেষ]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "বড় গোলাকার জাল বিশেষ।",
        "examples": [
          "জালটির প্রান্তে লোহার ছোট ছোট গুটি লাগানো থাকে। বিশেষ কৌশলে জালটি আকাশে উড়িয়ে মাছের ঝাঁক লক্ষ্য করে ফেলতে হয়। এই জালের দারা মাছের ঝাঁক আটকানো যায় বলে এই নাম। ছোট-বড় সবরকম মাছই এ জাল দিয়ে ধরা যায়। ঝাখা ক3hakha [< আঞ্চবাং ঝাঁকা = খাচা বিশেষ] লা ভাষার অভিধান ও ভাষাতত্ত"
        ]
      },
      {
        "part_of_speech": "বি.",
        "definition": "হাঁস বা মুরগির ছানা ঢেকে রাখার জন্য বাঁশের তৈরি খাঁচা।",
        "examples": [
          "আসর ছাওগুইন ঝাকাদি গুরি থ নাইলে কাউআয় নিবগি। ঝাটা 13hata [< ববাং শব্দ ঝাটা]"
        ]
      },
      {
        "part_of_speech": "বি.",
        "definition": "মাছ শিকারের অস্ত্র বিশেষ। গেঁথে ‘ঝাটা’ তৈরি করা হয়। এটি ‘কুসা’ থেকে বড়। ঝান্টি 13anţi [<হি. ঝান্ডা = পতাকা]",
        "cross_references": [
          "কুসা"
        ]
      },
      {
        "part_of_speech": "বি.",
        "definition": "পতাকা; নিশান।",
        "examples": [
          "বউত মানু ঝানটি উড়াইআ জাইত্রা। ঝাফ্ 13haf [< ধ্ব. ঝপ্ = ঢাকনা ফেলার আওয়াজ]"
        ]
      },
      {
        "part_of_speech": "বি.",
        "definition": "ছোট দোকান ঘরের সম্মুখের খোলা অংশের আচ্ছাদন।",
        "examples": [
          "বাঁশবেত বা টিন-কাঠ দিয়ে তৈরি করা হয়় এই আচ্ছাদন। ঝাফরি কʒhafri [< ববাং ঝাফ +র কোমলতায় +ই সাদৃশ্যে"
        ]
      },
      {
        "part_of_speech": "বি.",
        "definition": "ছোট ছোট ছিদ্র যুক্ত বড় ঢাকনা বা বেড়া বা মাচান।",
        "examples": [
          "উরি ঝারর লাগি এখান ঝাফরি বানাইতাম। ঝাফড়া 13hafṛa [< বাং ঝাঁক + ড়া অনাদরে]"
        ]
      },
      {
        "part_of_speech": "বি.",
        "definition": "অবিন্যস্ত গুচ্ছ; ঘন ও জট পাকানো গোছা।",
        "examples": [
          "গাছর ঝাফড়াত চল্ লুকাই রই।"
        ]
      }
    ],
    "source_page": "IMG_0166"
  },
  {
