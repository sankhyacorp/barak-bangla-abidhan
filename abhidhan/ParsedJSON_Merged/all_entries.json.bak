  {
    "headword": "পাটোআ",
    "transliteration": "patoa",
    "phonetics": "paṭoa",
    "etymology": "[< ববাং শব্দ পাটোআ)]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "বিষধর সাপ বিশেষ।",
        "examples": [
          "বরাক উপত্যকায় পাটোয়া সাপ সর্বজন পরিচিত। হলদে-কালোতে চৌকোণা রং-ছাপ। ফণা আছে। লম্বায় প্রায় আড়াই হাত হতে পারে। রাতে চরে। এর দৃদিকে মুখ। সাপটি মাছ বেঙ খেতে খুব ভালোবাসে।"
        ]
      }
    ],
    "source_page": "IMG_0230"
  },
  {
    "headword": "পাত",
    "transliteration": "pat",
    "phonetics": "pat",
    "etymology": "[< সং পাত্র]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "আহারের জন্য পেতে দেওয়া থালা বা পাতা।",
        "examples": [
          "বইরাতির পাতো মাছউছ বেশ্করি দিবায়। পাত<sub>s</sub> Pat [< সং পত্র =পাতা]"
        ]
      },
      {
        "part_of_speech": "বি.",
        "definition": "গাছের পাতা। ‘গাইনজার চিরল চিরল পাত <math>\\Rightarrow</math> গাইনজা খাইআ মগ্নো অইআ নাচে নাচে ভুলানাথ।’ — বরাকগীত"
      },
      {
        "part_of_speech": "বি.",
        "definition": "পাতার মতো চেপ্টা ধাতুখণ্ড। লুআর পাত > তামার পাত"
      }
    ],
    "source_page": "IMG_0230"
  },
