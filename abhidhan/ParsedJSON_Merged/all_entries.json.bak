    "transliteration": "thaukorain",
    "phonetics": "ṭhaukɔrain",
    "etymology": "[<ববাং ঠাকুর + আইন লিপ্র স্ত্রীং]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "পুরোহিতের স্ত্রী।",
