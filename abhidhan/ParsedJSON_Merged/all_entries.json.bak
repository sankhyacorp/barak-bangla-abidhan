  {
    "headword": "ত্ত্বকতি",
    "transliteration": "ttbokoti",
    "phonetics": "ttbɔkɔti",
    "etymology": "[< মারা. গুপ্তী = Sword-Stick]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "হাতিধরার কাজে ব্যবহৃত লোহার পরিচালন যন্ত্র।",
        "examples": [
          "ভারী ও তীক্ষ্ণ তিরের ফলার মতো যন্ত্র। লৌহনির্মিত। হাতলে ছিদ্র করে একগাছা দড়ি লাগানো থাকে। হাতি ধরার সময় মাহুত এ যন্ত্র দিয়ে খুঁচিয়ে হাতিকে চলার সংকেত দেয়। এক অনুচ্চারিত হাতি চালনার পরিভাষা।"
        ]
      }
    ],
    "source_page": "IMG_0126"
  },
