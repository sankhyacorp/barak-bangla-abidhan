  },
  {
    "headword": "ভায়ভায়",
    "transliteration": "vajo়vajo়",
    "phonetics": "vaʒɔ়vaʒɔ়",
    "etymology": "[< দ্র. বায়বায়]",
    "senses": [
      {
        "part_of_speech": "ক্রিবিণ.",
        "definition": "না চটিয়ে; ধীরে ধীরে; কোনোরূপ বিরোধিতা না করে।",
        "examples": [
          "দ্র. বায় বায়।",
          "ভায়ভায় টেকাটাইন আগে উগাইলাই বাদে শুধ লইমু।"
        ]
      }
    ],
