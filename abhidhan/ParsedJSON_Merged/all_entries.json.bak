  },
  {
    "headword": "খেমতা",
    "transliteration": "khemota",
    "phonetics": "khemɔta",
    "etymology": "[<বাং ক্ষমতা]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "সামর্থা।",
        "examples": [
          "‘খাবাইবার খেমতা নাই বেটা কমনি তিন মাউগর হাই। —বরাকপ্রবাদ"
        ]
      },
      {
        "part_of_speech": "বাগধা. ক্রি.",
        "definition": "নিম্মল চেষ্টা করা।",
        "examples": [
          "চাউকরির লাগি খেরো দা ভাংগিআ লাভ নাই, এরতনে আরো কুনু পথ কর।"
        ]
      },
      {
        "part_of_speech": "বাগধা. ক্রি.",
        "definition": "হাতে পায়ে ধরা; যেকোনো কন্ট সহ্য করা।",
        "examples": [
          "দাদি এ কইতা, 'মামলত লইতে খেরো ফুত।'"
        ]
      },
      {
        "part_of_speech": "বিণ.",
        "definition": "নিতান্ত তুচ্ছ।",
        "examples": [
          "'শারথো (= স্বার্থ) থাকলে হুনবো থুড়া অইন্নো মাত খেরর লুড়া।’ — আনন্দ"
        ]
      }
    ],
    "source_page": "IMG_0112"
  },
  {
    "headword": "খেড়া",
    "transliteration": "khedo়a",
    "phonetics": "kheḍɔ়a",
    "etymology": "[< ববাং শব্দ খেড়া]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "নব যৌবনবান মহিষ শাবক।",
        "examples": [
          "স্ত্রীলিঙ্গে খেড়ি। প্রথম যৌবনে উপনীত চঞ্চল যুবক যুবতীর বেলায়ও শব্দদুটি প্রযোজ্য। তবে তা প্রয়োগ করবেন রঙ্গরস করতে পারেন এমন সম্পর্কিত কেউ।",
          "দুদুএ কইত্রা, ‘খেড়ারে গুড়ফেরানিত দেও নাইলে তেজ কমতো নায়।"
        ]
      }
    ],
    "source_page": "IMG_0113"
  },
