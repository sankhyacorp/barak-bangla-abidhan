    "phonetics": "lilla",
    "etymology": "[< আ. লিল্লাহ = ধর্মের উদ্দেশ্যে দান]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "দান; বিনিময় ছাড়া যা পাওয়া যায়।",
        "examples": [
          "রাগ ইখান মুই লিল্লা পাইসলাম। > অর্থের অবনমন ঘটেছে। ধর্মের উদ্দেশ্যে দান থেকে যে-কোনো দান।",
