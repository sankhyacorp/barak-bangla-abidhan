  {
    "headword": "আমদা",
    "transliteration": "amoda",
    "phonetics": "amɔda",
    "etymology": "[<ফা. আমাদ = প্রচুর ?]",
    "senses": [
      {
        "part_of_speech": "বিণ.",
        "definition": "প্রচুর।",
        "examples": [
          "বাংলাদেশো মাছ এখেরে আমদা, জতো খাইতায় পার।"
