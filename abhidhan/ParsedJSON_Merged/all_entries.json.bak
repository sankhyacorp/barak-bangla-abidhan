  {
    "headword": "আফানি পিঠা",
    "transliteration": "afani pitha",
    "phonetics": "afani piṭha",
    "etymology": "[<ববাং শব্দ আফানি ~ পিঠা]",
    "senses": [
      {
        "raw_text": "[<ববাং শব্দ আফানি ~ পিঠা]"
      },
      {
        "part_of_speech": "বি.",
        "definition": "বিরন চালের গুড়ো দিয়ে তৈরি হালকা পিঠা বিশেষ।",
        "examples": [
          "বিরন চাল ভিজিয়ে জল ঝরিয়ে এমনভাবে গুড়ো তৈরি করতে হবে বেশিক্ষণ যাতে হাওয়া না লাগে। ত এবং শুকনো থাকে। এরপর কড়াই আগুনের অল্প তাপে বসিয়ে পাতৃলা প্রলেপের মতো করে দিলেই পিঠা প্রস্তুত হয়।"
        ]
      }
    ],
    "source_page": "IMG_0055"
  },
  {
