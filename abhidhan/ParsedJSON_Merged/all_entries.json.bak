  {
    "headword": "পেচকুনা",
    "transliteration": "pechokuna",
    "phonetics": "pec∫ɔkuna",
    "etymology": "[< ধ্ব. ফিচিন ফিচিন = ফিঙে পাখির ডাকা]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "ফিঙে পাখি; Black Drongo।",
        "examples": [
          "মিশমিশে কালো লম্বা লেজ বিশিষ্ট শাখাশ্রয়ী পাখি। কীটপতঙ্গ এদের প্রধান খাদ্য। ফিঙে খুব সাহসী ও ঝগড়াটে। বরাক উপত্যকায় এদের সাহসিকতা নিয়ে উপকথা প্রচলিত আছে। বৈজ্ঞানিক নাম — Dicrurus Adsimilis",
          "'হাজিতে-পাড়িতে পেচকুনা রাজা।' –বরাকপ্রবাদ"
        ]
      },
      {
        "part_of_speech": "বাগধা. ক্রি.",
        "definition": "চাতুরী করা; কৃট-কৌশল অবলম্বন করা।",
        "examples": [
          "টেকাগুইন মারার লাগি হে পেচপাচ্চা করের।"
        ]
      }
    ],
    "source_page": "IMG_0239"
  },
  {
    "headword": "পেচারা",
    "transliteration": "pechara",
    "phonetics": "pec∫ara",
    "etymology": "[< বাং পাঁচা + বাঁশ]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "ভালুকা বা ঝাই বরুআর মতো বাঁশ বিশেষ।",
        "examples": [
          "এ বাঁশ ২৫/৩০ হাত লম্বা হয়। তবে বরুয়ার মতো বড়, পুরু ও শক্ত নয়। কিছুটা হালকা। ঝাড় বাঁধে। বাঁশ হয় খাড়া ঋজু ও গোটা গোটা। বরাক উপত্যকা সহ দক্ষিণ আসামে এ জাতীয় বাঁশ প্রচুর উৎপন্ন হয়। এর বৈজ্ঞানিক নাম Dendrocalamus Hamiltonii"
        ]
      }
    ],
    "source_page": "IMG_0239"
  },
