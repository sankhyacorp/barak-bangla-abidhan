  {
    "headword": "বাদা",
    "transliteration": "bada",
    "phonetics": "bada",
    "etymology": "[< দ্র. বাদা,]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "কুড়াল, কোদাল প্রভৃতির অস্ত্রের হাতল।",
        "examples": [
          "কুড়ালর বাদা; দা'র বাদা; কাচির বাদা। বামুলা ত্বভাত — বাগধা. বি. — মূতাতাগা বাধিঃ যৌনব্যাধি।",
          "হুনছি তান বাদুআ বেমার অইছে।"
        ]
      }
    ],
    "source_page": "IMG_0269"
  },
