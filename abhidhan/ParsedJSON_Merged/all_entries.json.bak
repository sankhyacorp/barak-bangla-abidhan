  },
  {
    "headword": "টেকি",
    "transliteration": "teki",
    "phonetics": "ṭeki",
    "etymology": "[<বাং টেকা + ই যুক্তার্থে]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "টাকার নোট বা মুদ্রা।",
        "examples": [
          "একটেকি — একটাকার নোট বা মুদ্রা পাঁচটেকি — পাঁচটাকার নোট বা মুদ্রা দশটেকি — দশ টাকার নোট একশোটেকি — একশো টাকার নোট।"
        ]
