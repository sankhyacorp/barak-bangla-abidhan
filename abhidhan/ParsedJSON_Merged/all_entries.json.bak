    "transliteration": "khali",
    "phonetics": "khali",
    "etymology": "[< ‘আ. খালিস্ = অমিশ্র, কেবল’ — কোষ]",
    "senses": [
      {
        "raw_text": "[< ‘আ. খালিস্ = অমিশ্র, কেবল’ — কোষ] যোজ — শুধু [ প্রতিষেধক]। ⇒ খালি খাইআ ঘুমাইআ কাটাইলে অইত নায়"
      },
      {
        "part_of_speech": "বাগধা. ক্রি.",
        "definition": "আত্মমর্যাদায় আঘাত পাওয়া; মনে আঘাত পাওয়া।",
        "examples": [
          "'কইন্না বেটিএ কই দিছে তে আনলায় কেনে। ইখান হুনিআ বুড়া বেটির ধরি লাইছে খালো কমরো কাপড় পেচ মারি উঠি গেছে ফালো।’ —মাহতাবুর"
        ]
      }
    ],
    "source_page": "IMG_0108"
