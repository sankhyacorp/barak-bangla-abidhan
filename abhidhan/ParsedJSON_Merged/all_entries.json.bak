  {
    "headword": "রিঠাই",
    "transliteration": "rithai",
    "phonetics": "riṭhai",
    "etymology": "[< সং রীঠা = ফল বিশেষ]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "‘আঁষ ফলের মত গোল কঠিনত্বক ফল বিশেষ। ইহা জলে ভিজাইলে সাবানের ফেনার মত ফেনা হয় বলিয়া সংস্কৃতে ইহার নামান্তর ‘‘ফেনিল’’ এবং ইংরাজিতে ‘‘সাবানফল’’ soapnut। রীঠার জলে পশমী বস্ত্রাদি ধৌত করা হয়।’ জ্ঞানেন্দ্র মোহন দাস",
        "examples": [
          "বরাক উপত্যকা সহ উত্তর-পূর্ব ভারতে সাবান রূপে রিঠার ব্যবহার অতি প্রাচীন। রিঠা ফলের কদর বাজারেও আছে।"
        ]
      }
    ],
    "source_page": "IMG_0310"
  },
  {
    "headword": "রিত",
    "transliteration": "rit",
    "phonetics": "rit",
    "etymology": "[< আমবা রিত্ < সং রীতি]",
    "senses": [
