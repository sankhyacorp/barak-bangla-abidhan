  },
  {
    "headword": "টুপা",
    "transliteration": "tupa",
    "phonetics": "ṭupa",
    "etymology": "[<আঞ্চবাং টুপা]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "বোরো ধান বিশেষ। শ্নকা সোনালি রঙের ধান। চাল সাদা। গোলাকৃতি। ভাত লম্বাটে হয়। মাঝারি দানা। অল্প গন্ধ আছে। সুস্বাদু। ফলন প্রচুর।"
      }
    ],
    "source_page": "IMG_0174"
  },
  {
    "headword": "টুপিরভাট্টা",
    "transliteration": "tupirovatta",
    "phonetics": "ṭupirɔvaṭṭa",
    "etymology": "[<আঞ্চ. টোপিয়া + ববাং ভাট্টা]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "আউশ ধান বিশেষ।",
        "examples": [
          "অনুষ্কৃল সোনালি রঙের মাঝারি দানার ধান। চাল সাদা। উৎপাদন ভালো। খেতেও মন্দ নয়।"
        ]
      }
    ],
    "source_page": "IMG_0174"
  },
  {
