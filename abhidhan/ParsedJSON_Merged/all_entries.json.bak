  },
  {
    "headword": "কালিগদা",
    "transliteration": "kaligoda",
    "phonetics": "kaligɔda",
    "etymology": "[<বাং কাল (= কালো) + ই ~ গদা]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "একপ্রকার উৎকৃষ্ট বাঁশ।",
        "examples": [
          "বাঁশটি বরুয়াবাঁশের মতো বড় ও অত্যন্ত ভারী। ভারী ও শক্ত হওয়ার জন্য একে ‘গদা’র তুল্য বলা হয়। বাঁশের রং খুব গাঢ় সবুজ অর্থাৎ কালচে সবুজ তাই নাম হয়েছে ‘কালিগদা’। বৃহত্তর বরাক উপত্যকার বাঁশবনে বাঁশটি সহজলভ্য। বৈজ্ঞানিক নাম— Bambusa Valgars."
        ]
      }
    ],
    "source_page": "IMG_0090"
  },
  {
    "headword": "কালিজিরাধান",
    "transliteration": "kalijiradhan",
    "phonetics": "kaliʒiradhan",
    "etymology": "[<বাং কাল + ই ~ জিরা ]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "উৎকৃষ্ট শালি ধান।",
        "examples": [
          "কালো রঙের জিরার মতো চিকন দানা বলেই এই নাম। চাল মিহি ও হলদে সাদা। অতি রুচিকর, স্বাদু ও উপাদেয়। সুগন্ধে অতুল্য। রোগীর উত্তম পথ্য।"
        ]
      }
    ],
    "source_page": "IMG_0090"
  },
  {
