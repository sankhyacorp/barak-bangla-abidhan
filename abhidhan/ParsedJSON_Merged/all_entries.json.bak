  {
    "headword": "লুত",
    "transliteration": "lut",
    "phonetics": "lut",
    "etymology": "[< ধ্ব. লুত্লুত্ = সিক্তভাব সূচক]",
    "senses": [
      {
        "part_of_speech": "বিণ.",
        "definition": "ঘামে সিক্ত; বৃষ্টির জলে ভেজা; জবজবে।",
        "examples": [
          "গরমে ঘামে তাই একেরে লৃত।"
