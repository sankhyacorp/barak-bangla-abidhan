  {
    "headword": "ওলাল",
    "transliteration": "olal",
    "phonetics": "olal",
    "etymology": "[<ববাং শব্দ গুলাল]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "সুমিষ্ট ফলের বিক্ষ বিশেষ।",
        "examples": [
          "গাছটি ২৫ হাত পর্যন্ত উঁচু হয়। পাতা ঘন সবুজ। আমপাতার মতো। ফল গোলাকার ভেতরে তিনটে থেকে চারটি কোয়া থাকে। কোয়াগুলি সুমিষ্ট। বিচি সুপারির মতো হলেও লম্বাটে। ফলটি পাকলে হলুদ রঙ হয়। গাছটি বিরল।"
        ]
      },
      {
        "part_of_speech": "বাগধা. বি.",
        "definition": "আত্মীয়স্বজন; স্বজাতীয় লোকজন।",
        "examples": [
          "দুদুর হরাদো গুশটিগাড়া হকলউ আইআ একখানো জমিশ্লা।"
        ]
      }
    ],
    "source_page": "IMG_0128"
  },
  {
    "headword": "্র্রাটো",
    "transliteration": "rrato",
    "phonetics": "rraṭo",
    "etymology": "[<সং গোষ্ঠলীলা সংক্ষেপে]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "বৃন্দাবনে শ্রীকৃষ্ণের গোচারণ লীলা সম্পর্কীয় গীতিনাটা। গ্রামীণ যাত্রাগান অনুষ্ঠিত হয়। এর মধ্যে শ্রীকৃষ্ণের গোষ্ঠলীলা প্রধান। সমতল মঞ্চে কথা, গান, অভিনয়, নৃত্য ইত্যাদিতে জমাটি এই গীতিনাট্য। গোষ্ঠলীলার নানা পালাও রয়েছে। যেমন— রাখাল রাজা ; সুবলমিলন; কালীয়দমন; গোষ্ঠগমন; মানভঞ্জন। এসব পালাগানের ভাষায় বরাক উপত্যকার আঞ্চলিক ভাষার প্রভাব বিস্তর।",
        "examples": [
          "বরাক উপত্যকায় কার্তিক মাসে প্রায় সব গ্রামেই"
        ]
      }
    ],
    "source_page": "IMG_0128"
  },
  {
    "headword": "গুসা",
    "transliteration": "gusa",
    "phonetics": "gusa",
    "etymology": "[<আ. গুস্সা = রাগ]",
