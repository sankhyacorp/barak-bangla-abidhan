  {
    "headword": "দাড়া",
    "transliteration": "dado়a",
    "phonetics": "daḍɔ়a",
    "etymology": "[< বাং ধারা = পদ্ধতি]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "পদ্ধতি; কৌশল; নিয়মশৃঙ্খলা।",
        "examples": [
          "পুলর কামোর দাড়া হিখিতে হিখিতেউ বউত দিন জায়গি। দাড়"
        ]
      },
      {
        "part_of_speech": "বাগধা. বি.",
        "definition": "অক্ষমের ক্ষমতাশালী ব্যক্তির অনুকরণ করা।",
        "examples": [
          "‘রউঅ উজাইন, মাগুরও উজাইন; দেখাদেখি উজাইন দাড়কিনাও।’— বরাক প্রবাদ"
        ]
      }
    ],
    "source_page": "IMG_0206"
  },
  {
    "headword": "দাড়াইশ",
    "transliteration": "dado়aish",
    "phonetics": "daḍɔ়ai∫",
    "etymology": "[<আঞ্চ. বাং দাঁড়াশ = সাপ বিশেষ]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "একপ্রকার নির্বিষ লম্বা সাপ। M ইংরেজি নাম— Rat Snake.",
        "examples": [
          "এরা লম্বায় আড়াই মিটার পর্যন্ত হয়। দ্রুতগতিতে চলে। এদের আকৃতি ও গায়ের রং কেউটের মতো। অর্থাৎ কালোয়-হলুদে হয়। শস্য ধ্বংসকারী ইঁদুর খেয়ে কৃষকদের উপকার করে এই সাপ। দিনেরবেলাতেই এরা মাঠে-ঘাটে ঘুরে বেড়ায়। শুধু ইঁদুর নয় ব্যাঙ, পাখি প্রভৃতিও খায়। দাঁড়াশ সাপের কামড় খুবই যন্ত্রণাদায়ক। এরা দ্রুতগতিতে আত্মরক্ষা করে। মেয়ে সাপ ৮ টা থেকে ১৬ টা ডিম পাড়ে। বৈজ্ঞানিক নাম— Ptyas Mucosus."
        ]
      }
    ],
    "source_page": "IMG_0206"
  },
  {
    "headword": "দালিদ্দর",
    "transliteration": "daliddor",
    "phonetics": "daliddɔr",
    "etymology": "[< বাং দারিদ্র্য বিষমীভবনে]",
