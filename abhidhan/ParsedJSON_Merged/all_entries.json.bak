    "senses": [
      {
        "part_of_speech": "ক্রিবিণ.",
        "definition": "ঢগঢগ করে।",
        "examples": [
          "খেড়িত তনে আইআ মুই ঢগঢগাইআ একলুটা পানি খাইতাম।"
        ]
      }
    ],
    "source_page": "IMG_0188"
  },
  {
    "headword": "ঢগলা",
    "transliteration": "dhogola",
    "phonetics": "ḍhɔgɔla",
    "etymology": "[<ববাং ঢখরা লকারীভবনে]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "খাবলা; গোলাকার অংশ।",
        "examples": [
          "বনরবেটায় জব্বারর উরাত্তনে এক ঢগ্লা মাংশ নিছেগি।"
        ]
