  {
    "headword": "রেশারেশি",
    "transliteration": "reshareshi",
    "phonetics": "re∫are∫i",
    "etymology": "[< ববাং রিশ + আ ~ রিশ + ই]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "শত্রুতা; হিংসাহিংসি; অন্তর্দ্বন্দ্ব।",
