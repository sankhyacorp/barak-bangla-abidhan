  {
    "headword": "মট",
    "transliteration": "mot",
    "phonetics": "mɔṭ",
    "etymology": "[< ববাং মাটিআ = মাটি সম্বন্ধীয়]",
    "senses": [
      {
        "raw_text": "[< ববাং মাটিআ = মাটি সম্বন্ধীয়]"
      },
      {
        "part_of_speech": "বি.",
        "definition": "মেটে কলাই ডালের প্রকার বিশেষ।",
        "examples": [
          "বরাক উপত্যকার কলাইডাল অতি সুস্বাদু ও খাদ্যগুণ বিশিষ্ট। মট কলাই ডালের চেয়ে সামান্য বড় দানা, স্বাদও কম। ফলন ভালো।"
        ]
      }
    ],
