  {
    "headword": "অকাত্",
    "transliteration": "okat",
    "phonetics": "ɔkat",
    "etymology": "[<আ. ৱক্ত = সময় ?]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "সামর্থ্য; উৎস; আয়।",
        "examples": [
          "'অকাত আনমান জকাত।' —বপ্র অগো ၁go [<বাং ওগো]"
        ]
      },
      {
        "part_of_speech": "অনম্ব.",
        "definition": "ওগো।",
        "examples": [
          "অগো, মোরে থুড়া ধরো। → পরিচিত নারীকে সম্ভ্রমাত্মক সম্বোধন। আবার স্বামী-স্ত্রীর মধ্যে এই আহ্বান বা সম্বোধন খুবই প্রচলিত।"
        ]
      }
    ],
    "source_page": "IMG_0040"
  },
