    "etymology": "[< প্ত. র্ঘনর্ঘনা ১]",
    "senses": [
      {
        "raw_text": "[<ধ্ব. ঠন্ঠন্ = ধাতুর মুদ্রার আওয়াজা"
      },
      {
        "part_of_speech": "বিণ.",
        "definition": "নগদ বা হাতে হাতে প্রদেয়।",
        "examples": [
          "বাবনর বাকি দামন্দর ঠনঠনা। ঠেন্ঠেনা, thonthona [< প্ত. র্ঘনর্ঘনা ১]"
        ]
      },
      {
        "part_of_speech": "বিণ.",
        "definition": "কথায় ও বুদ্ধিতে পাকা এমন।",
        "examples": [
          "দেখতে হরু হেম্তে ঠন্ঠনা। ধ্ব. ঠন্ঠন্ এর আলংকারিক প্রয়োগ অর্থাৎ ‘পরিপূর্ণতা’ বা ‘পাকা’ ভাবব্যঞ্জক।"
        ]
      }
    ],
    "source_page": "IMG_0176"
  },
  {
    "headword": "ঠনা",
    "transliteration": "thona",
    "phonetics": "ṭhɔna",
    "etymology": "[<ববাং শব্দ ঠনা]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "পদ্মের ফল।",
        "examples": [
