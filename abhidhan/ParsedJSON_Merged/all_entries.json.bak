  {
    "headword": "হিমইল",
    "transliteration": "himoil",
    "phonetics": "ɦimɔil",
    "etymology": "[< বাং শিমুল হকারীভবন ও স্বরসঙ্গতিতে < বৈদিক. শিশ্বল]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "শিমুলগাছ; বড়জাতের তুলার গাছ বা ফুল।",
        "examples": [
          "তুশক জাজিম বালিশ হিমইল তুলাদি বানাইন। ‘যাঁরা শব্দবিদ্যায় কুতৃহলী তাদের কাছে বলে রাখি যে বাংলা ‘শিমুল’ সরাসরি সংস্কৃত ‘শাল্মলি’ থেকে আসেনি, তা আসতেও পারে না। এসেছে প্রাচীন বৈদিক ‘শিম্বল’ থেকে [ঋগবেদ ৩.৫৩.২২]; শব্দটির মানে করেছেন সায়ন — ‘শিমুল ফুল’।’ — সেন ‘বাংলা স্থান নাম’।"
        ]
      }
    ],
    "source_page": "IMG_0347"
  },
