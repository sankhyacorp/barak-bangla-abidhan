  {
    "headword": "ছম্",
    "transliteration": "chhom",
    "phonetics": "c∫hɔm",
    "etymology": "[< ববাং শব্দ ]",
    "senses": [
      {
        "part_of_speech": "ক্রি.",
        "definition": "শুয়ে পড় [অনুজ্ঞায়]।",
        "examples": [
          "হাতি চালনার পরিভাষা। মাহুত ‘ছম্’ বললেই হাতি বুঝবে তাকে নুয়ে পড়তে হবে। ‘ছমতেরে’ বলার সঙ্গে সঙ্গেই হাতি পাগুলো সটান করে শুয়ে পড়বে। ‘তেরেছম্’ বললে সাষ্টাঙ্গ প্রণামের মতো তার সাধ্য অনুযায়ী সমস্ত অঙ্গকে মাটির সঙ্গে লেপটে শুয়ে পড়বে।"
        ]
      }
    ],
    "source_page": "IMG_0148"
  },
