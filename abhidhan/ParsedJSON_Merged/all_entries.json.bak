  {
    "headword": "মাইলং",
    "transliteration": "mailng",
    "phonetics": "mailŋ",
    "etymology": "[< ডি. মাইলং = ফলবিশেষ]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "কুল জাতীয় টকফল বিশেষ।",
        "examples": [
          "ফলটি বরাক উপত্যকার উত্তর সী মান্তে খুব ফ লে কাঁচা থাকতে সবুজ, পুষ্ট হলে হলদে, পাকলে লাল হয়। ফুল সাদা এবং হাসনাহানার মতো গন্ধ। গাছের শাখা ঝাড় বাঁধে। বর্ষায় ফলে।"
        ]
      }
    ],
    "source_page": "IMG_0296"
  },
  {
    "headword": "মাউগ",
    "transliteration": "maug",
    "phonetics": "maug",
    "etymology": "[< পা. মাতুগাম]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "পত্নী; চরিত্রহীনা নারী।",
        "examples": [
          "‘মাগ’ বাংলায় অসম্ভ্রমার্থে ব্যবহৃত হয়। বরাকবাংলায় ‘পত্নী’ অর্থেই ‘মাউগ’ শব্দটির চল্। অনেক সময় নিব্দার্থে প্রয়োগও হয়। দ্র. ‘মাউগর ভাড়ুআ’। আবার কচিৎ ‘চরিত্রহীনা মহিলা’ অর্থেও ব্যবহার করে কেউ কেউ। মাউগর ভাড়আ — বাগধা. বি ণ. — স্ত্রীর অনুগত",
          "এলকুর পুআইন বিআর বাদেউ মাউগর ভাড়ুআ।"
        ]
      }
    ],
    "source_page": "IMG_0296"
  },
  {
    "headword": "মাউত্তল",
    "transliteration": "mauttol",
    "phonetics": "mauttɔl",
    "etymology": "[< ববাং মাও (সম্বোধনে) + ত(ল) তপ্র. সম্বন্ধার্থে ]",
    "senses": [
      {
        "raw_text": "[< ববাং মাও (সম্বোধনে) + ত(ল) তপ্র. সম্বন্ধার্থে ]"
      },
      {
        "part_of_speech": "বিণ.",
        "definition": "সৎমার সম্পর্কসূত্রে বদ্ধ: সৎমার সম্ভানের সূত্রে সম্পর্কিত।",
        "examples": [
          "মাউতল ভাই = সৎমার ঘরের ভাই। মাউতল বইন = সৎমার ঘরের বোন। ‘বা’র (বাঁশের) তলে পরইলা গাই, তাইন মোর মাউতল ভাই।’ — বপ্র."
        ]
      }
    ],
