  {
    "headword": "পিস্লি",
    "transliteration": "pisli",
    "phonetics": "pisli",
    "etymology": "[< ববাং শব্দ পিস্লি]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "উরু ও কোমরের সন্ধিস্থল।",
        "examples": [
          "নারী বা পুরুষের গুপ্তাঙ্গের দুপাশের উরু- কোমরের সন্ধিস্থানের নিচু অংশ।"
        ]
      }
    ],
    "source_page": "IMG_0236"
  },
  {
    "headword": "পিং",
    "transliteration": "ping",
    "phonetics": "piŋ",
    "etymology": "[<আঞ্চ. বাং পিং]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "একপ্রকার চিরসবুজ গাছ।",
        "examples": [
          "এই গাছ ৫০-৬০ হাত উঁচু হয়। বেড়ে ৬ হাত পর্যন্ত হয়। নিমগাছের মতো পাতা। কিনারা দল্ভর নয়। বাকল মসৃণ ও ঈষৎ সবুজ। ফুল সাদা, ফল ক্যাপসুলাকার। কাঠ লাল ও শক্ত। ঘর ও সেতু তৈরির কাজে এই কাঠ ব্যবহৃত হয়। বৈজ্ঞানিক নাম— Cynometra Polyandra."
        ]
      }
    ],
    "source_page": "IMG_0236"
  },
  {
    "headword": "পিংকাঠ",
    "transliteration": "pingkath",
    "phonetics": "piŋkaṭh",
    "etymology": "[< ইং Pincers]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "ছুতোরের ব্যবহৃত যন্ত্র বিশেষ।",
        "examples": [
          "লোহার পেরেক, কব্জা, দরজা খোলার ও তোলার কাজে ব্যবহাত হয় এই যন্ত্রটি। লোহার মোটা দণ্ডের একদিক খুস্তির মতো, অন্যপ্রান্ত চেপ্টা ও দ্বিখণ্ডিত।"
        ]
