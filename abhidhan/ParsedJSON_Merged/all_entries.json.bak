    "source_page": "IMG_0270"
  },
  {
    "headword": "বাবরি",
    "transliteration": "babori",
    "phonetics": "babɔri",
    "etymology": "[< ববাং শব্দ. বাবরি]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "গাঁট যুক্ত ঝাড় বিশিষ্ট ছোট গাছ। \\Rightarrow ৫/৭ হাত উঁচু হয়। ঝাড় বাঁধে। এই গাছের ভেতরের ফাঁপা অংশে শোলার মতো হালকা স্তর থাকে যা থেকে স্থানীয় পশু শিকারীরা বারুদ তৈরি করেন। গাছটি বাংলা আসাম ত্রিপুরায় অতি পরিচিত। টিলা বা মাঠে জন্মায় ও ঝোপজঙ্গল তৈরি করে। এর ছাই থেকে ভালো টিকা (তামাকের জ্বালানি) প্রস্তুত হয়।"
      }
    ],
    "source_page": "IMG_0270"
  },
  {
    "headword": "বাবাশ",
    "transliteration": "babash",
    "phonetics": "baba∫",
    "etymology": "[< ববাং শব্দ বাবাশ]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "কুঁচে মাছ জাতীয় বড় আকারের মাছ। হয়। এই তৈলাক্ত মাছটির বাস নদীতে। এই মাছ দিয়ে অর্শরোগের লোকায়ত চিকিৎসা করা হয়।"
      },
      {
        "part_of_speech": "বাগধা. বি.",
        "definition": "তুমুল দুর্যোগ।",
        "examples": [
          "বৈশাখের দ্বাদশ ও ত্রয়োদশ দিবসে প্রতি বছরই প্রচণ্ড ঝড় তুফান বৃষ্টি হয়— এরূপ একটি বিশ্বাস বরাক উপত্যকায় দূঢ়মূল। এই বিশ্বাস থেকেই এই বাগধারার সৃষ্টি।"
        ]
      }
    ],
    "source_page": "IMG_0270"
  },
  {
    "headword": "বার চাবা",
    "transliteration": "bar chaba",
    "phonetics": "bar c∫aba",
    "etymology": "[< বাং বাহির ~ √চা =চাওয়া]",
    "senses": [
      {
        "part_of_speech": "সক্রি.",
        "definition": "অপেক্ষা করা। করাই সুচিত করে যদি চাওয়াটা বার বার হয়। বৈষ্ণবপদ মনে পড়ে— লো ভাষাব অভিধান ও ভাষাত্ত ১. ‘ঘরের বাইরে দণ্ডে শতবার তিলে তিলে আইসে যায় মন উচাটন নিশ্বাস সঘন কদম্ব কাননে চায়।’ — দ্বিজ চণ্ডীদাস ⇒ জলদি যা, তাই কতবিল তনে তোর বার চার।"
      }
    ],
    "source_page": "IMG_0270"
  },
  {
    "headword": "বারজা",
    "transliteration": "baroja",
    "phonetics": "barɔʒa",
    "etymology": "[< ববাং শব্দ বারজা]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "শ্লেট বা ব্লেকবোর্ডের চারদিকে বসানো কাঠের তৈরি ফ্রেম।",
        "examples": [
