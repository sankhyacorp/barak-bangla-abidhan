  {
    "headword": "পানানি",
    "transliteration": "panani",
    "phonetics": "panani",
    "etymology": "[< প্রা. পহু]",
    "senses": [
      {
        "part_of_speech": "ক্রি.",
        "definition": "দুধ দোহনের সময় গাইয়ের বাটে চু মেরে বাছুরের দুধ নামানো।",
        "examples": [
          "তাইন দুদ খিরাইতে দুইবার পানাইন।"
        ]
      },
      {
        "part_of_speech": "বি.",
        "definition": "বাছুরকে দিয়ে গাইয়ের বাটে দুধ নামানোর কাজ। > দুই পানানি দিলে বাইচ্চার লাগি দুদ থাকে 페। ক্রি. (আলং) — দফায় দফায় সম্পদ শোষণ করা।",
        "examples": [
          "মন্ত্রিয়ে অত টেকা পানাইআ হেশে চাকরি দিলা না।"
        ]
      },
      {
        "part_of_speech": "বাগধা. ক্রি.",
        "definition": "মন্দকর্মের ফলভোগ করতে আরম্ভ করা।",
        "examples": [
          "তান পাপ বালিক অইছে এলকু ধনমান হকলভাউ জাইব।"
        ]
      }
    ],
    "source_page": "IMG_0232"
  },
