  {
    "headword": "আংগাজ",
    "transliteration": "anggaj",
    "phonetics": "aŋgaʒ",
    "etymology": "[<উর্দু আংগেযনা = সহ্যকরা ?]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "সহ্য করার ক্ষমতা; সহিষ্ণুতা।",
        "examples": [
          "ভার বইতে আংগাজ লাগে। মানসিক সহিষ্ণুতার কথা বোঝালে ‘জারা’ হয়। ⇒ দজজাল হড়ির জালা জারা হকল বউএ পারইন না। ক্রি. ⇒ জামাইর মাইর জারতো না পারিআ তাই বিশ খাইআ মরছে।"
        ]
      }
    ],
    "source_page": "IMG_0061"
  },
  {
