    "phonetics": "manḍɔr",
    "etymology": "[< সং মদংগ্র]",
    "senses": [
      {
        "raw_text": "[< সং মদংগ্র] বি — আঁশহীন স্বনাম প্রসিদ্ধ মাছ। ⇒ জিয়ল মাছ বিশেষ। কালচে লাল, বাদামি, মেটে প্রভৃতি রঙের হয় এই মাছ। পাঁকনার দুধারে তীক্ষ্ণ ও বিষাক্ত কাঁট্টা থাকে। লম্বা শুঁয়ো আছে। রোগী, গর্ভবতী ও সদ্য সম্ভানবতীর আদর্শ পথ্য।"
      }
    ],
    "source_page": "IMG_0297"
  },
  {
    "headword": "মাচাং",
    "transliteration": "machang",
    "phonetics": "mac∫aŋ",
    "etymology": "[<সাঁও. মাচট<ক. মচ্চ = উপরতলা]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "মাচা; বাঁশের তৈরি উঁচু মঞ্চ যা লাউকুমড়া প্রভৃতি বেয়ে ওঠার জন্য দেওয়া হয়। for watching crops. দ্র. চাং"
      }
    ],
    "source_page": "IMG_0297"
  },
  {
    "headword": "মাছলি",
    "transliteration": "machholi",
    "phonetics": "mac∫hɔli",
    "etymology": "[< সং মেচক]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "মুখমন্ডলে ক্ষুদ্র মাছির মতো বাদামি-কালো দাগ বিশেষ; Freckles ২০৭ মাঠা",
        "examples": [
          "তাইর মুখো মাছলি ফুটিছে।",
          "‘ক্রোধ ও পরিশ্রম প্রভৃতি কারণে শ্যামবর্ণ ও কৃষ্ণবর্ণ অনুন্নত মন্ডল মুখে উৎপাদিত হইলে তাহাকে মেচেতা বা মুখব্যঙ্গ কহে।’ — ডা. যোগেশচন্দ্র ঘোষ। এটি আসলে চর্মরোগ বিশেষ। স্ত্রীপুরুষ নির্বিশেষে সকলেরই হতে পারে। বাল্যকালে এ রোগ হয় না।"
        ]
      }
    ],
    "source_page": "IMG_0297"
  },
  {
    "headword": "মাছু পিঠা",
    "transliteration": "machhu pitha",
    "phonetics": "mac∫hu piṭha",
    "etymology": "[< বাং মাছ + উ যুক্তার্থে ~ পিঠা]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "চালের গুঁড়ি ও মাছ মিশিয়ে তৈরি সুস্বাদু পিঠা বিশেষ।",
        "examples": [
          "মাছুপিঠা দূরকমের ঃ গুঁড়িমাছ ও মশলামাছ। ১. গুঁড়িমাছ প্রস্তুতপ্রণালী— আড়মাছ, বোয়াল, চ্যাং, মাগুর প্রভৃতি স্বল্প কাঁটাযুক্ত মাছ তেলছাড়া ভেজে কাঁটা ছাড়িয়ে নিতে হয়। এরপর আন্দাজমতো নুনলংকা দিয়ে চালের গুঁড়োর সঙ্গে মেখে ভাপে দিয়ে নামালেই হয়ে গেল। মশলামাছ প্রস্তুতপ্রণালী— ৫০০ গ্রাম ছোট মাছ; ৫০ . গ্রাম সর্ষে বা লাইবিচি বাটা; জিরা হলুদ নুন লংকা আন্দাজমতো। মখা, পুঁটি, টেংরা, কইআ প্রভৃতি যেকোনো ছোটমাছ l কেটে ধুয়ে রাখতে হয়। সর্ষে বা লাইবিচি বাটার সঙ্গে জিরা হলুদ নুন লংকা স্বাদ মতো দিয়ে মেখে মাছণ্ডলো কলাপাতা বা হলুদপাতা দিয়ে মুড়ে খালি কড়াইতে হালকা আঁচে বসাতে হয়। চাপা দিতে হয় জলভরা পাত্র দিয়ে। এরপর কয়েকবার উলটে- পালটে মাছের রস শুকিয়ে গেলে নামিয়ে নিলেই প্রস্তুত হল মশলামাছের মাছুপিঠা। অতি সুস্বাদু ও রুচিকর এই মাছুপিঠা বরাক উপত্যকায় খুবই জনপ্রিয়।"
        ]
      }
    ],
    "source_page": "IMG_0297"
  },
