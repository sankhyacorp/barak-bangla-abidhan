  {
    "headword": "কু",
    "transliteration": "ku",
    "phonetics": "ku",
    "etymology": "[<ববাং শব্দ কু ]",
    "senses": [
      {
        "raw_text": "[<ববাং শব্দ কু ] ক্রি. (অনুজ্ঞায়) — হাতি চালনার পরিভাষা। মানে ‘পায়ের তলায় ফেলে ভেঙে দুমড়ে ফেল।’ ⇒ ‘কূ’ বললাঁ শিক্ষ নির্মিষ্ঠ বস্তু ভারাত জলাগ্র ঢুকিয়ে দুমড়ে মুছড়ে ভেঙে ফেলবে।"
      }
    ],
    "source_page": "IMG_0093"
  },
  {
    "headword": "কুঅড়",
    "transliteration": "kuodo়",
    "phonetics": "kuɔḍɔ়",
    "etymology": "[<অঞ্চবাং কোআড় = গোরুর কয়েদখানা]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "গোরু-মহিষ ইত্যাদি যেখানে অবরোধ করে রাখা হয়: গোরু-মহিষাদির বন্দিশালা।",
        "examples": [
          "কারো গোরু বা মহিষ অন্যের শসাদি খেয়ে নষ্ট করলে খেতের মালিক সেই গৃহপালিত পশুকে কোআড়ে বা কুঅড়ে নিয়ে দিয়ে আসেন। গোরুর মালিক শেষে গোরুর বন্ধনাগার থেকে উপযুক্ত জরিমানা দিয়ে তার গোরু-মহিষকে মুক্ত করে আনেন। কোয়াড় সাধারণত পঞ্চায়েতের দ্বারা পরিচালিত হয়।"
        ]
      }
    ],
    "source_page": "IMG_0093"
  },
