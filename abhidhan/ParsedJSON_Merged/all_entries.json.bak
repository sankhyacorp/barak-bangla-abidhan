  },
  {
    "headword": "পিঠাকরা",
    "transliteration": "pithakora",
    "phonetics": "piṭhakɔra",
    "etymology": "[<বাং পিঠা + √ কর + আ]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "একপ্রকার চিরসবুজ গাছ।",
        "examples": [
          "এই গাছটি ৪০-৪৫ ফুট উঁচু হয়। বেড়ে মাত্র সাড়ে তিন হাত। পাতা তেজপাতার মতো, তবে সামান্য খাটো। বাকল ও কাঠ সাদা। ডেফলের মতো ফল। রং সাদাটে। হালকা মিঠা। হরিণের প্রিয় খাদ্য। সকলেই খেতে পারে।"
        ]
      }
    ],
    "source_page": "IMG_0235"
  },
  {
    "headword": "পিঠাখাউরি",
    "transliteration": "pithakhauri",
    "phonetics": "piṭhakhauri",
    "etymology": "[< বাং পিঠা ~ ববাং √খা + উরি ‘নিপুণ’ অর্থে]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "বৃক্ষ বিশেষ।",
        "examples": [
          "ছোট ছোট পাতা। সবুজ ফল। পাকলে হলদে হয়। ফল খেতে মিঠা ও বালিবালি। বনের পাখিরা খুব ভালোবাসে।"
        ]
      },
      {
        "part_of_speech": "বাগধা. ক্রি.",
        "definition": "রৌদ্র তাপে কঠোর পরিশ্রম করা।",
        "examples": [
          "খেতোআল গুরোয় পিঠো মখা ছকাইত্রা আর সাএবগুরোর ঠান্ডাগাড়ি (= শীততাপ নিয়ন্ত্রিত) চড়িত্রা।"
        ]
      }
    ],
    "source_page": "IMG_0235"
  },
