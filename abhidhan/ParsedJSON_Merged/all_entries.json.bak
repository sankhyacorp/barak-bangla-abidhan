    "transliteration": "khirani",
    "phonetics": "khirani",
    "etymology": "[< দ্র. খিরানি, ]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "শোষণ।",
        "examples": [
          "গরিব মানরে খিরানি ভালা নায়।"
        ]
      },
      {
        "part_of_speech": "ক্রি.",
        "definition": "শোষণ করা।",
        "examples": [
          "অফিশো কুনু কামর লাগি গেলায়তে পেদায় খিরার, কিরানি এ খিরার, সাএবেও খিরার।",
          "'খিরানি' অর্থ 'দোহন' বা 'দোহনের পাত্র'। এখানে বিশিষ্টার্থে প্রয়োগ করা হয়েছে।"
        ]
      }
    ],
    "source_page": "IMG_0109"
  },
  {
    "headword": "খিনি",
    "transliteration": "khini",
    "phonetics": "khini",
    "etymology": "[<বাং খানি স্বরসংগতিতে]",
    "senses": [
      {
        "raw_text": "[<বাং খানি স্বরসংগতিতে] অ প্র. — ‘টুকু’ অর্থে এই পরিমাণ বাচক অনুসর্গীয় প্রত্যয়টি ব্যবহৃত হয়। ⇒ ইতিকিনি । ইতিখিনি [ = এই সামান্যটুকু] ‘ইতিখিনি দুদে কেওরর ফুইতো নায়।’ ⇒ বইরাগি বাড়ির মানু বড় কনজিশ্, পশাদ (= প্রসাদ) দিলেও ইতিকিনি ইতিকিনি করি দেইন।"
      }
    ],
    "source_page": "IMG_0109"
  },
  {
    "headword": "খিরন",
    "transliteration": "khiron",
    "phonetics": "khirɔn",
    "etymology": "[<আঞ্চ. খির (ঘনকালি) <সং ক্ষীর]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "আনদ্ধ বাদ্যযন্ত্রের চামড়ার উপর ঘন কালির প্রলেপ।",
        "examples": [
          "মৃদঙ্গ, তবলা প্রভৃতিতে সঠিক ‘বোল’ তোলার জন্য ‘খিরন’ দেওয়া হয়। ) খিরিমিরি [<ধ্ব. খির্ + মির্ গভীরতাজ্ঞাপক]"
        ]
      },
      {
        "part_of_speech": "বিণ.",
        "definition": "গভীর।",
        "examples": [
          "তলে দি চাইলে পাও কাপে জে খিরিমিরি ঝুরুং।"
        ]
      }
    ],
    "source_page": "IMG_0109"
  },
  {
    "headword": "খিরু",
    "transliteration": "khiru",
    "phonetics": "khiru",
    "etymology": "[< প্রা. খীর + উ তপ্র সাদৃশ্যে <সং ক্ষীর]",
    "senses": [
      {
        "part_of_speech": "বি.",
        "definition": "মগজ; মেধা।",
        "examples": [
          "পুআটার একেরে খিরু নাই। >> প্রা. খীর > প্রাবা. খির ⇒ ‘লঙ্কার দুআরে চরিত্রা আমিনি গতি নিলা জগানে খির বাটি। সে খিরবাটি তথা বরদা হইআ। চরিত্রা আমিনি আইল জহ জহ দিয়া। — শূন্যপুরাণ"
        ]
      }
    ],
    "source_page": "IMG_0109"
  },
  {
    "headword": "খুআ",
    "transliteration": "khua",
    "phonetics": "khua",
    "etymology": "[<প্রাবা. কুয়ার]",
