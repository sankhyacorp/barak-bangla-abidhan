    },
    {
      "type": "paragraph",
      "text": "নিম্ন বিবৃত প্রসৃত কেন্দ্রীয়",
      "source_page": 382,
      "source_image": "IMG_0382.jpg"
    },
    {
      "type": "paragraph",
