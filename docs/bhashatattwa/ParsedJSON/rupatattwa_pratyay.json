    },
    {
      "type": "paragraph",
      "text": "জামাইগুরো",
      "source_page": 428,
      "source_image": "IMG_0428.jpg"
    },
    {
      "type": "example_group",
      "items": [
        "বর্তি (=ব্রতী) গুরো"
      ],
      "source_page": 428,
      "source_image": "IMG_0428.jpg"
    },
    {
      "type": "paragraph",
      "text": "পাথরগুইন",
