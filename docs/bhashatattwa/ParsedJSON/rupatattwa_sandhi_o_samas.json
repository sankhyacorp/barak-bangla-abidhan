    },
    {
      "type": "paragraph",
      "text": "ক্রিয়াবিশেষ্য ⇒",
      "source_page": 431,
      "source_image": "IMG_0431.jpg"
    },
    {
      "type": "paragraph",
      "text": "জাবাআবা",
      "source_page": 431,
      "source_image": "IMG_0431.jpg"
    },
    {
      "type": "paragraph",
      "text": "হাজাপাড়া",
      "source_page": 431,
      "source_image": "IMG_0431.jpg"
    },
    {
      "type": "paragraph",
      "text": "লআথআ",
      "source_page": 431,
      "source_image": "IMG_0431.jpg"
    },
    {
      "type": "paragraph",
      "text": "মান্জাঘশা",
      "source_page": 431,
      "source_image": "IMG_0431.jpg"
    },
    {
      "type": "table",
      "headers": [],
      "rows": [
        [
          "সমার্থকশব্দ ⇒",
          "আরিপরি"
        ],
