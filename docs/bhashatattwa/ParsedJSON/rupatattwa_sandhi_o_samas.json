          "অবায়হবায়"
        ],
        [
          "সর্বনামীয় দ্বন্দ্ব আদর্শ বাংলার মতনই।",
          ""
        ]
      ],
      "source_page": 432,
      "source_image": "IMG_0432.jpg"
    },
    {
      "type": "paragraph",
      "text": "বহুব্রীহি— এতে সমস্যমান শব্দগুলির কোনোটির অর্থই প্রধান নয়, এদের মিলিত অর্থ অন্য কিছুকে বোঝায়।",
      "source_page": 432,
      "source_image": "IMG_0432.jpg"
    },
    {
      "type": "paragraph",
      "text": "খুচিধরা",
      "source_page": 432,
      "source_image": "IMG_0432.jpg"
    },
    {
      "type": "paragraph",
      "text": "ব্যধিকরণ—",
      "source_page": 432,
      "source_image": "IMG_0432.jpg"
    },
    {
      "type": "paragraph",
      "text": "গরবাওআনি",
      "source_page": 432,
      "source_image": "IMG_0432.jpg"
    },
    {
      "type": "paragraph",
      "text": "বারবাওআনি",
      "source_page": 432,
      "source_image": "IMG_0432.jpg"
    },
    {
      "type": "paragraph",
      "text": "সমানাধিকরণ—",
      "source_page": 432,
      "source_image": "IMG_0432.jpg"
    },
    {
      "type": "paragraph",
      "text": "উলপরানি",
      "source_page": 432,
