      "source_page": 432,
      "source_image": "IMG_0432.jpg"
    },
    {
      "type": "paragraph",
      "text": "ব্যতিহার---",
      "source_page": 432,
      "source_image": "IMG_0432.jpg"
    },
    {
      "type": "paragraph",
      "text": "উগাউগি",
      "source_page": 432,
